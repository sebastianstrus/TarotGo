                "es": { "stringUnit": { "state": "translated", "value": "Manipulación de la relación o abuso de poder en el amor. Control tiránico sobre la pareja. Crueldad a través del intelecto. Usar la verdad como arma." } },
                "fr": { "stringUnit": { "state": "translated", "value": "Manipulation relationnelle ou abus de pouvoir en amour. Contrôle tyrannique sur le partenaire. Cruauté par l'intellect. Utiliser la vérité comme arme." } },
                "it": { "stringUnit": { "state": "translated", "value": "Manipolazione relazionale o abuso di potere in amore. Controllo tirannico sul partner. Crudeltà attraverso l'intelletto. Usare la verità come arma." } },
                "ja": { "stringUnit": { "state": "translated", "value": "恋愛における関係操作または権力乱用。パートナーへの専制的な支配。知性による残酷さ。真実を武器として使う。" } },
                "nb": { "stringUnit": { "state": "translated", "value": "Forholdsmanipulasjon eller maktmisbruk i kjærlighet. Tyrannisk kontroll over partner. Grusomhet gjennom intellekt. Bruke sannheten som våpen." } },
                "pl": { "stringUnit": { "state": "translated", "value": "Manipulacja w związku lub nadużycie władzy w miłości. Tyrańska kontrola nad partnerem. Okrucieństwo poprzez intelekt. Używanie prawdy jako broni." } },
                "pt-BR": { "stringUnit": { "state": "translated", "value": "Manipulação de relacionamento ou abuso de poder no amor. Controle tirânico sobre o parceiro. Crueldade através do intelecto. Usar a verdade como arma." } },
                "sv": { "stringUnit": { "state": "translated", "value": "Relationsmanipulation eller maktmissbruk i kärlek. Tyrannisk kontroll över partner. Grymhet genom intellekt. Använda sanningen som vapen." } },
                "uk": { "stringUnit": { "state": "translated", "value": "Маніпуляція стосунками або зловживання владою в коханні. Тиранічний контроль над партнером. Жорстокість через інтелект. Використання правди як зброї." } }
            }
        },
