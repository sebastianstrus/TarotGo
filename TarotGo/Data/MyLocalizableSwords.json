                "de": { "stringUnit": { "state": "translated", "value": "Aktion, Ehrgeiz, schnelles Denken und angetriebene Energie. Du bewegst dich schnell und entschlossen. Geistige Klarheit treibt den Vorwärtsimpuls an. Schmiede das Eisen, solange es heiß ist." } },
                "es": { "stringUnit": { "state": "translated", "value": "Acción, ambición, pensamiento rápido y energía impulsada. Te mueves rápida y decididamente. La claridad mental impulsa el impulso hacia adelante. Hierro mientras está caliente." } },
                "fr": { "stringUnit": { "state": "translated", "value": "Action, ambition, pensée rapide et énergie motrice. Vous avancez rapidement et avec détermination. La clarté mentale alimente l'élan vers l'avant. Battez le fer pendant qu'il est chaud." } },
                "it": { "stringUnit": { "state": "translated", "value": "Azione, ambizione, pensiero rapido ed energia trainante. Ti muovi rapidamente e con decisione. La chiarezza mentale alimenta lo slancio in avanti. Battere il ferro finché è caldo." } },
                "ja": { "stringUnit": { "state": "translated", "value": "行動、野心、速い思考、駆り立てられるエネルギー。あなたは素早く決断的に動いている。精神的な明晰さが前進の勢いを生む。鉄は熱いうちに打て。" } },
                "nb": { "stringUnit": { "state": "translated", "value": "Handling, ambisjon, rask tenkning og drevet energi. Du beveger deg raskt og besluttsomt. Mental klarhet driver fremoverfart. Smi mens jernet er varmt." } },
                "pl": { "stringUnit": { "state": "translated", "value": "Działanie, ambicja, szybkie myślenie i napędzana energia. Poruszasz się szybko i zdecydowanie. Jasność umysłu napędza pęd do przodu. Kuj żelazo póki gorące." } },
                "pt-BR": { "stringUnit": { "state": "translated", "value": "Ação, ambição, pensamento rápido e energia impulsionada. Você está se movendo rápida e decisivamente. Clareza mental alimenta o impulso para frente. Bata no ferro enquanto está quente." } },
                "sv": { "stringUnit": { "state": "translated", "value": "Handling, ambition, snabbt tänkande och driven energi. Du rör dig snabbt och beslutsamt. Mental klarhet driver framåtrörelse. Smi medan järnet är varmt." } },
                "uk": { "stringUnit": { "state": "translated", "value": "Дія, амбітність, швидке мислення та енергія. Ви рухаєтеся швидко і рішуче. Розумова ясність живить імпульс вперед. Коваль залізо, поки гаряче." } }
            }
        },
        "interpretation.knight_of_swords_general_reversed": {
            "extractionState": "manual",
            "localizations": {
                "en": { "stringUnit": { "state": "translated", "value": "Recklessness, impatience, unfocused energy, and impulsiveness. You're moving too fast without thinking. Slow down before you crash." } },
                "de": { "stringUnit": { "state": "translated", "value": "Rücksichtslosigkeit, Ungeduld, unkonzentrierte Energie und Impulsivität. Du bewegst dich zu schnell, ohne nachzudenken. Bremse ab, bevor du abstürzt." } },
                "es": { "stringUnit": { "state": "translated", "value": "Imprudencia, impaciencia, energía sin enfoque e impulsividad. Te mueves demasiado rápido sin pensar. Reduce la velocidad antes de estrellarte." } },
                "fr": { "stringUnit": { "state": "translated", "value": "Imprudence, impatience, énergie non focalisée et impulsivité. Vous avancez trop vite sans réfléchir. Ralentissez avant de vous écraser." } },
                "it": { "stringUnit": { "state": "translated", "value": "Spericolatezza, impazienza, energia non focalizzata e impulsività. Ti muovi troppo velocemente senza pensare. Rallenta prima di schiantarti." } },
                "ja": { "stringUnit": { "state": "translated", "value": "無謀さ、焦り、焦点の定まらないエネルギー、衝動性。あなたは考えずに速すぎる動きをしている。墜落する前にスピードを落とせ。" } },
                "nb": { "stringUnit": { "state": "translated", "value": "Uforsiktighet, utålmodighet, ufokusert energi og impulsivitet. Du beveger deg for raskt uten å tenke. Senk farten før du krasjer." } },
                "pl": { "stringUnit": { "state": "translated", "value": "Lekkomyślność, niecierpliwość, nieskoncentrowana energia i impulsywność. Poruszasz się zbyt szybko bez myślenia. Zwolnij, zanim się rozbijesz." } },
                "pt-BR": { "stringUnit": { "state": "translated", "value": "Imprudência, impaciência, energia sem foco e impulsividade. Você está se movendo rápido demais sem pensar. Diminua a velocidade antes de bater." } },
                "sv": { "stringUnit": { "state": "translated", "value": "Vårdslöshet, otålighet, ofokuserad energi och impulsivitet. Du rör dig för snabbt utan att tänka. Sakta ner innan du kraschar." } },
                "uk": { "stringUnit": { "state": "translated", "value": "Необережність, нетерплячість, несфокусована енергія та імпульсивність. Ви рухаєтеся занадто швидко, не думаючи. Сповільніться, перш ніж розіб'єтеся." } }
            }
        },
        "interpretation.queen_of_swords_love_upright": {
            "extractionState": "manual",
            "localizations": {
                "en": { "stringUnit": { "state": "translated", "value": "Independent, clear-thinking approach to love. Honest and direct in relationships. Intellectual partnership. Truth and boundaries strengthen connection." } },
                "de": { "stringUnit": { "state": "translated", "value": "Unabhängiger, klardenkender Ansatz in der Liebe. Ehrlich und direkt in Beziehungen. Intellektuelle Partnerschaft. Wahrheit und Grenzen stärken die Verbindung." } },
                "es": { "stringUnit": { "state": "translated", "value": "Enfoque independiente y de pensamiento claro en el amor. Honesto y directo en las relaciones. Asociación intelectual. La verdad y los límites fortalecen la conexión." } },
                "fr": { "stringUnit": { "state": "translated", "value": "Approche indépendante et claire de l'amour. Honnête et direct dans les relations. Partenariat intellectuel. La vérité et les limites renforcent la connexion." } },
                "it": { "stringUnit": { "state": "translated", "value": "Approccio indipendente e chiaro all'amore. Onesto e diretto nelle relazioni. Partnership intellettuale. Verità e confini rafforzano la connessione." } },
                "ja": { "stringUnit": { "state": "translated", "value": "恋愛における独立した明確な思考のアプローチ。関係において正直で率直。知的パートナーシップ。真実と境界が絆を強める。" } },
                "nb": { "stringUnit": { "state": "translated", "value": "Uavhengig, klartenkende tilnærming til kjærlighet. Ærlig og direkte i forhold. Intellektuelt partnerskap. Sannhet og grenser styrker forbindelsen." } },
                "pl": { "stringUnit": { "state": "translated", "value": "Niezależne, jasno myślące podejście do miłości. Uczciwy i bezpośredni w związkach. Intelektualne partnerstwo. Prawda i granice wzmacniają więź." } },
                "pt-BR": { "stringUnit": { "state": "translated", "value": "Abordagem independente e de pensamento claro no amor. Honesto e direto nos relacionamentos. Parceria intelectual. Verdade e limites fortalecem a conexão." } },
                "sv": { "stringUnit": { "state": "translated", "value": "Oberoende, klartänkande inställning till kärlek. Ärlig och direkt i relationer. Intellektuellt partnerskap. Sanning och gränser stärker anslutningen." } },
                "uk": { "stringUnit": { "state": "translated", "value": "Незалежний, чіткомислячий підхід до кохання. Чесно і прямо у стосунках. Інтелектуальне партнерство. Правда та межі зміцнюють зв'язок." } }
            }
        },
        "interpretation.queen_of_swords_love_reversed": {
            "extractionState": "manual",
            "localizations": {
                "en": { "stringUnit": { "state": "translated", "value": "Coldness or cruelty in love. Bitter about relationships. Isolated through defensiveness. Harsh honesty damages partnership. Soften." } },
                "de": { "stringUnit": { "state": "translated", "value": "Kälte oder Grausamkeit in der Liebe. Verbittert über Beziehungen. Durch Abwehrhaltung isoliert. Harte Ehrlichkeit schadet der Partnerschaft. Werde weicher." } },
                "es": { "stringUnit": { "state": "translated", "value": "Frialdad o crueldad en el amor. Amargado por las relaciones. Aislado por la actitud defensiva. La honestidad dura daña la pareja. Suavízate." } },
                "fr": { "stringUnit": { "state": "translated", "value": "Froideur ou cruauté en amour. Amer à propos des relations. Isolé par la défensive. L'honnêteté dure nuit au partenariat. Adoucissez-vous." } },
                "it": { "stringUnit": { "state": "translated", "value": "Freddezza o crudeltà in amore. Amareggiato per le relazioni. Isolato dalla difensiva. L'onestà dura danneggia la partnership. Ammorbidisciti." } },
                "ja": { "stringUnit": { "state": "translated", "value": "恋愛における冷たさや残酷さ。関係に対する bitterness。防御的な態度による孤立。厳しい正直さはパートナーシップを傷つける。優しくなれ。" } },
                "nb": { "stringUnit": { "state": "translated", "value": "Kulde eller grusomhet i kjærlighet. Bitter om forhold. Isolert gjennom defensivitet. Hard ærlighet skader partnerskap. Mykne." } },
                "pl": { "stringUnit": { "state": "translated", "value": "Chłód lub okrucieństwo w miłości. Gorzki w stosunku do związków. Odizolowany przez defensywność. Surowa uczciwość szkodzi partnerstwu. Zmięknij." } },
                "pt-BR": { "stringUnit": { "state": "translated", "value": "Frieza ou crueldade no amor. Amargurado sobre relacionamentos. Isolado pela defensividade. Honestidade dura prejudica a parceria. Suavize." } },
                "sv": { "stringUnit": { "state": "translated", "value": "Kyla eller grymhet i kärlek. Bitter om relationer. Isolerad genom defensivitet. Hård ärlighet skadar partnerskap. Mjukna." } },
                "uk": { "stringUnit": { "state": "translated", "value": "Холодність або жорстокість у коханні. Гіркота щодо стосунків. Ізоляція через захисну реакцію. Сувора чесність шкодить партнерству. Пом'якшайте." } }
            }
        },
