            }
        },
        "interpretation.king_of_swords_finance_upright": {
            "extractionState": "manual",
            "localizations": {
                "en": { "stringUnit": { "state": "translated", "value": "Authoritative, truthful financial approach. Intellectual power with money. Clear-minded resource management. Honest leadership in prosperity." } },
                "de": { "stringUnit": { "state": "translated", "value": "Autoritativer, wahrheitsliebender finanzieller Ansatz. Intellektuelle Kraft mit Geld. Klarköpfiges Ressourcenmanagement. Ehrliche Führung im Wohlstand." } },
                "es": { "stringUnit": { "state": "translated", "value": "Enfoque financiero autoritario y veraz. Poder intelectual con el dinero. Gestión de recursos con mente clara. Liderazgo honesto en la prosperidad." } },
                "fr": { "stringUnit": { "state": "translated", "value": "Approche financière autoritaire et véridique. Puissance intellectuelle avec l'argent. Gestion des ressources à l'esprit clair. Leadership honnête dans la prospérité." } },
                "it": { "stringUnit": { "state": "translated", "value": "Approccio finanziario autorevole e veritiero. Potere intellettuale con il denaro. Gestione delle risorse a mente chiara. Leadership onesta nella prosperità." } },
                "ja": { "stringUnit": { "state": "translated", "value": "権威的で真実の金銭的アプローチ。お金に関する知力。明確なリソース管理。繁栄における正直なリーダーシップ。" } },
                "nb": { "stringUnit": { "state": "translated", "value": "Autoritær, sannferdig finansiell tilnærming. Intellektuell kraft med penger. Klarhodet ressursforvaltning. Ærlig lederskap i velstand." } },
                "pl": { "stringUnit": { "state": "translated", "value": "Autorytarne, prawdomówne podejście finansowe. Siła intelektu z pieniędzmi. Zarządzanie zasobami z jasnym umysłem. Uczciwe przywództwo w dobrobycie." } },
                "pt-BR": { "stringUnit": { "state": "translated", "value": "Abordagem financeira autoritária e verdadeira. Poder intelectual com dinheiro. Gestão de recursos com mente clara. Liderança honesta na prosperidade." } },
                "sv": { "stringUnit": { "state": "translated", "value": "Auktoritär, sanningsenlig finansiell inställning. Intellektuell kraft med pengar. Klartänkt resurshantering. Ärligt ledarskap i välstånd." } },
                "uk": { "stringUnit": { "state": "translated", "value": "Авторитетний, правдивий фінансовий підхід. Інтелектуальна сила з грошима. Чітке управління ресурсами. Чесне лідерство в процвітанні." } }
            }
        },
