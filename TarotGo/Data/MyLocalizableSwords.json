        "interpretation.nine_of_swords_love_upright": {
            "extractionState": "manual",
            "localizations": {
                "en": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Romantic anxiety and relationship worry. Nightmares about love keep you up. Fear about partnership is overwhelming. Your mind torments you. Reach out for support."
                    }
                },
                "de": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Romantische Angst und Beziehungssorgen. Albträume über die Liebe halten dich wach. Die Angst vor der Partnerschaft ist überwältigend. Dein Geist quält dich. Suche dir Unterstützung."
                    }
                },
                "es": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Ansiedad romántica y preocupación por la relación. Pesadillas sobre el amor te mantienen despierto. El miedo a la pareja es abrumador. Tu mente te atormenta. Busca apoyo."
                    }
                },
                "fr": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Anxiété romantique et inquiétude relationnelle. Les cauchemars d'amour vous tiennent éveillé. La peur du partenariat est accablante. Votre esprit vous tourmente. Cherchez du soutien."
                    }
                },
                "it": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Ansia romantica e preoccupazione relazionale. Gli incubi sull'amore ti tengono sveglio. La paura della partnership è travolgente. La tua mente ti tormenta. Cerca supporto."
                    }
                },
                "ja": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "恋愛不安と関係の心配。愛についての悪夢で眠れない。パートナーシップへの恐れが圧倒的。あなたの心があなたを苦しめる。サポートを求めて。"
                    }
                },
                "nb": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Romantisk angst og forholdsbekymring. Mareritt om kjærlighet holder deg våken. Frykt for partnerskap er overveldende. Sinnet ditt plager deg. Søk støtte."
                    }
                },
                "pl": {
