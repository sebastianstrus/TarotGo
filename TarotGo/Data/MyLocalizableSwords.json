                "it": { "stringUnit": { "state": "translated", "value": "Manipolazione finanziaria o abuso del potere del denaro. Controllo tirannico sulle risorse. Usare la ricchezza come arma. Leadership finanziaria crudele." } },
                "ja": { "stringUnit": { "state": "translated", "value": "金銭的操作またはお金の力の乱用。リソースへの専制的な支配。富を武器として使う。残酷な金銭的リーダーシップ。" } },
                "nb": { "stringUnit": { "state": "translated", "value": "Økonomisk manipulasjon eller maktmisbruk med penger. Tyrannisk kontroll over ressurser. Bruke rikdom som våpen. Grusom finansiell lederskap." } },
                "pl": { "stringUnit": { "state": "translated", "value": "Manipulacja finansowa lub nadużycie władzy pieniężnej. Tyrańska kontrola nad zasobami. Używanie bogactwa jako broni. Okrutne przywództwo finansowe." } },
                "pt-BR": { "stringUnit": { "state": "translated", "value": "Manipulação financeira ou abuso do poder do dinheiro. Controle tirânico sobre os recursos. Usar a riqueza como arma. Liderança financeira cruel." } },
                "sv": { "stringUnit": { "state": "translated", "value": "Finansiell manipulation eller maktmissbruk med pengar. Tyrannisk kontroll över resurser. Använda rikedom som vapen. Grymt finansiellt ledarskap." } },
                "uk": { "stringUnit": { "state": "translated", "value": "Фінансова маніпуляція або зловживання грошовою владою. Тиранічний контроль над ресурсами. Використання багатства як зброї. Жорстоке фінансове лідерство." } }
            }
        },
        "interpretation.king_of_swords_health_upright": {
            "extractionState": "manual",
            "localizations": {
                "en": { "stringUnit": { "state": "translated", "value": "Authoritative, clear-minded wellness approach. Intellectual power serves health. Honest assessment of body. Logic guides healing." } },
                "de": { "stringUnit": { "state": "translated", "value": "Autoritativer, klarköpfiger Wellness-Ansatz. Intellektuelle Kraft dient der Gesundheit. Ehrliche Bewertung des Körpers. Logik leitet die Heilung." } },
                "es": { "stringUnit": { "state": "translated", "value": "Enfoque de bienestar autoritario y de mente clara. El poder intelectual sirve a la salud. Evaluación honesta del cuerpo. La lógica guía la curación." } },
                "fr": { "stringUnit": { "state": "translated", "value": "Approche bien-être autoritaire et claire. La puissance intellectuelle sert la santé. Évaluation honnête du corps. La logique guide la guérison." } },
                "it": { "stringUnit": { "state": "translated", "value": "Approccio al benessere autorevole e a mente chiara. Il potere intellettuale serve la salute. Valutazione onesta del corpo. La logica guida la guarigione." } },
                "ja": { "stringUnit": { "state": "translated", "value": "権威的で明確なウェルネスアプローチ。知力が健康に役立つ。体の正直な評価。論理が癒しを導く。" } },
                "nb": { "stringUnit": { "state": "translated", "value": "Autoritær, klarhodet velværetilnærming. Intellektuell kraft tjener helsen. Ærlig vurdering av kroppen. Logikk veileder helbredelse." } },
                "pl": { "stringUnit": { "state": "translated", "value": "Autorytarne, jasne podejście do dobrego samopoczucia. Siła intelektu służy zdrowiu. Uczciwa ocena ciała. Logika prowadzi do uzdrowienia." } },
                "pt-BR": { "stringUnit": { "state": "translated", "value": "Abordagem de bem-estar autoritária e de mente clara. O poder intelectual serve à saúde. Avaliação honesta do corpo. A lógica guia a cura." } },
                "sv": { "stringUnit": { "state": "translated", "value": "Auktoritär, klartänkt välmåendeansats. Intellektuell kraft tjänar hälsan. Ärlig bedömning av kroppen. Logik vägleder läkning." } },
                "uk": { "stringUnit": { "state": "translated", "value": "Авторитетний, чіткомислячий підхід до благополуччя. Інтелектуальна сила служить здоров'ю. Чесна оцінка тіла. Логіка веде до зцілення." } }
            }
        },
        "interpretation.king_of_swords_health_reversed": {
            "extractionState": "manual",
            "localizations": {
                "en": { "stringUnit": { "state": "translated", "value": "Health manipulation or tyrannical control over body. Cruel wellness approach. Abusing intellectual power for harmful health practices." } },
                "de": { "stringUnit": { "state": "translated", "value": "Gesundheitsmanipulation oder tyrannische Kontrolle über den Körper. Grausamer Wellness-Ansatz. Missbrauch intellektueller Kraft für schädliche Gesundheitspraktiken." } },
                "es": { "stringUnit": { "state": "translated", "value": "Manipulación de la salud o control tiránico sobre el cuerpo. Enfoque de bienestar cruel. Abusar del poder intelectual para prácticas de salud dañinas." } },
                "fr": { "stringUnit": { "state": "translated", "value": "Manipulation de la santé ou contrôle tyrannique du corps. Approche bien-être cruelle. Abuser du pouvoir intellectuel pour des pratiques de santé nocives." } },
                "it": { "stringUnit": { "state": "translated", "value": "Manipolazione della salute o controllo tirannico sul corpo. Approccio al benessere crudele. Abusare del potere intellettuale per pratiche sanitarie dannose." } },
                "ja": { "stringUnit": { "state": "translated", "value": "健康操作または体への専制的な支配。残酷なウェルネスアプローチ。有害な健康習慣のために知力を乱用する。" } },
                "nb": { "stringUnit": { "state": "translated", "value": "Helsemanipulasjon eller tyrannisk kontroll over kroppen. Grusom velværetilnærming. Misbruk av intellektuell kraft for skadelige helsepraksiser." } },
                "pl": { "stringUnit": { "state": "translated", "value": "Manipulacja zdrowiem lub tyrańska kontrola nad ciałem. Okrutne podejście do dobrego samopoczucia. Nadużywanie siły intelektu dla szkodliwych praktyk zdrowotnych." } },
                "pt-BR": { "stringUnit": { "state": "translated", "value": "Manipulação da saúde ou controle tirânico sobre o corpo. Abordagem cruel de bem-estar. Abusar do poder intelectual para práticas de saúde prejudiciais." } },
                "sv": { "stringUnit": { "state": "translated", "value": "Hälosmanipulation eller tyrannisk kontroll över kroppen. Grym välmåendeansats. Missbruka intellektuell kraft för skadliga hälsopraktiker." } },
                "uk": { "stringUnit": { "state": "translated", "value": "Маніпуляція здоров'ям або тиранічний контроль над тілом. Жорстокий підхід до благополуччя. Зловживання інтелектуальною силою для шкідливих практик здоров'я." } }
            }
        },
        "interpretation.king_of_swords_general_upright": {
            "extractionState": "manual",
            "localizations": {
                "en": { "stringUnit": { "state": "translated", "value": "Authority, truth, intellectual power, and clear mind. You lead with logic and ethics. Your judgment is sound and your communication is authoritative. Power through clarity." } },
                "de": { "stringUnit": { "state": "translated", "value": "Autorität, Wahrheit, intellektuelle Kraft und klarer Geist. Du führst mit Logik und Ethik. Dein Urteil ist fundiert und deine Kommunikation ist autoritativ. Macht durch Klarheit." } },
                "es": { "stringUnit": { "state": "translated", "value": "Autoridad, verdad, poder intelectual y mente clara. Lideras con lógica y ética. Tu juicio es sólido y tu comunicación es autoritaria. Poder a través de la claridad." } },
                "fr": { "stringUnit": { "state": "translated", "value": "Autorité, vérité, puissance intellectuelle et esprit clair. Vous dirigez avec logique et éthique. Votre jugement est solide et votre communication est autoritaire. Le pouvoir par la clarté." } },
                "it": { "stringUnit": { "state": "translated", "value": "Autorità, verità, potere intellettuale e mente chiara. Guidate con logica ed etica. Il tuo giudizio è solido e la tua comunicazione è autorevole. Potere attraverso la chiarezza." } },
                "ja": { "stringUnit": { "state": "translated", "value": "権威、真実、知力、明晰な心。あなたは論理と倫理で導く。あなたの判断は確かで、コミュニケーションは権威的。明確さを通しての力。" } },
                "nb": { "stringUnit": { "state": "translated", "value": "Autoritet, sannhet, intellektuell kraft og klart sinn. Du leder med logikk og etikk. Din dømmekraft er solid og kommunikasjonen din er autoritær. Makt gjennom klarhet." } },
                "pl": { "stringUnit": { "state": "translated", "value": "Władza, prawda, siła intelektu i jasny umysł. Prowadzisz z logiką i etyką. Twój osąd jest solidny, a komunikacja autorytatywna. Siła przez jasność." } },
                "pt-BR": { "stringUnit": { "state": "translated", "value": "Autoridade, verdade, poder intelectual e mente clara. Você lidera com lógica e ética. Seu julgamento é sólido e sua comunicação é autoritária. Poder através da clareza." } },
                "sv": { "stringUnit": { "state": "translated", "value": "Auktoritet, sanning, intellektuell kraft och klart sinne. Du leder med logik och etik. Din bedömning är sund och din kommunikation är auktoritär. Makt genom klarhet." } },
                "uk": { "stringUnit": { "state": "translated", "value": "Авторитет, правда, інтелектуальна сила та ясний розум. Ви ведете з логікою та етикою. Ваше судження є надійним, а ваше спілкування авторитетним. Сила через ясність." } }
            }
        },
        "interpretation.king_of_swords_general_reversed": {
            "extractionState": "manual",
            "localizations": {
                "en": { "stringUnit": { "state": "translated", "value": "Manipulation, abuse of power, tyranny, and cruelty. You're using your intellect and position as weapons. Logic without compassion becomes tyranny. Soften." } },
                "de": { "stringUnit": { "state": "translated", "value": "Manipulation, Machtmissbrauch, Tyrannei und Grausamkeit. Du nutzt deinen Intellekt und deine Position als Waffen. Logik ohne Mitgefühl wird zur Tyrannei. Werde weicher." } },
                "es": { "stringUnit": { "state": "translated", "value": "Manipulación, abuso de poder, tiranía y crueldad. Estás usando tu intelecto y posición como armas. La lógica sin compasión se convierte en tiranía. Suavízate." } },
                "fr": { "stringUnit": { "state": "translated", "value": "Manipulation, abus de pouvoir, tyrannie et cruauté. Vous utilisez votre intellect et votre position comme armes. La logique sans compassion devient tyrannie. Adoucissez-vous." } },
                "it": { "stringUnit": { "state": "translated", "value": "Manipolazione, abuso di potere, tirannia e crudeltà. Stai usando il tuo intelletto e la tua posizione come armi. La logica senza compassione diventa tirannia. Ammorbidisciti." } },
                "ja": { "stringUnit": { "state": "translated", "value": "操作、権力乱用、専制、残酷さ。あなたは知性と立場を武器として使っている。思いやりのない論理は専制になる。優しくなれ。" } },
                "nb": { "stringUnit": { "state": "translated", "value": "Manipulasjon, maktmisbruk, tyranni og grusomhet. Du bruker intellektet og posisjonen din som våpen. Logikk uten medfølelse blir tyranni. Mykne." } },
                "pl": { "stringUnit": { "state": "translated", "value": "Manipulacja, nadużycie władzy, tyrania i okrucieństwo. Używasz swojego intelektu i pozycji jako broni. Logika bez współczucia staje się tyranią. Zmięknij." } },
                "pt-BR": { "stringUnit": { "state": "translated", "value": "Manipulação, abuso de poder, tirania e crueldade. Você está usando seu intelecto e posição como armas. Lógica sem compaixão se torna tirania. Suavize." } },
                "sv": { "stringUnit": { "state": "translated", "value": "Manipulation, maktmissbruk, tyranni och grymhet. Du använder ditt intellekt och din position som vapen. Logik utan medkänsla blir tyranni. Mjukna." } },
                "uk": { "stringUnit": { "state": "translated", "value": "Маніпуляція, зловживання владою, тиранія та жорстокість. Ви використовуєте свій інтелект і позицію як зброю. Логіка без співчуття стає тиранією. Пом'якшайте." } }
            }
        },
