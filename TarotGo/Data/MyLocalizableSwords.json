        },
        "interpretation.five_of_swords_health_upright": {
            "extractionState": "manual",
            "localizations": {
                "en": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Health conflict and fighting body. Win-at-all-costs approach to wellness. Pushing too hard damages health. Examine your methods."
                    }
                },
                "de": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Gesundheitskonflikt und Kampf gegen den Körper. Sieg-um-jeden-Preis-Ansatz für das Wohlbefinden. Zu starkes Drängen schadet der Gesundheit. Überprüfe deine Methoden."
                    }
                },
                "es": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Conflicto de salud y lucha contra el cuerpo. Enfoque de ganar a toda costa para el bienestar. Forzar demasiado daña la salud. Examina tus métodos."
                    }
                },
                "fr": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Conflit de santé et lutte contre le corps. Approche gagner à tout prix du bien-être. Forcer trop fort nuit à la santé. Examinez vos méthodes."
                    }
                },
                "it": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Conflitto di salute e lotta contro il corpo. Approccio del vincere a tutti i costi per il benessere. Spingere troppo forte danneggia la salute. Esamina i tuoi metodi."
                    }
                },
                "ja": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "健康の葛藤と体との戦い。ウェルネスに対する勝利のためのアプローチ。頑張りすぎは健康を損なう。自分の方法を検討せよ。"
                    }
                },
                "nb": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Helsekonflikt og kamp mot kroppen. Vinn-for-all-pris-tilnærming til velvære. Å presse for hardt skader helsen. Undersøk metodene dine."
                    }
                },
                "pl": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Konflikt zdrowotny i walka z ciałem. Podejście zwycięstwa za wszelką cenę do dobrego samopoczucia. Zbyt mocne naciskanie szkodzi zdrowiu. Sprawdź swoje metody."
                    }
                },
                "pt-BR": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Conflito de saúde e luta contra o corpo. Abordagem de vencer a qualquer custo para o bem-estar. Forçar demais prejudica a saúde. Examine seus métodos."
                    }
                },
                "sv": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Hälsokonflikt och kamp mot kroppen. Vinn-till-varje-pris-inställning till välbefinnande. Att pressa för hårt skadar hälsan. Undersök dina metoder."
                    }
                },
                "uk": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Конфлікт здоров'я та боротьба з тілом. Підхід до благополуччя \"перемога за будь-яку ціну\". Занадто сильне напруження шкодить здоров'ю. Перевірте свої методи."
                    }
                }
            }
        },
