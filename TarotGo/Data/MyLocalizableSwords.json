        "interpretation.three_of_swords_general_upright": {
            "extractionState": "manual",
            "localizations": {
                "en": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Heartbreak, sorrow, pain, and grief. Truth cuts deep and hurts. Betrayal or loss pierces your heart. Your pain is real and valid. Feel it fully to heal."
                    }
                },
                "de": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Herzschmerz, Trauer, Schmerz und Kummer. Die Wahrheit schneidet tief und tut weh. Verrat oder Verlust durchbohrt dein Herz. Dein Schmerz ist real und berechtigt. Fühle ihn vollständig, um zu heilen."
                    }
                },
                "es": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Desamor, tristeza, dolor y aflicción. La verdad corta profundamente y duele. La traición o la pérdida perforan tu corazón. Tu dolor es real y válido. Siéntelo completamente para sanar."
                    }
                },
                "fr": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Chagrin, tristesse, douleur et peine. La vérité coupe profondément et fait mal. La trahison ou la perte transpercent votre cœur. Votre douleur est réelle et valide. Ressentez-la pleinement pour guérir."
                    }
                },
                "it": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Crepacuore, dolore, sofferenza e afflizione. La verità taglia a fondo e fa male. Il tradimento o la perdita trafiggono il tuo cuore. Il tuo dolore è reale e valido. Sentilo appieno per guarire."
                    }
                },
                "ja": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "失恋、悲しみ、痛み、嘆き。真実は深く切り込み、痛む。裏切りや喪失があなたの心を貫く。あなたの痛みは現実で正当なものだ。癒すために完全に感じよ。"
                    }
                },
                "nb": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Hjertesorg, sorg, smerte og fortvilelse. Sannheten skjærer dypt og gjør vondt. Svik eller tap gjennomborer hjertet ditt. Smerten din er ekte og gyldig. Føl den fullt ut for å helbrede."
                    }
                },
                "pl": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Złamane serce, smutek, ból i żal. Prawda rani głęboko i boli. Zdrada lub strata przeszywa twoje serce. Twój ból jest prawdziwy i uzasadniony. Poczuj go w pełni, aby uzdrowić."
                    }
                },
                "pt-BR": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Desgosto, tristeza, dor e luto. A verdade corta profundamente e dói. Traição ou perda perfuram seu coração. Sua dor é real e válida. Sinta-a completamente para curar."
                    }
                },
                "sv": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Hjärtesorg, sorg, smärta och bedrövelse. Sanningen skär djupt och gör ont. Svek eller förlust genomborrar ditt hjärta. Din smärta är verklig och giltig. Känn den fullt ut för att läka."
                    }
                },
                "uk": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Розбите серце, смуток, біль і скорбота. Правда ріже глибоко і болить. Зрада або втрата пронизують ваше серце. Ваш біль реальний і виправданий. Відчуйте його повністю, щоб зцілитися."
                    }
                }
            }
        },
        "interpretation.three_of_swords_general_reversed": {
            "extractionState": "manual",
            "localizations": {
                "en": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Recovery, forgiveness, moving on, and healing. The worst of the pain is passing. You're beginning to mend. Grief transforms into wisdom."
                    }
                },
                "de": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Erholung, Vergebung, Loslassen und Heilung. Das Schlimmste des Schmerzes geht vorüber. Du beginnst zu heilen. Trauer verwandelt sich in Weisheit."
                    }
                },
                "es": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Recuperación, perdón, superación y curación. Lo peor del dolor está pasando. Empiezas a repararte. El dolor se transforma en sabiduría."
                    }
                },
                "fr": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Rétablissement, pardon, dépassement et guérison. Le pire de la douleur s'en va. Vous commencez à vous réparer. Le chagrin se transforme en sagesse."
                    }
                },
                "it": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Recupero, perdono, superamento e guarigione. Il peggio del dolore sta passando. Stai iniziando a ripararti. Il dolore si trasforma in saggezza."
                    }
                },
                "ja": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "回復、許し、前進、癒し。痛みの最悪の部分は過ぎ去っている。あなたは修復し始めている。悲しみは知恵に変わる。"
                    }
                },
                "nb": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Bedring, tilgivelse, videregang og helbredelse. Det verste av smerten går over. Du begynner å bli frisk. Sorg blir til visdom."
                    }
                },
                "pl": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Powrót do zdrowia, przebaczenie, pójście dalej i uzdrowienie. Najgorszy ból mija. Zaczynasz się leczyć. Smutek przekształca się w mądrość."
                    }
                },
                "pt-BR": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Recuperação, perdão, superação e cura. O pior da dor está passando. Você está começando a se reparar. A tristeza se transforma em sabedoria."
                    }
                },
                "sv": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Återhämtning, förlåtelse, vidaregång och läkning. Det värsta av smärtan går över. Du börjar läka. Sorg förvandlas till visdom."
                    }
                },
                "uk": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Одужання, прощення, рух далі та зцілення. Найгірша частина болю минає. Ви починаєте зцілюватися. Горе перетворюється на мудрість."
                    }
                }
            }
        },
        "interpretation.four_of_swords_love_upright": {
