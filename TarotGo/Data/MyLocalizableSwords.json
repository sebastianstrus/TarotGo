                "de": { "stringUnit": { "state": "translated", "value": "Autoritativer, wahrheitsliebender Berufsansatz. Intellektuelle Kraft und klarer Geist bei der Arbeit. Ehrliche Karriereführung. Logik und Ethik leiten den Erfolg." } },
                "es": { "stringUnit": { "state": "translated", "value": "Enfoque profesional autoritario y veraz. Poder intelectual y mente clara en el trabajo. Liderazgo profesional honesto. La lógica y la ética guían el éxito." } },
                "fr": { "stringUnit": { "state": "translated", "value": "Approche professionnelle autoritaire et véridique. Puissance intellectuelle et esprit clair au travail. Leadership professionnel honnête. La logique et l'éthique guident le succès." } },
                "it": { "stringUnit": { "state": "translated", "value": "Approccio professionale autorevole e veritiero. Potere intellettuale e mente chiara al lavoro. Leadership professionale onesta. Logica ed etica guidano il successo." } },
                "ja": { "stringUnit": { "state": "translated", "value": "権威的で真実の仕事へのアプローチ。職場における知力と明晰な心。正直なキャリアリーダーシップ。論理と倫理が成功を導く。" } },
                "nb": { "stringUnit": { "state": "translated", "value": "Autoritær, sannferdig profesjonell tilnærming. Intellektuell kraft og klart sinn på jobb. Ærlig karriere lederskap. Logikk og etikk veileder suksess." } },
                "pl": { "stringUnit": { "state": "translated", "value": "Autorytarne, prawdomówne podejście zawodowe. Siła intelektu i jasny umysł w pracy. Uczciwe przywództwo w karierze. Logika i etyka prowadzą do sukcesu." } },
                "pt-BR": { "stringUnit": { "state": "translated", "value": "Abordagem profissional autoritária e verdadeira. Poder intelectual e mente clara no trabalho. Liderança de carreira honesta. Lógica e ética guiam o sucesso." } },
                "sv": { "stringUnit": { "state": "translated", "value": "Auktoritär, sanningsenlig professionell inställning. Intellektuell kraft och klart sinne på jobbet. Ärligt karriärledarskap. Logik och etik vägleder framgång." } },
                "uk": { "stringUnit": { "state": "translated", "value": "Авторитетний, правдивий професійний підхід. Інтелектуальна сила та ясний розум на роботі. Чесне кар'єрне лідерство. Логіка та етика ведуть до успіху." } }
            }
        },
