        "interpretation.ten_of_swords_health_upright": {
            "extractionState": "manual",
            "localizations": {
                "en": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Health rock bottom and physical crisis. Body betrayal and wellness breakdown. This is the worst it can get—healing begins here."
                    }
                },
                "de": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Gesundheitlicher Tiefpunkt und körperliche Krise. Körperverrat und Wohlfühl-Zusammenbruch. Schlimmer kann es nicht werden – hier beginnt die Heilung."
                    }
                },
                "es": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Fondo de salud y crisis física. Traición del cuerpo y colapso del bienestar. Esto es lo peor que puede pasar—la curación comienza aquí."
                    }
                },
                "fr": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Bas de santé et crise physique. Trahison du corps et effondrement du bien-être. C'est le pire qui puisse arriver – la guérison commence ici."
                    }
                },
                "it": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Punto più basso della salute e crisi fisica. Tradimento del corpo e crollo del benessere. Questo è il peggio che possa succedere – la guarigione inizia qui."
                    }
                },
                "ja": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "健康のどん底と身体の危機。体の裏切りとウェルネスの崩壊。これ以上悪くはならない——癒しはここから始まる。"
                    }
                },
                "nb": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Helsebunn og fysisk krise. Kroppssvik og velvære-sammenbrudd. Dette er det verste det kan bli – helbredelse begynner her."
                    }
                },
                "pl": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Dno zdrowotne i kryzys fizyczny. Zdrada ciała i załamanie dobrego samopoczucia. To najgorsze, co może się zdarzyć – leczenie zaczyna się tutaj."
                    }
                },
                "pt-BR": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Fundo de saúde e crise física. Traição do corpo e colapso do bem-estar. Este é o pior que pode ficar—a cura começa aqui."
                    }
                },
                "sv": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Hälsbotten och fysisk kris. Kroppssvek och välmåendekollaps. Detta är det värsta det kan bli – läkning börjar här."
                    }
                },
                "uk": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Дно здоров'я і фізична криза. Зрада тіла та крах благополуччя. Це найгірше, що може бути — зцілення починається тут."
                    }
                }
            }
        },
