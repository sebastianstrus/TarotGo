        "interpretation.five_of_swords_general_upright": {
            "extractionState": "manual",
            "localizations": {
                "en": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Conflict, defeat, win-at-all-costs, and betrayal. You might win the battle but lose the war. Fighting dirty damages relationships. Is this victory worth the cost?"
                    }
                },
                "de": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Konflikt, Niederlage, Sieg um jeden Preis und Verrat. Du gewinnst vielleicht die Schlacht, verlierst aber den Krieg. Unfaire Kämpfe schaden Beziehungen. Ist dieser Sieg die Kosten wert?"
                    }
                },
                "es": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Conflicto, derrota, ganar a toda costa y traición. Puedes ganar la batalla pero perder la guerra. Luchar sucio daña las relaciones. ¿Vale la pena esta victoria?"
                    }
                },
                "fr": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Conflit, défaite, gagner à tout prix et trahison. Vous pouvez gagner la bataille mais perdre la guerre. Se battre sale nuit aux relations. Cette victoire en vaut-elle la peine ?"
                    }
                },
                "it": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Conflitto, sconfitta, vincere a tutti i costi e tradimento. Potresti vincere la battaglia ma perdere la guerra. Combattere sporco danneggia le relazioni. Questa vittoria vale il costo?"
                    }
                },
                "ja": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "葛藤、敗北、勝利のための精神、裏切り。戦いに勝っても戦争に負けるかもしれない。汚い戦いは人間関係を損なう。この勝利は代償に見合うか？"
                    }
                },
                "nb": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Konflikt, nederlag, vinn-for-all-pris, og svik. Du kan vinne slaget, men tape krigen. Å kjempe skittent skader relasjoner. Er denne seieren verdt prisen?"
                    }
                },
                "pl": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Konflikt, porażka, zwycięstwo za wszelką cenę i zdrada. Możesz wygrać bitwę, ale przegrać wojnę. Nieczysta walka rani relacje. Czy to zwycięstwo jest warte kosztów?"
                    }
                },
                "pt-BR": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Conflito, derrota, vencer a qualquer custo e traição. Você pode vencer a batalha, mas perder a guerra. Lutar sujo prejudica os relacionamentos. Esta vitória vale o custo?"
                    }
                },
                "sv": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Konflikt, nederlag, vinn-till-varje-pris och svek. Du kan vinna slaget men förlora kriget. Att slåss smutsigt skadar relationer. Är denna seger värd kostnaden?"
                    }
                },
                "uk": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Конфлікт, поразка, перемога за будь-яку ціну та зрада. Ви можете виграти битву, але програти війну. Брудна боротьба шкодить стосункам. Чи варта ця перемога такої ціни?"
                    }
                }
            }
        },
        "interpretation.five_of_swords_general_reversed": {
            "extractionState": "manual",
            "localizations": {
                "en": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Reconciliation, making amends, moving on, and compromise. You're ready to end the conflict. Choosing peace over victory. Cooperation replaces combat."
                    }
                },
                "de": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Versöhnung, Wiedergutmachung, Loslassen und Kompromiss. Du bist bereit, den Konflikt zu beenden. Frieden statt Sieg wählen. Zusammenarbeit ersetzt Kampf."
                    }
                },
                "es": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Reconciliación, reparación, superación y compromiso. Estás listo para terminar el conflicto. Elegir la paz sobre la victoria. La cooperación reemplaza el combate."
                    }
                },
                "fr": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Réconciliation, réparation, dépassement et compromis. Vous êtes prêt à mettre fin au conflit. Choisir la paix plutôt que la victoire. La coopération remplace le combat."
                    }
                },
                "it": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Riconciliazione, riparazione, superamento e compromesso. Sei pronto a porre fine al conflitto. Scegliere la pace sulla vittoria. La cooperazione sostituisce la lotta."
                    }
                },
                "ja": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "和解、償い、前進、妥協。あなたは葛藤を終わらせる準備ができている。勝利よりも平和を選ぶ。戦いの代わりに協力。"
                    }
                },
                "nb": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Forlik, oppreisning, videregang og kompromiss. Du er klar til å avslutte konflikten. Velge fred fremfor seier. Samarbeid erstatter kamp."
                    }
                },
                "pl": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Pojednanie, naprawienie błędów, pójście dalej i kompromis. Jesteś gotowy zakończyć konflikt. Wybór pokoju nad zwycięstwem. Współpraca zastępuje walkę."
                    }
                },
                "pt-BR": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Reconciliação, reparação, superação e compromisso. Você está pronto para encerrar o conflito. Escolher a paz em vez da vitória. Cooperação substitui o combate."
                    }
                },
                "sv": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Försoning, gottgörelse, vidaregång och kompromiss. Du är redo att avsluta konflikten. Välja fred framför seger. Samarbete ersätter kamp."
                    }
                },
                "uk": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Примирення, виправлення, рух далі та компроміс. Ви готові закінчити конфлікт. Обрати мир замість перемоги. Співпраця замінює боротьбу."
                    }
                }
            }
        },
        "interpretation.six_of_swords_love_upright": {
            "extractionState": "manual",
            "localizations": {
                "en": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Relationship transition and moving forward from love pain. Healing journey in partnership. Leaving romantic turbulence for calmer waters. Progress through difficulty."
                    }
                },
                "de": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Beziehungsübergang und Fortschritt vom Liebesschmerz. Heilungsreise in der Partnerschaft. Romantische Turbulenzen hinter sich lassen für ruhigere Gewässer. Fortschritt durch Schwierigkeiten."
                    }
                },
                "es": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Transición de la relación y avance desde el dolor del amor. Viaje de sanación en la pareja. Dejar atrás la turbulencia romántica hacia aguas más tranquilas. Progreso a través de la dificultad."
                    }
                },
                "fr": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Transition relationnelle et avancée à partir de la douleur amoureuse. Voyage de guérison en partenariat. Quitter les turbulences romantiques pour des eaux plus calmes. Progrès à travers la difficulté."
                    }
                },
                "it": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Transizione relazionale e avanzamento dal dolore dell'amore. Viaggio di guarigione nella partnership. Lasciare le turbolenze romantiche per acque più calme. Progresso attraverso la difficoltà."
                    }
                },
                "ja": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "関係の移行と愛の痛みからの前進。パートナーシップにおける癒しの旅。恋愛の激動を離れ、穏やかな水域へ。困難を通しての進歩。"
                    }
                },
                "nb": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Forholdsovergang og fremgang fra kjærlighetssmerte. Helbredelsesreise i partnerskap. Forlate romantisk turbulens for roligere farvann. Fremgang gjennom vanskeligheter."
                    }
                },
                "pl": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Przejście w związku i odejście od bólu miłości. Podróż uzdrawiania w partnerstwie. Opuszczenie romantycznych turbulencji dla spokojniejszych wód. Postęp przez trudności."
                    }
                },
                "pt-BR": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Transição de relacionamento e avanço a partir da dor do amor. Jornada de cura na parceria. Deixando a turbulência romântica para águas mais calmas. Progresso através da dificuldade."
                    }
                },
                "sv": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Relationsövergång och framsteg från kärlekssmärta. Läkningsresa i partnerskap. Lämna romantisk turbulens för lugnare vatten. Framsteg genom svårigheter."
                    }
                },
                "uk": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Перехід у стосунках і рух вперед від болю кохання. Цілюща подорож у партнерстві. Залишення романтичної турбулентності для спокійніших вод. Прогрес через труднощі."
                    }
                }
            }
        },
        "interpretation.six_of_swords_love_reversed": {
            "extractionState": "manual",
            "localizations": {
                "en": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Stuck in past relationship pain. Resisting necessary love transition. Unfinished romantic business prevents moving forward. Rough emotional waters continue."
                    }
                },
                "de": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "In vergangenen Beziehungsschmerzen stecken. Widerstand gegen den notwendigen Liebesübergang. Unerledigte romantische Angelegenheiten verhindern das Vorankommen. Stürmische emotionale Gewässer bleiben bestehen."
                    }
                },
                "es": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Atrapado en el dolor de relaciones pasadas. Resistirse a la transición amorosa necesaria. Asuntos románticos pendientes impiden avanzar. Continúan las aguas emocionales turbulentas."
                    }
                },
                "fr": {
                    "stringUnit": {
                        "state": "translated",
