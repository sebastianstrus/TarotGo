        "interpretation.ace_of_swords_love_upright": {
            "extractionState": "manual",
            "localizations": {
                "en": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Mental clarity and breakthrough in love. Truth cuts through romantic confusion. New perspective on relationships. Clear communication transforms partnership."
                    }
                },
                "de": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Geistige Klarheit und Durchbruch in der Liebe. Wahrheit durchdringt romantische Verwirrung. Neue Perspektive auf Beziehungen. Klare Kommunikation verwandelt Partnerschaft."
                    }
                },
                "es": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Claridad mental y avance en el amor. La verdad corta la confusión romántica. Nueva perspectiva sobre las relaciones. La comunicación clara transforma la pareja."
                    }
                },
                "fr": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Clarté mentale et percée en amour. La vérité tranche la confusion romantique. Nouvelle perspective sur les relations. Une communication claire transforme le partenariat."
                    }
                },
                "it": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Chiarezza mentale e svolta nell'amore. La verità taglia la confusione romantica. Nuova prospettiva sulle relazioni. La comunicazione chiara trasforma la partnership."
                    }
                },
                "ja": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "恋愛における精神的な明晰さと突破口。真実が恋愛の混乱を断ち切る。人間関係の新しい視点。明確なコミュニケーションがパートナーシップを変革する。"
                    }
                },
                "nb": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Mental klarhet og gjennombrudd i kjærlighet. Sannheten skjærer gjennom romantisk forvirring. Nytt perspektiv på relasjoner. Klar kommunikasjon forvandler partnerskap."
                    }
                },
                "pl": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Mentalna jasność i przełom w miłości. Prawda przecina romantyczne zamieszanie. Nowa perspektywa na związki. Jasna komunikacja przekształca partnerstwo."
                    }
                },
                "pt-BR": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Clareza mental e avanço no amor. A verdade corta a confusão romântica. Nova perspectiva sobre relacionamentos. Comunicação clara transforma a parceria."
                    }
                },
                "sv": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Mental klarhet och genombrott i kärlek. Sanningen skär igenom romantisk förvirring. Nytt perspektiv på relationer. Tydlig kommunikation förvandlar partnerskap."
                    }
                },
                "uk": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Розумова ясність і прорив у коханні. Правда розрізає романтичну плутанину. Новий погляд на стосунки. Чітке спілкування перетворює партнерство."
                    }
                }
            }
        },
        "interpretation.ace_of_swords_love_reversed": {
            "extractionState": "manual",
            "localizations": {
                "en": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Romantic confusion and lack of clarity. Miscommunication damages love. Chaotic thoughts about relationship. Mental breakthrough blocked. Seek truth."
                    }
                },
                "de": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Romantische Verwirrung und Mangel an Klarheit. Missverständnisse schaden der Liebe. Chaotische Gedanken über die Beziehung. Geistiger Durchbruch blockiert. Suche die Wahrheit."
                    }
                },
                "es": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Confusión romántica y falta de claridad. La mala comunicación daña el amor. Pensamientos caóticos sobre la relación. Bloqueo del avance mental. Busca la verdad."
                    }
                },
                "fr": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Confusion romantique et manque de clarté. Une mauvaise communication nuit à l'amour. Pensées chaotiques sur la relation. Percée mentale bloquée. Cherche la vérité."
                    }
                },
                "it": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Confusione romantica e mancanza di chiarezza. L'incomprensione danneggia l'amore. Pensieri caotici sulla relazione. Svolta mentale bloccata. Cerca la verità."
                    }
                },
                "ja": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "恋愛における混乱と明確さの欠如。誤解が愛を傷つける。関係についての混沌とした思考。精神的な突破口は妨げられている。真実を求めて。"
                    }
                },
                "nb": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Romantisk forvirring og mangel på klarhet. Misforståelser skader kjærligheten. Kaotiske tanker om forholdet. Mentalt gjennombrudd blokkert. Søk sannheten."
                    }
                },
                "pl": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Romantyczne zamieszanie i brak jasności. Nieporozumienia ranią miłość. Chaotyczne myśli o związku. Mentalny przełom zablokowany. Szukaj prawdy."
                    }
                },
                "pt-BR": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Confusão romântica e falta de clareza. Falta de comunicação prejudica o amor. Pensamentos caóticos sobre o relacionamento. Avanço mental bloqueado. Busque a verdade."
                    }
                },
                "sv": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Romantisk förvirring och brist på klarhet. Missförstånd skadar kärleken. Kaotiska tankar om relationen. Mentalt genombrott blockerat. Sök sanningen."
                    }
                },
                "uk": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Романтична плутанина та відсутність ясності. Непорозуміння шкодить коханню. Хаотичні думки про стосунки. Розумовий прорив заблоковано. Шукай правду."
                    }
                }
            }
        },
        "interpretation.ace_of_swords_career_upright": {
            "extractionState": "manual",
            "localizations": {
                "en": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Professional breakthrough and mental clarity. New ideas and clear thinking advance career. Truth and communication bring success. Intellectual victory at work."
                    }
                },
                "de": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Beruflicher Durchbruch und geistige Klarheit. Neue Ideen und klares Denken fördern die Karriere. Wahrheit und Kommunikation bringen Erfolg. Intellektueller Sieg bei der Arbeit."
                    }
                },
                "es": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Avance profesional y claridad mental. Nuevas ideas y pensamiento claro impulsan la carrera. La verdad y la comunicación traen éxito. Victoria intelectual en el trabajo."
                    }
                },
                "fr": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Percée professionnelle et clarté mentale. Nouvelles idées et pensée claire font avancer la carrière. Vérité et communication apportent le succès. Victoire intellectuelle au travail."
                    }
                },
                "it": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Svolta professionale e chiarezza mentale. Nuove idee e pensiero chiaro fanno avanzare la carriera. Verità e comunicazione portano successo. Vittoria intellettuale sul lavoro."
                    }
                },
                "ja": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "仕事上のブレイクスルーと精神的な明晰さ。新しいアイデアと明確な思考がキャリアを前進させる。真実とコミュニケーションが成功をもたらす。仕事における知的勝利。"
                    }
                },
                "nb": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Profesjonelt gjennombrudd og mental klarhet. Nye ideer og klar tenkning fremmer karrieren. Sannhet og kommunikasjon bringer suksess. Intellektuell seier på jobb."
                    }
                },
                "pl": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Profesjonalny przełom i mentalna jasność. Nowe pomysły i jasne myślenie rozwijają karierę. Prawda i komunikacja przynoszą sukces. Intelektualne zwycięstwo w pracy."
                    }
                },
                "pt-BR": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Avanço profissional e clareza mental. Novas ideias e pensamento claro impulsionam a carreira. Verdade e comunicação trazem sucesso. Vitória intelectual no trabalho."
                    }
                },
                "sv": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Professionellt genombrott och mental klarhet. Nya idéer och tydligt tänkande främjar karriären. Sanning och kommunikation ger framgång. Intellektuell seger på jobbet."
                    }
                },
                "uk": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Професійний прорив і розумова ясність. Нові ідеї та чітке мислення просувають кар'єру. Правда та комунікація приносять успіх. Інтелектуальна перемога на роботі."
                    }
                }
            }
        },
