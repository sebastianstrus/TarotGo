                    }
                },
                "pl": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Ciekawość, zwinność umysłowa, czujność i komunikacja. Uczysz się, obserwujesz i pozostajesz czujny. Twój umysł jest bystry i szybki. Napływają wiadomości."
                    }
                },
                "pt-BR": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Curiosidade, agilidade mental, vigilância e comunicação. Você está aprendendo, observando e se mantendo alerta. Sua mente é afiada e rápida. Mensagens chegam."
                    }
