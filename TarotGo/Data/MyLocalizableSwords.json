                "de": { "stringUnit": { "state": "translated", "value": "Unabhängiger, klardenkender professioneller Ansatz. Ehrlich und direkt bei der Arbeit. Intellektuelle Führung. Wahrheit und Grenzen dienen der Karriere." } },
                "es": { "stringUnit": { "state": "translated", "value": "Enfoque profesional independiente y de pensamiento claro. Honesto y directo en el trabajo. Liderazgo intelectual. La verdad y los límites sirven a la carrera." } },
                "fr": { "stringUnit": { "state": "translated", "value": "Approche professionnelle indépendante et claire. Honnête et direct au travail. Leadership intellectuel. La vérité et les limites servent la carrière." } },
                "it": { "stringUnit": { "state": "translated", "value": "Approccio professionale indipendente e chiaro. Onesto e diretto al lavoro. Leadership intellettuale. Verità e confini servono la carriera." } },
                "ja": { "stringUnit": { "state": "translated", "value": "独立した明確な思考の仕事へのアプローチ。職場で正直で率直。知的リーダーシップ。真実と境界がキャリアに役立つ。" } },
                "nb": { "stringUnit": { "state": "translated", "value": "Uavhengig, klartenkende profesjonell tilnærming. Ærlig og direkte på jobb. Intellektuelt lederskap. Sannhet og grenser tjener karrieren." } },
                "pl": { "stringUnit": { "state": "translated", "value": "Niezależne, jasno myślące podejście zawodowe. Uczciwy i bezpośredni w pracy. Intelektualne przywództwo. Prawda i granice służą karierze." } },
                "pt-BR": { "stringUnit": { "state": "translated", "value": "Abordagem profissional independente e de pensamento claro. Honesto e direto no trabalho. Liderança intelectual. Verdade e limites servem à carreira." } },
                "sv": { "stringUnit": { "state": "translated", "value": "Oberoende, klartänkande professionell inställning. Ärlig och direkt på jobbet. Intellektuellt ledarskap. Sanning och gränser tjänar karriären." } },
                "uk": { "stringUnit": { "state": "translated", "value": "Незалежний, чіткомислячий професійний підхід. Чесно і прямо на роботі. Інтелектуальне лідерство. Правда та межі служать кар'єрі." } }
            }
        },
        "interpretation.queen_of_swords_career_reversed": {
            "extractionState": "manual",
            "localizations": {
                "en": { "stringUnit": { "state": "translated", "value": "Professional coldness or workplace cruelty. Career bitterness. Isolated through defensiveness. Harsh communication damages work relationships." } },
                "de": { "stringUnit": { "state": "translated", "value": "Berufliche Kälte oder Grausamkeit am Arbeitsplatz. Karriere-Bitterkeit. Durch Abwehrhaltung isoliert. Harte Kommunikation schadet den Arbeitsbeziehungen." } },
                "es": { "stringUnit": { "state": "translated", "value": "Frialdad profesional o crueldad en el lugar de trabajo. Amargura profesional. Aislado por la actitud defensiva. La comunicación dura daña las relaciones laborales." } },
                "fr": { "stringUnit": { "state": "translated", "value": "Froideur professionnelle ou cruauté sur le lieu de travail. Amertume professionnelle. Isolé par la défensive. Une communication dure nuit aux relations de travail." } },
                "it": { "stringUnit": { "state": "translated", "value": "Freddezza professionale o crudeltà sul posto di lavoro. Amarezza professionale. Isolato dalla difensiva. La comunicazione dura danneggia le relazioni lavorative." } },
                "ja": { "stringUnit": { "state": "translated", "value": "仕事上の冷たさや職場での残酷さ。キャリアへの bitterness。防御的な態度による孤立。厳しいコミュニケーションが仕事関係を損なう。" } },
                "nb": { "stringUnit": { "state": "translated", "value": "Profesjonell kulde eller grusomhet på arbeidsplassen. Karrierebitterhet. Isolert gjennom defensivitet. Hard kommunikasjon skader arbeidsforhold." } },
                "pl": { "stringUnit": { "state": "translated", "value": "Zawodowy chłód lub okrucieństwo w miejscu pracy. Gorycz kariery. Odizolowany przez defensywność. Surowe komunikowanie szkodzi relacjom w pracy." } },
                "pt-BR": { "stringUnit": { "state": "translated", "value": "Frieza profissional ou crueldade no local de trabalho. Amargura na carreira. Isolado pela defensividade. Comunicação dura prejudica as relações de trabalho." } },
                "sv": { "stringUnit": { "state": "translated", "value": "Professionell kyla eller grymhet på arbetsplatsen. Karriärbitterhet. Isolerad genom defensivitet. Hård kommunikation skadar arbetsrelationer." } },
                "uk": { "stringUnit": { "state": "translated", "value": "Професійна холодність або жорстокість на робочому місці. Кар'єрна гіркота. Ізоляція через захисну реакцію. Суворе спілкування шкодить робочим стосункам." } }
            }
        },
        "interpretation.queen_of_swords_finance_upright": {
            "extractionState": "manual",
            "localizations": {
                "en": { "stringUnit": { "state": "translated", "value": "Independent, clear-thinking financial approach. Honest and direct about money. Intellectual resource management. Truth about finances empowers." } },
                "de": { "stringUnit": { "state": "translated", "value": "Unabhängiger, klardenkender finanzieller Ansatz. Ehrlich und direkt über Geld. Intellektuelles Ressourcenmanagement. Die Wahrheit über Finanzen stärkt." } },
                "es": { "stringUnit": { "state": "translated", "value": "Enfoque financiero independiente y de pensamiento claro. Honesto y directo sobre el dinero. Gestión intelectual de recursos. La verdad sobre las finanzas empodera." } },
                "fr": { "stringUnit": { "state": "translated", "value": "Approche financière indépendante et claire. Honnête et direct sur l'argent. Gestion intellectuelle des ressources. La vérité sur les finances responsabilise." } },
                "it": { "stringUnit": { "state": "translated", "value": "Approccio finanziario indipendente e chiaro. Onesto e diretto sul denaro. Gestione intellettuale delle risorse. La verità sulle finanze dà potere." } },
                "ja": { "stringUnit": { "state": "translated", "value": "独立した明確な思考の金銭的アプローチ。お金について正直で率直。知的リソース管理。財政についての真実が力を与える。" } },
                "nb": { "stringUnit": { "state": "translated", "value": "Uavhengig, klartenkende finansiell tilnærming. Ærlig og direkte om penger. Intellektuell ressursforvaltning. Sannheten om økonomi styrker." } },
                "pl": { "stringUnit": { "state": "translated", "value": "Niezależne, jasno myślące podejście finansowe. Uczciwy i bezpośredni o pieniądzach. Intelektualne zarządzanie zasobami. Prawda o finansach daje siłę." } },
                "pt-BR": { "stringUnit": { "state": "translated", "value": "Abordagem financeira independente e de pensamento claro. Honesto e direto sobre dinheiro. Gestão intelectual de recursos. A verdade sobre as finanças fortalece." } },
                "sv": { "stringUnit": { "state": "translated", "value": "Oberoende, klartänkande finansiell inställning. Ärlig och direkt om pengar. Intellektuell resurshantering. Sanningen om ekonomi stärker." } },
                "uk": { "stringUnit": { "state": "translated", "value": "Незалежний, чіткомислячий фінансовий підхід. Чесно і прямо про гроші. Інтелектуальне управління ресурсами. Правда про фінанси дає силу." } }
            }
        },
        "interpretation.queen_of_swords_finance_reversed": {
            "extractionState": "manual",
            "localizations": {
                "en": { "stringUnit": { "state": "translated", "value": "Financial coldness or money cruelty. Bitter about resources. Isolated through financial defensiveness. Harsh money decisions damage relationships." } },
                "de": { "stringUnit": { "state": "translated", "value": "Finanzielle Kälte oder Geldgrausamkeit. Verbittert über Ressourcen. Durch finanzielle Abwehrhaltung isoliert. Harte Geldentscheidungen schaden Beziehungen." } },
                "es": { "stringUnit": { "state": "translated", "value": "Frialdad financiera o crueldad con el dinero. Amargado por los recursos. Aislado por la actitud defensiva financiera. Las decisiones duras sobre el dinero dañan las relaciones." } },
                "fr": { "stringUnit": { "state": "translated", "value": "Froideur financière ou cruauté monétaire. Amer à propos des ressources. Isolé par la défensive financière. Des décisions monétaires dures nuisent aux relations." } },
                "it": { "stringUnit": { "state": "translated", "value": "Freddezza finanziaria o crudeltà monetaria. Amareggiato per le risorse. Isolato dalla difensiva finanziaria. Le dure decisioni sul denaro danneggiano le relazioni." } },
                "ja": { "stringUnit": { "state": "translated", "value": "金銭的な冷たさまたはお金の残酷さ。リソースに対する bitterness。金銭的な防御による孤立。厳しい金銭的決断が人間関係を損なう。" } },
                "nb": { "stringUnit": { "state": "translated", "value": "Økonomisk kulde eller pengegrusomhet. Bitter om ressurser. Isolert gjennom økonomisk defensivitet. Harde pengebeslutninger skader relasjoner." } },
                "pl": { "stringUnit": { "state": "translated", "value": "Finansowy chłód lub okrucieństwo pieniężne. Gorzki w stosunku do zasobów. Odizolowany przez defensywność finansową. Surowe decyzje pieniężne szkodzą relacjom." } },
                "pt-BR": { "stringUnit": { "state": "translated", "value": "Frieza financeira ou crueldade com o dinheiro. Amargurado sobre recursos. Isolado pela defensividade financeira. Decisões financeiras duras prejudicam relacionamentos." } },
                "sv": { "stringUnit": { "state": "translated", "value": "Finansiell kyla eller pengagrymhet. Bitter om resurser. Isolerad genom finansiell defensivitet. Hårda pengebestlut skadar relationer." } },
                "uk": { "stringUnit": { "state": "translated", "value": "Фінансова холодність або грошова жорстокість. Гіркота щодо ресурсів. Ізоляція через фінансову захисну реакцію. Суворі грошові рішення шкодять стосункам." } }
            }
        },
        "interpretation.queen_of_swords_health_upright": {
            "extractionState": "manual",
            "localizations": {
                "en": { "stringUnit": { "state": "translated", "value": "Independent, clear-thinking wellness approach. Honest about body needs. Intellectual health management. Truth about physical state empowers." } },
                "de": { "stringUnit": { "state": "translated", "value": "Unabhängiger, klardenkender Wellness-Ansatz. Ehrlich über Körperbedürfnisse. Intellektuelles Gesundheitsmanagement. Die Wahrheit über den körperlichen Zustand stärkt." } },
                "es": { "stringUnit": { "state": "translated", "value": "Enfoque de bienestar independiente y de pensamiento claro. Honesto sobre las necesidades del cuerpo. Gestión intelectual de la salud. La verdad sobre el estado físico empodera." } },
                "fr": { "stringUnit": { "state": "translated", "value": "Approche bien-être indépendante et claire. Honnête sur les besoins du corps. Gestion intellectuelle de la santé. La vérité sur l'état physique responsabilise." } },
                "it": { "stringUnit": { "state": "translated", "value": "Approccio al benessere indipendente e chiaro. Onesto sui bisogni del corpo. Gestione intellettuale della salute. La verità sullo stato fisico dà potere." } },
                "ja": { "stringUnit": { "state": "translated", "value": "独立した明確な思考のウェルネスアプローチ。体のニーズについて正直。知的健康管理。身体状態についての真実が力を与える。" } },
                "nb": { "stringUnit": { "state": "translated", "value": "Uavhengig, klartenkende velværetilnærming. Ærlig om kroppens behov. Intellektuell helseforvaltning. Sannheten om fysisk tilstand styrker." } },
                "pl": { "stringUnit": { "state": "translated", "value": "Niezależne, jasno myślące podejście do dobrego samopoczucia. Uczciwy wobec potrzeb ciała. Intelektualne zarządzanie zdrowiem. Prawda o stanie fizycznym daje siłę." } },
                "pt-BR": { "stringUnit": { "state": "translated", "value": "Abordagem de bem-estar independente e de pensamento claro. Honesto sobre as necessidades do corpo. Gestão intelectual da saúde. A verdade sobre o estado físico fortalece." } },
                "sv": { "stringUnit": { "state": "translated", "value": "Oberoende, klartänkande välmåendeansats. Ärlig om kroppens behov. Intellektuell hälsohantering. Sanningen om fysiskt tillstånd stärker." } },
                "uk": { "stringUnit": { "state": "translated", "value": "Незалежний, чіткомислячий підхід до благополуччя. Чесно про потреби тіла. Інтелектуальне управління здоров'ям. Правда про фізичний стан дає силу." } }
            }
        },
        "interpretation.queen_of_swords_health_reversed": {
            "extractionState": "manual",
            "localizations": {
                "en": { "stringUnit": { "state": "translated", "value": "Health coldness or cruel self-talk about body. Bitter about wellness. Isolated through physical defensiveness. Harsh health approach damages self." } },
                "de": { "stringUnit": { "state": "translated", "value": "Gesundheitliche Kälte oder grausame Selbstgespräche über den Körper. Verbittert über das Wohlbefinden. Durch körperliche Abwehrhaltung isoliert. Harter Gesundheitsansatz schadet dem Selbst." } },
                "es": { "stringUnit": { "state": "translated", "value": "Frialdad de salud o diálogo interno cruel sobre el cuerpo. Amargado por el bienestar. Aislado por la actitud defensiva física. El enfoque duro de la salud se daña a sí mismo." } },
                "fr": { "stringUnit": { "state": "translated", "value": "Froideur de santé ou discours intérieur cruel sur le corps. Amer à propos du bien-être. Isolé par la défensive physique. Une approche sévère de la santé nuit à soi-même." } },
                "it": { "stringUnit": { "state": "translated", "value": "Freddezza sanitaria o dialogo interiore crudele sul corpo. Amareggiato per il benessere. Isolato dalla difensiva fisica. L'approccio sanitario duro danneggia il sé." } },
                "ja": { "stringUnit": { "state": "translated", "value": "健康の冷たさまたは体についての残酷な自己対話。ウェルネスへの bitterness。身体的な防御による孤立。厳しい健康アプローチが自分自身を傷つける。" } },
                "nb": { "stringUnit": { "state": "translated", "value": "Helsekulde eller grusom selvsnakk om kroppen. Bitter om velvære. Isolert gjennom fysisk defensivitet. Hard helsetilnærming skader selvet." } },
                "pl": { "stringUnit": { "state": "translated", "value": "Zdrowotny chłód lub okrutny wewnętrzny dialog o ciele. Gorzki w stosunku do dobrego samopoczucia. Odizolowany przez fizyczną defensywność. Surowe podejście do zdrowia szkodzi sobie." } },
                "pt-BR": { "stringUnit": { "state": "translated", "value": "Frieza de saúde ou autodiálogo cruel sobre o corpo. Amargurado sobre bem-estar. Isolado pela defensividade física. Abordagem dura da saúde prejudica a si mesmo." } },
                "sv": { "stringUnit": { "state": "translated", "value": "Hälsokyla eller grym självprat om kroppen. Bitter om välbefinnande. Isolerad genom fysisk defensivitet. Hård hälsosyn skadar jaget." } },
                "uk": { "stringUnit": { "state": "translated", "value": "Холодність здоров'я або жорстокий внутрішній діалог про тіло. Гіркота щодо благополуччя. Ізоляція через фізичну захисну реакцію. Суворий підхід до здоров'я шкодить собі." } }
            }
        },
        "interpretation.queen_of_swords_general_upright": {
            "extractionState": "manual",
            "localizations": {
                "en": { "stringUnit": { "state": "translated", "value": "Independence, clear thinking, honesty, and directness. You see truth clearly and speak it. Boundaries protect you. Your mind is sharp and your heart is guarded wisely." } },
                "de": { "stringUnit": { "state": "translated", "value": "Unabhängigkeit, klares Denken, Ehrlichkeit und Direktheit. Du siehst die Wahrheit klar und sprichst sie aus. Grenzen schützen dich. Dein Geist ist scharf und dein Herz ist weise geschützt." } },
                "es": { "stringUnit": { "state": "translated", "value": "Independencia, pensamiento claro, honestidad y franqueza. Ves la verdad con claridad y la dices. Los límites te protegen. Tu mente es aguda y tu corazón está sabiamente guardado." } },
                "fr": { "stringUnit": { "state": "translated", "value": "Indépendance, clarté d'esprit, honnêteté et franchise. Vous voyez la vérité clairement et la dites. Les limites vous protègent. Votre esprit est vif et votre cœur est sagement gardé." } },
                "it": { "stringUnit": { "state": "translated", "value": "Indipendenza, pensiero chiaro, onestà e direttezza. Vedi la verità chiaramente e la dici. I confini ti proteggono. La tua mente è acuta e il tuo cuore è saggiamente custodito." } },
                "ja": { "stringUnit": { "state": "translated", "value": "独立、明確な思考、正直さ、率直さ。あなたは真実をはっきりと見て、それを語る。境界があなたを守る。あなたの心は鋭く、あなたの心は賢く守られている。" } },
                "nb": { "stringUnit": { "state": "translated", "value": "Uavhengighet, klar tenkning, ærlighet og direkthet. Du ser sannheten klart og sier den. Grenser beskytter deg. Sinnet ditt er skarpt og hjertet ditt er klokt bevoktet." } },
                "pl": { "stringUnit": { "state": "translated", "value": "Niezależność, jasne myślenie, uczciwość i bezpośredniość. Widzisz prawdę wyraźnie i mówisz ją. Granice cię chronią. Twój umysł jest bystry, a serce mądrze strzeżone." } },
                "pt-BR": { "stringUnit": { "state": "translated", "value": "Independência, pensamento claro, honestidade e franqueza. Você vê a verdade claramente e a fala. Limites protegem você. Sua mente é afiada e seu coração é sabiamente guardado." } },
                "sv": { "stringUnit": { "state": "translated", "value": "Självständighet, klart tänkande, ärlighet och direktör. Du ser sanningen tydligt och säger den. Gränser skyddar dig. Ditt sinne är skarpt och ditt hjärta är klokt bevakat." } },
                "uk": { "stringUnit": { "state": "translated", "value": "Незалежність, чітке мислення, чесність і прямота. Ви бачите правду ясно і говорите її. Межі захищають вас. Ваш розум гострий, а серце мудро захищене." } }
            }
        },
        "interpretation.queen_of_swords_general_reversed": {
            "extractionState": "manual",
            "localizations": {
                "en": { "stringUnit": { "state": "translated", "value": "Coldness, cruelty, bitterness, and isolation. Your sharp mind has become a weapon. Defensiveness isolates you. Soften your edges." } },
                "de": { "stringUnit": { "state": "translated", "value": "Kälte, Grausamkeit, Bitterkeit und Isolation. Dein scharfer Verstand ist zur Waffe geworden. Abwehrhaltung isoliert dich. Mildere deine Schärfe." } },
                "es": { "stringUnit": { "state": "translated", "value": "Frialdad, crueldad, amargura y aislamiento. Tu mente aguda se ha convertido en un arma. La actitud defensiva te aísla. Suaviza tus bordes." } },
                "fr": { "stringUnit": { "state": "translated", "value": "Froideur, cruauté, amertume et isolement. Votre esprit vif est devenu une arme. La défensive vous isole. Adoucissez vos angles." } },
                "it": { "stringUnit": { "state": "translated", "value": "Freddezza, crudeltà, amarezza e isolamento. La tua mente acuta è diventata un'arma. La difensiva ti isola. Ammorbidisci i tuoi spigoli." } },
                "ja": { "stringUnit": { "state": "translated", "value": "冷たさ、残酷さ、 bitterness、孤立。あなたの鋭い心は武器になってしまった。防御的な態度があなたを孤立させる。角を丸くしろ。" } },
                "nb": { "stringUnit": { "state": "translated", "value": "Kulde, grusomhet, bitterhet og isolasjon. Dine skarpe sinn har blitt et våpen. Defensivitet isolerer deg. Mykne kantene dine." } },
                "pl": { "stringUnit": { "state": "translated", "value": "Chłód, okrucieństwo, gorycz i izolacja. Twój bystry umysł stał się bronią. Defensywność cię izoluje. Zmiękcz swoje krawędzie." } },
                "pt-BR": { "stringUnit": { "state": "translated", "value": "Frieza, crueldade, amargura e isolamento. Sua mente afiada se tornou uma arma. A defensividade isola você. Suavize suas arestas." } },
                "sv": { "stringUnit": { "state": "translated", "value": "Kyla, grymhet, bitterhet och isolering. Ditt skarpa sinne har blivit ett vapen. Defensivitet isolerar dig. Mjuka upp dina kanter." } },
                "uk": { "stringUnit": { "state": "translated", "value": "Холодність, жорстокість, гіркота та ізоляція. Ваш гострий розум став зброєю. Захисна реакція ізолює вас. Пом'якшіть свої кути." } }
            }
        },
        "interpretation.king_of_swords_love_upright": {
            "extractionState": "manual",
            "localizations": {
                "en": { "stringUnit": { "state": "translated", "value": "Authoritative, truthful approach to love. Intellectual power and clear mind in relationships. Honest leadership in partnership. Logic serves connection." } },
                "de": { "stringUnit": { "state": "translated", "value": "Autoritativer, wahrheitsliebender Ansatz in der Liebe. Intellektuelle Kraft und klarer Geist in Beziehungen. Ehrliche Führung in der Partnerschaft. Logik dient der Verbindung." } },
                "es": { "stringUnit": { "state": "translated", "value": "Enfoque autoritario y veraz en el amor. Poder intelectual y mente clara en las relaciones. Liderazgo honesto en la pareja. La lógica sirve a la conexión." } },
                "fr": { "stringUnit": { "state": "translated", "value": "Approche autoritaire et véridique de l'amour. Puissance intellectuelle et esprit clair dans les relations. Leadership honnête en partenariat. La logique sert la connexion." } },
                "it": { "stringUnit": { "state": "translated", "value": "Approccio autorevole e veritiero all'amore. Potere intellettuale e mente chiara nelle relazioni. Leadership onesta nella partnership. La logica serve la connessione." } },
                "ja": { "stringUnit": { "state": "translated", "value": "恋愛における権威的で真実のアプローチ。人間関係における知力と明晰な心。パートナーシップにおける正直なリーダーシップ。論理が繋がりに役立つ。" } },
                "nb": { "stringUnit": { "state": "translated", "value": "Autoritær, sannferdig tilnærming til kjærlighet. Intellektuell kraft og klart sinn i forhold. Ærlig lederskap i partnerskap. Logikk tjener forbindelsen." } },
                "pl": { "stringUnit": { "state": "translated", "value": "Autorytarne, prawdomówne podejście do miłości. Siła intelektu i jasny umysł w związkach. Uczciwe przywództwo w partnerstwie. Logika służy więzi." } },
                "pt-BR": { "stringUnit": { "state": "translated", "value": "Abordagem autoritária e verdadeira do amor. Poder intelectual e mente clara nos relacionamentos. Liderança honesta na parceria. A lógica serve à conexão." } },
                "sv": { "stringUnit": { "state": "translated", "value": "Auktoritär, sanningsenlig inställning till kärlek. Intellektuell kraft och klart sinne i relationer. Ärligt ledarskap i partnerskap. Logik tjänar anslutningen." } },
                "uk": { "stringUnit": { "state": "translated", "value": "Авторитетний, правдивий підхід до кохання. Інтелектуальна сила та ясний розум у стосунках. Чесне лідерство в партнерстві. Логіка служить зв'язку." } }
            }
        },
