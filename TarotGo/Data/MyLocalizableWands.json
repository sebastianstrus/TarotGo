                "pt-BR": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Resiliência no relacionamento e persistência romântica. Limites de amor após desafios. Última resistência na parceria. Cauteloso, mas não desistindo."
                    }
                },
                "sv": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Relationsresiliens och romantisk uthållighet. Kärleksgränser efter utmaningar. Sista ståndet i partnerskapet. Försiktig men inte ge upp."
                    }
                },
                "uk": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Стійкість у стосунках і романтична наполегливість. Межі кохання після викликів. Остання битва в партнерстві. Обережний, але не здається."
                    }
                }
            }
        },
