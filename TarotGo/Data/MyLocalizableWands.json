                "nb": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Forholdsresiliens og romantisk vedholdenhet. Kjærlighetsgrenser etter utfordringer. Siste stand i partnerskapet. Voktsom, men ikke gi opp."
