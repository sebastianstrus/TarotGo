        "interpretation.nine_of_wands_general_upright": {
            "extractionState": "manual",
            "localizations": {
                "en": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Resilience, persistence, last stand, and boundaries. You're battle-weary but not beaten. One more push. Protect yourself but don't isolate."
                    }
                },
                "de": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Resilienz, Beharrlichkeit, letzter Stand und Grenzen. Du bist kampfmüde, aber nicht besiegt. Noch ein letzter Stoß. Schütze dich, aber isoliere dich nicht."
                    }
                },
                "es": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Resiliencia, persistencia, última resistencia y límites. Estás cansado de la batalla pero no vencido. Un último empujón. Protégete pero no te aísles."
                    }
                },
                "fr": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Résilience, persistance, dernier rempart et limites. Vous êtes fatigué par la bataille mais pas vaincu. Un dernier effort. Protégez-vous mais ne vous isolez pas."
                    }
                },
                "it": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Resilienza, persistenza, ultima resistenza e limiti. Sei stanco della battaglia ma non sconfitto. Un ultimo sforzo. Proteggiti ma non isolarti."
                    }
                },
                "ja": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "回復力、粘り強さ、最後の抵抗、そして境界。あなたは戦いに疲れているが、打ち負かされてはいない。あと一押し。自分を守れ、しかし孤立するな。"
                    }
                },
                "nb": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Resiliens, utholdenhet, siste stand og grenser. Du er krigstrøtt, men ikke slått. En siste push. Beskytt deg selv, men ikke isoler deg."
                    }
                },
                "pl": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Odporność, wytrwałość, ostatnia walka i granice. Jesteś zmęczony walką, ale nie pokonany. Jeszcze jeden pchnięcie. Chroń się, ale nie izoluj."
                    }
                },
                "pt-BR": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Resiliência, persistência, última resistência e limites. Você está cansado da batalha, mas não derrotado. Mais um empurrão. Proteja-se, mas não se isole."
                    }
                },
                "sv": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Resiliens, uthållighet, sista stånd och gränser. Du är stridstrött men inte besegrad. En sista knuff. Skydda dig själv men isolera dig inte."
                    }
                },
                "uk": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Стійкість, наполегливість, остання битва та межі. Ви втомлені від битви, але не переможені. Ще один поштовх. Захистіть себе, але не ізолюйтеся."
                    }
                }
            }
        },
        "interpretation.nine_of_wands_general_reversed": {
            "extractionState": "manual",
            "localizations": {
                "en": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Exhaustion, paranoia, struggling on, and refusing help. You can barely hold on. Accept support. You don't have to do this alone."
                    }
                },
                "de": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Erschöpfung, Paranoia, Durchkämpfen und Hilfe verweigern. Du kannst kaum durchhalten. Nimm Unterstützung an. Du musst das nicht alleine schaffen."
                    }
                },
                "es": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Agotamiento, paranoia, luchando y negando ayuda. Apenas puedes aguantar. Acepta apoyo. No tienes que hacerlo solo."
                    }
                },
                "fr": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Épuisement, paranoïa, lutte et refus d'aide. Vous tenez à peine le coup. Acceptez le soutien. Vous n'avez pas à faire cela seul."
                    }
                },
                "it": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Esaurimento, paranoia, lotta e rifiuto dell'aiuto. Riesci a malapena a resistere. Accetta il supporto. Non devi farlo da solo."
                    }
                },
                "ja": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "疲労、パラノイア、苦闘、そして助けの拒否。あなたはかろうじて持ちこたえている。サポートを受け入れなさい。これを一人でやる必要はない。"
                    }
                },
                "nb": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Utmattelse, paranoia, slitende og nekte hjelp. Du så vidt holder ut. Godta støtte. Du trenger ikke gjøre dette alene."
                    }
                },
                "pl": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Wyczerpanie, paranoja, walka i odmowa pomocy. Ledwo się trzymasz. Zaakceptuj wsparcie. Nie musisz tego robić sam."
                    }
                },
                "pt-BR": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Exaustão, paranoia, lutando e recusando ajuda. Você mal consegue se segurar. Aceite apoio. Você não precisa fazer isso sozinho."
                    }
                },
                "sv": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Utmattning, paranoia, kämpa och vägra hjälp. Du håller knappt ut. Acceptera stöd. Du behöver inte göra detta ensam."
                    }
                },
                "uk": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Виснаження, параноя, боротьба та відмова від допомоги. Ви ледве тримаєтеся. Прийміть підтримку. Вам не потрібно робити це наодинці."
                    }
                }
            }
        },
        "interpretation.ten_of_wands_love_upright": {
            "extractionState": "manual",
            "localizations": {
                "en": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Relationship burden and romantic responsibility. Love feels heavy. Partnership requires hard work. Taking on too much in connection. Stress affects intimacy."
                    }
                },
                "de": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Beziehungsbelastung und romantische Verantwortung. Liebe fühlt sich schwer an. Partnerschaft erfordert harte Arbeit. Zu viel in der Verbindung übernehmen. Stress beeinträchtigt die Intimität."
                    }
                },
                "es": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Carga en la relación y responsabilidad romántica. El amor se siente pesado. La pareja requiere trabajo duro. Asumiendo demasiado en la conexión. El estrés afecta la intimidad."
                    }
                },
                "fr": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Fardeau relationnel et responsabilité romantique. L'amour semble lourd. Le partenariat exige un travail acharné. En prendre trop dans la connexion. Le stress affecte l'intimité."
                    }
                },
                "it": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Fardello della relazione e responsabilità romantica. L'amore sembra pesante. La partnership richiede duro lavoro. Assumere troppo nella connessione. Lo stress influisce sull'intimità."
                    }
                },
                "ja": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "関係の負担と恋愛の責任。愛が重く感じられる。パートナーシップにはハードワークが必要。つながりにおいて負いすぎる。ストレスが親密さに影響する。"
                    }
                },
                "nb": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Forholdsbyrde og romantisk ansvar. Kjærlighet føles tung. Partnerskap krever hardt arbeid. Tar på seg for mye i forbindelsen. Stress påvirker intimitet."
                    }
                },
                "pl": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Ciężar związku i romantyczna odpowiedzialność. Miłość wydaje się ciężka. Partnerstwo wymaga ciężkiej pracy. Branie na siebie zbyt wiele w połączeniu. Stres wpływa na intymność."
                    }
                },
                "pt-BR": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Fardo no relacionamento e responsabilidade romântica. O amor parece pesado. A parceria exige trabalho árduo. Assumindo muito na conexão. O estresse afeta a intimidade."
                    }
                },
                "sv": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Relationsbörda och romantiskt ansvar. Kärlek känns tung. Partnerskap kräver hårt arbete. Ta på sig för mycket i anslutningen. Stress påverkar intimiteten."
                    }
                },
                "uk": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Тягар стосунків і романтична відповідальність. Кохання здається важким. Партнерство вимагає важкої праці. Брати на себе забагато у зв'язку. Стрес впливає на близькість."
                    }
                }
            }
        },
        "interpretation.ten_of_wands_love_reversed": {
            "extractionState": "manual",
            "localizations": {
                "en": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Releasing relationship burden or delegating love responsibilities. Letting go of partnership stress. Lightening romantic load."
                    }
                },
                "de": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Loslassen von Beziehungsbelastungen oder Delegieren von Liebesverantwortungen. Partnerschaftsstress loslassen. Romantische Last erleichtern."
                    }
                },
                "es": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Soltando la carga de la relación o delegando responsabilidades amorosas. Dejando ir el estrés de la pareja. Aligerando la carga romántica."
                    }
                },
                "fr": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Relâcher le fardeau relationnel ou déléguer les responsabilités amoureuses. Lâcher prise sur le stress du partenariat. Alléger la charge romantique."
                    }
                },
                "it": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Rilasciare il fardello della relazione o delegare le responsabilità amorose. Lasciare andare lo stress della partnership. Alleggerire il carico romantico."
                    }
                },
                "ja": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "関係の負担を手放すか、愛の責任を委譲する。パートナーシップのストレスを手放す。恋愛の負担を軽くする。"
                    }
                },
                "nb": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Slippe forholdsbyrde eller delegere kjærlighetsansvar. Slippe tak i partnerskapsstress. Lette romantisk belastning."
                    }
                },
                "pl": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Uwalnianie ciężaru związku lub delegowanie odpowiedzialności miłosnych. Puszczanie stresu z partnerstwa. Zmniejszanie romantycznego obciążenia."
                    }
                },
                "pt-BR": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Liberando o fardo do relacionamento ou delegando responsabilidades amorosas. Deixando o estresse da parceria ir embora. Aliviando a carga romântica."
                    }
                },
                "sv": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Släppa relationsbörda eller delegera kärleksansvar. Släppa taget om partnerskapsstress. Lätta romantisk belastning."
                    }
                },
                "uk": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Звільнення від тягаря стосунків або делегування любовних обов'язків. Відпускання стресу партнерства. Полегшення романтичного тягаря."
                    }
                }
            }
        },
        "interpretation.ten_of_wands_career_upright": {
            "extractionState": "manual",
            "localizations": {
                "en": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Professional burden and work responsibility. Career feels overwhelming. Job requires excessive hard work. Taking on too much at work. Stress affects performance."
                    }
                },
                "de": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Berufliche Belastung und Arbeitsverantwortung. Karriere fühlt sich überwältigend an. Job erfordert übermäßig harte Arbeit. Zu viel auf der Arbeit übernehmen. Stress beeinträchtigt die Leistung."
                    }
                },
                "es": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Carga profesional y responsabilidad laboral. La carrera se siente abrumadora. El trabajo requiere un trabajo excesivamente duro. Asumiendo demasiado en el trabajo. El estrés afecta el rendimiento."
                    }
                },
                "fr": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Fardeau professionnel et responsabilité professionnelle. La carrière semble accablante. Le travail exige un travail excessivement dur. En prendre trop au travail. Le stress affecte la performance."
                    }
                },
                "it": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Fardello professionale e responsabilità lavorativa. La carriera sembra opprimente. Il lavoro richiede un duro lavoro eccessivo. Assumere troppo sul lavoro. Lo stress influisce sulle prestazioni."
                    }
                },
                "ja": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "職業的な負担と仕事の責任。キャリアが圧倒的に感じられる。仕事は過度のハードワークを必要とする。仕事で負いすぎる。ストレスがパフォーマンスに影響する。"
                    }
                },
                "nb": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Profesjonell byrde og arbeidsansvar. Karrieren føles overveldende. Jobben krever overdreven hardt arbeid. Tar på seg for mye på jobb. Stress påvirker ytelsen."
                    }
                },
                "pl": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Ciężar zawodowy i odpowiedzialność za pracę. Kariera wydaje się przytłaczająca. Praca wymaga nadmiernie ciężkiej pracy. Branie na siebie zbyt wiele w pracy. Stres wpływa na wydajność."
                    }
                },
                "pt-BR": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Fardo profissional e responsabilidade no trabalho. A carreira parece esmagadora. O trabalho exige trabalho excessivamente árduo. Assumindo muito no trabalho. O estresse afeta o desempenho."
                    }
                },
                "sv": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Professionell börda och arbetsansvar. Karriären känns överväldigande. Jobbet kräver överdrivet hårt arbete. Ta på sig för mycket på jobbet. Stress påverkar prestationen."
                    }
                },
                "uk": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Професійний тягар і робоча відповідальність. Кар'єра здається непосильною. Робота вимагає надмірно важкої праці. Брати на себе забагато на роботі. Стрес впливає на продуктивність."
                    }
                }
            }
        },
