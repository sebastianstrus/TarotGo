        "interpretation.ten_of_wands_general_upright": {
            "extractionState": "manual",
            "localizations": {
                "en": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Burden, responsibility, hard work, and stress. You're carrying too much. Almost at the destination but overwhelmed. Delegate or let go of something."
                    }
                },
                "de": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Last, Verantwortung, harte Arbeit und Stress. Du trägst zu viel. Fast am Ziel, aber überfordert. Delegiere oder lasse etwas los."
                    }
                },
                "es": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Carga, responsabilidad, trabajo duro y estrés. Estás cargando demasiado. Casi en el destino pero abrumado. Delega o deja ir algo."
                    }
                },
                "fr": {
                    "stringUnit": {
                        "state": "translated",
