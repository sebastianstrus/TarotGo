                    }
                },
                "it": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Ritardi, mancanza di direzione, opportunità mancate e battute d'arresto. Il tuo fuoco creativo è bloccato o male indirizzato. Rianima la tua passione."
                    }
                },
                "ja": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "遅延、方向性の欠如、逃した機会、そして挫折。あなたの創造的な火はブロックされているか、誤った方向に向かっています。情熱を再燃させなさい。"
                    }
                },
                "nb": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Forsinkelser, mangel på retning, tapte muligheter og tilbakeslag. Din kreative ild er blokkert eller feilstyrt. Tenn lidenskapen på nytt."
                    }
                },
                "pl": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Opóźnienia, brak kierunku, stracone okazje i niepowodzenia. Twoja kreatywna energia jest zablokowana lub źle skierowana. Rozpal na nowo swoją pasję."
                    }
                },
                "pt-BR": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Atrasos, falta de direção, oportunidades perdidas e reveses. Seu fogo criativo está bloqueado ou mal direcionado. Reacenda sua paixão."
                    }
                },
                "sv": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Förseningar, brist på riktning, missade möjligheter och motgångar. Din kreativa eld är blockerad eller felriktad. Tänd din passion igen."
                    }
                },
                "uk": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Затримки, відсутність напрямку, втрачені можливості та невдачі. Ваше творче полум'я заблоковане або спрямоване неправильно. Розпаліть свою пристрасть знову."
                    }
                }
            }
        },
        "interpretation.two_of_wands_love_upright": {
            "extractionState": "manual",
            "localizations": {
                "en": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Planning romantic future and relationship vision. Progress in love through decisions. Partnership at crossroads. Choose your path forward together."
                    }
                },
                "de": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Planung der romantischen Zukunft und Beziehungsvision. Fortschritt in der Liebe durch Entscheidungen. Partnerschaft am Scheideweg. Wählt gemeinsam euren Weg nach vorne."
                    }
                },
                "es": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Planificando el futuro romántico y la visión de la relación. Progreso en el amor a través de decisiones. Pareja en una encrucijada. Elijan su camino juntos."
                    }
                },
                "fr": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Planifier l'avenir romantique et la vision de la relation. Progrès dans l'amour grâce aux décisions. Partenariat à la croisée des chemins. Choisissez votre chemin ensemble."
                    }
                },
                "it": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Pianificare il futuro romantico e la visione della relazione. Progressi nell'amore attraverso le decisioni. Partnership al bivio. Scegliete insieme la strada da percorrere."
                    }
                },
                "ja": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "ロマンチックな未来と関係のビジョンを計画する。決断を通じて愛が進展する。パートナーシップは岐路に立っている。一緒に前進する道を選びなさい。"
                    }
                },
                "nb": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Planlegge romantisk fremtid og forholdsvisjon. Fremgang i kjærlighet gjennom beslutninger. Partnerskap ved veiskillet. Velg veien fremover sammen."
                    }
                },
                "pl": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Planowanie romantycznej przyszłości i wizji związku. Postęp w miłości poprzez decyzje. Partnerstwo na rozdrożu. Wybierzcie wspólnie drogę naprzód."
                    }
                },
                "pt-BR": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Planejando o futuro romântico e a visão do relacionamento. Progresso no amor através de decisões. Parceria em uma encruzilhada. Escolham o caminho juntos."
                    }
                },
                "sv": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Planera romantisk framtid och relationsvision. Framsteg i kärlek genom beslut. Partnerskap vid vägskäl. Välj er väg framåt tillsammans."
                    }
                },
                "uk": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Планування романтичного майбутнього та бачення стосунків. Прогрес у коханні через рішення. Партнерство на роздоріжжі. Оберіть свій шлях вперед разом."
                    }
                }
            }
        },
        "interpretation.two_of_wands_love_reversed": {
            "extractionState": "manual",
            "localizations": {
