                "pl": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Strach przed romantyczną nieznaną lub brak planowania związku. Grać bezpiecznie w miłości. Złe planowanie partnerstwa. Niejasna wizja związku."
                    }
                },
                "pt-BR": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Medo do desconhecido romântico ou falta de planejamento do relacionamento. Jogar pelo seguro no amor. Mau planejamento da parceria. Visão de relacionamento pouco clara."
                    }
                },
                "sv": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Rädsla för romantisk ovisshet eller brist på relationsplanering. Spela säkert i kärlek. Dålig partnerskapsplanering. Oklar relationsvision."
                    }
                },
                "uk": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Страх перед романтичним невідомим або відсутність планування стосунків. Грати безпечно в коханні. Погане планування партнерства. Нечітке бачення стосунків."
                    }
                }
            }
        },
