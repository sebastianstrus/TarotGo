        "interpretation.eight_of_wands_general_upright": {
            "extractionState": "manual",
            "localizations": {
                "en": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Speed, action, movement, and swift change. Things are happening fast. Messages arrive. Travel possible. Ride the momentum."
                    }
                },
                "de": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Geschwindigkeit, Aktion, Bewegung und schneller Wandel. Die Dinge passieren schnell. Nachrichten treffen ein. Reisen möglich. Nutze den Schwung."
                    }
                },
                "es": {
                    "stringUnit": {
                        "state": "translated",
