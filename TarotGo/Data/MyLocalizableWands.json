        "interpretation.six_of_wands_general_upright": {
            "extractionState": "manual",
            "localizations": {
                "en": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Success, recognition, victory, and achievement. You're winning and everyone sees it. Public acknowledgment of your efforts. Take a bow—you earned this."
                    }
                },
                "de": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Erfolg, Anerkennung, Sieg und Leistung. Du gewinnst und jeder sieht es. Öffentliche Anerkennung deiner Bemühungen. Verneige dich – das hast du dir verdient."
                    }
                },
                "es": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Éxito, reconocimiento, victoria y logro. Estás ganando y todos lo ven. Reconocimiento público de tus esfuerzos. Haz una reverencia, te lo has ganado."
                    }
                },
                "fr": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Succès, reconnaissance, victoire et accomplissement. Vous gagnez et tout le monde le voit. Reconnaissance publique de vos efforts. Inclinez-vous, vous l'avez mérité."
                    }
                },
                "it": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Successo, riconoscimento, vittoria e realizzazione. Stai vincendo e tutti lo vedono. Riconoscimento pubblico dei tuoi sforzi. Fai un inchino: te lo sei guadagnato."
                    }
                },
                "ja": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "成功、認識、勝利、そして達成。あなたは勝っていて、誰もがそれを見ている。あなたの努力の公的認知。お辞儀をしなさい - あなたはこれを獲得した。"
                    }
                },
                "nb": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Suksess, anerkjennelse, seier og prestasjon. Du vinner og alle ser det. Offentlig anerkjennelse av innsatsen din. Bukk – du har fortjent dette."
                    }
                },
                "pl": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Sukces, uznanie, zwycięstwo i osiągnięcie. Wygrywasz i wszyscy to widzą. Publiczne uznanie twoich wysiłków. Ukłoń się – zasłużyłeś na to."
                    }
                },
                "pt-BR": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Sucesso, reconhecimento, vitória e realização. Você está vencendo e todos veem. Reconhecimento público dos seus esforços. Faça uma reverência - você merece isso."
                    }
                },
                "sv": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Framgång, erkännande, seger och prestation. Du vinner och alla ser det. Offentligt erkännande av dina ansträngningar. Bocka dig - du förtjänar detta."
                    }
                },
                "uk": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Успіх, визнання, перемога та досягнення. Ви перемагаєте, і всі це бачать. Публічне визнання ваших зусиль. Вклоніться - ви заслужили це."
                    }
                }
            }
        },
        "interpretation.six_of_wands_general_reversed": {
            "extractionState": "manual",
            "localizations": {
                "en": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Failure, lack of recognition, arrogance, and egotism. Success isn't coming or you're too full of yourself. Check your ego."
                    }
                },
                "de": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Versagen, mangelnde Anerkennung, Arroganz und Egoismus. Der Erfolg bleibt aus oder du bist zu selbstverliebt. Überprüfe dein Ego."
                    }
                },
                "es": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Fracaso, falta de reconocimiento, arrogancia y egocentrismo. El éxito no llega o estás demasiado lleno de ti mismo. Controla tu ego."
                    }
                },
                "fr": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Échec, manque de reconnaissance, arrogance et égocentrisme. Le succès ne vient pas ou vous êtes trop imbu de vous-même. Vérifiez votre ego."
                    }
                },
                "it": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Fallimento, mancanza di riconoscimento, arroganza ed egocentrismo. Il successo non arriva o sei troppo pieno di te. Controlla il tuo ego."
                    }
                },
                "ja": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "失敗、認識不足、傲慢さ、そして自己中心性。成功が来ないか、あなたは自分自身に満ち溢れすぎている。あなたのエゴをチェックしなさい。"
                    }
                },
                "nb": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Svikt, mangel på anerkjennelse, arroganse og egosentrisme. Suksess kommer ikke eller du er for full av deg selv. Sjekk egoet ditt."
                    }
                },
                "pl": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Niepowodzenie, brak uznania, arogancja i egocentryzm. Sukces nie przychodzi lub jesteś zbyt pewny siebie. Sprawdź swoje ego."
                    }
                },
                "pt-BR": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Fracasso, falta de reconhecimento, arrogância e egocentrismo. O sucesso não está chegando ou você está muito cheio de si mesmo. Verifique seu ego."
                    }
                },
                "sv": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Misslyckande, brist på erkännande, arrogans och egocentrism. Framgången kommer inte eller du är för full av dig själv. Kolla ditt ego."
                    }
                },
                "uk": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Невдача, відсутність визнання, зарозумілість і егоїзм. Успіх не приходить, або ви занадто самовпевнені. Перевірте своє его."
                    }
                }
            }
        },
        "interpretation.seven_of_wands_love_upright": {
            "extractionState": "manual",
            "localizations": {
                "en": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Defending relationship and maintaining romantic control. Love under challenge. Standing your ground in partnership. Persevering through opposition."
                    }
                },
                "de": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Beziehung verteidigen und romantische Kontrolle bewahren. Liebe unter Herausforderung. Deinen Standpunkt in der Partnerschaft vertreten. Durchhalten gegen Widerstände."
                    }
                },
                "es": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Defendiendo la relación y manteniendo el control romántico. Amor bajo desafío. Manteniendo tu posición en la pareja. Perseverando a través de la oposición."
                    }
                },
                "fr": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Défendre la relation et maintenir le contrôle romantique. L'amour sous défi. Tenir bon dans le partenariat. Persévérer face à l'opposition."
                    }
                },
                "it": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Difendere la relazione e mantenere il controllo romantico. Amore sotto sfida. Mantenere la propria posizione nella partnership. Perseverare nonostante l'opposizione."
                    }
                },
                "ja": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "関係を守り、恋愛のコントロールを維持する。挑戦にさらされた愛。パートナーシップで自分の立場を守る。反対を乗り越えて忍耐する。"
                    }
                },
                "nb": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Forsvare forholdet og opprettholde romantisk kontroll. Kjærlighet under utfordring. Stå din grunn i partnerskapet. Holde ut mot motstand."
                    }
                },
                "pl": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Bronienie związku i utrzymywanie romantycznej kontroli. Miłość pod presją. Utrzymywanie swojej pozycji w partnerstwie. Wytrwanie pomimo opozycji."
                    }
                },
                "pt-BR": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Defendendo o relacionamento e mantendo o controle romântico. Amor sob desafio. Mantendo sua posição na parceria. Perseverando através da oposição."
                    }
                },
                "sv": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Försvara relationen och upprätthålla romantisk kontroll. Kärlek under utmaning. Stå fast i partnerskapet. Härda ut genom motstånd."
                    }
                },
                "uk": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Захист стосунків та підтримання романтичного контролю. Кохання під викликом. Стояти на своєму в партнерстві. Наполегливість через опір."
                    }
                }
            }
        },
