        "interpretation.five_of_wands_general_upright": {
            "extractionState": "manual",
            "localizations": {
                "en": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Competition, conflict, tension, and diversity. Everyone's fighting for their way. Is this healthy challenge or unnecessary drama? Navigate the chaos."
                    }
                },
                "de": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Wettbewerb, Konflikt, Spannung und Vielfalt. Jeder kämpft für seinen Weg. Ist das eine gesunde Herausforderung oder unnötiges Drama? Navigiere durch das Chaos."
                    }
                },
                "es": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Competencia, conflicto, tensión y diversidad. Todos luchan por su camino. ¿Es un desafío saludable o un drama innecesario? Navega por el caos."
                    }
                },
                "fr": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Compétition, conflit, tension et diversité. Tout le monde se bat pour sa voie. Est-ce un défi sain ou un drame inutile? Naviguez dans le chaos."
                    }
                },
                "it": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Competizione, conflitto, tensione e diversità. Tutti lottano per la propria strada. È una sfida salutare o un dramma inutile? Naviga nel caos."
                    }
                },
                "ja": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "競争、衝突、緊張、そして多様性。誰もが自分の道のために戦っている。これは健全な挑戦か、不必要なドラマか？混沌を進みなさい。"
                    }
                },
                "nb": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Konkurranse, konflikt, spenning og mangfold. Alle kjemper for sin vei. Er dette sunn utfordring eller unødvendig drama? Naviger i kaoset."
                    }
                },
                "pl": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Rywalizacja, konflikt, napięcie i różnorodność. Każdy walczy o swoją drogę. Czy to zdrowa rywalizacja czy niepotrzebny dramat? Poruszaj się w chaosie."
                    }
                },
                "pt-BR": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Competição, conflito, tensão e diversidade. Todo mundo está lutando pelo seu caminho. Isso é um desafio saudável ou drama desnecessário? Navegue pelo caos."
                    }
                },
                "sv": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Konkurrens, konflikt, spänning och mångfald. Alla kämpar för sin väg. Är detta en hälsosam utmaning eller onödigt drama? Navigera i kaoset."
                    }
                },
                "uk": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Конкуренція, конфлікт, напруга та різноманітність. Кожен бореться за свій шлях. Це здоровий виклик чи непотрібна драма? Орієнтуйтеся в хаосі."
                    }
                }
            }
        },
