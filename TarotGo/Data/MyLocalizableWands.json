                    "stringUnit": {
                        "state": "translated",
                        "value": "Opóźnienia romantyczne lub stracone okazje miłosne. Brak kierunku w związkach. Niepowodzenia w partnerstwie. Pasja zablokowana lub źle skierowana."
                    }
                },
                "pt-BR": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Atrasos românticos ou oportunidades de amor perdidas. Falta de direção nos relacionamentos. Reveses na parceria. Paixão bloqueada ou mal direcionada."
                    }
                },
                "sv": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Romantiska förseningar eller missade kärleksmöjligheter. Brist på riktning i relationer. Motgångar i partnerskapet. Passion blockerad eller felriktad."
                    }
