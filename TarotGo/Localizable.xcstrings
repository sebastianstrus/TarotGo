    "interpretation.judgement_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vermeidung von Beziehungsselbstreflexion oder strenge Selbstverurteilung. Weigerung, aus vergangenen romantischen Mustern zu lernen. Selbstzweifel blockieren die Liebeswiedergeburt."
