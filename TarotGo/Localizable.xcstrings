        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hälsoförtvivlan eller frånkoppling från läkning. Hopplöshet blockerar återhämtning. Återknyt kontakten med tron på din kropps visdom."
