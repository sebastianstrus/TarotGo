        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lekkomyślny w miłości lub niecierpliwy w związku. Nieskoncentrowana energia romantyczna. Impulsywne decyzje partnerskie. Zwolnij i pomyśl."
