        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Approccio professionale indipendente e chiaro. Onesto e diretto al lavoro. Leadership intellettuale. Verità e confini servono la carriera."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "独立した明確な思考の仕事へのアプローチ。職場で正直で率直。知的リーダーシップ。真実と境界がキャリアに役立つ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uavhengig, klartenkende profesjonell tilnærming. Ærlig og direkte på jobb. Intellektuelt lederskap. Sannhet og grenser tjener karrieren."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niezależne, jasno myślące podejście zawodowe. Uczciwy i bezpośredni w pracy. Intelektualne przywództwo. Prawda i granice służą karierze."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abordagem profissional independente e de pensamento claro. Honesto e direto no trabalho. Liderança intelectual. Verdade e limites servem à carreira."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oberoende, klartänkande professionell inställning. Ärlig och direkt på jobbet. Intellektuellt ledarskap. Sanning och gränser tjänar karriären."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Незалежний, чіткомислячий професійний підхід. Чесно і прямо на роботі. Інтелектуальне лідерство. Правда та межі служать кар'єрі."
          }
        }
      }
    },
    "interpretation.queen_of_swords_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Kälte oder Geldgrausamkeit. Verbittert über Ressourcen. Durch finanzielle Abwehrhaltung isoliert. Harte Geldentscheidungen schaden Beziehungen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial coldness or money cruelty. Bitter about resources. Isolated through financial defensiveness. Harsh money decisions damage relationships."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Frialdad financiera o crueldad con el dinero. Amargado por los recursos. Aislado por la actitud defensiva financiera. Las decisiones duras sobre el dinero dañan las relaciones."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Froideur financière ou cruauté monétaire. Amer à propos des ressources. Isolé par la défensive financière. Des décisions monétaires dures nuisent aux relations."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Freddezza finanziaria o crudeltà monetaria. Amareggiato per le risorse. Isolato dalla difensiva finanziaria. Le dure decisioni sul denaro danneggiano le relazioni."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "金銭的な冷たさまたはお金の残酷さ。リソースに対する bitterness。金銭的な防御による孤立。厳しい金銭的決断が人間関係を損なう。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk kulde eller pengegrusomhet. Bitter om ressurser. Isolert gjennom økonomisk defensivitet. Harde pengebeslutninger skader relasjoner."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finansowy chłód lub okrucieństwo pieniężne. Gorzki w stosunku do zasobów. Odizolowany przez defensywność finansową. Surowe decyzje pieniężne szkodzą relacjom."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Frieza financeira ou crueldade com o dinheiro. Amargurado sobre recursos. Isolado pela defensividade financeira. Decisões financeiras duras prejudicam relacionamentos."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finansiell kyla eller pengagrymhet. Bitter om resurser. Isolerad genom finansiell defensivitet. Hårda pengebestlut skadar relationer."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансова холодність або грошова жорстокість. Гіркота щодо ресурсів. Ізоляція через фінансову захисну реакцію. Суворі грошові рішення шкодять стосункам."
          }
        }
      }
    },
