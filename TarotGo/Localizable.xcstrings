    "interpretation.page_of_cups_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Emotionale Unreife, kreative Blockaden oder schlechte Nachrichten. Eskapismus und Unsicherheit verhindern Wachstum. Du hörst deine Intuition nicht klar. Erden dich emotional."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Emotional immaturity, creative blocks, or bad news. Escapism and insecurity prevent growth. You're not hearing your intuition clearly. Ground yourself emotionally."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inmadurez emocional, bloqueos creativos o malas noticias. El escapismo y la inseguridad impiden el crecimiento. No escuchas tu intuición con claridad. Conéctate emocionalmente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Immaturité émotionnelle, blocages créatifs ou mauvaises nouvelles. L'évasion et l'insécurité empêchent la croissance. Vous n'entendez pas clairement votre intuition. Ancrez-vous émotionnellement."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Immaturità emotiva, blocchi creativi o cattive notizie. L'evasione e l'insicurezza impediscono la crescita. Non ascolti chiaramente la tua intuizione. Radicati emotivamente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "感情的な未熟さ、創造的ブロック、悪い知らせ。逃避と不安が成長を妨げる。直感がはっきり聞こえていない。感情的に地に足をつけよ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Emosjonell umodenhet, kreative blokkeringer eller dårlige nyheter. Eskapisme og usikkerhet hindrer vekst. Du hører ikke intuisjonen din tydelig. Jord deg følelsesmessig."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niedojrzałość emocjonalna, blokady twórcze lub złe wieści. Eskapizm i niepewność uniemożliwiają rozwój. Nie słyszysz wyraźnie swojej intuicji. Uziemij się emocjonalnie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Imaturidade emocional, bloqueios criativos ou más notícias. Escapismo e insegurança impedem o crescimento. Você não está ouvindo sua intuição claramente. Firme-se emocionalmente."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Känslomässig omognad, kreativa blockeringar eller dåliga nyheter. Eskapism och osäkerhet förhindrar tillväxt. Du hör inte din intuition tydligt. Jorda dig känslomässigt."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Емоційна незрілість, творчі блокування або погані новини. Ескапізм і невпевненість перешкоджають зростанню. Ви не чуєте своєї інтуїції чітко. Заземліться емоційно."
          }
        }
      }
    },
    "interpretation.page_of_cups_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
