    },
    "interpretation.two_of_swords_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unentschlossenheit verschlimmert sich, Verwirrung vertieft sich oder Durchbruch kommt. Verzögerte Entscheidungen schaffen mehr Probleme oder Stillstand wird endlich gebrochen. Stelle dich jetzt der Wahrheit."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Indecision worsens, confusion deepens, or breakthrough arrives. Delayed decisions create more problems or stalemate finally breaks. Face truth now."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La indecisión empeora, la confusión se profundiza o llega un avance. Las decisiones retrasadas crean más problemas o el estancamiento finalmente se rompe. Enfrenta la verdad ahora."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'indécision s'aggrave, la confusion s'approfondit ou une percée arrive. Les décisions retardées créent plus de problèmes ou l'impasse se brise enfin. Faites face à la vérité maintenant."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'indecisione peggiora, la confusione si approfondisce o arriva la svolta. Le decisioni ritardate creano più problemi o lo stallo finalmente si rompe. Affronta la verità ora."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "優柔不断が悪化し、混乱が深まるか、ブレイクスルーが訪れる。遅れた決断がさらなる問題を生むか、膠着状態がついに打破される。今すぐ真実と向き合え。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ubesluttsomhet forverres, forvirring blir dypere, eller gjennombrudd kommer. Forsinkede beslutninger skaper flere problemer eller stagnasjon bryter endelig. Møt sannheten nå."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niezdecydowanie się pogłębia, zamieszanie narasta lub nadchodzi przełom. Opóźnione decyzje tworzą więcej problemów lub zastój wreszcie zostaje przełamany. Zmierz się z prawdą teraz."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Indecisão piora, confusão se aprofunda ou avanço chega. Decisões atrasadas criam mais problemas ou o impasse finalmente se rompe. Enfrente a verdade agora."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Obeslutsamhet förvärras, förvirring fördjupas eller genombrott kommer. Försenade beslut skapar fler problem eller dödläge bryts äntligen. Möt sanningen nu."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Нерішучість посилюється, плутанина поглиблюється або настає прорив. Відкладені рішення створюють більше проблем або застій нарешті руйнується. Зустрінься з правдою зараз."
          }
        }
      }
    },
    "interpretation.two_of_swords_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schwierige Entscheidungen, Stillstand, Vermeidung und Verleugnung. Du steckst fest und weigerst dich, die Wahrheit zu sehen. Nimm die Augenbinde ab. Triff die Entscheidung, die du vermeidest."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Difficult decisions, stalemate, avoidance, and denial. You're stuck and refusing to see the truth. Remove the blindfold. Make the choice you're avoiding."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Decisiones difíciles, estancamiento, evasión y negación. Estás atascado y te niegas a ver la verdad. Quítate la venda. Toma la decisión que estás evitando."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Décisions difficiles, impasse, évitement et déni. Vous êtes coincé et refusez de voir la vérité. Retirez le bandeau. Prenez la décision que vous évitez."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Decisioni difficili, stallo, evitamento e negazione. Sei bloccato e ti rifiuti di vedere la verità. Togli la benda. Prendi la decisione che stai evitando."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "難しい決断、膠着状態、回避、否定。あなたは行き詰まり、真実を見ようとしない。目隠しを外せ。避けている選択をしろ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vanskelige beslutninger, stagnasjon, unngåelse og fornektelse. Du sitter fast og nekter å se sannheten. Fjern bindet for øynene. Ta valget du unngår."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trudne decyzje, zastój, unikanie i zaprzeczanie. Jesteś uwięziony i odmawiasz zobaczenia prawdy. Zdejmij przepaskę. Podejmij decyzję, której unikasz."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Decisões difíceis, estagnação, evitação e negação. Você está preso e se recusa a ver a verdade. Tire a venda. Tome a decisão que você está evitando."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Svåra beslut, dödläge, undvikande och förnekelse. Du sitter fast och vägrar se sanningen. Ta av ögonbindeln. Gör valet du undviker."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Складні рішення, застій, уникнення та заперечення. Ви застрягли і відмовляєтеся бачити правду. Зніміть пов'язку з очей. Зробіть вибір, якого уникаєте."
          }
        }
      }
    },
    "interpretation.two_of_swords_health_reversed" : {
