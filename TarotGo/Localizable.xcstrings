    "interpretation.seven_of_swords_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reinen Tisch machen in der Beziehung oder Liebesgeheimnisse gestehen. Ehrlichkeit ersetzt Täuschung. Strategischen Ansatz in der Partnerschaft überdenken. Wahrheit kommt ans Licht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Coming clean in relationship or confessing love secrets. Honesty replaces deception. Rethinking strategic approach to partnership. Truth emerges."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confesar en la relación o revelar secretos de amor. La honestidad reemplaza el engaño. Repensar el enfoque estratégico de la pareja. La verdad emerge."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se confesser dans la relation ou avouer des secrets d'amour. L'honnêteté remplace la tromperie. Repenser l'approche stratégique du partenariat. La vérité émerge."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confessare nella relazione o rivelare segreti d'amore. L'onestà sostituisce l'inganno. Ripensare l'approccio strategico alla partnership. La verità emerge."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "関係での白状または恋愛の秘密の告白。誠実さが欺瞞に取って代わる。パートナーシップへの戦略的アプローチを再考する。真実が現れる。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Renere bord i forholdet eller tilstå kjærlighetshemmeligheter. Ærlighet erstatter bedrag. Revurdere strategisk tilnærming til partnerskap. Sannheten kommer frem."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oczyszczenie w związku lub wyznanie miłosnych tajemnic. Uczciwość zastępuje oszustwo. Ponowne przemyślenie strategicznego podejścia do partnerstwa. Prawda wychodzi na jaw."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confessar no relacionamento ou revelar segredos de amor. A honestidade substitui o engano. Repensar a abordagem estratégica da parceria. A verdade emerge."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Komma ren i relationen eller bekänna kärlekshemligheter. Ärlighet ersätter bedrägeri. Omtänka strategisk inställning till partnerskap. Sanningen kommer fram."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Зізнання у стосунках або розкриття любовних секретів. Чесність замінює обман. Переосмислення стратегічного підходу до партнерства. Правда виходить назовні."
          }
        }
      }
    },
    "interpretation.seven_of_swords_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beziehungstäuschung oder strategischer Ansatz in der Liebe. Herumschleichen oder etwas in der Partnerschaft durchkommen lassen. Unehrlichkeit schadet dem Vertrauen. Überprüfe deine Methoden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Relationship deception or strategic approach to love. Sneaking around or getting away with something in partnership. Dishonesty damages trust. Examine your methods."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Engaño en la relación o enfoque estratégico del amor. Escabullirse o salirse con la suya en la pareja. La deshonestidad daña la confianza. Examina tus métodos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tromperie relationnelle ou approche stratégique de l'amour. Se faufiler ou s'en tirer dans un partenariat. La malhonnêteté nuit à la confiance. Examinez vos méthodes."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inganno relazionale o approccio strategico all'amore. Intrufolarsi o farla franca in una partnership. La disonestà danneggia la fiducia. Esamina i tuoi metodi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "関係の欺瞞または恋愛への戦略的アプローチ。パートナーシップでのこそこそ行動または逃げ切り。不誠実は信頼を損なう。自分の方法を検討せよ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Forholdsbedrag eller strategisk tilnærming til kjærlighet. Sniking eller å komme unna med noe i partnerskap. Uærlighet skader tillit. Undersøk metodene dine."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oszustwo w związku lub strategiczne podejście do miłości. Zakradanie się lub uchodzenie na sucho w partnerstwie. Nieuczciwość niszczy zaufanie. Sprawdź swoje metody."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Engano no relacionamento ou abordagem estratégica do amor. Esgueirar-se ou safar-se em uma parceria. A desonestidade prejudica a confiança. Examine seus métodos."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Relationsbedrägeri eller strategisk inställning till kärlek. Smyga omkring eller komma undan med något i partnerskap. Oärlighet skadar förtroendet. Undersök dina metoder."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Обман у стосунках або стратегічний підхід до кохання. Прокрадання або безкарність у партнерстві. Недобросовісність шкодить довірі. Перевірте свої методи."
          }
        }
      }
    },
    "interpretation.seven_of_wands_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erschöpft von der Karriereverteidigung. Berufliches Aufgeben. Von den Herausforderungen der Arbeit überwältigt. Arbeitsplatz verlieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Exhausted from career defense. Giving up professionally. Overwhelmed by work challenges. Losing job ground."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Agotado de defender la carrera. Rindiéndose profesionalmente. Abrumado por los desafíos laborales. Perdiendo terreno en el trabajo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Épuisé de défendre sa carrière. Abandonner professionnellement. Débordé par les défis du travail. Perdre du terrain professionnel."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esausto dal difendere la carriera. Arrendersi professionalmente. Sopraffatto dalle sfide lavorative. Perdere terreno sul lavoro."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャリアを守ることに疲れ果てた。職業的にあきらめる。仕事の課題に圧倒される。仕事の立場を失う。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utslitt av karriereforsvar. Gi opp profesjonelt. Overveldet av jobbutfordringer. Miste jobbgrunn."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wyczerpany obroną kariery. Poddawanie się zawodowo. Przytłoczony wyzwaniami pracy. Tracenie gruntu w pracy."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Exausto de defender a carreira. Desistindo profissionalmente. Sobrecarregado pelos desafios do trabalho. Perdendo terreno no trabalho."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utmattad av karriärförsvar. Ge upp professionellt. Överväldigad av arbetsutmaningar. Förlora jobbmark."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Виснажений захистом кар'єри. Здатися професійно. Перевантажений робочими викликами. Втрата робочих позицій."
          }
        }
      }
    },
    "interpretation.seven_of_wands_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verteidigung der beruflichen Position und Aufrechterhaltung der Arbeitskontrolle. Karriere unter Druck. Auf dem Arbeitsplatz standhaft bleiben. Durchhalten gegen Widerstände."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Defending professional position and maintaining work control. Career under challenge. Standing your ground at job. Persevering through opposition."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Defendiendo la posición profesional y manteniendo el control laboral. Carrera bajo desafío. Manteniendo tu posición en el trabajo. Perseverando a través de la oposición."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Défendre la position professionnelle et maintenir le contrôle du travail. Carrière sous défi. Tenir bon au travail. Persévérer face à l'opposition."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Difendere la posizione professionale e mantenere il controllo del lavoro. Carriera sotto sfida. Mantenere la propria posizione sul lavoro. Perseverare nonostante l'opposizione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "職業的な立場を守り、仕事のコントロールを維持する。挑戦にさらされたキャリア。仕事で自分の立場を守る。反対を乗り越えて忍耐する。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Forsvare profesjonell posisjon og opprettholde arbeidskontroll. Karriere under utfordring. Stå din grunn på jobb. Holde ut mot motstand."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bronienie pozycji zawodowej i utrzymywanie kontroli nad pracą. Kariera pod presją. Utrzymywanie swojej pozycji w pracy. Wytrwanie pomimo opozycji."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Defendendo a posição profissional e mantendo o controle do trabalho. Carreira sob desafio. Mantendo sua posição no trabalho. Perseverando através da oposição."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Försvara professionell position och upprätthålla arbetskontroll. Karriär under utmaning. Stå fast på jobbet. Härda ut genom motstånd."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Захист професійної позиції та підтримання контролю над роботою. Кар'єра під викликом. Стояти на своєму на роботі. Наполегливість через опір."
          }
        }
      }
    },
    "interpretation.seven_of_wands_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erschöpft von der finanziellen Verteidigung. Wohlstand aufgeben. Von Geldproblemen überwältigt. Ressourcen verlieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Exhausted from financial defense. Giving up on prosperity. Overwhelmed by money challenges. Losing resource ground."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Agotado de defender las finanzas. Rindiéndose en la prosperidad. Abrumado por los desafíos económicos. Perdiendo terreno en recursos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Épuisé de la défense financière. Abandonner la prospérité. Débordé par les défis monétaires. Perdre du terrain en ressources."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esausto dalla difesa finanziaria. Arrendersi alla prosperità. Sopraffatto dalle sfide monetarie. Perdere terreno nelle risorse."
