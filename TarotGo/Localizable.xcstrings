    "interpretation.queen_of_wands_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Egoismus, Eifersucht, Unsicherheit und temperamentvolles Verhalten. Dein Selbstvertrauen ist zu Arroganz geworden. Aufmerksamkeitssuche untergräbt Beziehungen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Selfishness, jealousy, insecurity, and temperamental behavior. Your confidence has become arrogance. Attention-seeking undermines relationships."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Egoísmo, celos, inseguridad y comportamiento temperamental. Tu confianza se ha convertido en arrogancia. La búsqueda de atención socava las relaciones."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Égoïsme, jalousie, insécurité et comportement colérique. Votre confiance est devenue de l'arrogance. La recherche d'attention nuit aux relations."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Egoismo, gelosia, insicurezza e comportamento temperamentale. La tua fiducia è diventata arroganza. La ricerca di attenzione mina le relazioni."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "利己主義、嫉妬、不安定、気まぐれな行動。あなたの自信は傲慢さに変わった。注目欲求が人間関係を損なう。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Egoisme, sjalusi, usikkerhet og temperamentsfull atferd. Selvtilliten din har blitt arroganse. Oppmerksomhetssøken undergraver relasjoner."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Egoizm, zazdrość, niepewność i wybuchowe zachowanie. Twoja pewność siebie stała się arogancją. Poszukiwanie uwagi niszczy relacje."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Egoísmo, ciúme, insegurança e comportamento temperamental. Sua confiança se tornou arrogância. A busca por atenção prejudica os relacionamentos."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Själviskhet, svartsjuka, osäkerhet och temperamentsfullt beteende. Ditt självförtroende har blivit arrogans. Uppmärksamhetssökande undergräver relationer."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Егоїзм, ревнощі, невпевненість і темпераментна поведінка. Ваша впевненість перетворилася на зарозумілість. Пошук уваги підриває стосунки."
          }
        }
      }
    },
    "interpretation.queen_of_wands_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Selbstvertrauen, Entschlossenheit, Lebendigkeit und sozialer Magnetismus. Du bist ein natürlicher Anführer, der andere anzieht. Deine Leidenschaft und Wärme inspirieren. Erkenne deine Stärke an."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confidence, determination, vibrancy, and social magnetism. You're a natural leader who attracts others. Your passion and warmth inspire. Own your power."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confianza, determinación, vitalidad y magnetismo social. Eres un líder nato que atrae a los demás. Tu pasión y calidez inspiran. Reconoce tu poder."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confiance, détermination, vitalité et magnétisme social. Vous êtes un leader né qui attire les autres. Votre passion et votre chaleur inspirent. Assumez votre pouvoir."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fiducia, determinazione, vitalità e magnetismo sociale. Sei un leader naturale che attrae gli altri. La tua passione e calore ispirano. Possiedi il tuo potere."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "自信、決断力、活力、社会的魅力。あなたは他を惹きつける生まれながらのリーダーです。あなたの情熱と温かさが刺激を与えます。自分の力を所有しましょう。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Selvtillit, besluttsomhet, livlighet og sosial magnetisme. Du er en naturlig leder som tiltrekker andre. Din lidenskap og varme inspirerer. Eie din kraft."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pewność siebie, determinacja, żywiołowość i magnetyzm społeczny. Jesteś naturalnym liderem, który przyciąga innych. Twoja pasja i ciepło inspirują. Zaakceptuj swoją moc."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confiança, determinação, vibração e magnetismo social. Você é um líder nato que atrai os outros. Sua paixão e calor inspiram. Assuma seu poder."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Självförtroende, beslutsamhet, livfullhet och social magnetism. Du är en naturlig ledare som lockar andra. Din passion och värme inspirerar. Äg din kraft."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Впевненість, рішучість, життєрадісність і соціальний магнетизм. Ви природжений лідер, який приваблює інших. Ваша пристрасть і теплота надихають. Визнайте свою силу."
          }
        }
      }
    },
