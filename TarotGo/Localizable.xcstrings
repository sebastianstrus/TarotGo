    "interpretation.page_of_pentacles_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Prokrastination, mangelnder Fortschritt, schlechte Planung und verpasste Chancen. Sie setzen nichts um. Werden Sie praktisch und handeln Sie."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Procrastination, lack of progress, poor planning, and missed opportunities. You're not following through. Get practical and take action."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Procrastinación, falta de progreso, mala planificación y oportunidades perdidas. No estás siguiendo adelante. Sé práctico y actúa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Procrastination, manque de progrès, mauvaise planification et opportunités manquées. Vous ne donnez pas suite. Soyez pratique et passez à l'action."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Procrastinazione, mancanza di progressi, cattiva pianificazione e opportunità perse. Non stai portando a termine. Sii pratico e agisci."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "先延ばし、進歩の欠如、不十分な計画、逃した機会。あなたはやり遂げていない。実用的になり、行動を起こせ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Prokrastinering, mangel på fremgang, dårlig planlegging og gåtte muligheter tapt. Du følger ikke opp. Vær praktisk og ta handling."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Prokrastynacja, brak postępów, złe planowanie i utracone szanse. Nie doprowadzasz rzeczy do końca. Bądź praktyczny i podejmij działanie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Procrastinação, falta de progresso, mau planejamento e oportunidades perdidas. Você não está dando sequência. Seja prático e tome ação."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Prokrastinering, brist på framsteg, dålig planering och missade möjligheter. Du följer inte upp. Var praktisk och agera."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Прокрастинація, відсутність прогресу, погане планування та втрачені можливості. Ви не доводите справу до кінця. Будьте практичними та дійте."
