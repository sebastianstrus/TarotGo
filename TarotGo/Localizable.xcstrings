        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niestabilność kariery lub brak wsparcia zawodowego. Wyzwania związane z przejściem w pracy. Konflikt w biurze. Opóźnione świętowanie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Instabilidade na carreira ou falta de apoio profissional. Desafios na transição de trabalho. Conflito no escritório. Celebração adiada."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriärinstabilitet eller brist på professionellt stöd. Utmaningar med arbetsövergång. Kontorskonflikt. Firande försenat."
