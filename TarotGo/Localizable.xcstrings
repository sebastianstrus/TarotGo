{
  "sourceLanguage": "en",
  "strings": {
    "\"%@\"": {
      "comment": "A label displaying a user-submitted question. The text is wrapped to two lines.",
      "isCommentAutoGenerated": true
    },
    "(R)": {
      "comment": "A label indicating that the card is reversed.",
      "isCommentAutoGenerated": true
    },
    "%lld. %@": {
      "comment": "A number followed by a period and a card position name. The argument is the index of the card in the drawn cards list.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$lld. %2$@"
          }
        }
      }
    },
    "•": {
      "comment": "A separator between the suit and the card's number.",
      "isCommentAutoGenerated": true
    },
