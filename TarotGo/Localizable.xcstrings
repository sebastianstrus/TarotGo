        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eredità di salute e fondamento di benessere duraturo. La forza fisica è di famiglia. Saggezza sanitaria generazionale. Costruire una salute che dura."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "健康の遺産と永続的なウェルネスの基盤。身体的な強さは家族に受け継がれる。世代を超えた健康の知恵。持続する健康を築く。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Helsearv og varig velværegrunnlag. Fysisk styrke går i familien. Generasjonshelsevisdom. Bygge helse som varer."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dziedzictwo zdrowotne i trwała podstawa wellness. Siła fizyczna jest rodzinna. Mądrość zdrowotna pokoleń. Budowanie zdrowia, które trwa."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Legado de saúde e base de bem-estar duradoura. Força física é familiar. Sabedoria de saúde geracional. Construindo saúde que dura."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hälsoarv och varaktig hälso- och välmåendegrund. Fysisk styrka löper i familjen. Generationshälsovisdom. Bygga hälsa som varar."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Спадщина здоров'я та тривала оздоровча основа. Фізична сила передається в сім'ї. Поколінна мудрість здоров'я. Побудова здоров'я, яке триває."
          }
        }
      }
    },
    "interpretation.ten_of_pentacles_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Familienstreitigkeiten beeinträchtigen die Beziehung. Finanzielle Instabilität belastet die Partnerschaft. Gebrochenes Familienerbe oder Beziehungsunsicherheit. Das Fundament muss repariert werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Family disputes affect relationship. Financial instability strains partnership. Broken family legacy or relationship insecurity. Foundation needs repair."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las disputas familiares afectan la relación. La inestabilidad financiera tensa la sociedad. Legado familiar roto o inseguridad en la relación. La base necesita reparación."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les conflits familiaux affectent la relation. L'instabilité financière pèse sur le partenariat. Héritage familial brisé ou insécurité relationnelle. Les fondations ont besoin d'être réparées."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le dispute familiari influiscono sulla relazione. L'instabilità finanziaria mette a dura prova la partnership. Eredità familiare infranta o insicurezza relazionale. Le fondamenta necessitano di riparazione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "家族の争いが関係に影響する。経済的不安定がパートナーシップに負担をかける。壊れた家族の遺産または関係の不安定性。基盤の修復が必要。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Familiekonflikter påvirker forholdet. Økonomisk ustabilitet belaster partnerskapet. Brutt familiearv eller forholdsusikkerhet. Fundamentet trenger reparasjon."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spory rodzinne wpływają na związek. Niestabilność finansowa obciąża partnerstwo. Zerwane dziedzictwo rodzinne lub niepewność w związku. Fundament wymaga naprawy."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Disputas familiares afetam o relacionamento. Instabilidade financeira sobrecarrega a parceria. Legado familiar quebrado ou insegurança no relacionamento. Fundação precisa de reparo."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Familjetvister påverkar relationen. Ekonomisk instabilitet belastar partnerskapet. Brutit familjearv eller relationsosäkerhet. Grunden behöver repareras."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сімейні суперечки впливають на стосунки. Фінансова нестабільність обтяжує партнерство. Зруйнована сімейна спадщина або нестабільність стосунків. Фундамент потребує ремонту."
          }
        }
      }
    },
    "interpretation.ten_of_pentacles_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beziehungsstabilität und Familienerbe in der Liebe. Langfristige Partnerschaft, aufgebaut auf einem soliden Fundament. Generationensegen und dauerhaftes Engagement. Gemeinsam Familie aufbauen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Relationship stability and family legacy in love. Long-term partnership built on solid foundation. Generational blessing and lasting commitment. Building family together."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estabilidad en la relación y legado familiar en el amor. Sociedad a largo plazo construida sobre una base sólida. Bendición generacional y compromiso duradero. Construyendo familia juntos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stabilité relationnelle et héritage familial en amour. Partenariat à long terme construit sur une base solide. Bénédiction générationnelle et engagement durable. Construire une famille ensemble."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stabilità relazionale ed eredità familiare nell'amore. Partnership a lungo termine costruita su solide fondamenta. Benedizione generazionale e impegno duraturo. Costruire una famiglia insieme."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "愛における関係の安定と家族の遺産。確固たる基盤の上に築かれた長期的なパートナーシップ。世代を超えた祝福と永続的なコミットメント。一緒に家族を築く。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Forholdsstabilitet og familiearv i kjærlighet. Langsiktig partnerskap bygget på solid grunnmur. Generasjonsvelsignelse og varig forpliktelse. Bygge familie sammen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stabilność związku i rodzinne dziedzictwo w miłości. Długoterminowe partnerstwo zbudowane na solidnym fundamencie. Błogosławieństwo pokoleniowe i trwałe zaangażowanie. Budowanie rodziny razem."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estabilidade no relacionamento e legado familiar no amor. Parceria de longo prazo construída em base sólida. Bênção geracional e compromisso duradouro. Construindo família juntos."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Relationsstabilitet och familjearv i kärlek. Långsiktigt partnerskap byggt på solid grund. Generationsvälsignelse och varaktigt engagemang. Bygga familj tillsammans."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Стабільність стосунків та сімейна спадщина в любові. Довгострокове партнерство, побудоване на міцному фундаменті. Поколінне благословення та тривала відданість. Побудова сім'ї разом."
          }
        }
      }
    },
    "interpretation.ten_of_swords_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erholung von der Karriere-Krise oder Widerstand gegen das berufliche Ende. Regeneration nach dem Arbeitstiefpunkt. Vermeidung des unvermeidlichen Jobendes."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recovery from career crisis or resisting professional ending. Regeneration after work rock bottom. Avoiding inevitable job conclusion."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recuperación de la crisis profesional o resistencia al final profesional. Regeneración después del fondo laboral. Evitar la conclusión inevitable del trabajo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rétablissement après une crise professionnelle ou résistance à la fin professionnelle. Régénération après un creux de travail. Éviter la conclusion inévitable du travail."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recupero dalla crisi professionale o resistenza alla fine professionale. Rigenerazione dopo il punto più basso lavorativo. Evitare la conclusione inevitabile del lavoro."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャリアの危機からの回復または仕事上の終焉への抵抗。仕事のどん底からの再生。避けられない仕事の結末を回避する。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bedring fra karrierekrise eller motstand mot profesjonell slutt. Regenerasjon etter arbeidsbunn. Unngå uunngåelig jobbkonklusjon."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Powrót do zdrowia po kryzysie zawodowym lub opór przed zawodowym zakończeniem. Regeneracja po dnie pracy. Unikanie nieuniknionego zakończenia pracy."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recuperação da crise na carreira ou resistência ao término profissional. Regeneração após o fundo do trabalho. Evitar a conclusão inevitável do trabalho."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Återhämtning från karriärkris eller motstånd mot professionellt slut. Regeneration efter arbetsbotten. Undvika oundviklig jobbkonklusion."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Одужання від кар'єрної кризи або опір професійному завершенню. Регенерація після робочого дна. Уникнення неминучого завершення роботи."
          }
        }
      }
    },
    "interpretation.ten_of_swords_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karrieretiefpunkt und schmerzhaftes berufliches Ende. Arbeitsverrat und Jobkrise. Schlimmer kann es nicht werden – hier beginnt die Transformation."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Career rock bottom and painful professional ending. Work betrayal and job crisis. This is the worst it can get—transformation begins here."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fondo de la carrera y final profesional doloroso. Traición laboral y crisis laboral. Esto es lo peor que puede pasar—la transformación comienza aquí."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bas de carrière et fin professionnelle douloureuse. Trahison au travail et crise professionnelle. C'est le pire qui puisse arriver – la transformation commence ici."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Punto più basso della carriera e fine professionale dolorosa. Tradimento sul lavoro e crisi lavorativa. Questo è il peggio che possa succedere – la trasformazione inizia qui."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャリアのどん底と痛みを伴う仕事上の終焉。職場での裏切りと仕事の危機。これ以上悪くはならない——変革はここから始まる。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karrierebunn og smertefull profesjonell slutt. Arbeidssvik og jobbkrise. Dette er det verste det kan bli – transformasjon begynner her."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dno kariery i bolesne zawodowe zakończenie. Zdrada w pracy i kryzys zawodowy. To najgorsze, co może się zdarzyć – transformacja zaczyna się tutaj."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fundo da carreira e término profissional doloroso. Traição no trabalho e crise no emprego. Este é o pior que pode ficar—a transformação começa aqui."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriärbotten och smärtsamt professionellt slut. Arbetsförräderi och jobbkris. Detta är det värsta det kan bli – förvandling börjar här."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Кар'єрне дно і болісне професійне завершення. Зрада на роботі та криза на роботі. Це найгірше, що може бути — трансформація починається тут."
          }
        }
      }
    },
