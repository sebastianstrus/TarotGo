    },
    "interpretation.two_of_swords_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schwierige finanzielle Entscheidung oder Geld-Stillstand. Die Wahrheit über Geld zu vermeiden, erzeugt Stress. Zwischen finanziellen Entscheidungen feststecken. Mehr Informationen benötigt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Difficult financial decision or money stalemate. Avoiding money truth creates stress. Stuck between financial choices. Need more information."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Decisión financiera difícil o estancamiento económico. Evitar la verdad sobre el dinero crea estrés. Atascado entre opciones financieras. Se necesita más información."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Décision financière difficile ou impasse monétaire. Éviter la vérité sur l'argent crée du stress. Coincé entre des choix financiers. Besoin de plus d'informations."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Decisione finanziaria difficile o stallo monetario. Evitare la verità sul denaro crea stress. Bloccato tra scelte finanziarie. Necessità di più informazioni."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "難しい金銭的決断またはお金の膠着状態。お金の真実を避けることでストレスが生まれる。金銭的な選択肢の間で行き詰まる。より多くの情報が必要。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vanskelig økonomisk beslutning eller penge-stagnasjon. Å unngå penge-sannhet skaper stress. Fast mellom økonomiske valg. Trenger mer informasjon."
          }
