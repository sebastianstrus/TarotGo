    "summary.closing.1" : {
      "comment" : "these cards are telling a story that requires your attention and honest reflection.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "diese Karten erzählen eine Geschichte, die deine Aufmerksamkeit und ehrliche Reflexion erfordert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "these cards are telling a story that requires your attention and honest reflection."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "estas cartas cuentan una historia que requiere tu atención y reflexión honesta."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ces cartes racontent une histoire qui nécessite votre attention et une réflexion honnête."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "queste carte raccontano una storia che richiede la tua attenzione e una riflessione onesta."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "これらのカードはあなたの注意と正直な内省を必要とする物語を語っています。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "disse kortene forteller en historie som krever din oppmerksomhet og ærlig refleksjon."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "te karty opowiadają historię, która wymaga twojej uwagi i szczerej refleksji."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "estas cartas estão contando uma história que requer sua atenção e reflexão honesta."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "dessa kort berättar en historia som kräver din uppmärksamhet och ärlig reflektion."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ці карти розповідають історію, яка потребує вашої уваги та чесного роздуму."
          }
        }
      }
    },
    "summary.closing.2" : {
      "comment" : "pay attention to how these energies are showing up in your life right now.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "achte darauf, wie sich diese Energien gerade jetzt in deinem Leben zeigen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "pay attention to how these energies are showing up in your life right now."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "presta atención a cómo estas energías se manifiestan en tu vida ahora mismo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "faites attention à la façon dont ces énergies se manifestent dans votre vie en ce moment."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "presta attenzione a come queste energie si manifestano nella tua vita in questo momento."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "これらのエネルギーが今あなたの人生でどのように現れているかに注意を払ってください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "vær oppmerksom på hvordan disse energiene viser seg i livet ditt akkurat nå."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "zwróć uwagę na to, jak te energie przejawiają się w twoim życiu teraz."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "preste atenção em como essas energias estão se manifestando em sua vida agora."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "var uppmärksam på hur dessa energier visar sig i ditt liv just nu."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "зверніть увагу на те, як ці енергії проявляються у вашому житті прямо зараз."
          }
        }
      }
    },
    "summary.closing.3" : {
      "comment" : "the cards invite you to sit with these insights and see what resonates.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "die Karten laden dich ein, mit diesen Einsichten zu verweilen und zu sehen, was in dir widerhallt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "the cards invite you to sit with these insights and see what resonates."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "las cartas te invitan a quedarte con estos conocimientos y ver qué resuena."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "les cartes vous invitent à méditer sur ces révélations et à voir ce qui résonne."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "le carte ti invitano a riflettere su queste intuizioni e vedere cosa risuona."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "カードはこれらの洞察とともに過ごし、何が共鳴するかを見るようあなたを招いています。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "kortene inviterer deg til å sitte med disse innsiktene og se hva som resonerer."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "karty zapraszają cię, abyś przemyślał te przesłania i zobaczył, co w tobie rezonuje."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "as cartas convidam você a sentar com esses insights e ver o que ressoa."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "korten bjuder in dig att sitta med dessa insikter och se vad som resonerar."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "карти запрошують вас посидіти з цими прозріннями та побачити, що відгукується."
          }
        }
      }
    },
    "summary.closing.4" : {
      "comment" : "trust your intuition as you interpret what the cards are revealing.",
