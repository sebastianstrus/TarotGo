    "interpretation.page_of_cups_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kreative Blockaden bei der Arbeit oder berufliche Unreife. Schlechte Karrierenachrichten oder verpasste kreative Chancen. Eskapismus beeinträchtigt die berufliche Leistung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Creative blocks at work or professional immaturity. Bad career news or missed creative opportunities. Escapism affecting professional performance."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bloqueos creativos en el trabajo o inmadurez profesional. Malas noticias profesionales u oportunidades creativas perdidas. El escapismo afecta el rendimiento profesional."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Blocages créatifs au travail ou immaturité professionnelle. Mauvaises nouvelles de carrière ou opportunités créatives manquées. L'évasion affecte les performances professionnelles."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Blocchi creativi al lavoro o immaturità professionale. Cattive notizie di carriera o opportunità creative perse. L'evasione influisce sulle prestazioni professionali."
          }
        },
