    "interpretation.judgement_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vermeidung von beruflicher Selbstreflexion oder strenge berufliche Selbstkritik. Weigerung, aus vergangenen Fehlern zu lernen. Selbstzweifel blockieren die Karrierewiedergeburt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avoiding career self-assessment or harsh professional self-criticism. Refusing to learn from past mistakes. Self-doubt blocks career rebirth."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Evitar la autoevaluación profesional o una dura autocrítica profesional. Negarse a aprender de errores pasados. La duda de sí mismo bloquea el renacimiento profesional."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Éviter l'auto-évaluation professionnelle ou une dure autocritique professionnelle. Refus d'apprendre des erreurs passées. Le doute de soi bloque la renaissance de carrière."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Evitare l'autovalutazione professionale o una dura autocrítica professionale. Rifiuto di imparare dagli errori passati. Il dubbio su se stessi blocca la rinascita professionale."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャリアの自己評価の回避や厳しい自己批判。過去の過ちから学ぶことを拒否する。自己不信がキャリアの再生を妨げます。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unngå karriereselvrefleksjon eller hard selvkritikk. Nekte å lære av tidligere feil. Selvtvil blokkerer karrieregjenfødelse."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unikanie samooceny zawodowej lub surowa samokrytyka zawodowa. Odmowa uczenia się z przeszłych błędów. Zwątpienie w siebie blokuje odrodzenie kariery."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Evitar a autoavaliação profissional ou autocrítica profissional severa. Recusar-se a aprender com erros passados. A dúvida bloqueia o renascimento da carreira."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Undvika karriärsjälvreflektion eller hård självkritik. Vägra att lära av tidigare misstag. Självtvivel blockerar karriäråterfödelse."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Уникнення кар'єрної саморефлексії або сувора професійна самокритика. Відмова вчитися на минулих помилках. Невпевненість у собі блокує кар'єрне відродження."
          }
        }
      }
    },
    "interpretation.judgement_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Berufliches Erwachen und Abrechnung. Bewerte deine Arbeit ehrlich und triff wichtige Entscheidungen. Vergangene Bemühungen werden beurteilt – Wiedergeburt folgt der Reflexion."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Career awakening and professional reckoning. Evaluate your work honestly and make important decisions. Past efforts are judged—rebirth follows reflection."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Despertar profesional y ajuste de cuentas. Evalúa tu trabajo honestamente y toma decisiones importantes. Los esfuerzos pasados se juzgan, el renacimiento sigue a la reflexión."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Éveil professionnel et règlement de comptes. Évaluez honnêtement votre travail et prenez des décisions importantes. Les efforts passés sont jugés – la renaissance suit la réflexion."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Risveglio professionale e resa dei conti. Valuta onestamente il tuo lavoro e prendi decisioni importanti. Gli sforzi passati vengono giudicati – la rinascita segue la riflessione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャリアの目覚めと清算。自分の仕事を正直に評価し、重要な決断を下してください。過去の努力は評価されます – 反省の後に再生が続きます。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriereoppvåkning og avregning. Vurder arbeidet ditt ærlig og ta viktige beslutninger. Tidligere innsats blir dømt – gjenfødelse følger refleksjon."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przebudzenie zawodowe i rozliczenie. Oceń uczciwie swoją pracę i podejmij ważne decyzje. Przeszłe wysiłki są oceniane – odrodzenie następuje po refleksji."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Despertar profissional e acerto de contas. Avalie seu trabalho honestamente e tome decisões importantes. Esforços passados são julgados – o renascimento segue a reflexão."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriäruppvaknande och uppgörelse. Utvärdera ditt arbete ärligt och fatta viktiga beslut. Tidigare insatser bedöms – återfödelse följer reflektion."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Кар'єрне пробудження та розрахунок. Оцініть свою роботу чесно та прийміть важливі рішення. Минулі зусилля оцінюються – відродження слідує за рефлексією."
          }
        }
      }
    },
    "interpretation.judgement_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vermeidung der finanziellen Realität oder strenge finanzielle Selbstverurteilung. Weigerung, aus vergangenen finanziellen Fehlern zu lernen. Selbsthass blockiert den Wohlstand."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avoiding financial reality or harsh money self-judgment. Refusing to learn from past financial mistakes. Self-loathing blocks prosperity."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Evitar la realidad financiera o un duro auto-juicio financiero. Negarse a aprender de errores financieros pasados. El odio a uno mismo bloquea la prosperidad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Éviter la réalité financière ou un dur auto-jugement financier. Refus d'apprendre des erreurs financières passées. La haine de soi bloque la prospérité."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Evitare la realtà finanziaria o un duro auto-giudizio finanziario. Rifiuto di imparare dagli errori finanziari passati. L'auto-disprezzo blocca la prosperità."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的現実の回避や厳しい自己判断。過去の経済的過ちから学ぶことを拒否する。自己嫌悪が繁栄を妨げます。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unngå økonomisk virkelighet eller hard økonomisk selvdømming. Nekte å lære av tidligere økonomiske feil. Selvhat blokkerer velstand."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unikanie rzeczywistości finansowej lub surowe samoosądzenie finansowe. Odmowa uczenia się z przeszłych błędów finansowych. Nienawiść do siebie blokuje dobrobyt."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Evitar a realidade financeira ou julgamento severo de si mesmo sobre finanças. Recusar-se a aprender com erros financeiros passados. O auto-ódio bloqueia a prosperidade."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Undvika ekonomisk verklighet eller hård ekonomisk självbedömning. Vägra att lära av tidigare ekonomiska misstag. Självhat blockerar välstånd."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Уникнення фінансової реальності або суворе фінансове самоосудження. Відмова вчитися на минулих фінансових помилках. Самоненависть блокує процвітання."
          }
        }
      }
    },
    "interpretation.judgement_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Abrechnung und ehrliche Bewertung. Überprüfe vergangene Geldentscheidungen und erwache zu einem neuen finanziellen Bewusstsein. Wiedergeburt durch Verantwortlichkeit."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial reckoning and honest assessment. Review past money decisions and awaken to new financial consciousness. Rebirth through accountability."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Juicio financiero y evaluación honesta. Revisa decisiones pasadas sobre el dinero y despierta a una nueva conciencia financiera. Renacimiento a través de la responsabilidad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Règlement financier et évaluation honnête. Passez en revue vos décisions financières passées et éveillez-vous à une nouvelle conscience financière. Renaissance par la responsabilité."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resa dei conti finanziaria e valutazione onesta. Rivedi le decisioni finanziarie passate e risvegliati a una nuova coscienza finanziaria. Rinascita attraverso la responsabilità."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "財政的な清算と正直な評価。過去のお金の決断を見直し、新しい財政意識に目覚めてください。説明責任を通じた再生。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk oppgjør og ærlig vurdering. Gå gjennom tidligere pengeavgjørelser og våkn opp til ny økonomisk bevissthet. Gjenfødelse gjennom ansvarlighet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rozliczenie finansowe i uczciwa ocena. Przejrzyj przeszłe decyzje finansowe i obudź się do nowej świadomości finansowej. Odrodzenie poprzez odpowiedzialność."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Acerto de contas financeiro e avaliação honesta. Revise decisões financeiras passadas e desperte para uma nova consciência financeira. Renascimento através da responsabilidade."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomisk uppgörelse och ärlig bedömning. Gå igenom tidigare penningbeslut och vakna upp till ny ekonomisk medvetenhet. Återfödelse genom ansvarsskyldighet."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансовий розрахунок і чесна оцінка. Перегляньте минулі грошові рішення та прокидайтесь до нової фінансової свідомості. Відродження через відповідальність."
          }
        }
      }
    },
    "interpretation.judgement_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Selbstzweifel, mangelndes Selbstbewusstsein oder Weigerung, aus der Vergangenheit zu lernen. Strenge Selbstverurteilung oder völlige Verleugnung. Stell dich der Wahrheit mit Mitgefühl."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Self-doubt, lack of self-awareness, or refusal to learn from the past. Harsh self-judgment or complete denial. Face truth with compassion."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dudas, falta de autoconciencia o negativa a aprender del pasado. Duro auto-juicio o negación total. Enfrenta la verdad con compasión."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Doute de soi, manque de conscience de soi ou refus d'apprendre du passé. Dure auto-jugement ou déni total. Affrontez la vérité avec compassion."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dubbio su se stessi, mancanza di autoconsapevolezza o rifiuto di imparare dal passato. Duro auto-giudizio o negazione totale. Affronta la verità con compassione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "自己不信、自己認識の欠如、または過去から学ぶことの拒否。厳しい自己判断または完全な否定。思いやりを持って真実と向き合ってください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Selvtvil, mangel på selvbevissthet eller nektelse av å lære av fortiden. Hard selvdømming eller fullstendig fornektelse. Møt sannheten med medfølelse."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zwątpienie w siebie, brak samoświadomości lub odmowa uczenia się z przeszłości. Surowa samoocena lub całkowite zaprzeczenie. Zmierz się z prawdą ze współczuciem."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dúvida, falta de autoconsciência ou recusa em aprender com o passado. Julgamento severo de si mesmo ou negação total. Enfrente a verdade com compaixão."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Självtvivel, brist på självmedvetenhet eller vägran att lära av det förflutna. Hård självbedömning eller fullständig förnekelse. Möt sanningen med medkänsla."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Невпевненість у собі, відсутність самосвідомості або відмова вчитися на минулому. Суворе самоосудження або повне заперечення. Зіткніться з правдою зі співчуттям."
          }
        }
      }
    },
    "interpretation.judgement_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reflexion, Abrechnung, Erwachen und Wiedergeburt. Ehrliche Selbstreflexion führt zur Transformation. Vergangene Entscheidungen werden überprüft – lerne und erhebe dich erneuert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reflection, reckoning, awakening, and rebirth. Honest self-assessment leads to transformation. Past decisions are reviewed—learn and rise renewed."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reflexión, juicio, despertar y renacimiento. La autoevaluación honesta conduce a la transformación. Las decisiones pasadas se revisan, aprende y levántate renovado."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Réflexion, règlement de comptes, éveil et renaissance. Une auto-évaluation honnête mène à la transformation. Les décisions passées sont examinées – apprenez et levez-vous renouvelé."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Riflessione, resa dei conti, risveglio e rinascita. L'onesta autovalutazione porta alla trasformazione. Le decisioni passate vengono riviste – impara e rialziti rinnovato."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "反省、清算、目覚め、再生。正直な自己評価が変容をもたらします。過去の決断が見直されます – 学び、新たに立ち上がってください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Refleksjon, oppgjør, oppvåkning og gjenfødelse. Ærlig selvransakelse fører til transformasjon. Tidligere avgjørelser gjennomgås – lær og reis deg fornyet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Refleksja, rozliczenie, przebudzenie i odrodzenie. Uczciwa samoocena prowadzi do transformacji. Przeszłe decyzje są przeglądane – ucz się i powstań odnowiony."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reflexão, acerto de contas, despertar e renascimento. A autoavaliação honesta leva à transformação. Decisões passadas são revisadas – aprenda e levante-se renovado."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reflektion, uppgörelse, uppvaknande och återfödelse. Ärlig självbedömning leder till transformation. Tidigare beslut granskas – lär dig och res dig förnyad."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Рефлексія, розрахунок, пробудження та відродження. Чесно самооцінювання веде до трансформації. Минулі рішення переглядаються – вчіться і вставайте оновленими."
          }
        }
      }
    },
    "interpretation.judgement_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vermeidung der gesundheitlichen Realität oder strenge Selbstverurteilung des Körpers. Weigerung, aus vergangenen Gesundheitsmustern zu lernen. Selbstkritik blockiert die Heilung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avoiding health reality or harsh body judgment. Refusing to learn from past health patterns. Self-criticism blocks healing."
