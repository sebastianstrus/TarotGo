        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un approccio finanziario equilibrato porta stabilità. Spendere e risparmiare con moderazione crea armonia. Costruire ricchezza con pazienza attraverso uno sforzo costante."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "バランスの取れた財務アプローチが安定性をもたらします。節度ある支出と節約が調和を生み出します。着実な努力による忍耐強い富の構築。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En balansert økonomisk tilnærming gir stabilitet. Moderat utgifter og sparing skaper harmoni. Tålmodig formuesbygging gjennom jevn innsats."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zrównoważone podejście finansowe przynosi stabilność. Umiarkowane wydawanie i oszczędzanie tworzy harmonię. Cierpliwe budowanie bogactwa poprzez stały wysiłek."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uma abordagem financeira equilibrada traz estabilidade. Gastar e poupar com moderação cria harmonia. Construção de riqueza paciente através de esforço constante."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ett balanserat finansiellt tillvägagångssätt ger stabilitet. Måttliga utgifter och sparande skapar harmoni. Tålmodig förmögenhetsbyggande genom stadig ansträngning."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Збалансований фінансовий підхід приносить стабільність. Помірні витрати та заощадження створюють гармонію. Терпляче створення багатства через постійні зусилля."
          }
        }
      }
    },
    "interpretation.temperance_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ungleichgewicht, Exzesse und Extreme erzeugen Zwietracht. Mangel an Geduld oder Harmonie. Stelle die Mäßigung wieder her und finde deine Mitte."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Imbalance, excess, and extremes create discord. Lack of patience or harmony. Restore moderation and find your center."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El desequilibrio, el exceso y los extremos crean discordia. Falta de paciencia o armonía. Restablece la moderación y encuentra tu centro."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le déséquilibre, les excès et les extrêmes créent la discorde. Manque de patience ou d'harmonie. Rétablissez la modération et retrouvez votre centre."
