          }
        }
      }
    },
    "interpretation.four_of_cups_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erneuerte Berufsmotivation und Anerkennung von Chancen. Du siehst Möglichkeiten, die du vorher übersehen hast. Bereit, sich wieder mit der Arbeit zu beschäftigen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Renewed career motivation and recognition of opportunities. You're seeing possibilities you missed before. Ready to engage with work again."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Renovada motivación profesional y reconocimiento de oportunidades. Estás viendo posibilidades que antes pasaste por alto. Listo para volver a comprometerte con el trabajo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Motivation professionnelle renouvelée et reconnaissance des opportunités. Vous voyez des possibilités que vous aviez manquées auparavant. Prêt à vous réengager dans le travail."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Motivazione professionale rinnovata e riconoscimento delle opportunità. Vedi possibilità che avevi perso in precedenza. Pronto a impegnarti di nuovo nel lavoro."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "新たなキャリアへの意欲と機会の認識。以前は見逃していた可能性に気づいています。再び仕事に取り組む準備ができました。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fornyet karrieremotivasjon og anerkjennelse av muligheter. Du ser muligheter du gikk glipp av før. Klar til å engasjere deg i arbeid igjen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odnowiona motywacja zawodowa i rozpoznawanie możliwości. Widzisz możliwości, które wcześniej przeoczyłeś. Gotowy, aby ponownie zaangażować się w pracę."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Motivação de carreira renovada e reconhecimento de oportunidades. Você está vendo possibilidades que perdeu antes. Pronto para se envolver com o trabalho novamente."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Förnyad karriärmotivation och erkännande av möjligheter. Du ser möjligheter du missade tidigare. Redo att engagera dig i arbetet igen."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Оновлена кар'єрна мотивація та визнання можливостей. Ви бачите можливості, які раніше пропустили. Готові знову зайнятися роботою."
          }
        }
      }
    },
    "interpretation.four_of_cups_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Berufliche Langeweile oder Apathie. Du denkst über eine Veränderung nach, handelst aber noch nicht. Es werden dir Chancen geboten, die dich nicht begeistern. Zeit für eine ehrliche Neubewertung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professional boredom or apathy. You're contemplating change but not yet acting. Opportunities are presented but don't excite you. Time for honest reevaluation."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aburrimiento profesional o apatía. Estás contemplando un cambio, pero aún no actúas. Se te presentan oportunidades, pero no te emocionan. Es hora de una reevaluación honesta."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ennui professionnel ou apathie. Vous envisagez un changement mais n'agissez pas encore. Des opportunités se présentent mais ne vous excitent pas. Il est temps de procéder à une réévaluation honnête."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Noia professionale o apatia. Stai contemplando un cambiamento ma non stai ancora agendo. Le opportunità vengono presentate ma non ti entusiasmano. È tempo di una onesta rivalutazione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "仕事上の退屈や無関心。あなたは変化を考えているが、まだ行動に移していません。機会は提示されていますが、あなたを興奮させません。正直な再評価の時です。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profesjonell kjedsomhet eller likegyldighet. Du vurderer endring, men handler ikke ennå. Muligheter presenteres, men begeistrer deg ikke. Tid for ærlig revurdering."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nuda zawodowa lub apatia. Rozważasz zmianę, ale jeszcze nie działasz. Pojawiają się możliwości, ale cię nie ekscytują. Czas na szczerą ponowną ocenę."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tédio profissional ou apatia. Você está contemplando uma mudança, mas ainda não agiu. Oportunidades são apresentadas, mas não o excitam. Hora de uma reavaliação honesta."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professionell tristess eller apati. Du överväger förändring men agerar inte ännu. Möjligheter presenteras men entusiasmerar dig inte. Dags för ärlig omvärdering."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Професійна нудьга або апатія. Ви обмірковуєте зміни, але ще не дієте. Можливості представлені, але не хвилюють вас. Час для чесної переоцінки."
          }
        }
      }
    },
    "interpretation.four_of_cups_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielles Erwachen und erneuerte Motivation. Du siehst jetzt finanzielle Chancen klar. Akzeptanz dessen, was verfügbar ist, anstatt sich auf Mangel zu konzentrieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial awakening and renewed motivation. You're seeing money opportunities clearly now. Acceptance of what's available rather than focusing on lack."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Despertar financiero y motivación renovada. Estás viendo las oportunidades de dinero con claridad ahora. Aceptación de lo que está disponible en lugar de centrarse en la falta."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Éveil financier et motivation renouvelée. Vous voyez clairement les opportunités monétaires maintenant. Acceptation de ce qui est disponible plutôt que de se concentrer sur le manque."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Risveglio finanziario e rinnovata motivazione. Ora vedi chiaramente le opportunità di denaro. Accettazione di ciò che è disponibile piuttosto che concentrarsi sulla mancanza."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的な目覚めと新たなモチベーション。あなたは今、お金の機会をはっきりと見ています。不足に焦点を当てるのではなく、利用可能なものを受け入れること。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk oppvåkning og fornyet motivasjon. Du ser pengemuligheter tydelig nå. Aksept av hva som er tilgjengelig i stedet for å fokusere på mangel."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przebudzenie finansowe i odnowiona motywacja. Teraz wyraźnie widzisz możliwości związane z pieniędzmi. Akceptacja tego, co jest dostępne, zamiast skupiania się na braku."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Despertar financeiro e motivação renovada. Você está vendo oportunidades de dinheiro claramente agora. Aceitação do que está disponível em vez de se concentrar na falta."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomiskt uppvaknande och förnyad motivation. Du ser pengamöjligheter tydligt nu. Acceptans av vad som finns tillgängligt snarare än att fokusera på brist."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансове пробудження та оновлена мотивація. Тепер ви чітко бачите грошові можливості. Прийняття того, що доступно, а не зосередження на нестачі."
          }
        }
      }
    },
    "interpretation.four_of_cups_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Apathie oder das als selbstverständlich Betrachten des Überflusses. Du siehst die verfügbaren Chancen nicht. Das Nachdenken vor finanziellen Entscheidungen ist klug, aber verpasse nicht, was dir angeboten wird."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial apathy or taking abundance for granted. You're not seeing the opportunities available. Contemplation before financial decisions is wise, but don't miss what's offered."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apatía financiera o dar la abundancia por sentada. No estás viendo las oportunidades disponibles. La contemplación antes de las decisiones financieras es sabia, pero no te pierdas lo que se te ofrece."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apathie financière ou abondance considérée comme acquise. Vous ne voyez pas les opportunités disponibles. La contemplation avant les décisions financières est sage, mais ne manquez pas ce qui vous est offert."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apatia finanziaria o dare l'abbondanza per scontata. Non stai vedendo le opportunità disponibili. La contemplazione prima delle decisioni finanziarie è saggia, ma non perdere ciò che ti viene offerto."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的な無関心、または豊かさを当然のことと思っていること。あなたは利用可能な機会を見ていません。財務上の決定の前に熟考することは賢明ですが、提供されているものを見逃さないでください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk likegyldighet eller å ta overflod for gitt. Du ser ikke mulighetene som er tilgjengelige. Ettertanke før økonomiske beslutninger er klokt, men ikke gå glipp av det som tilbys."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apatia finansowa lub branie obfitości za pewnik. Nie widzisz dostępnych możliwości. Rozważanie przed podjęciem decyzji finansowych jest mądre, ale nie przegap tego, co jest oferowane."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apatia financeira ou tomar a abundância como garantida. Você não está vendo as oportunidades disponíveis. A contemplação antes de decisões financeiras é sábia, mas não perca o que é oferecido."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomisk apati eller att ta överflöd för givet. Du ser inte de tillgängliga möjligheterna. Begrundan inför ekonomiska beslut är klokt, men missa inte det som erbjuds."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансова апатія або сприйняття достатку як належне. Ви не бачите доступних можливостей. Роздуми перед фінансовими рішеннями є мудрими, але не пропустіть те, що вам пропонують."
          }
        }
      }
    },
    "interpretation.four_of_cups_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erwachen aus der Apathie. Erneuerte Motivation und frische Perspektiven kommen. Du siehst endlich die Chancen, die die ganze Zeit da waren. Akzeptanz ersetzt Unzufriedenheit."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Awakening from apathy. Renewed motivation and fresh perspectives arrive. You're finally seeing the opportunities that have been there all along. Acceptance replaces dissatisfaction."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Despertar de la apatía. Llegan una motivación renovada y nuevas perspectivas. Finalmente estás viendo las oportunidades que han estado ahí todo el tiempo. La aceptación reemplaza la insatisfacción."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Éveil de l'apathie. Motivation renouvelée et perspectives nouvelles arrivent. Vous voyez enfin les opportunités qui ont toujours été là. L'acceptation remplace l'insatisfaction."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Risveglio dall'apatia. Arrivano rinnovata motivazione e prospettive fresche. Finalmente vedi le opportunità che sono sempre state lì. L'accettazione sostituisce l'insoddisfazione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "無関心からの目覚め。新たなモチベーションと新鮮な視点がやってきます。あなたはついにずっとそこにあった機会を見ています。不満は受容に取って代わられます。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oppvåkning fra likegyldighet. Fornyet motivasjon og friske perspektiver kommer. Du ser endelig mulighetene som har vært der hele tiden. Aksept erstatter misnøye."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przebudzenie z apatii. Nadchodzi odnowiona motywacja i świeże perspektywy. Wreszcie widzisz możliwości, które były tam cały czas. Akceptacja zastępuje niezadowolenie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Despertar da apatia. Motivação renovada e novas perspectivas chegam. Você finalmente está vendo as oportunidades que estiveram lá o tempo todo. A aceitação substitui a insatisfação."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uppvaknande från apati. Förnyad motivation och nya perspektiv anländer. Du ser äntligen de möjligheter som har funnits hela tiden. Acceptans ersätter missnöje."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Пробудження від апатії. З'являються оновлена мотивація та свіжі перспективи. Ви нарешті бачите можливості, які були там увесь час. Прийняття замінює незадоволення."
          }
        }
      }
    },
    "interpretation.four_of_cups_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apathie, Nachdenklichkeit und verpasste Gelegenheiten. Du konzentrierst dich so sehr nach innen oder auf das, was falsch ist, dass du nicht siehst, was dir angeboten wird. Das ist ein Weckruf, dich umzusehen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apathy, contemplation, and missed opportunities. You're so focused inward or on what's wrong that you don't see what's being offered. This is a wake-up call to look around you."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apatía, contemplación y oportunidades perdidas. Estás tan enfocado hacia adentro o en lo que está mal que no ves lo que se te ofrece. Esta es una llamada de atención para que mires a tu alrededor."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apathie, contemplation et opportunités manquées. Vous êtes tellement concentré vers l'intérieur ou sur ce qui ne va pas que vous ne voyez pas ce qui vous est offert. C'est un signal d'alarme pour regarder autour de vous."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apatia, contemplazione e opportunità mancate. Sei così concentrato verso l'interno o su ciò che è sbagliato che non vedi cosa ti viene offerto. Questo è un campanello d'allarme per guardarti intorno."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "無関心、熟考、そして逃した機会。あなたは内側や何が悪いかに集中しすぎて、何が提供されているかを見ていません。これはあなたの周りを見渡すための警告です。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Likegyldighet, ettertanke og tapte muligheter. Du er så fokusert innover eller på hva som er galt at du ikke ser hva som blir tilbudt. Dette er et oppvåkning for å se deg rundt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apatia, kontemplacja i utracone możliwości. Jesteś tak skupiony do wewnątrz lub na tym, co złe, że nie widzisz, co jest oferowane. To sygnał do przebudzenia, aby rozejrzeć się wokół siebie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apatia, contemplação e oportunidades perdidas. Você está tão focado para dentro ou no que está errado que não vê o que está sendo oferecido. Este é um alerta para olhar ao seu redor."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apati, begrundan och missade möjligheter. Du är så fokuserad inåt eller på vad som är fel att du inte ser vad som erbjuds. Det här är en väckarklocka för att titta dig omkring."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Апатія, роздуми та втрачені можливості. Ви так зосереджені всередині або на тому, що не так, що не бачите, що вам пропонують. Це сигнал для пробудження, щоб подивитися навколо."
          }
        }
      }
    },
    "interpretation.four_of_cups_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erneuerte Gesundheitsmotivation und Bewusstsein. Du bist endlich bereit, Hilfe anzunehmen und Veränderungen vorzunehmen. Neue Perspektiven zum Wohlbefinden entstehen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Renewed health motivation and awareness. You're finally ready to accept help and make changes. New perspectives on wellness emerge."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Renovada motivación y conciencia de la salud. Finalmente estás listo para aceptar ayuda y hacer cambios. Surgen nuevas perspectivas sobre el bienestar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Motivation et conscience renouvelées pour la santé. Vous êtes enfin prêt à accepter de l'aide et à faire des changements. De nouvelles perspectives sur le bien-être émergent."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Motivazione e consapevolezza della salute rinnovate. Finalmente sei pronto ad accettare aiuto e apportare cambiamenti. Emergono nuove prospettive sul benessere."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "新たな健康への意欲と意識。あなたはついに助けを受け入れ、変化を受け入れる準備ができました。健康に関する新しい視点が生まれます。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fornyet helsemotivasjon og bevissthet. Du er endelig klar til å akseptere hjelp og gjøre endringer. Nye perspektiver på velvære dukker opp."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odnowiona motywacja i świadomość zdrowotna. Wreszcie jesteś gotowy, aby zaakceptować pomoc i wprowadzić zmiany. Pojawiają się nowe perspektywy dotyczące dobrego samopoczucia."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Motivação e consciência de saúde renovadas. Você finalmente está pronto para aceitar ajuda e fazer mudanças. Novas perspectivas sobre bem-estar surgem."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Förnyad hälso motivation och medvetenhet. Du är äntligen redo att acceptera hjälp och göra förändringar. Nya perspektiv på välbefinnande uppstår."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Оновлена мотивація та обізнаність щодо здоров'я. Ви нарешті готові прийняти допомогу та внести зміни. З'являються нові погляди на оздоровлення."
          }
        }
      }
    },
    "interpretation.four_of_cups_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gesundheitliche Überlegungen und mögliche Apathie. Du weißt, dass du Veränderungen vornehmen solltest, aber es fehlt dir an Motivation. Ignoriere nicht die Chancen für Wohlbefinden, die dir geboten werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Health contemplation and possible apathy. You know you should make changes but lack motivation. Don't ignore the opportunities for wellness being offered."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Contemplación de la salud y posible apatía. Sabes que deberías hacer cambios, pero te falta motivación. No ignores las oportunidades de bienestar que se te ofrecen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Contemplation de la santé et apathie possible. Vous savez que vous devriez faire des changements mais manquez de motivation. N'ignorez pas les opportunités de bien-être qui vous sont offertes."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Contemplazione della salute e possibile apatia. Sai che dovresti apportare cambiamenti ma manchi di motivazione. Non ignorare le opportunità di benessere che ti vengono offerte."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "健康への熟考と可能性のある無関心。あなたは変化すべきだと知っているが、やる気が不足している。提供されている健康の機会を無視しないでください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Helsebetraktning og mulig likegyldighet. Du vet at du burde gjøre endringer, men mangler motivasjon. Ikke ignorer mulighetene for velvære som blir tilbudt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kontemplacja zdrowia i możliwa apatia. Wiesz, że powinieneś wprowadzić zmiany, ale brakuje ci motywacji. Nie ignoruj oferowanych możliwości poprawy samopoczucia."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Contemplação da saúde e possível apatia. Você sabe que deveria fazer mudanças, mas falta motivação. Não ignore as oportunidades de bem-estar que estão sendo oferecidas."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hälsokontemplation och möjlig apati. Du vet att du borde göra förändringar men saknar motivation. Ignorera inte de möjligheter till välbefinnande som erbjuds."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Роздуми про здоров'я та можлива апатія. Ви знаєте, що повинні внести зміни, але бракує мотивації. Не ігноруйте можливості для оздоровлення, які вам пропонують."
          }
        }
      }
    },
    "interpretation.four_of_cups_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erwachen zu den Möglichkeiten der Liebe. Du siehst endlich, was dir angeboten wurde. Neue Wertschätzung für deine Beziehung. Die Motivation, sich zu engagieren, kehrt zurück."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Awakening to love's possibilities. You're finally seeing what's been offered. Renewed appreciation for your relationship. Motivation to engage returns."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Despertar a las posibilidades del amor. Finalmente estás viendo lo que se te ha ofrecido. Renovado aprecio por tu relación. Vuelve la motivación para comprometerte."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Éveil aux possibilités de l'amour. Vous voyez enfin ce qui vous a été offert. Appréciation renouvelée pour votre relation. La motivation à s'engager revient."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Risveglio alle possibilità dell'amore. Finalmente vedi cosa ti è stato offerto. Rinnovato apprezzamento per la tua relazione. La motivazione a impegnarti ritorna."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "愛の可能性への目覚め。あなたはついに何が提供されてきたかを見ています。関係への新たな感謝。関与する意欲が戻ってきます。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oppvåkning til kjærlighetens muligheter. Du ser endelig hva som har blitt tilbudt. Fornyet takknemlighet for forholdet ditt. Motivasjonen for å engasjere seg kommer tilbake."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przebudzenie do możliwości miłości. Wreszcie widzisz, co było oferowane. Odnowione uznanie dla twojego związku. Motywacja do zaangażowania powraca."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Despertar para as possibilidades do amor. Você finalmente está vendo o que foi oferecido. Apreciação renovada pelo seu relacionamento. A motivação para se envolver retorna."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uppvaknande till kärlekens möjligheter. Du ser äntligen vad som har erbjudits. Förnyad uppskattning för din relation. Motivationen att engagera sig återvänder."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Пробудження до можливостей кохання. Ви нарешті бачите, що вам пропонували. Оновлена вдячність за ваші стосунки. Мотивація до участі повертається."
          }
        }
      }
    },
    "interpretation.four_of_cups_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Romantische Apathie oder die Liebe als selbstverständlich betrachten. Du konzentrierst dich so sehr auf das, was fehlt, dass du nicht siehst, was dir angeboten wird. Schau auf – direkt vor dir ist Liebe."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Romantic apathy or taking love for granted. You're so focused on what's missing that you don't see what's being offered. Look up—there's love right in front of you."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apatía romántica o dar el amor por sentado. Estás tan concentrado en lo que falta que no ves lo que se te ofrece. Mira hacia arriba: hay amor justo frente a ti."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apathie romantique ou amour considéré comme acquis. Vous êtes tellement concentré sur ce qui manque que vous ne voyez pas ce qui vous est offert. Regardez en l'air – l'amour est juste devant vous."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apatia romantica o dare l'amore per scontato. Sei così concentrato su ciò che manca che non vedi cosa ti viene offerto. Guarda in alto: l'amore è proprio di fronte a te."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "恋愛における無関心、または愛を当然のことと思っていること。あなたは何が欠けているかに集中しすぎて、何が提供されているかを見ていません。見上げてください―あなたの目の前に愛があります。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Romantisk likegyldighet eller å ta kjærlighet for gitt. Du er så fokusert på hva som mangler at du ikke ser hva som blir tilbudt. Se opp – det er kjærlighet rett foran deg."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Romantyczna apatia lub branie miłości za pewnik. Jesteś tak skupiony na tym, czego brakuje, że nie widzisz, co jest oferowane. Spójrz w górę – miłość jest tuż przed tobą."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apatia romântica ou tomar o amor como garantido. Você está tão focado no que está faltando que não vê o que está sendo oferecido. Olhe para cima – há amor bem na sua frente."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Romantisk apati eller att ta kärlek för given. Du är så fokuserad på vad som saknas att du inte ser vad som erbjuds. Titta upp – det finns kärlek precis framför dig."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Романтична апатія або сприйняття кохання як належне. Ви так зосереджені на тому, чого не вистачає, що не бачите, що вам пропонують. Подивіться вгору – кохання прямо перед вами."
          }
        }
      }
    },
    "interpretation.four_of_pentacles_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Berufliche Stagnation durch übermäßige Vorsicht. Gier oder Besitzgier bei der Arbeit. Zu starkes Festhalten an Position oder Kontrolle. Angst verhindert berufliches Wachstum."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Career stagnation through excessive caution. Greed or possessiveness at work. Holding too tight to position or control. Fear prevents professional growth."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estancamiento profesional por exceso de precaución. Codicia o egoísmo en el trabajo. Aferrarse demasiado a la posición o el control. El miedo impide el crecimiento profesional."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stagnation de carrière due à une prudence excessive. Cupidité ou possessivité au travail. S'accrocher trop à la position ou au contrôle. La peur empêche la croissance professionnelle."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stagnazione della carriera per eccessiva cautela. Avidità o possessività sul lavoro. Tenere troppo stretto alla posizione o al controllo. La paura impedisce la crescita professionale."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "過度の慎重さによるキャリアの停滞。職場での貪欲さや独占欲。地位やコントロールに強くしがみつきすぎる。恐怖が職業的成長を妨げる。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karrierestagnasjon på grunn av overdreven forsiktighet. Grådighet eller besittelse på jobb. Holder for hardt fast på posisjon eller kontroll. Frykt hindrer profesjonell vekst."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stagnacja kariery przez nadmierną ostrożność. Chciwość lub zaborczość w pracy. Zbyt mocne trzymanie się pozycji lub kontroli. Strach hamuje rozwój zawodowy."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estagnação da carreira por cautela excessiva. Ganância ou possessividade no trabalho. Segurar com muita força a posição ou controle. O medo impede o crescimento profissional."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriärstagnation på grund av överdriven försiktighet. Girighet eller besittande på jobbet. Hålla för hårt fast vid position eller kontroll. Rädsla förhindrar professionell tillväxt."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Застій у кар'єрі через надмірну обережність. Жадібність або власництво на роботі. Занадто міцне тримання за позицію або контроль. Страх перешкоджає професійному зростанню."
          }
        }
      }
    },
    "interpretation.four_of_pentacles_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Berufliche Sicherheit durch sorgfältige Kontrolle. Stabile Karriere, aber möglicherweise zu konservativ. Ihre Vorsicht schützt Sie, kann aber das Wachstum einschränken. Balancieren Sie Sicherheit mit Risiko."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professional security through careful control. Stable career but possibly too conservative. Your caution protects you but may limit growth. Balance safety with risk."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seguridad profesional a través de un control cuidadoso. Carrera estable pero posiblemente demasiado conservadora. Tu precaución te protege pero puede limitar el crecimiento. Equilibra la seguridad con el riesgo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sécurité professionnelle grâce à un contrôle minutieux. Carrière stable mais peut-être trop conservatrice. Votre prudence vous protège mais peut limiter la croissance. Équilibrez la sécurité avec le risque."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sicurezza professionale attraverso un attento controllo. Carriera stabile ma forse troppo conservativa. La tua prudenza ti protegge ma può limitare la crescita. Bilancia la sicurezza con il rischio."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "慎重なコントロールによる職業的安全。安定したキャリアだが、おそらく保守的すぎる。あなたの慎重さはあなたを守るが、成長を制限するかもしれない。安全性とリスクのバランスを取る。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profesjonell sikkerhet gjennom forsiktig kontroll. Stabil karriere, men muligens for konservativ. Forsiktigheten din beskytter deg, men kan begrense vekst. Balanser sikkerhet med risiko."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bezpieczeństwo zawodowe dzięki starannej kontroli. Stabilna kariera, ale być może zbyt konserwatywna. Twoja ostrożność chroni cię, ale może ograniczać rozwój. Zrównoważ bezpieczeństwo z ryzykiem."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Segurança profissional através de controle cuidadoso. Carreira estável, mas possivelmente conservadora demais. Sua cautela protege você, mas pode limitar o crescimento. Equilibre segurança com risco."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professionell säkerhet genom noggrann kontroll. Stabil karriär men möjligen för konservativ. Din försiktighet skyddar dig men kan begränsa tillväxt. Balansera säkerhet med risk."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Професійна безпека через ретельний контроль. Стабільна кар'єра, але, можливо, надто консервативна. Ваша обережність захищає вас, але може обмежувати зростання. Балансуйте безпеку з ризиком."
          }
        }
      }
    },
    "interpretation.four_of_pentacles_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Gier oder übermäßiges Horten. Besitzdenken in Bezug auf Geld verhindert den Fluss. Materialismus über das Wohlbefinden. Die Kontrolle über Ressourcen schlägt fehl. Lockern Sie Ihren Griff."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial greed or excessive hoarding. Possessiveness about money prevents flow. Materialism over wellbeing. Control over resources backfires. Loosen grip."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Codicia financiera o acaparamiento excesivo. La posesividad por el dinero impide el flujo. Materialismo por encima del bienestar. El control sobre los recursos sale mal. Afloja el agarre."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cupidité financière ou accumulation excessive. La possessivité à propos de l'argent empêche le flux. Matérialisme plutôt que bien-être. Le contrôle des ressources se retourne contre vous. Relâchez votre emprise."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avidità finanziaria o accumulo eccessivo. La possessività del denaro impedisce il flusso. Materialismo sul benessere. Il controllo sulle risorse si ritorce contro. Allenta la presa."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的貪欲または過度のため込み。お金に対する独占欲が流れを妨げる。幸福よりも物質主義。リソースのコントロールが裏目に出る。握りを緩める。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk grådighet eller overdreven hamstring. Besittelse av penger hindrer flyt. Materialisme fremfor velvære. Kontroll over ressurser slår tilbake. Løsne grepet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chciwość finansowa lub nadmierne gromadzenie. Zaborczość wobec pieniędzy blokuje przepływ. Materializm kosztem dobrego samopoczucia. Kontrola nad zasobami przynosi odwrotny skutek. Poluzuj uścisk."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ganância financeira ou acúmulo excessivo. Possessividade sobre o dinheiro impede o fluxo. Materialismo sobre o bem-estar. Controle sobre os recursos sai pela culatra. Afrouxe o aperto."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomisk girighet eller överdriven hamstring. Besittande av pengar hindrar flöde. Materialism framför välbefinnande. Kontroll över resurser slår tillbaka. Lossa greppet."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансова жадібність або надмірне накопичення. Власництво грошима перешкоджає потоку. Матеріалізм над добробутом. Контроль над ресурсами має зворотний ефект. Послабте хватку."
          }
        }
      }
    },
    "interpretation.four_of_pentacles_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Sicherheit durch sorgfältige Erhaltung. Ihre Ressourcen sind geschützt, aber möglicherweise zu stark kontrolliert. Gesundes Sparen, aber hüten Sie sich vor Horten. Finden Sie ein Gleichgewicht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial security through careful conservation. Your resources are protected but possibly too controlled. Healthy saving but be careful of hoarding. Find balance."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seguridad financiera a través de una cuidadosa conservación. Tus recursos están protegidos pero posiblemente demasiado controlados. Ahorro saludable pero cuidado con el acaparamiento. Encuentra el equilibrio."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sécurité financière grâce à une conservation minutieuse. Vos ressources sont protégées mais peut-être trop contrôlées. Épargne saine mais attention à l'accumulation. Trouvez l'équilibre."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sicurezza finanziaria attraverso un'attenta conservazione. Le tue risorse sono protette ma forse troppo controllate. Risparmio sano ma attenzione all'accumulo. Trova un equilibrio."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "慎重な保全による経済的安全。リソースは保護されているが、おそらくコントロールされすぎている。健全な貯蓄だが、溜め込みに注意。バランスを見つける。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk sikkerhet gjennom forsiktig bevaring. Ressursene dine er beskyttet, men muligens for kontrollert. Sunn sparing, men vær forsiktig med hamstring. Finn balanse."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bezpieczeństwo finansowe dzięki starannej konserwacji. Twoje zasoby są chronione, ale być może zbyt kontrolowane. Zdrowe oszczędzanie, ale uważaj na gromadzenie. Znajdź równowagę."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Segurança financeira através de conservação cuidadosa. Seus recursos estão protegidos, mas possivelmente muito controlados. Economia saudável, mas cuidado com o acúmulo. Encontre equilíbrio."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomisk säkerhet genom noggrann bevarande. Dina resurser är skyddade men möjligen för kontrollerade. Friskt sparande men var försiktig med hamstring. Hitta balans."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансова безпека через ретельне збереження. Ваші ресурси захищені, але, можливо, надто контрольовані. Здорове заощадження, але остерігайтеся накопичення. Знайдіть баланс."
          }
        }
      }
    },
    "interpretation.four_of_pentacles_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gier, Besitzgier und zu festes Festhalten. Materialismus und übermäßige Kontrolle schlagen fehl. Sie blockieren den Fluss durch Angst. Lassen Sie los und vertrauen Sie."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Greed, possessiveness, and holding on too tight. Materialism and excessive control backfire. You're blocking flow through fear. Let go and trust."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Codicia, posesividad y aferrarse demasiado. El materialismo y el control excesivo salen mal. Estás bloqueando el flujo a través del miedo. Suelta y confía."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cupidité, possessivité et s'accrocher trop fort. Le matérialisme et un contrôle excessif se retournent contre vous. Vous bloquez le flux par la peur. Lâchez prise et faites confiance."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avidità, possessività e tenere troppo stretto. Il materialismo e il controllo eccessivo si ritorcono contro. Stai bloccando il flusso attraverso la paura. Lascia andare e fidati."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "貪欲、独占欲、強く握りしめすぎる。物質主義と過度のコントロールが裏目に出る。恐怖によって流れを妨げている。手放して信頼する。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Grådighet, besittelse og å holde for hardt fast. Materialisme og overdreven kontroll slår tilbake. Du blokkerer flyt gjennom frykt. Slipp taket og stol på."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chciwość, zaborczość i zbyt mocne trzymanie się. Materializm i nadmierna kontrola przynoszą odwrotny skutek. Blokujesz przepływ przez strach. Odpuść i zaufaj."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ganância, possessividade e segurar com muita força. Materialismo e controle excessivo saem pela culatra. Você está bloqueando o fluxo através do medo. Deixe ir e confie."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Girighet, besittande och att hålla för hårt. Materialism och överdriven kontroll slår tillbaka. Du blockerar flöde genom rädsla. Släpp taget och lita på."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Жадібність, власництво та надто міцне тримання. Матеріалізм та надмірний контроль мають зворотний ефект. Ви блокуєте потік через страх. Відпустіть і довіртеся."
          }
        }
      }
    },
    "interpretation.four_of_pentacles_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sicherheit, Erhaltung und Kontrolle. Sie schützen Ihre Ressourcen und halten fest daran fest. Das schafft Stabilität, aber überprüfen Sie, ob Angst Sie zu starr macht. Ausgleich ist nötig."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Security, conservation, and control. You're protecting your resources and holding on tight. This creates stability but check if fear is making you too rigid. Balance needed."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seguridad, conservación y control. Estás protegiendo tus recursos y aferrándote a ellos. Esto crea estabilidad, pero comprueba si el miedo te está haciendo demasiado rígido. Se necesita equilibrio."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sécurité, conservation et contrôle. Vous protégez vos ressources et vous y accrochez. Cela crée une stabilité mais vérifiez si la peur ne vous rend pas trop rigide. Un équilibre est nécessaire."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sicurezza, conservazione e controllo. Stai proteggendo le tue risorse e tenendoti stretto. Questo crea stabilità ma verifica se la paura ti sta rendendo troppo rigido. Necessario equilibrio."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "安全、保全、コントロール。あなたはリソースを保護し、しっかりと保持している。これは安定を生み出すが、恐怖があなたを硬直させていないか確認する。バランスが必要。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sikkerhet, bevaring og kontroll. Du beskytter ressursene dine og holder godt fast. Dette skaper stabilitet, men sjekk om frykt gjør deg for stiv. Balanse nødvendig."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bezpieczeństwo, oszczędzanie i kontrola. Chronisz swoje zasoby i mocno się ich trzymasz. Stwarza to stabilność, ale sprawdź, czy strach nie czyni cię zbyt sztywnym. Potrzeba równowagi."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Segurança, conservação e controle. Você está protegendo seus recursos e se segurando firmemente. Isso cria estabilidade, mas verifique se o medo não está tornando você rígido demais. Equilíbrio necessário."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Säkerhet, bevarande och kontroll. Du skyddar dina resurser och håller hårt i dem. Detta skapar stabilitet men kontrollera om rädsla gör dig för stel. Balans behövs."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Безпека, збереження та контроль. Ви захищаєте свої ресурси та міцно тримаєтеся за них. Це створює стабільність, але перевірте, чи страх не робить вас надто ригідним. Потрібен баланс."
          }
        }
      }
    },
    "interpretation.four_of_pentacles_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Übermäßige Kontrolle über die Gesundheit führt zu Starrheit. Besitzergreifend in Bezug auf den Körper oder den Wellness-Ansatz. Angstbasierte Gesundheitsentscheidungen. Mehr Flexibilität und Vertrauen sind nötig."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Excessive control over health creates rigidity. Possessive about body or wellness approach. Fear-based health decisions. Need more flexibility and trust."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El control excesivo de la salud crea rigidez. Actitud de posesión sobre el cuerpo o el enfoque de bienestar. Decisiones de salud basadas en el miedo. Se necesita más flexibilidad y confianza."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un contrôle excessif de la santé crée une rigidité. Attitude possessive envers le corps ou l'approche du bien-être. Décisions de santé basées sur la peur. Besoin de plus de flexibilité et de confiance."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un controllo eccessivo sulla salute crea rigidità. Possessività verso il corpo o l'approccio al benessere. Decisioni sanitarie basate sulla paura. Necessaria maggiore flessibilità e fiducia."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "健康に対する過度のコントロールが硬直を生む。身体やウェルネスへのアプローチに対する独占欲。恐怖に基づく健康上の決定。より多くの柔軟性と信頼が必要。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Overdreven kontroll over helse skaper stivhet. Besittende over kropp eller velværetilnærming. Fryktbaserte helsebeslutninger. Trenger mer fleksibilitet og tillit."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nadmierna kontrola nad zdrowiem powoduje sztywność. Zaborczość wobec ciała lub podejścia do wellness. Decyzje zdrowotne oparte na strachu. Potrzeba więcej elastyczności i zaufania."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Controle excessivo sobre a saúde cria rigidez. Possessividade sobre o corpo ou abordagem de bem-estar. Decisões de saúde baseadas no medo. Mais flexibilidade e confiança necessárias."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Överdriven kontroll över hälsa skapar stelhet. Besittande av kropp eller hälso- och välmående tillvägagångssätt. Rädslobaserade hälsobeslut. Behöver mer flexibilitet och tillit."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Надмірний контроль над здоров'ям створює ригідність. Власництво над тілом або оздоровчим підходом. Рішення про здоров'я, засновані на страху. Потрібна більша гнучкість та довіра."
          }
        }
      }
    },
    "interpretation.four_of_pentacles_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gesundheitliche Stabilität durch sorgfältige Kontrolle. Schützender Ansatz für das Wohlbefinden. Sie schützen Ihre körperlichen Ressourcen weise, aber lassen Sie die Angst nicht dominieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Health stability through careful control. Protective approach to wellness. You're guarding your physical resources wisely but don't let fear dominate."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estabilidad de la salud a través de un control cuidadoso. Enfoque protector del bienestar. Estás protegiendo tus recursos físicos sabiamente, pero no dejes que el miedo domine."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stabilité de la santé grâce à un contrôle minutieux. Approche protectrice du bien-être. Vous protégez judicieusement vos ressources physiques mais ne laissez pas la peur dominer."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stabilità della salute attraverso un attento controllo. Approccio protettivo al benessere. Stai proteggendo saggiamente le tue risorse fisiche ma non lasciare che la paura domini."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "慎重なコントロールによる健康の安定。ウェルネスへの保護的アプローチ。あなたは賢明に身体のリソースを守っているが、恐怖を支配させないでください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Helsestabilitet gjennom forsiktig kontroll. Beskyttende tilnærming til velvære. Du beskytter dine fysiske ressurser klokt, men ikke la frykt dominere."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stabilność zdrowia poprzez staranną kontrolę. Ochronne podejście do wellness. Mądrze chronisz swoje zasoby fizyczne, ale nie pozwól, by dominował strach."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estabilidade da saúde através de controle cuidadoso. Abordagem protetora do bem-estar. Você está protegendo seus recursos físicos sabiamente, mas não deixe o medo dominar."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hälsostabilitet genom noggrann kontroll. Skyddande förhållningssätt till välbefinnande. Du skyddar dina fysiska resurser klokt men låt inte rädslan dominera."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Стабільність здоров'я через ретельний контроль. Захисний підхід до благополуччя. Ви мудро захищаєте свої фізичні ресурси, але не дозволяйте страху домінувати."
          }
        }
      }
    },
    "interpretation.four_of_pentacles_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Besitzgier und Habgier schaden der Beziehung. Aus Angst zu festhalten. Materialismus über authentische Verbindung. Kontrollprobleme belasten die Liebe. Loslassen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Possessiveness and greed damage relationship. Holding on too tight out of fear. Materialism over authentic connection. Control issues strain love. Let go."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El egoísmo y la codicia dañan la relación. Aferrarse demasiado por miedo. Materialismo por encima de la conexión auténtica. Los problemas de control tensionan el amor. Dejar ir."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La possessivité et la cupidité nuisent à la relation. S'accrocher trop fort par peur. Matérialisme plutôt que connexion authentique. Les problèmes de contrôle pèsent sur l'amour. Lâcher prise."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Possessività e avidità danneggiano la relazione. Tenere troppo stretto per paura. Materialismo sulla connessione autentica. I problemi di controllo mettono a dura prova l'amore. Lasciare andare."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "独占欲と貪欲さが関係を損なう。恐怖から強く握りしめすぎる。真のつながりよりも物質主義。コントロールの問題が愛に負担をかける。手放す。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Besittelse og grådighet skader forholdet. Holde for hardt fast av frykt. Materialisme fremfor autentisk forbindelse. Kontrollproblemer belaster kjærligheten. Slipp taket."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zaborczość i chciwość niszczą związek. Zbyt mocne trzymanie się ze strachu. Materializm kosztem autentycznej więzi. Problemy z kontrolą obciążają miłość. Odpuścić."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Possessividade e ganância prejudicam o relacionamento. Segurar com muita força por medo. Materialismo sobre a conexão autêntica. Problemas de controle sobrecarregam o amor. Deixar ir."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Besittande och girighet skadar relationen. Hålla för hårt av rädsla. Materialism framför autentisk koppling. Kontrollproblem belastar kärleken. Släppa taget."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Власництво та жадібність шкодять стосункам. Занадто міцне тримання через страх. Матеріалізм замість автентичного зв'язку. Проблеми контролю обтяжують любов. Відпустити."
          }
        }
      }
    },
    "interpretation.four_of_pentacles_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sicherheit und Stabilität in der Beziehung, aber möglicherweise zu viel Kontrolle. Du klammerst dich an die Liebe. Das schafft Sicherheit, kann aber das Wachstum einschränken. Balanciere Sicherheit mit Offenheit."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Security and stability in relationship but possibly too much control. You're holding on tight to love. This creates safety but may limit growth. Balance security with openness."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seguridad y estabilidad en la relación pero posiblemente demasiado control. Te aferras con fuerza al amor. Esto crea seguridad pero puede limitar el crecimiento. Equilibra la seguridad con la apertura."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sécurité et stabilité dans la relation mais peut-être trop de contrôle. Vous vous accrochez fermement à l'amour. Cela crée une sécurité mais peut limiter la croissance. Équilibrez la sécurité avec l'ouverture."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sicurezza e stabilità nella relazione ma forse troppo controllo. Ti stai aggrappando forte all'amore. Questo crea sicurezza ma può limitare la crescita. Bilancia la sicurezza con l'apertura."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "関係における安定と安全性だが、おそらくコントロールしすぎ。あなたは愛にしっかりとしがみついている。これは安全を生み出すが、成長を制限するかもしれない。安全性と開放性のバランスを取る。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sikkerhet og stabilitet i forholdet, men muligens for mye kontroll. Du holder godt fast i kjærligheten. Dette skaper trygghet, men kan begrense vekst. Balanser sikkerhet med åpenhet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bezpieczeństwo i stabilność w związku, ale być może zbyt duża kontrola. Mocno trzymasz się miłości. Stwarza to bezpieczeństwo, ale może ograniczać rozwój. Zrównoważ bezpieczeństwo z otwartością."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Segurança e estabilidade no relacionamento, mas possivelmente muito controle. Você está se segurando firmemente ao amor. Isso cria segurança, mas pode limitar o crescimento. Equilibre segurança com abertura."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Säkerhet och stabilitet i relationen men möjligen för mycket kontroll. Du håller fast hårt i kärleken. Detta skapar trygghet men kan begränsa tillväxt. Balansera säkerhet med öppenhet."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Безпека та стабільність у стосунках, але, можливо, надто багато контролю. Ви міцно тримаєтесь за любов. Це створює безпеку, але може обмежувати зростання. Балансуйте безпеку з відкритістю."
          }
        }
      }
    },
    "interpretation.four_of_swords_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Berufliche Unruhe oder Karriere-Burnout. Verweigerung der Arbeitserholungszeit. Stress verhindert beruflichen Fortschritt. Mangel an Ruhe untergräbt die Karriere."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professional restlessness or career burnout. Refusing work recovery time. Stress prevents professional progress. Lack of rest undermines career."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inquietud profesional o agotamiento laboral. Negarse a tomar tiempo de recuperación laboral. El estrés impide el progreso profesional. La falta de descanso socava la carrera."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Agitation professionnelle ou épuisement professionnel. Refuser le temps de récupération du travail. Le stress empêche les progrès professionnels. Le manque de repos nuit à la carrière."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Irrequietezza professionale o burnout professionale. Rifiuto del tempo di recupero dal lavoro. Lo stress impedisce il progresso professionale. La mancanza di riposo mina la carriera."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "仕事上の落ち着きのなさまたはキャリアの burnout。仕事の回復時間の拒否。ストレスが仕事上の進歩を妨げる。休息の不足がキャリアを損なう。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profesjonell rastløshet eller karriere-utbrenthet. Nekte arbeidsrestitusjonstid. Stress hindrer profesjonell fremgang. Mangel på hvile undergraver karrieren."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zawodowy niepokój lub wypalenie zawodowe. Odmowa czasu na regenerację w pracy. Stres uniemożliwia postęp zawodowy. Brak odpoczynku podważa karierę."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inquietação profissional ou esgotamento na carreira. Recusar tempo de recuperação do trabalho. O estresse impede o progresso profissional. A falta de descanso prejudica a carreira."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professionell rastlöshet eller karriärsutbrändhet. Vägra arbetstid för återhämtning. Stress förhindrar professionella framsteg. Brist på vila undergräver karriären."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Професійний неспокій або кар'єрне вигорання. Відмова від часу на відновлення після роботи. Стрес перешкоджає професійному прогресу. Відсутність відпочинку підриває кар'єру."
          }
        }
      }
    },
    "interpretation.four_of_swords_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karrierepause und berufliche Kontemplation. Eine Arbeitspause zur Erholung einlegen. Geistige Erholung verbessert die Leistung. Strategische Pause dient der Karriere."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Career rest and professional contemplation. Taking work break for recovery. Mental recuperation improves performance. Strategic pause serves career."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Descanso profesional y contemplación laboral. Tomar un descanso del trabajo para recuperarse. La recuperación mental mejora el rendimiento. La pausa estratégica beneficia la carrera."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Repos professionnel et contemplation professionnelle. Prendre une pause de travail pour récupérer. La récupération mentale améliore les performances. La pause stratégique sert la carrière."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Riposo professionale e contemplazione lavorativa. Prendersi una pausa dal lavoro per recuperare. Il recupero mentale migliora le prestazioni. La pausa strategica serve la carriera."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャリアの休息と仕事上の熟考。回復のために仕事から休憩を取る。精神的な回復がパフォーマンスを向上させる。戦略的休止がキャリアに役立つ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karrierehvile og profesjonell kontemplasjon. Ta arbeidspause for restitusjon. Mental restitusjon forbedrer ytelsen. Strategisk pause tjener karrieren."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odpoczynek zawodowy i zawodowa kontemplacja. Przerwa w pracy na regenerację. Regeneracja psychiczna poprawia wydajność. Strategiczna przerwa służy karierze."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Descanso na carreira e contemplação profissional. Fazer uma pausa no trabalho para recuperação. A recuperação mental melhora o desempenho. Pausa estratégica serve à carreira."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriärvila och professionell kontemplation. Ta arbetsledighet för återhämtning. Mental återhämtning förbättrar prestation. Strategisk paus tjänar karriären."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Кар'єрний відпочинок і професійне споглядання. Відпочинок від роботи для відновлення. Розумове відновлення покращує продуктивність. Стратегічна пауза служить кар'єрі."
          }
        }
      }
    },
    "interpretation.four_of_swords_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Unruhe oder Geld-Burnout. Verweigerung der notwendigen finanziellen Pause. Stress verhindert kluge Geldentscheidungen. Ruhe ist nötig."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial restlessness or money burnout. Refusing necessary financial pause. Stress prevents smart money decisions. Rest needed."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inquietud financiera o agotamiento económico. Negarse a la pausa financiera necesaria. El estrés impide decisiones financieras inteligentes. Se necesita descanso."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Agitation financière ou épuisement monétaire. Refuser la pause financière nécessaire. Le stress empêche des décisions financières judicieuses. Le repos est nécessaire."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Irrequietezza finanziaria o burnout monetario. Rifiuto della necessaria pausa finanziaria. Lo stress impedisce decisioni finanziarie intelligenti. Necessario riposo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "金銭的な落ち着きのなさまたはお金の burnout。必要な金銭的休止の拒否。ストレスが賢明なお金の決断を妨げる。休息が必要。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk rastløshet eller penge-utbrenthet. Nekte nødvendig økonomisk pause. Stress forhindrer smarte pengebeslutninger. Hvile trengs."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finansowy niepokój lub wypalenie pieniężne. Odmowa niezbędnej przerwy finansowej. Stres uniemożliwia mądre decyzje pieniężne. Potrzebny odpoczynek."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inquietação financeira ou esgotamento financeiro. Recusar a pausa financeira necessária. O estresse impede decisões financeiras inteligentes. Descanso necessário."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finansiell rastlöshet eller pengautbrändhet. Vägra nödvändig finansiell paus. Stress förhindrar smarta pengebestlut. Vila behövs."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансовий неспокій або грошове вигорання. Відмова від необхідної фінансової паузи. Стрес перешкоджає розумним грошовим рішенням. Потрібен відпочинок."
          }
        }
      }
    },
    "interpretation.four_of_swords_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Ruhe und Geldkontemplation. Eine Auszeit vom finanziellen Stress nehmen. Meditation über Ressourcenmanagement. Erholung verbessert finanzielle Entscheidungen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial rest and money contemplation. Taking break from financial stress. Meditation on resource management. Recovery improves financial decisions."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Descanso financiero y contemplación del dinero. Tomar un descanso del estrés financiero. Meditación sobre la gestión de recursos. La recuperación mejora las decisiones financieras."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Repos financier et contemplation de l'argent. Faire une pause dans le stress financier. Méditation sur la gestion des ressources. La récupération améliore les décisions financières."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Riposo finanziario e contemplazione del denaro. Prendersi una pausa dallo stress finanziario. Meditazione sulla gestione delle risorse. Il recupero migliora le decisioni finanziarie."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "金銭的な休息とお金の熟考。金銭的ストレスから休憩を取る。リソース管理についての瞑想。回復が金銭的決断を改善する。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk hvile og pengekontemplasjon. Ta pause fra økonomisk stress. Meditasjon over ressursforvaltning. Restitusjon forbedrer økonomiske beslutninger."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finansowy odpoczynek i kontemplacja pieniędzy. Przerwa od stresu finansowego. Medytacja nad zarządzaniem zasobami. Regeneracja poprawia decyzje finansowe."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Descanso financeiro e contemplação do dinheiro. Fazer uma pausa do estresse financeiro. Meditação sobre a gestão de recursos. A recuperação melhora as decisões financeiras."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finansiell vila och pengakontemplation. Ta paus från ekonomisk stress. Meditation över resurshantering. Återhämtning förbättrar finansiella beslut."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансовий відпочинок і грошове споглядання. Відпочинок від фінансового стресу. Медитація про управління ресурсами. Відновлення покращує фінансові рішення."
          }
        }
      }
    },
    "interpretation.four_of_swords_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unruhe, Burnout, Stress und Verweigerung von Ruhe. Du drängst zu hart und es ist kontraproduktiv. Mangelnde Erholung untergräbt den Fortschritt. Hör jetzt auf."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Restlessness, burnout, stress, and refusing rest. You're pushing too hard and it's counterproductive. Lack of recovery undermines progress. Stop now."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inquietud, agotamiento, estrés y negativa a descansar. Estás esforzándote demasiado y es contraproducente. La falta de recuperación socava el progreso. Detente ahora."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Agitation, épuisement, stress et refus de repos. Vous poussez trop fort et c'est contre-productif. Le manque de récupération nuit aux progrès. Arrêtez-vous maintenant."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Irrequietezza, burnout, stress e rifiuto del riposo. Stai spingendo troppo forte ed è controproducente. La mancanza di recupero mina il progresso. Fermati ora."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "落ち着きのなさ、burnout、ストレス、休息の拒否。あなたは頑張りすぎており、逆効果だ。回復不足が進歩を損なう。今すぐ止まれ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rastløshet, utbrenthet, stress og nektelse av hvile. Du presser for hardt og det er kontraproduktivt. Mangel på restitusjon undergraver fremgang. Stopp nå."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niepokój, wypalenie, stres i odmowa odpoczynku. Zbyt mocno naciskasz, a to jest kontrproduktywne. Brak regeneracji podważa postęp. Zatrzymaj się teraz."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inquietação, esgotamento, estresse e recusa de descanso. Você está se esforçando demais e é contraproducente. A falta de recuperação prejudica o progresso. Pare agora."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rastlöshet, utbrändhet, stress och vägran att vila. Du pressar för hårt och det är kontraproduktivt. Brist på återhämtning undergräver framsteg. Stanna nu."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Неспокій, вигорання, стрес і відмова від відпочинку. Ви занадто сильно тиснете, і це контрпродуктивно. Відсутність відновлення підриває прогрес. Зупиніться зараз."
          }
        }
      }
    },
    "interpretation.four_of_swords_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ruhe, Erholung, Kontemplation und Meditation. Dein Geist und Körper brauchen eine Pause. Strategische Pause stellt die Energie wieder her. Stille ist Handlung. Erlaube dir selbst, anzuhalten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rest, recovery, contemplation, and meditation. Your mind and body need a break. Strategic pause restores energy. Stillness is action. Give yourself permission to stop."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Descanso, recuperación, contemplación y meditación. Tu mente y cuerpo necesitan un descanso. La pausa estratégica restaura la energía. La quietud es acción. Date permiso para parar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Repos, récupération, contemplation et méditation. Votre esprit et votre corps ont besoin d'une pause. La pause stratégique restaure l'énergie. L'immobilité est une action. Autorisez-vous à vous arrêter."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Riposo, recupero, contemplazione e meditazione. La tua mente e il tuo corpo hanno bisogno di una pausa. La pausa strategica ripristina l'energia. La quiete è azione. Concediti il permesso di fermarti."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "休息、回復、熟考、瞑想。あなたの心と体は休憩を必要としている。戦略的休止がエネルギーを回復する。静けさが行動だ。自分自身に止まる許可を与えよ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hvile, restitusjon, kontemplasjon og meditasjon. Sinnet og kroppen din trenger en pause. Strategisk pause gjenoppretter energi. Stillhet er handling. Gi deg selv tillatelse til å stoppe."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odpoczynek, regeneracja, kontemplacja i medytacja. Twój umysł i ciało potrzebują przerwy. Strategiczna przerwa przywraca energię. Bezruch jest działaniem. Daj sobie pozwolenie na zatrzymanie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Descanso, recuperação, contemplação e meditação. Sua mente e corpo precisam de uma pausa. A pausa estratégica restaura a energia. A quietude é ação. Dê a si mesmo permissão para parar."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vila, återhämtning, kontemplation och meditation. Ditt sinne och kropp behöver en paus. Strategisk paus återställer energi. Stillhet är handling. Ge dig själv tillstånd att stanna."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Відпочинок, відновлення, споглядання та медитація. Ваш розум і тіло потребують перерви. Стратегічна пауза відновлює енергію. Тиша - це дія. Дозвольте собі зупинитися."
          }
        }
      }
    },
    "interpretation.four_of_swords_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unruhige Gesundheit oder Verweigerung der Erholung. Burnout verhindert Heilung. Stress untergräbt das Wohlbefinden. Mangel an Ruhe schadet dem Körper. Stopp und erhole dich."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Restless health or refusing recovery. Burnout prevents healing. Stress undermines wellness. Lack of rest harms body. Stop and recover."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Salud inquieta o negativa a recuperarse. El agotamiento impide la curación. El estrés socava el bienestar. La falta de descanso daña el cuerpo. Detente y recupérate."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Santé agitée ou refus de récupération. L'épuisement empêche la guérison. Le stress nuit au bien-être. Le manque de repos nuit au corps. Arrêtez-vous et récupérez."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Salute irrequieta o rifiuto del recupero. L'esaurimento impedisce la guarigione. Lo stress mina il benessere. La mancanza di riposo danneggia il corpo. Fermati e recupera."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "落ち着かない健康状態または回復の拒否。burnout が治癒を妨げる。ストレスがウェルネスを損なう。休息不足が体に害を及ぼす。止まって回復しろ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rastløs helse eller nektelse av restitusjon. Utbrenthet hindrer helbredelse. Stress undergraver velvære. Mangel på hvile skader kroppen. Stopp og bli frisk."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niespokojne zdrowie lub odmowa powrotu do zdrowia. Wypalenie uniemożliwia leczenie. Stres podważa dobre samopoczucie. Brak odpoczynku szkodzi ciału. Zatrzymaj się i zregeneruj."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Saúde inquieta ou recusa de recuperação. O esgotamento impede a cura. O estresse prejudica o bem-estar. A falta de descanso prejudica o corpo. Pare e se recupere."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rastlös hälsa eller vägran att återhämta sig. Utbrändhet förhindrar läkning. Stress undergräver välbefinnande. Brist på vila skadar kroppen. Stanna och återhämta dig."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Неспокійне здоров'я або відмова від відновлення. Вигорання перешкоджає зціленню. Стрес підриває благополуччя. Відсутність відпочинку шкодить тілу. Зупинись і відновися."
          }
        }
      }
    },
    "interpretation.four_of_swords_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Körperliche Ruhe und Gesundheitserholung. Geistige Erholung unterstützt die Heilung. Meditation und Kontemplation nützen dem Körper. Strategische Pause stellt das Wohlbefinden wieder her."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Physical rest and health recovery. Mental recuperation supports healing. Meditation and contemplation benefit body. Strategic pause restores wellness."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Descanso físico y recuperación de la salud. La recuperación mental favorece la curación. La meditación y la contemplación benefician al cuerpo. La pausa estratégica restaura el bienestar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Repos physique et rétablissement de la santé. La récupération mentale favorise la guérison. La méditation et la contemplation profitent au corps. La pause stratégique rétablit le bien-être."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Riposo fisico e recupero della salute. Il recupero mentale supporta la guarigione. La meditazione e la contemplazione giovano al corpo. La pausa strategica ripristina il benessere."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "身体の休息と健康の回復。精神的な回復が治癒を支える。瞑想と熟考が体に良い。戦略的休止がウェルネスを回復する。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fysisk hvile og helsegjenoppretting. Mental restitusjon støtter helbredelse. Meditasjon og kontemplasjon gagner kroppen. Strategisk pause gjenoppretter velvære."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odpoczynek fizyczny i powrót do zdrowia. Regeneracja psychiczna wspomaga leczenie. Medytacja i kontemplacja korzystnie wpływają na ciało. Strategiczna przerwa przywraca dobre samopoczucie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Descanso físico e recuperação da saúde. A recuperação mental apoia a cura. Meditação e contemplação beneficiam o corpo. Pausa estratégica restaura o bem-estar."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fysisk vila och hälsorehabilitering. Mental återhämtning stödjer läkning. Meditation och kontemplation gynnar kroppen. Strategisk pause återställer välbefinnande."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фізичний відпочинок і відновлення здоров'я. Розумове відновлення підтримує зцілення. Медитація та споглядання корисні для тіла. Стратегічна пауза відновлює благополуччя."
          }
        }
      }
    },
    "interpretation.four_of_swords_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unruhige Beziehung oder Vermeidung der notwendigen Liebesreflexion. Ausgebrannt von der Partnerschaft oder Verweigerung der Erholungszeit. Stress verhindert Beziehungsfortschritt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Restless relationship or avoiding necessary love reflection. Burnout from partnership or refusing recovery time. Stress prevents relationship progress."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Relación inquieta o evitación de la reflexión amorosa necesaria. Agotamiento por la pareja o negativa a tomar tiempo de recuperación. El estrés impide el progreso de la relación."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Relation agitée ou évitement de la réflexion amoureuse nécessaire. Épuisement dû au partenariat ou refus du temps de récupération. Le stress empêche les progrès relationnels."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Relazione irrequieta o evitamento della necessaria riflessione amorosa. Esaurimento dalla partnership o rifiuto del tempo di recupero. Lo stress impedisce il progresso relazionale."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "落ち着かない関係または必要な恋愛の内省の回避。パートナーシップからの burnout または回復時間の拒否。ストレスが関係の進展を妨げる。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rastløst forhold eller unngåelse av nødvendig kjærlighetsrefleksjon. Utbrenthet fra partnerskap eller nektelse av restitusjonstid. Stress hindrer forholdsfremgang."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niespokojny związek lub unikanie niezbędnej refleksji miłosnej. Wypalenie z partnerstwa lub odmowa czasu na regenerację. Stres uniemożliwia postęp w związku."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Relacionamento inquieto ou evitando a reflexão amorosa necessária. Esgotamento da parceria ou recusa de tempo de recuperação. O estresse impede o progresso do relacionamento."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rastlöst förhållande eller undvikande av nödvändig kärleksreflektion. Utbrändhet från partnerskap eller vägran av återhämtningstid. Stress förhindrar relationsframsteg."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Неспокійні стосунки або уникнення необхідної любовної рефлексії. Вигорання від партнерства або відмова від часу на відновлення. Стрес перешкоджає прогресу у стосунках."
          }
        }
      }
    },
    "interpretation.four_of_swords_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beziehungspause und romantische Kontemplation. Eine Auszeit von der Intensität der Liebe nehmen. Meditation über die Bedürfnisse der Partnerschaft. Erholungszeit stärkt die Verbindung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Relationship rest and romantic contemplation. Taking break from love intensity. Meditation on partnership needs. Recovery time strengthens connection."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Descanso en la relación y contemplación romántica. Tomar un descanso de la intensidad del amor. Meditación sobre las necesidades de la pareja. El tiempo de recuperación fortalece la conexión."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Repos relationnel et contemplation romantique. Faire une pause dans l'intensité de l'amour. Méditation sur les besoins du partenariat. Le temps de récupération renforce le lien."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Riposo relazionale e contemplazione romantica. Prendersi una pausa dall'intensità dell'amore. Meditazione sui bisogni della partnership. Il tempo di recupero rafforza la connessione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "関係の休息と恋愛の熟考。愛の強度から休憩を取る。パートナーシップのニーズについての瞑想。回復時間が絆を強める。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Forholdshvile og romantisk kontemplasjon. Ta en pause fra kjærlighetsintensitet. Meditasjon over partnerskapsbehov. Restitusjonstid styrker forbindelsen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odpoczynek w związku i romantyczna kontemplacja. Przerwa od intensywności miłości. Medytacja nad potrzebami partnerstwa. Czas regeneracji wzmacnia więź."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Descanso no relacionamento e contemplação romântica. Fazer uma pausa da intensidade do amor. Meditação sobre as necessidades da parceria. Tempo de recuperação fortalece a conexão."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Relationsvila och romantisk kontemplation. Ta en paus från kärleksintensitet. Meditation över partnerskapsbehov. Återhämtningstid stärker anslutningen."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Відпочинок у стосунках і романтичне споглядання. Відпочинок від інтенсивності кохання. Медитація про потреби партнерства. Час відновлення зміцнює зв'язок."
          }
        }
      }
    },
    "interpretation.four_of_wands_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriereinstabilität oder mangelnde berufliche Unterstützung. Herausforderungen beim Arbeitsplatzwechsel. Bürokonflikt. Feier verzögert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Career instability or lack of professional support. Work transition challenges. Office conflict. Celebration delayed."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inestabilidad profesional o falta de apoyo profesional. Desafíos en la transición laboral. Conflicto en la oficina. Celebración retrasada."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Instabilité de carrière ou manque de soutien professionnel. Défis de transition professionnelle. Conflit au bureau. Célébration retardée."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Instabilità di carriera o mancanza di supporto professionale. Sfide di transizione lavorativa. Conflitto in ufficio. Celebrazione ritardata."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャリアの不安定性や職業上のサポートの欠如。仕事の移行の課題。職場の衝突。お祝いが遅れている。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriereustabilitet eller mangel på profesjonell støtte. Utfordringer med jobbovergang. Kontorkonflikt. Feiring forsinket."
