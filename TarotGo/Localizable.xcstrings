        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manipolazione professionale o abuso di potere sul lavoro. Leadership tirannica. Crudeltà professionale. Usare intelletto e posizione come armi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "仕事上の操作または職場での権力乱用。専制的リーダーシップ。キャリアの残酷さ。知性と立場を武器として使う。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profesjonell manipulasjon eller maktmisbruk på arbeidsplassen. Tyrannisk lederskap. Karrieregrusomhet. Bruke intellekt og posisjon som våpen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manipulacja zawodowa lub nadużycie władzy w miejscu pracy. Tyrańskie przywództwo. Okrucieństwo w karierze. Używanie intelektu i pozycji jako broni."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manipulação profissional ou abuso de poder no local de trabalho. Liderança tirânica. Crueldade na carreira. Usar intelecto e posição como armas."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professionell manipulation eller maktmissbruk på arbetsplatsen. Tyranniskt ledarskap. Karriärsgrymhet. Använda intellekt och position som vapen."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Професійна маніпуляція або зловживання владою на робочому місці. Тиранічне лідерство. Кар'єрна жорстокість. Використання інтелекту та позиції як зброї."
          }
        }
      }
    },
    "interpretation.king_of_swords_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Autoritativer, wahrheitsliebender Berufsansatz. Intellektuelle Kraft und klarer Geist bei der Arbeit. Ehrliche Karriereführung. Logik und Ethik leiten den Erfolg."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Authoritative, truthful professional approach. Intellectual power and clear mind at work. Honest career leadership. Logic and ethics guide success."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enfoque profesional autoritario y veraz. Poder intelectual y mente clara en el trabajo. Liderazgo profesional honesto. La lógica y la ética guían el éxito."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Approche professionnelle autoritaire et véridique. Puissance intellectuelle et esprit clair au travail. Leadership professionnel honnête. La logique et l'éthique guident le succès."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Approccio professionale autorevole e veritiero. Potere intellettuale e mente chiara al lavoro. Leadership professionale onesta. Logica ed etica guidano il successo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "権威的で真実の仕事へのアプローチ。職場における知力と明晰な心。正直なキャリアリーダーシップ。論理と倫理が成功を導く。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Autoritær, sannferdig profesjonell tilnærming. Intellektuell kraft og klart sinn på jobb. Ærlig karriere lederskap. Logikk og etikk veileder suksess."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Autorytarne, prawdomówne podejście zawodowe. Siła intelektu i jasny umysł w pracy. Uczciwe przywództwo w karierze. Logika i etyka prowadzą do sukcesu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abordagem profissional autoritária e verdadeira. Poder intelectual e mente clara no trabalho. Liderança de carreira honesta. Lógica e ética guiam o sucesso."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Auktoritär, sanningsenlig professionell inställning. Intellektuell kraft och klart sinne på jobbet. Ärligt karriärledarskap. Logik och etik vägleder framgång."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Авторитетний, правдивий професійний підхід. Інтелектуальна сила та ясний розум на роботі. Чесне кар'єрне лідерство. Логіка та етика ведуть до успіху."
          }
        }
      }
    },
    "interpretation.king_of_swords_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
