        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "養育的で実用的な関係アプローチ。地に足のついた愛とパートナーへの提供。地に足のついたケアが安全を生み出す。家と心が美しく調和する。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Omsorgsfull, praktisk forholdstilnærming. Jordnær kjærlighet og forsørgelse av partner. Jordnær omsorg skaper trygghet. Hjem og hjerte passer vakkert sammen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opiekuńcze, praktyczne podejście do związku. Przyziemna miłość i zapewnianie partnerowi. Uziemiona opieka tworzy bezpieczeństwo. Dom i serce pięknie się łączą."
