    "onboarding.interpret.desc": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Each card offers wisdom tailored to your question"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Jede Karte bietet Weisheit, die auf deine Frage zugeschnitten ist"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cada carta ofrece sabiduría adaptada a tu pregunta"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chaque carte offre une sagesse adaptée à votre question"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ogni carta offre saggezza adattata alla tua domanda"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "それぞれのカードがあなたの質問に合わせた知恵を提供します"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Hvert kort tilbyr visdom tilpasset spørsmålet ditt"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Każda karta oferuje mądrość dostosowaną do twojego pytania"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Cada carta oferece sabedoria adaptada à sua pergunta"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Varje kort erbjuder visdom anpassad till din fråga"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Кожна карта пропонує мудрість, адаптовану до вашого питання"
          }
        }
      }
    },
