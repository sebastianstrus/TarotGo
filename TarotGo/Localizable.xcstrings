        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Необачне кохання або поспіх у стосунках. Романтична фрустрація. Пасивне партнерство, незважаючи на пристрасні почуття. Імпульсивні проблеми зі зв'язком."
          }
        }
      }
    },
    "interpretation.knight_of_wands_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Leidenschaftliches romantisches Streben und energiegeladene Liebe. Abenteuerlicher Beziehungsansatz. Impulsive Partnerschaft. Dem Herzen schnell folgen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Passionate romantic pursuit and energetic love. Adventurous relationship approach. Impulsive partnership. Following your heart quickly."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Búsqueda romántica apasionada y amor energético. Enfoque de relación aventurero. Asociación impulsiva. Siguiendo tu corazón rápidamente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Poursuite romantique passionnée et amour énergique. Approche relationnelle aventureuse. Partenariat impulsif. Suivre son cœur rapidement."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inseguimento romantico appassionato e amore energetico. Approccio relazionale avventuroso. Partnership impulsiva. Seguire il cuore rapidamente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "情熱的な恋愛の追求と活力ある愛。冒険的な関係へのアプローチ。衝動的なパートナーシップ。素早く心に従う。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lidenskapelig romantisk forfølgelse og energirik kjærlighet. Eventyrlig relasjonstilnærming. Impulsivt partnerskap. Følg hjertet raskt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Namiętne romantyczne dążenie i energetyczna miłość. Awanturnicze podejście do związków. Impulsywne partnerstwo. Szybkie podążanie za sercem."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Busca romântica apaixonada e amor energético. Abordagem de relacionamento aventureira. Parceria impulsiva. Seguindo seu coração rapidamente."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lidelsefull romantisk strävan och energirik kärlek. Äventyrlig relationsapproach. Impulsivt partnerskap. Följ ditt hjärta snabbt."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Пристрасне романтичне прагнення та енергійне кохання. Авантюрний підхід до стосунків. Імпульсивне партнерство. Швидке слідування за серцем."
          }
        }
      }
    },
    "interpretation.nine_of_cups_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Berufliche Unzufriedenheit trotz Erfolgs. Deine Errungenschaften bringen nicht die erwartete Freude. Ständig mehr zu wollen, verhindert Zufriedenheit. Überdenke, was Erfolg bedeutet."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professional dissatisfaction despite success. Your achievements don't bring expected joy. Constantly wanting more prevents satisfaction. Reevaluate what success means."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Insatisfacción profesional a pesar del éxito. Tus logros no traen la alegría esperada. Querer constantemente más impide la satisfacción. Reevalúa lo que significa el éxito."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Insatisfaction professionnelle malgré le succès. Vos réalisations n'apportent pas la joie escomptée. Vouloir constamment plus empêche la satisfaction. Réévaluez ce que signifie le succès."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Insoddisfazione professionale nonostante il successo. I tuoi risultati non portano la gioia prevista. Volere costantemente di più impedisce la soddisfazione. Rivaluta cosa significa successo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "成功にもかかわらず仕事上の不満。あなたの業績は期待された喜びをもたらしません。常にもっと欲しがることは満足を妨げます。成功の意味を再評価してください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profesjonell misnøye til tross for suksess. Dine prestasjoner gir ikke forventet glede. Å alltid ville ha mer hindrer tilfredshet. Revurder hva suksess betyr."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niezadowolenie zawodowe pomimo sukcesu. Twoje osiągnięcia nie przynoszą oczekiwanej radości. Ciągłe pragnienie więcej uniemożliwia satysfakcję. Przewartościuj, co oznacza sukces."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Insatisfação profissional apesar do sucesso. Suas conquistas não trazem a alegria esperada. Querer constantemente mais impede a satisfação. Reavalie o que significa sucesso."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professionellt missnöje trots framgång. Dina prestationer ger inte förväntad glädje. Att ständigt vilja ha mer hindrar tillfredsställelse. Omvärdera vad framgång betyder."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Професійне незадоволення, незважаючи на успіх. Ваші досягнення не приносять очікуваної радості. Постійне бажання більшого перешкоджає задоволенню. Переоцініть, що означає успіх."
          }
        }
      }
    },
    "interpretation.nine_of_cups_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Berufliche Zufriedenheit und erfüllte Karrierewünsche. Du genießt die Früchte deiner Arbeit. Der Erfolg bringt Zufriedenheit. Dafür hast du gearbeitet – genieße es."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professional satisfaction and career wishes fulfilled. You're enjoying the fruits of your labor. Success brings contentment. This is what you worked for—savor it."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Satisfacción profesional y deseos profesionales cumplidos. Estás disfrutando los frutos de tu trabajo. El éxito trae satisfacción. Esto es por lo que trabajaste: saborea."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Satisfaction professionnelle et souhaits de carrière exaucés. Vous profitez des fruits de votre travail. Le succès apporte le contentement. C'est pour cela que vous avez travaillé – savourez-le."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Soddisfazione professionale e desideri di carriera realizzati. Stai godendo i frutti del tuo lavoro. Il successo porta contentezza. Questo è ciò per cui hai lavorato: assaporalo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "仕事上の満足とキャリアの願いの成就。あなたは自分の労働の成果を楽しんでいます。成功は満足をもたらします。これはあなたが働いてきた成果です―味わってください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profesjonell tilfredshet og karriereønsker oppfylt. Du nyter fruktene av ditt arbeid. Suksess bringer tilfredshet. Dette er det du jobbet for – nyt det."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Satysfakcja zawodowa i spełnione pragnienia zawodowe. Cieszysz się owocami swojej pracy. Sukces przynosi zadowolenie. Na to pracowałeś – delektuj się tym."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Satisfação profissional e desejos de carreira realizados. Você está aproveitando os frutos do seu trabalho. O sucesso traz contentamento. É para isso que você trabalhou – saboreie."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professionell tillfredsställelse och karriärönskningar uppfyllda. Du njuter av frukterna av ditt arbete. Framgång ger tillfredsställelse. Det här är vad du arbetade för – njut av det."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Професійне задоволення та здійснені кар'єрні бажання. Ви насолоджуєтеся плодами своєї праці. Успіх приносить вдоволення. Це те, заради чого ви працювали – насолоджуйтесь цим."
          }
        }
      }
    },
    "interpretation.nine_of_cups_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Unzufriedenheit, obwohl man genug hat. Gier oder Materialismus verhindern Zufriedenheit. Unerfüllte Erwartungen darüber, was Geld bringen würde. Übe Dankbarkeit."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial dissatisfaction despite having enough. Greed or materialism prevents contentment. Unfulfilled expectations about what money would bring. Practice gratitude."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Insatisfacción financiera a pesar de tener suficiente. La codicia o el materialismo impiden el contento. Expectativas incumplidas sobre lo que el dinero traería. Practica la gratitud."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Insatisfaction financière malgré avoir suffisamment. La cupidité ou le matérialisme empêchent le contentement. Attentes non satisfaites quant à ce que l'argent apporterait. Pratiquez la gratitude."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Insoddisfazione finanziaria nonostante abbia abbastanza. L'avidità o il materialismo impediscono la contentezza. Aspettative non soddisfatte su cosa avrebbe portato il denaro. Pratica la gratitudine."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "十分に持っているにもかかわらず、経済的な不満。貪欲さや物質主義が満足を妨げます。お金がもたらすものについての未達成の期待。感謝の気持ちを持ちましょう。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk misnøye til tross for å ha nok. Grådighet eller materialisme hindrer tilfredshet. Uoppfylte forventninger om hva penger ville bringe. Øv på takknemlighet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niezadowolenie finansowe pomimo posiadania wystarczających środków. Chciwość lub materializm uniemożliwiają zadowolenie. Niespełnione oczekiwania co do tego, co przyniosą pieniądze. Praktykuj wdzięczność."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Insatisfação financeira apesar de ter o suficiente. Ganância ou materialismo impedem o contentamento. Expectativas não cumpridas sobre o que o dinheiro traria. Pratique a gratidão."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomiskt missnöje trots att ha tillräckligt. Girighet eller materialism hindrar tillfredsställelse. Ouppfyllda förväntningar på vad pengar skulle ge. Öva tacksamhet."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансове незадоволення, незважаючи на достатність. Жадібність або матеріалізм перешкоджають задоволенню. Невиправдані очікування щодо того, що принесуть гроші. Практикуйте вдячність."
          }
        }
      }
    },
    "interpretation.nine_of_cups_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Zufriedenheit und Wohlstand. Deine Geldwünsche sind erfüllt. Du hast den Wohlstand, den du dir gewünscht hast. Zeit, deine Ressourcen zu genießen und großzügig zu teilen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial satisfaction and prosperity. Your money wishes are fulfilled. You have the abundance you desired. Time to enjoy your resources and share generously."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Satisfacción financiera y prosperidad. Tus deseos de dinero se cumplen. Tienes la abundancia que deseabas. Es hora de disfrutar tus recursos y compartir generosamente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Satisfaction financière et prospérité. Vos souhaits d'argent sont exaucés. Vous avez l'abondance que vous désiriez. Il est temps de profiter de vos ressources et de partager généreusement."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Soddisfazione finanziaria e prosperità. I tuoi desideri di denaro sono esauditi. Hai l'abbondanza che desideravi. È tempo di goderti le tue risorse e condividere generosamente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的な満足と繁栄。あなたのお金に関する願いは叶えられています。あなたは望んでいた豊かさを手に入れています。自分のリソースを楽しみ、惜しみなく共有する時です。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk tilfredshet og velstand. Dine pengeønsker er oppfylt. Du har overfloden du ønsket. Tid til å nyte ressursene dine og dele raust."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zadowolenie finansowe i dobrobyt. Twoje pragnienia pieniężne są spełnione. Masz obfitość, której pragnąłeś. Czas cieszyć się swoimi zasobami i dzielić się hojnie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Satisfação financeira e prosperidade. Seus desejos financeiros são realizados. Você tem a abundância que desejava. Hora de aproveitar seus recursos e compartilhar generosamente."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomisk tillfredsställelse och välstånd. Dina pengaönskningar är uppfyllda. Du har den överflöd du önskade. Dags att njuta av dina resurser och dela generöst."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансове задоволення та процвітання. Ваші грошові бажання здійснилися. Ви маєте достаток, якого бажали. Час насолоджуватися своїми ресурсами та щедро ділитися."
          }
        }
      }
    },
    "interpretation.nine_of_cups_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unzufriedenheit, obwohl man viel hat. Gier, Materialismus oder unrealistische Erwartungen verhindern Zufriedenheit. Du hast deine Wünsche erfüllt, aber sie haben nicht das erwartete Glück gebracht. Schaue tiefer."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dissatisfaction despite having much. Greed, materialism, or unrealistic expectations prevent contentment. You achieved your wishes but they didn't bring expected happiness. Look deeper."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Insatisfacción a pesar de tener mucho. La codicia, el materialismo o las expectativas poco realistas impiden el contento. Lograste tus deseos, pero no trajeron la felicidad esperada. Mira más profundo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Insatisfaction malgré avoir beaucoup. La cupidité, le matérialisme ou des attentes irréalistes empêchent le contentement. Vous avez réalisé vos souhaits mais ils n'ont pas apporté le bonheur attendu. Regardez plus profondément."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Insoddisfazione nonostante si abbia molto. L'avidità, il materialismo o le aspettative irrealistiche impediscono la contentezza. Hai realizzato i tuoi desideri ma non hanno portato la felicità attesa. Guarda più a fondo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "多くを持っているにもかかわらず不満。貪欲さ、物質主義、または非現実的な期待が満足を妨げます。あなたは願いを達成しましたが、それらは期待された幸福をもたらしませんでした。もっと深く見つめてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Misnøye til tross for å ha mye. Grådighet, materialisme eller urealistiske forventninger hindrer tilfredshet. Du oppnådde ønskene dine, men de ga ikke forventet lykke. Se dypere."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niezadowolenie pomimo posiadania wiele. Chciwość, materializm lub nierealistyczne oczekiwania uniemożliwiają zadowolenie. Osiągnąłeś swoje pragnienia, ale nie przyniosły one oczekiwanego szczęścia. Spójrz głębiej."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Insatisfação apesar de ter muito. Ganância, materialismo ou expectativas irreais impedem o contentamento. Você realizou seus desejos, mas eles não trouxeram a felicidade esperada. Olhe mais fundo."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Missnöje trots att ha mycket. Girighet, materialism eller orealistiska förväntningar hindrar tillfredsställelse. Du uppnådde dina önskningar men de gav inte förväntad lycka. Titta djupare."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Незадоволення, незважаючи на те, що маєте багато. Жадібність, матеріалізм або нереалістичні очікування перешкоджають задоволенню. Ви досягли своїх бажань, але вони не принесли очікуваного щастя. Подивіться глибше."
          }
        }
      }
    },
    "interpretation.nine_of_cups_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erfüllte Wünsche, Zufriedenheit und Genügsamkeit. Du hast, was du dir gewünscht hast. Dies ist die Karte des Alles-habens – emotional, materiell, spirituell. Genieße diesen schönen Moment der Vollendung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wishes fulfilled, satisfaction, and contentment. You have what you desired. This is the card of having it all—emotionally, materially, spiritually. Enjoy this beautiful moment of completion."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deseos cumplidos, satisfacción y contento. Tienes lo que deseabas. Esta es la carta de tenerlo todo: emocional, material y espiritualmente. Disfruta este hermoso momento de plenitud."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Souhaits exaucés, satisfaction et contentement. Vous avez ce que vous désiriez. C'est la carte du « tout avoir » – émotionnellement, matériellement, spirituellement. Profitez de ce beau moment d'accomplissement."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desideri realizzati, soddisfazione e contentezza. Hai ciò che desideravi. Questa è la carta dell'avere tutto: emotivamente, materialmente, spiritualmente. Goditi questo bellissimo momento di completamento."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "願いの成就、満足、そして満足感。あなたは望んでいたものを手に入れました。これは、感情的にも、物質的にも、精神的にも、すべてを手に入れるカードです。この完璧な瞬間を楽しんでください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oppfylte ønsker, tilfredshet og fornøydhet. Du har det du ønsket. Dette er kortet for å ha alt – følelsesmessig, materielt, åndelig. Nyt dette vakre øyeblikket av fullførelse."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spełnione pragnienia, satysfakcja i zadowolenie. Masz to, czego pragnąłeś. To karta posiadania wszystkiego – emocjonalnie, materialnie, duchowo. Ciesz się tym pięknym momentem spełnienia."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desejos realizados, satisfação e contentamento. Você tem o que desejava. Esta é a carta de ter tudo – emocional, material e espiritualmente. Aproveite este belo momento de realização."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uppfyllda önskningar, tillfredsställelse och belåtenhet. Du har det du önskade. Det här är kortet för att ha allt – känslomässigt, materiellt, andligt. Njut av detta vackra ögonblick av fullbordan."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Здійснені бажання, задоволення та вдоволення. Ви маєте те, чого бажали. Це карта того, що ви маєте все – емоційно, матеріально, духовно. Насолоджуйтесь цим прекрасним моментом завершення."
          }
        }
      }
    },
    "interpretation.nine_of_cups_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gesundheitliche Unzufriedenheit oder unrealistische Körpererwartungen. Du hast Wohlbefinden, kannst es aber nicht sehen. Übermäßiger Genuss beeinträchtigt die Gesundheit. Dankbarkeit für die Gaben deines Körpers ist nötig."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Health dissatisfaction or unrealistic body expectations. You have wellness but can't see it. Overindulgence affects health. Gratitude for your body's gifts needed."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Insatisfacción con la salud o expectativas corporales poco realistas. Tienes bienestar pero no puedes verlo. El exceso afecta la salud. Se necesita gratitud por los dones de tu cuerpo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Insatisfaction en matière de santé ou attentes corporelles irréalistes. Vous avez le bien-être mais vous ne pouvez pas le voir. Les excès nuisent à la santé. La gratitude pour les dons de votre corps est nécessaire."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Insoddisfazione per la salute o aspettative corporee irrealistiche. Hai benessere ma non riesci a vederlo. L'eccessiva indulgenza influisce sulla salute. Necessaria gratitudine per i doni del tuo corpo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "健康への不満や非現実的な身体への期待。あなたは健康だが、それに気づいていない。過度の贅沢が健康に影響を与えます。あなたの体の賜物への感謝が必要です。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Helsemisnøye eller urealistiske kroppsforventninger. Du har velvære, men kan ikke se det. Overdreven nytelse påvirker helsen. Takknemlighet for kroppens gaver er nødvendig."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niezadowolenie ze zdrowia lub nierealistyczne oczekiwania wobec ciała. Masz dobre samopoczucie, ale nie możesz go zobaczyć. Nadmierne pobłażanie sobie wpływa na zdrowie. Potrzebna wdzięczność za dary twojego ciała."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Insatisfação com a saúde ou expectativas corporais irreais. Você tem bem-estar, mas não consegue ver. O excesso afeta a saúde. Gratidão pelos dons do seu corpo é necessária."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hälsomissnöje eller orealistiska kroppsförväntningar. Du har välbefinnande men kan inte se det. Överdrivet njutande påverkar hälsan. Tacksamhet för din kropps gåvor behövs."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Незадоволення здоров'ям або нереалістичні очікування щодо тіла. У вас є благополуччя, але ви цього не бачите. Надмірне потурання впливає на здоров'я. Потрібна вдячність за дари вашого тіла."
          }
        }
      }
    },
    "interpretation.nine_of_cups_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gesundheitliche Zufriedenheit und erreichte Wellness-Ziele. Dein Körper fühlt sich gut an und du bist zufrieden mit deiner Vitalität. Genieße diese Phase des körperlichen Wohlbefindens."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Health satisfaction and wellness goals achieved. Your body feels good and you're content with your vitality. Enjoy this phase of physical wellbeing."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Satisfacción de salud y metas de bienestar logradas. Tu cuerpo se siente bien y estás contento con tu vitalidad. Disfruta esta fase de bienestar físico."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Satisfaction en matière de santé et objectifs de bien-être atteints. Votre corps se sent bien et vous êtes satisfait de votre vitalité. Profitez de cette phase de bien-être physique."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Soddisfazione per la salute e obiettivi di benessere raggiunti. Il tuo corpo si sente bene e sei contento della tua vitalità. Goditi questa fase di benessere fisico."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "健康への満足とウェルネス目標の達成。あなたの体は快適で、活力に満足しています。この身体的な健康の段階を楽しんでください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Helsetilfredshet og velværemål oppnådd. Kroppen din føles bra, og du er fornøyd med vitaliteten din. Nyt denne fasen av fysisk velvære."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zadowolenie ze zdrowia i osiągnięte cele wellness. Twoje ciało czuje się dobrze i jesteś zadowolony ze swojej witalności. Ciesz się tą fazą fizycznego dobrego samopoczucia."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Satisfação com a saúde e metas de bem-estar alcançadas. Seu corpo se sente bem e você está contente com sua vitalidade. Aproveite esta fase de bem-estar físico."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hälsotillfredsställelse och uppnådda friskvårdsmål. Din kropp känns bra och du är nöjd med din vitalitet. Njut av denna fas av fysiskt välbefinnande."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Задоволення здоров'ям та досягнення оздоровчих цілей. Ваше тіло почувається добре, і ви задоволені своєю життєвою силою. Насолоджуйтеся цією фазою фізичного благополуччя."
          }
        }
      }
    },
    "interpretation.nine_of_cups_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Romantische Unzufriedenheit, obwohl du das zu haben scheinst, was du dir gewünscht hast. Gier nach mehr verhindert, dass du genießt, was ist. Materialismus über authentische Verbindung. Überprüfe deine Erwartungen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Romantic dissatisfaction despite having what you thought you wanted. Greed for more prevents enjoying what is. Materialism over authentic connection. Check your expectations."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Insatisfacción romántica a pesar de tener lo que creías querer. La codicia por más impide disfrutar lo que es. Materialismo sobre la conexión auténtica. Revisa tus expectativas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Insatisfaction romantique malgré ce que vous pensiez vouloir. La soif de plus empêche de profiter de ce qui est. Matérialisme plutôt que connexion authentique. Vérifiez vos attentes."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Insoddisfazione romantica nonostante tu abbia ciò che pensavi di volere. L'avidità di più impedisce di godere di ciò che è. Materialismo sulla connessione autentica. Controlla le tue aspettative."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "欲しいと思っていたものを手に入れているにもかかわらず、恋愛面での不満。もっと欲しいという貪欲さが、あるがままを楽しむことを妨げています。真のつながりよりも物質主義。あなたの期待を見直してください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Romantisk misnøye til tross for at du har det du trodde du ville ha. Grådighet etter mer forhindrer å nyte det som er. Materialisme fremfor autentisk forbindelse. Sjekk forventningene dine."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niezadowolenie romantyczne pomimo posiadania tego, co myślałeś, że chcesz. Chciwość więcej uniemożliwia cieszenie się tym, co jest. Materializm ponad autentyczną więź. Sprawdź swoje oczekiwania."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Insatisfação romântica, apesar de ter o que você pensava que queria. Ganância por mais impede de aproveitar o que é. Materialismo em vez de conexão autêntica. Verifique suas expectativas."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Romantisk missnöje trots att du har det du trodde du ville ha. Girighet efter mer hindrar att njuta av det som är. Materialism över äkta anslutning. Kontrollera dina förväntningar."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Романтичне незадоволення, незважаючи на те, що ви маєте те, що, як ви думали, хотіли. Жадібність до більшого заважає насолоджуватися тим, що є. Матеріалізм понад автентичний зв'язок. Перевірте свої очікування."
          }
        }
      }
    },
    "interpretation.nine_of_cups_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tiefe romantische Zufriedenheit und erfüllte Wünsche in der Liebe. Du hast die Beziehung, die du dir gewünscht hast. Zufriedenheit und Glück in Herzensangelegenheiten. Zähle deine Segnungen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deep romantic satisfaction and wishes fulfilled in love. You have the relationship you desired. Contentment and happiness in matters of the heart. Count your blessings."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profunda satisfacción romántica y deseos cumplidos en el amor. Tienes la relación que deseabas. Contento y felicidad en asuntos del corazón. Cuenta tus bendiciones."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Satisfaction romantique profonde et souhaits exaucés en amour. Vous avez la relation que vous désiriez. Contentement et bonheur dans les affaires de cœur. Comptez vos bénédictions."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profonda soddisfazione romantica e desideri realizzati in amore. Hai la relazione che desideravi. Contentezza e felicità nelle questioni di cuore. Conta le tue benedizioni."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "愛における深いロマンティックな満足と願いの成就。あなたは望んでいた関係を手に入れています。心の問題における満足と幸福。あなたの祝福を数えてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dyp romantisk tilfredshet og oppfylte ønsker i kjærlighet. Du har forholdet du ønsket. Tilfredshet og lykke i hjertesaker. Tell dine velsignelser."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Głęboka satysfakcja romantyczna i spełnione pragnienia w miłości. Masz związek, którego pragnąłeś. Zadowolenie i szczęście w sprawach sercowych. Policz swoje błogosławieństwa."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profunda satisfação romântica e desejos realizados no amor. Você tem o relacionamento que desejava. Contentamento e felicidade nas questões do coração. Conte suas bênçãos."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Djup romantisk tillfredsställelse och uppfyllda önskningar i kärlek. Du har förhållandet du önskade. Tillfredsställelse och lycka i hjärtfrågor. Räkna dina välsignelser."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Глибоке романтичне задоволення та здійснені бажання в коханні. У вас є стосунки, які ви бажали. Вдоволення та щастя в сердечних справах. Рахуйте свої благословення."
          }
        }
      }
    },
    "interpretation.nine_of_pentacles_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Berufliche Überarbeitung oder berufliche Isolation. Hetzen ohne Ausgleich. Über seine Verhältnisse leben oder vom Job abhängig sein. Verlorenes Gefühl der Errungenschaft. Neu bewerten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Career overwork or professional isolation. Hustling without balance. Living beyond means or dependent on job. Lost sense of accomplishment. Reassess."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Exceso de trabajo o aislamiento profesional. Agitación sin equilibrio. Vivir por encima de las posibilidades o depender del trabajo. Pérdida de la sensación de logro. Reevaluar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Surmenage professionnel ou isolement professionnel. S'agiter sans équilibre. Vivre au-dessus de ses moyens ou dépendre de son travail. Perte du sentiment d'accomplissement. Réévaluer."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Superlavoro o isolamento professionale. Frenesia senza equilibrio. Vivere al di sopra dei propri mezzi o dipendere dal lavoro. Senso di realizzazione perso. Rivalutare."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャリアの過労または職業上の孤立。バランスのないハッスル。身の丈以上の生活または仕事への依存。達成感の喪失。再評価する。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriereoverarbeid eller profesjonell isolasjon. Jag uten balanse. Å leve over evne eller være avhengig av jobb. Tapt følelse av prestasjon. Vurder på nytt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przepracowanie zawodowe lub izolacja zawodowa. Harówka bez równowagi. Życie ponad stan lub uzależnienie od pracy. Utrata poczucia osiągnięcia. Przeanalizuj ponownie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Excesso de trabalho ou isolamento profissional. Correria sem equilíbrio. Viver acima das posses ou dependente do trabalho. Perda do senso de realização. Reavaliar."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriärsöverarbete eller professionell isolering. Jäkt utan balans. Att leva över sina tillgångar eller vara beroende av jobbet. Förlorad känsla av prestation. Omvärdera."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Кар'єрне перевтомлення або професійна ізоляція. Метания без балансу. Життя не за коштами або залежність від роботи. Втрата відчуття досягнення. Переоцінити."
          }
        }
      }
    },
    "interpretation.nine_of_pentacles_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Berufliche Unabhängigkeit und Karriereerfolg. Selbstgemachter Erfolg und Anerkennung. Sie haben durch Ihre eigenen Bemühungen etwas Beeindruckendes aufgebaut. Genießen Sie Ihre Leistung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professional independence and career accomplishment. Self-made success and recognition. You've built something impressive through your own efforts. Enjoy your achievement."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Independencia profesional y logro profesional. Éxito y reconocimiento por méritos propios. Has construido algo impresionante a través de tus propios esfuerzos. Disfruta de tu logro."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Indépendance professionnelle et réussite professionnelle. Succès et reconnaissance autodidactes. Vous avez construit quelque chose d'impressionnant par vos propres efforts. Profitez de votre réussite."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Indipendenza professionale e successo nella carriera. Successo e riconoscimento fai-da-te. Hai costruito qualcosa di impressionante attraverso i tuoi sforzi. Goditi il tuo risultato."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "職業上の独立とキャリアの達成。自力での成功と認識。あなたは自分の努力を通じて印象的なものを築いてきた。あなたの成果を楽しみなさい。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profesjonell uavhengighet og karriereprestasjon. Egenprodusert suksess og anerkjennelse. Du har bygget noe imponerende gjennom din egen innsats. Nyt prestasjonen din."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niezależność zawodowa i osiągnięcia w karierze. Własny sukces i uznanie. Zbudowałeś coś imponującego dzięki własnym wysiłkom. Ciesz się swoim osiągnięciem."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Independência profissional e realização na carreira. Sucesso e reconhecimento por mérito próprio. Você construiu algo impressionante através de seus próprios esforços. Aproveite sua conquista."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professionell självständighet och karriärprestation. Egengjord framgång och erkännande. Du har byggt något imponerande genom dina egna ansträngningar. Njut av din prestation."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Професійна незалежність та кар'єрні досягнення. Саморобний успіх та визнання. Ви побудували щось вражаюче власними зусиллями. Насолоджуйтесь своїм досягненням."
          }
        }
      }
    },
    "interpretation.nine_of_pentacles_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Überarbeitung oder Leben über seine Verhältnisse. Abhängigkeit von der Einnahmequelle. Hetzen ohne die Früchte zu genießen. Isolation durch Materialismus. Finden Sie ein Gleichgewicht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial overwork or living beyond means. Dependency on income source. Hustling without enjoying fruits. Isolation through materialism. Find balance."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sobretrabajo financiero o vivir por encima de las posibilidades. Dependencia de la fuente de ingresos. Agitación sin disfrutar de los frutos. Aislamiento a través del materialismo. Encuentra el equilibrio."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Surmenage financier ou vivre au-dessus de ses moyens. Dépendance de la source de revenus. S'agiter sans profiter des fruits. Isolement par le matérialisme. Trouvez l'équilibre."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Superlavoro finanziario o vivere al di sopra dei propri mezzi. Dipendenza dalla fonte di reddito. Frenesia senza godere dei frutti. Isolamento attraverso il materialismo. Trova un equilibrio."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的な過労または身の丈以上の生活。収入源への依存。成果を楽しまずにハッスルする。物質主義による孤立。バランスを見つける。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk overarbeid eller å leve over evne. Avhengighet av inntektskilde. Jage uten å nyte fruktene. Isolasjon gjennom materialisme. Finn balanse."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przepracowanie finansowe lub życie ponad stan. Zależność od źródła dochodu. Harówka bez cieszenia się owocami. Izolacja przez materializm. Znajdź równowagę."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Excesso de trabalho financeiro ou viver acima das posses. Dependência da fonte de renda. Correria sem aproveitar os frutos. Isolamento através do materialismo. Encontre o equilíbrio."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomiskt överarbete eller att leva över sina tillgångar. Beroende av inkomstkälla. Jäkt utan att njuta av frukterna. Isolering genom materialism. Hitta balans."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансове перевтомлення або життя не за коштами. Залежність від джерела доходу. Метания без насолоди плодами. Ізоляція через матеріалізм. Знайдіть баланс."
          }
        }
      }
    },
    "interpretation.nine_of_pentacles_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Unabhängigkeit und selbstgemachter Wohlstand. Luxus, den Sie sich durch Ihre Bemühungen verdient haben. Selbstgenügsamkeit mit Ressourcen. Genießen Sie den von Ihnen geschaffenen Wohlstand."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial independence and self-made prosperity. Luxury earned through your efforts. Self-sufficiency with resources. Enjoying abundance you created."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Independencia financiera y prosperidad por méritos propios. Lujo ganado a través de tus esfuerzos. Autosuficiencia con los recursos. Disfrutando de la abundancia que creaste."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Indépendance financière et prospérité autodidacte. Luxe gagné grâce à vos efforts. Autosuffisance en ressources. Profiter de l'abondance que vous avez créée."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Indipendenza finanziaria e prosperità fai-da-te. Lusso guadagnato attraverso i tuoi sforzi. Autosufficienza con le risorse. Godere dell'abbondanza che hai creato."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的独立と自己流の繁栄。あなたの努力によって得られた贅沢。リソースの自給自足。あなたが生み出した豊かさを楽しむ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk uavhengighet og egenprodusert velstand. Luksus opptjent gjennom din innsats. Selvforsyning med ressurser. Nyte overfloden du har skapt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niezależność finansowa i samodzielnie osiągnięty dobrobyt. Luksus zdobyty dzięki twoim wysiłkom. Samowystarczalność z zasobami. Cieszenie się obfitością, którą stworzyłeś."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Independência financeira e prosperidade por mérito próprio. Luxo conquistado através de seus esforços. Autossuficiência com recursos. Aproveitando a abundância que você criou."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomiskt oberoende och egenproducerat välstånd. Lyx som du tjänat genom dina ansträngningar. Självförsörjning med resurser. Njut av överflöd du skapat."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансова незалежність та саморобне процвітання. Розкіш, зароблена вашими зусиллями. Самодостатність з ресурсами. Насолода достатком, який ви створили."
          }
        }
      }
    },
    "interpretation.nine_of_pentacles_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Überarbeitung, Hetzen, Leben über seine Verhältnisse oder Isolation durch Unabhängigkeit. Sie haben das Gleichgewicht verloren. Abhängigkeit, getarnt als Unabhängigkeit. Prioritäten neu bewerten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Overworking, hustling, living beyond means, or isolation through independence. You've lost balance. Dependency disguised as independence. Reassess priorities."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Exceso de trabajo, ajetreo, vivir por encima de las posibilidades o aislamiento por independencia. Has perdido el equilibrio. Dependencia disfrazada de independencia. Reevaluar prioridades."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Surmenage, agitation, vivre au-dessus de ses moyens ou isolement par l'indépendance. Vous avez perdu l'équilibre. Dépendance déguisée en indépendance. Réévaluer les priorités."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Superlavoro, frenesia, vivere al di sopra dei propri mezzi o isolamento attraverso l'indipendenza. Hai perso l'equilibrio. Dipendenza mascherata da indipendenza. Rivalutare le priorità."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "過労、ハッスル、身の丈以上の生活、または独立による孤立。あなたはバランスを失っている。独立を装った依存。優先順位を再評価する。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Overarbeid, jag, å leve over evne eller isolasjon gjennom uavhengighet. Du har mistet balansen. Avhengighet forkledd som uavhengighet. Vurder prioriteringene på nytt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przepracowanie, harówka, życie ponad stan lub izolacja przez niezależność. Straciłeś równowagę. Zależność przebrana za niezależność. Przeanalizuj priorytety."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Excesso de trabalho, correria, viver acima das posses ou isolamento através da independência. Você perdeu o equilíbrio. Dependência disfarçada de independência. Reavaliar prioridades."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Överarbete, jäkt, att leva över sina tillgångar eller isolering genom oberoende. Du har tappat balansen. Beroende förklädd till oberoende. Omvärdera prioriteringarna."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Перевтомлення, метання, життя не за коштами або ізоляція через незалежність. Ви втратили баланс. Залежність, замаскована під незалежність. Перегляньте пріоритети."
          }
        }
      }
    },
    "interpretation.nine_of_pentacles_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unabhängigkeit, Luxus, Selbstgenügsamkeit und Erfolg. Sie haben dies durch Ihre eigenen Bemühungen aufgebaut. Genießen Sie die Früchte Ihrer Arbeit. Sie haben sich diesen Wohlstand verdient."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Independence, luxury, self-sufficiency, and accomplishment. You've built this through your own efforts. Enjoy the fruits of your labor. You earned this abundance."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Independencia, lujo, autosuficiencia y logro. Has construido esto a través de tus propios esfuerzos. Disfruta de los frutos de tu trabajo. Te ganaste esta abundancia."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Indépendance, luxe, autosuffisance et accomplissement. Vous avez construit cela par vos propres efforts. Profitez des fruits de votre travail. Vous avez mérité cette abondance."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Indipendenza, lusso, autosufficienza e successo. Hai costruito questo attraverso i tuoi sforzi. Goditi i frutti del tuo lavoro. Ti sei guadagnato questa abbondanza."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "独立、贅沢、自給自足、そして達成。あなたは自分の努力を通じてこれを築いてきた。あなたの労働の成果を楽しみなさい。あなたはこの豊かさを手に入れた。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uavhengighet, luksus, selvforsyning og prestasjon. Du har bygget dette gjennom din egen innsats. Nyt fruktene av ditt arbeid. Du fortjente denne overfloden."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niezależność, luksus, samowystarczalność i osiągnięcie. Zbudowałeś to dzięki własnym wysiłkom. Ciesz się owocami swojej pracy. Zasłużyłeś na tę obfitość."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Independência, luxo, autossuficiência e realização. Você construiu isso através de seus próprios esforços. Aproveite os frutos do seu trabalho. Você mereceu essa abundância."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Självständighet, lyx, självförsörjning och prestation. Du har byggt detta genom dina egna ansträngningar. Njut av frukterna av ditt arbete. Du förtjänade detta överflöd."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Незалежність, розкіш, самодостатність та досягнення. Ви побудували це власними зусиллями. Насолоджуйтесь плодами своєї праці. Ви заслужили цей достаток."
          }
        }
      }
    },
    "interpretation.nine_of_pentacles_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Gesundheit leidet unter Überarbeitung. Vernachlässigung der Selbstfürsorge durch Hetzen. Lebensweise, die den Körper belastet. Bedarf an einer besseren Gesundheits-Arbeits-Balance."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Health suffers from overwork. Self-care neglect due to hustling. Living in ways that tax body. Need for better health-work balance."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La salud sufre por el exceso de trabajo. Negligencia en el autocuidado debido a la agitación. Vivir de una manera que afecta al cuerpo. Necesidad de un mejor equilibrio entre la salud y el trabajo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La santé souffre du surmenage. Négligence des soins personnels due à l'agitation. Vivre d'une manière qui taxe le corps. Besoin d'un meilleur équilibre entre santé et travail."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La salute soffre per il superlavoro. Trascuratezza della cura di sé a causa della frenesia. Vivere in modi che gravano sul corpo. Necessità di un migliore equilibrio tra salute e lavoro."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "過労により健康が損なわれる。ハッスルによるセルフケアの怠慢。身体に負担をかける生活。より良い健康と仕事のバランスの必要性。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Helsen lider av overarbeid. Forsømmelse av egenomsorg på grunn av jag. Leve på en måte som belaster kroppen. Behov for bedre helse-arbeidsbalanse."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zdrowie cierpi z powodu przepracowania. Zaniedbanie samoopieki z powodu harówki. Życie w sposób obciążający ciało. Potrzeba lepszej równowagi między zdrowiem a pracą."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A saúde sofre com o excesso de trabalho. Negligência do autocuidado devido à correria. Viver de maneiras que sobrecarregam o corpo. Necessidade de melhor equilíbrio entre saúde e trabalho."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hälsan lider av överarbete. Försummelse av egenvård på grund av jäkt. Att leva på sätt som belastar kroppen. Behov av bättre hälso-arbetsbalans."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Здоров'я страждає від перевтомлення. Нехтування самообслуговуванням через метання. Життя у спосіб, що обтяжує тіло. Потреба в кращому балансі між здоров'ям та роботою."
          }
        }
      }
    },
    "interpretation.nine_of_pentacles_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gesundheitliche Unabhängigkeit und Wellness-Erfolg. Selbstgenügsam in der Pflege Ihres Körpers. Genießen Sie den körperlichen Luxus und Komfort, den Sie sich durch Anstrengung verdient haben."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Health independence and wellness accomplishment. Self-sufficient in caring for your body. Enjoying physical luxury and comfort you've earned through effort."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Independencia en la salud y logro de bienestar. Autosuficiente en el cuidado de tu cuerpo. Disfrutando del lujo y la comodidad física que has ganado con esfuerzo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Indépendance en matière de santé et réussite en matière de bien-être. Autosuffisant dans les soins de votre corps. Profiter du luxe et du confort physique que vous avez gagnés grâce à vos efforts."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Indipendenza sanitaria e successo nel benessere. Autosufficiente nella cura del tuo corpo. Godere del lusso e del comfort fisico che hai guadagnato con lo sforzo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "健康の独立とウェルネスの達成。自分の身体のケアにおいて自給自足。努力によって得た身体的な贅沢と快適さを楽しむ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Helseuavhengighet og velværeprestasjon. Selvforsynt med å ta vare på kroppen din. Nyte fysisk luksus og komfort du har oppnådd gjennom innsats."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niezależność zdrowotna i osiągnięcie wellness. Samowystarczalność w dbaniu o swoje ciało. Cieszenie się fizycznym luksusem i komfortem, który zdobyłeś dzięki wysiłkowi."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Independência de saúde e realização de bem-estar. Autossuficiente no cuidado do seu corpo. Desfrutando do luxo e conforto físico que você conquistou através do esforço."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hälsooberoende och hälso- och välmåendeprestation. Självförsörjande i att ta hand om din kropp. Njut av fysisk lyx och komfort som du förtjänat genom ansträngning."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Незалежність здоров'я та оздоровче досягнення. Самодостатність у турботі про своє тіло. Насолода фізичною розкішшю та комфортом, які ви заслужили зусиллями."
          }
        }
      }
    },
    "interpretation.nine_of_pentacles_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beziehungskodependenz oder Isolation durch Überunabhängigkeit. Über seine Verhältnisse leben, um den Partner zu beeindrucken. Ungleichgewicht zwischen Arbeit und Leben beeinträchtigt die Liebe. Finden Sie gesunde Interdependenz."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Relationship codependency or isolation from over-independence. Living beyond means to impress partner. Work-life imbalance affects love. Find healthy interdependence."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Codependencia en la relación o aislamiento por sobreindependencia. Vivir por encima de las posibilidades para impresionar a la pareja. El desequilibrio entre el trabajo y la vida afecta al amor. Encuentra una interdependencia saludable."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Codépendance relationnelle ou isolement dû à une surindépendance. Vivre au-dessus de ses moyens pour impressionner son partenaire. Le déséquilibre entre vie professionnelle et vie privée affecte l'amour. Trouvez une interdépendance saine."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Codipendenza relazionale o isolamento da un'eccessiva indipendenza. Vivere al di sopra dei propri mezzi per impressionare il partner. Lo squilibrio tra lavoro e vita privata influisce sull'amore. Trova un'interdipendenza sana."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "関係の共依存または過度の独立による孤立。パートナーを impression するために身の丈以上の生活をする。ワークライフバランスの不均衡が愛に影響する。健康的な相互依存を見つける。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Forholdsavhengighet eller isolasjon fra overavhengighet. Å leve over evne for å imponere partneren. Ubalanse mellom arbeid og liv påvirker kjærligheten. Finn sunn gjensidig avhengighet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Współuzależnienie w związku lub izolacja z powodu nadmiernej niezależności. Życie ponad stan, aby zaimponować partnerowi. Brak równowagi między pracą a życiem wpływa na miłość. Znajdź zdrową współzależność."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Codependência no relacionamento ou isolamento por superindependência. Viver acima das posses para impressionar o parceiro. Desequilíbrio entre trabalho e vida afeta o amor. Encontre interdependência saudável."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Relationsmedberoende eller isolering från överdrivet oberoende. Att leva över sina tillgångar för att imponera på partnern. Obalans mellan arbete och liv påverkar kärleken. Hitta ett hälsosamt ömsesidigt beroende."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Співзалежність у стосунках або ізоляція через надмірну незалежність. Життя не за коштами, щоб вразити партнера. Дисбаланс між роботою та життям впливає на любов. Знайдіть здорову взаємозалежність."
          }
        }
      }
    },
    "interpretation.nine_of_pentacles_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unabhängigkeit und Selbstgenügsamkeit in der Liebe. Du bist für sich allein vollständig, und die Beziehung bereichert dich, anstatt dich zu vervollständigen. Luxus und Qualität in der Partnerschaft."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Independence and self-sufficiency in love. You're complete on your own and relationship enhances rather than completes you. Luxury and quality in partnership."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Independencia y autosuficiencia en el amor. Eres completo por ti mismo y la relación te realza en lugar de completarte. Lujo y calidad en la sociedad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Indépendance et autonomie en amour. Vous êtes complet par vous-même et la relation vous améliore plutôt que de vous compléter. Luxe et qualité dans le partenariat."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Indipendenza e autosufficienza nell'amore. Sei completo da solo e la relazione ti migliora piuttosto che completarti. Lusso e qualità nella partnership."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "愛における独立性と自己充足。あなたは自分自身で完全であり、関係はあなたを完成させるのではなく、高めるものです。パートナーシップにおける贅沢と質。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uavhengighet og selvforsyning i kjærlighet. Du er komplett på egen hånd, og forholdet forsterker deg heller enn å fullføre deg. Luksus og kvalitet i partnerskapet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niezależność i samowystarczalność w miłości. Jesteś kompletny sam w sobie, a związek cię wzbogaca, a nie uzupełnia. Luksus i jakość w partnerstwie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Independência e autossuficiência no amor. Você é completo por si só e o relacionamento melhora, em vez de completar você. Luxo e qualidade na parceria."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Självständighet och självförsörjning i kärlek. Du är komplett på egen hand och relationen förbättrar snarare än fullbordar dig. Lyx och kvalitet i partnerskapet."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Незалежність та самодостатність у любові. Ви повні самі по собі, і стосунки скоріше покращують вас, ніж доповнюють. Розкіш та якість у партнерстві."
          }
        }
      }
    },
    "interpretation.nine_of_swords_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriereangst lässt nach und berufliche Hoffnung keimt auf. Unterstützung bei der Arbeit suchen. Verzweiflung über den Job lässt nach. Erholung beginnt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Career anxiety subsiding and professional hope emerging. Reaching out for work support. Despair about job lifting. Recovery begins."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La ansiedad profesional disminuye y la esperanza laboral surge. Buscar apoyo laboral. La desesperación por el trabajo se disipa. La recuperación comienza."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'anxiété professionnelle s'atténue et l'espoir professionnel émerge. Chercher du soutien au travail. Le désespoir lié au travail s'atténue. La guérison commence."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'ansia professionale si attenua e la speranza professionale emerge. Cercare supporto lavorativo. La disperazione per il lavoro si attenua. La guarigione inizia."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャリア不安が和らぎ、仕事への希望が芽生える。仕事のサポートを求める。仕事への絶望が軽くなる。回復が始まる。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriereangst avtar og profesjonelt håp dukker opp. Søke arbeidsstøtte. Fortvilelse om jobb letter. Bedring begynner."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niepokój zawodowy ustępuje, a nadzieja zawodowa pojawia się. Szukanie wsparcia w pracy. Rozpacz związana z pracą ustępuje. Powrót do zdrowia zaczyna się."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ansiedade de carreira diminuindo e esperança profissional surgindo. Buscar apoio no trabalho. Desespero sobre o trabalho diminuindo. A recuperação começa."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriärångest avtar och professionellt hopp uppstår. Söka arbetsstöd. Förtvivlan om jobb lättar. Återhämtning börjar."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Кар'єрна тривога вщухає, з'являється професійна надія. Звернення по підтримку на роботі. Розпач щодо роботи зникає. Одужання починається."
          }
        }
      }
    },
    "interpretation.nine_of_swords_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriereangst und berufliche Sorgen. Arbeitsalbträume und überwältigende Jobangst. Dein Geist quält dich wegen deiner Karriere. Suche dir Unterstützung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Career anxiety and professional worry. Work nightmares and overwhelming job fear. Your mind torments you about career. Reach out for support."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ansiedad profesional y preocupación laboral. Pesadillas laborales y miedo abrumador al trabajo. Tu mente te atormenta por la carrera. Busca apoyo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anxiété professionnelle et inquiétude professionnelle. Cauchemars de travail et peur accablante du travail. Votre esprit vous tourmente à propos de votre carrière. Cherchez du soutien."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ansia professionale e preoccupazione lavorativa. Incubi sul lavoro e paura travolgente del lavoro. La tua mente ti tormenta sulla carriera. Cerca supporto."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャリア不安と仕事上の心配。仕事の悪夢と圧倒的な仕事への恐怖。あなたの心がキャリアについてあなたを苦しめる。サポートを求めて。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriereangst og profesjonell bekymring. Arbeidsmareritt og overveldende jobbfrykt. Sinnet ditt plager deg om karrieren. Søk støtte."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niepokój zawodowy i zmartwienie pracą. Koszmary o pracy i przytłaczający strach przed pracą. Twój umysł dręczy cię z powodu kariery. Szukaj wsparcia."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ansiedade de carreira e preocupação profissional. Pesadelos no trabalho e medo esmagador do trabalho. Sua mente te atormenta sobre a carreira. Busque apoio."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriärångest och professionell oro. Arbetsmardrömmar och överväldigande jobbrädsla. Ditt sinne plågar dig om karriären. Sök stöd."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Кар'єрна тривога та професійне занепокоєння. Кошмари на роботі та переважний страх перед роботою. Ваш розум мучить вас через кар'єру. Зверніться по підтримку."
          }
        }
      }
    },
    "interpretation.nine_of_swords_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Angst lässt nach und Geldhoffnung keimt auf. Finanzielle Unterstützung suchen. Verzweiflung über Ressourcen lässt nach. Erholung beginnt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial anxiety subsiding and money hope emerging. Reaching out for financial support. Despair about resources lifting. Recovery begins."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La ansiedad financiera disminuye y la esperanza económica surge. Buscar apoyo financiero. La desesperación por los recursos se disipa. La recuperación comienza."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'anxiété financière s'atténue et l'espoir monétaire émerge. Chercher un soutien financier. Le désespoir lié aux ressources s'atténue. La guérison commence."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'ansia finanziaria si attenua e la speranza monetaria emerge. Cercare supporto finanziario. La disperazione per le risorse si attenua. La guarigione inizia."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "金銭的不安が和らぎ、お金への希望が芽生える。金銭的サポートを求める。リソースへの絶望が軽くなる。回復が始まる。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk angst avtar og pengehåp dukker opp. Søke økonomisk støtte. Fortvilelse om ressurser letter. Bedring begynner."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lęk finansowy ustępuje, a nadzieja na pieniądze pojawia się. Szukanie wsparcia finansowego. Rozpacz związana z zasobami ustępuje. Powrót do zdrowia zaczyna się."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ansiedade financeira diminuindo e esperança financeira surgindo. Buscar apoio financeiro. Desespero sobre recursos diminuindo. A recuperação começa."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finansiell ångest avtar och pengahopp uppstår. Söka ekonomiskt stöd. Förtvivlan om resurser lättar. Återhämtning börjar."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансова тривога вщухає, з'являється надія на гроші. Звернення по фінансову підтримку. Розпач щодо ресурсів зникає. Одужання починається."
          }
        }
      }
    },
    "interpretation.nine_of_swords_finance_upright" : {
      "extractionState" : "manual",
