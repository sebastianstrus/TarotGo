    },
    "interpretation.seven_of_wands_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erschöpfung, Aufgeben, Überwältigung und Bodenverlust. Du kannst nicht mehr verteidigen. Zeit, entweder zurückzuziehen oder einen anderen Ansatz zu finden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Exhaustion, giving up, overwhelmed, and losing ground. You can't defend anymore. Time to either retreat or find another approach."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Agotamiento, rendición, abrumamiento y pérdida de terreno. Ya no puedes defenderte. Es hora de retirarse o encontrar otro enfoque."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Épuisement, abandon, dépassement et perte de terrain. Vous ne pouvez plus défendre. Il est temps de reculer ou de trouver une autre approche."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esaurimento, arrendersi, sopraffazione e perdita di terreno. Non puoi più difenderti. È tempo di ritirarsi o trovare un altro approccio."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "疲労、あきらめ、圧倒、そして立場の喪失。あなたはもう守ることができない。退却するか、別のアプローチを見つける時だ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utmattelse, gi opp, overveldet og tap av grunn. Du kan ikke forsvare lenger. På tide å enten trekke seg tilbake eller finne en annen tilnærming."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wyczerpanie, poddawanie się, przytłoczenie i utrata gruntu. Nie możesz już bronić. Czas się wycofać lub znaleźć inne podejście."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Exaustão, desistência, sobrecarga e perda de terreno. Você não pode mais se defender. Hora de recuar ou encontrar outra abordagem."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utmattning, ge upp, överväldigad och förlust av mark. Du kan inte försvara längre. Dags att antingen dra sig tillbaka eller hitta ett annat tillvägagångssätt."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Виснаження, здача, перевантаження та втрата позицій. Ви більше не можете захищатися. Час або відступити, або знайти інший підхід."
          }
        }
      }
    },
    "interpretation.seven_of_wands_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verteidigung, Ausdauer, Kontrollbewahrung und Herausforderung. Du wirst angegriffen, hältst aber deinen Boden. Stelle dich dem Widerstand. Gib jetzt nicht auf."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Defense, perseverance, maintaining control, and challenge. You're under attack but holding your ground. Standing up to opposition. Don't give up now."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Defensa, perseverancia, mantenimiento del control y desafío. Estás bajo ataque pero mantienes tu posición. Enfrentándote a la oposición. No te rindas ahora."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Défense, persévérance, maintien du contrôle et défi. Vous êtes attaqué mais vous tenez bon. Faire face à l'opposition. N'abandonnez pas maintenant."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Difesa, perseveranza, mantenimento del controllo e sfida. Sei sotto attacco ma tieni duro. Affrontare l'opposizione. Non arrenderti ora."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "防御、忍耐、コントロールの維持、そして挑戦。あなたは攻撃を受けているが、自分の立場を守っている。反対に立ち向かう。今、あきらめてはいけない。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Forsvar, utholdenhet, opprettholde kontroll og utfordring. Du er under angrep, men holder stand. Stå opp mot motstand. Ikke gi opp nå."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Obrona, wytrwałość, utrzymywanie kontroli i wyzwanie. Jesteś atakowany, ale trzymasz swoją pozycję. Stawianie czoła opozycji. Nie poddawaj się teraz."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Defesa, perseverança, manutenção do controle e desafio. Você está sob ataque, mas mantém sua posição. Enfrentando a oposição. Não desista agora."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Försvar, uthållighet, upprätthålla kontroll och utmaning. Du är under attack men håller din position. Stå upp mot motstånd. Ge inte upp nu."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Захист, наполегливість, підтримання контролю та виклик. Ви під атакою, але тримаєте свої позиції. Стояти проти опору. Не здавайтеся зараз."
          }
        }
      }
    },
    "interpretation.seven_of_wands_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erschöpft von der Gesundheitsverteidigung. Wohlbefinden aufgeben. Von körperlichen Herausforderungen überwältigt. Körperlichen Boden verlieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Exhausted from health defense. Giving up on wellness. Overwhelmed by body challenges. Losing physical ground."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Agotado de defender la salud. Rindiéndose en el bienestar. Abrumado por los desafíos corporales. Perdiendo terreno físico."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Épuisé de défendre sa santé. Abandonner le bien-être. Débordé par les défis corporels. Perdre du terrain physique."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esausto dalla difesa della salute. Arrendersi al benessere. Sopraffatto dalle sfide del corpo. Perdere terreno fisico."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "健康の防御に疲れ果てた。ウェルネスをあきらめる。身体の課題に圧倒される。身体的な立場を失う。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utslitt av helseforsvar. Gi opp velvære. Overveldet av kroppsutfordringer. Miste fysisk grunn."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wyczerpany obroną zdrowia. Poddawanie się wellness. Przytłoczony wyzwaniami ciała. Tracenie fizycznego gruntu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Exausto de defender a saúde. Desistindo do bem-estar. Sobrecarregado pelos desafios do corpo. Perdendo terreno físico."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utmattad av hälsoförsvar. Ge upp välmående. Överväldigad av kroppsutmaningar. Förlora fysisk mark."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Виснажений захистом здоров'я. Здатися благополуччю. Перевантажений викликами тіла. Втрата фізичних позицій."
          }
        }
      }
    },
    "interpretation.seven_of_wands_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verteidigung des Wohlbefindens und Aufrechterhaltung der Gesundheitskontrolle. Körper unter Druck. Standhaft bleiben bei der Heilung. Durchhalten gegen körperliche Widerstände."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Defending wellness and maintaining health control. Body under challenge. Standing your ground with healing. Persevering through physical opposition."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Defendiendo el bienestar y manteniendo el control de la salud. Cuerpo bajo desafío. Manteniendo tu posición con la curación. Perseverando a través de la oposición física."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Défendre le bien-être et maintenir le contrôle de la santé. Corps sous défi. Tenir bon avec la guérison. Persévérer face à l'opposition physique."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Difendere il benessere e mantenere il controllo della salute. Corpo sotto sfida. Mantenere la propria posizione con la guarigione. Perseverare nonostante l'opposizione fisica."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ウェルネスを守り、健康のコントロールを維持する。身体が挑戦にさらされる。癒しで自分の立場を守る。身体的な反対を乗り越えて忍耐する。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Forsvare velvære og opprettholde helsekontroll. Kropp under utfordring. Stå din grunn med helbredelse. Holde ut mot fysisk motstand."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bronienie dobrego samopoczucia i utrzymywanie kontroli nad zdrowiem. Ciało pod presją. Utrzymywanie swojej pozycji z uzdrawianiem. Wytrwanie pomimo fizycznej opozycji."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Defendendo o bem-estar e mantendo o controle da saúde. Corpo sob desafio. Mantendo sua posição com a cura. Perseverando através da oposição física."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Försvara välmående och upprätthålla hälsokontroll. Kropp under utmaning. Stå fast med läkning. Härda ut genom fysiskt motstånd."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Захист благополуччя та підтримання контролю над здоров'ям. Тіло під викликом. Стояти на своєму з зціленням. Наполегливість через фізичний опір."
          }
        }
      }
    },
    "interpretation.seven_of_wands_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erschöpft von der Verteidigung der Beziehung. Liebe aufgeben. Von den Herausforderungen der Partnerschaft überwältigt. Romantischen Boden verlieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Exhausted from defending relationship. Giving up on love. Overwhelmed by partnership challenges. Losing romantic ground."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Agotado de defender la relación. Rindiéndose en el amor. Abrumado por los desafíos de la pareja. Perdiendo terreno romántico."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Épuisé de défendre la relation. Abandonner l'amour. Débordé par les défis du partenariat. Perdre du terrain romantique."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esausto dal difendere la relazione. Arrendersi all'amore. Sopraffatto dalle sfide della partnership. Perdere terreno romantico."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "関係を守ることに疲れ果てた。愛をあきらめる。パートナーシップの課題に圧倒される。恋愛の立場を失う。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utslitt av å forsvare forholdet. Gi opp kjærligheten. Overveldet av partnerskapsutfordringer. Miste romantisk grunn."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wyczerpany bronieniem związku. Poddawanie się w miłości. Przytłoczony wyzwaniami partnerstwa. Tracenie romantycznego gruntu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Exausto de defender o relacionamento. Desistindo do amor. Sobrecarregado pelos desafios da parceria. Perdendo terreno romântico."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utmattad av att försvara relationen. Ge upp kärleken. Överväldigad av partnerskapsutmaningar. Förlora romantisk mark."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Виснажений захистом стосунків. Здатися в коханні. Перевантажений викликами партнерства. Втрата романтичних позицій."
          }
        }
      }
    },
    "interpretation.seven_of_wands_love_upright" : {
