        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Świętowanie zawodowe i harmonia w pracy. Osiągnięty kamień milowy kariery. Stabilność i wsparcie w pracy. Miejsce pracy czuje się jak w domu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Celebração profissional e harmonia no trabalho. Marco de carreira alcançado. Estabilidade e apoio no trabalho. Ambiente de trabalho parece um lar."
