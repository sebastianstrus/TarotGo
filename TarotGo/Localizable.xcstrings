        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Уникнення кар'єрного конфлікту або професійне вирішення. Співпраця на робочому місці. Робоча угода. Припинення непотрібної конкуренції."
          }
        }
      }
    },
