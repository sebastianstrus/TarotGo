        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "金銭的不安とお金の心配。リソースについての悪夢。財政への圧倒的な恐怖。あなたの心があなたを苦しめる。サポートを求めて。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk angst og pengebekymring. Mareritt om ressurser. Overveldende frykt for økonomi. Sinnet ditt plager deg. Søk støtte."
          }
        },
        "pl" : {
          "stringUnit" : {
