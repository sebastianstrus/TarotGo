      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Emotional blockage in love. You may be closing your heart due to past pain. Fear of vulnerability prevents new love from entering. Release old wounds to make space for new feelings."
          }
        }
      }
    },
    "interpretation.ace_of_cups_career_upright": {
