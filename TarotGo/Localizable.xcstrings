          "stringUnit" : {
            "state" : "translated",
            "value" : "Éxito en salud y reconocimiento del bienestar. Victoria física y logro corporal. Celebrando las victorias curativas. Vitalidad reconocida."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Succès en santé et reconnaissance du bien-être. Victoire physique et réalisation corporelle. Célébrer les victoires de guérison. Vitalité reconnue."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Successo nella salute e riconoscimento del benessere. Vittoria fisica e realizzazione corporea. Celebrare le vittorie della guarigione. Vitalità riconosciuta."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "健康の成功とウェルネスの認識。身体的な勝利と身体の達成。癒しの勝利を祝う。認められた活力。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Helsesuksess og velværeanerkjennelse. Fysisk seier og kroppsprestasjon. Feire helbredelsesserie. Anerkjent vitalitet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sukces zdrowotny i uznanie wellness. Fizyczne zwycięstwo i osiągnięcie ciała. Świętowanie zwycięstw uzdrawiania. Uznana witalność."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sucesso na saúde e reconhecimento do bem-estar. Vitória física e realização corporal. Celebrando as vitórias da cura. Vitalidade reconhecida."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hälsoframgång och välmående erkännande. Fysisk seger och kroppsprestation. Fira läkningssegrar. Erkänd vitalitet."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Успіх у здоров'ї та визнання благополуччя. Фізична перемога та досягнення тіла. Святкування перемог у зціленні. Визнана життєва сила."
          }
        }
      }
    },
    "interpretation.six_of_wands_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beziehungsversagen oder mangelnde romantische Anerkennung. Liebesarrogant oder partnerschaftlicher Egoismus. Private Herausforderungen trotz öffentlichem Auftreten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Relationship failure or lack of romantic recognition. Love arrogance or partnership egotism. Private challenges despite public appearance."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fracaso en la relación o falta de reconocimiento romántico. Arrogancia amorosa o egocentrismo en la pareja. Desafíos privados a pesar de la apariencia pública."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Échec relationnel ou manque de reconnaissance romantique. Arrogance amoureuse ou égocentrisme du partenariat. Défis privés malgré l'apparence publique."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fallimento della relazione o mancanza di riconoscimento romantico. Arroganza amorosa o egoismo nella partnership. Sfide private nonostante l'apparenza pubblica."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "関係の失敗や恋愛の認識不足。愛の傲慢さやパートナーシップの自己中心性。公の見かけにもかかわらず、私的な課題。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Forholdssvikt eller mangel på romantisk anerkjennelse. Kjærlighetsarroganse eller partnerskapsegoisme. Private utfordringer til tross for offentlig fremtoning."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niepowodzenie w związku lub brak romantycznego uznania. Arogancja miłosna lub egoizm w partnerstwie. Prywatne wyzwania pomimo publicznego wyglądu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fracasso no relacionamento ou falta de reconhecimento romântico. Arrogância amorosa ou egoísmo na parceria. Desafios privados apesar da aparência pública."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Relationsmisslyckande eller brist på romantisk erkännande. Kärleksarrogans eller partnerskapsegocentrism. Privata utmaningar trots offentligt utseende."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Невдача у стосунках або відсутність романтичного визнання. Зарозумілість у коханні або егоїзм у партнерстві. Приватні виклики, незважаючи на публічний вигляд."
          }
        }
      }
    },
    "interpretation.six_of_wands_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beziehungserfolg und romantische Anerkennung. Liebessieg und Partnerschaftserfolg. Öffentliche Anerkennung der Verbindung. Liebesserfolge feiern."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Relationship success and romantic recognition. Love victory and partnership achievement. Public acknowledgment of connection. Celebrating love wins."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Éxito en la relación y reconocimiento romántico. Victoria en el amor y logro en la pareja. Reconocimiento público de la conexión. Celebrando las victorias del amor."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Succès relationnel et reconnaissance romantique. Victoire amoureuse et réalisation du partenariat. Reconnaissance publique de la connexion. Célébrer les victoires de l'amour."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Successo nella relazione e riconoscimento romantico. Vittoria d'amore e realizzazione della partnership. Riconoscimento pubblico della connessione. Celebrare le vittorie dell'amore."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "関係の成功と恋愛の認識。愛の勝利とパートナーシップの達成。つながりの公的認知。愛の勝利を祝う。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Forholdssuksess og romantisk anerkjennelse. Kjærlighetsseier og partnerskapsprestasjon. Offentlig anerkjennelse av forbindelsen. Feire kjærlighetsseire."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sukces w związku i romantyczne uznanie. Zwycięstwo miłości i osiągnięcie w partnerstwie. Publiczne uznanie więzi. Świętowanie zwycięstw miłości."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sucesso no relacionamento e reconhecimento romântico. Vitória no amor e realização na parceria. Reconhecimento público da conexão. Celebrando as vitórias do amor."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Relationsframgång och romantisk erkännande. Kärleksseger och partnerskapsprestation. Offentligt erkännande av anslutningen. Fira kärlekssegrar."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Успіх у стосунках і романтичне визнання. Перемога в коханні та досягнення в партнерстві. Публічне визнання зв'язку. Святкування перемог у коханні."
          }
        }
      }
    },
    "interpretation.strength_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beruflicher Selbstzweifel oder Missbrauch von Macht. Du könntest zu aggressiv oder zu passiv sein. Verbinde dich wieder mit deiner inneren Stärke und deinem Selbstvertrauen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professional self-doubt or misuse of power. You might be too aggressive or too passive. Reconnect with your inner strength and confidence."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Duda profesional o abuso de poder. Puede que seas demasiado agresivo o demasiado pasivo. Reconecta con tu fuerza interior y confianza."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Doute professionnel ou abus de pouvoir. Vous êtes peut-être trop agressif ou trop passif. Renouez avec votre force intérieure et votre confiance."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dubbio professionale o abuso di potere. Potresti essere troppo aggressivo o troppo passivo. Riconnettiti con la tua forza interiore e fiducia."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "職業上の自信喪失または権力の乱用。あなたは攻撃的すぎるか、受動的すぎるかもしれません。内なる強さと自信と再びつながってください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profesjonell selvtvil eller maktmisbruk. Du kan være for aggressiv eller for passiv. Gjenopprett kontakten med din indre styrke og selvtillit."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zawodowe zwątpienie w siebie lub nadużywanie władzy. Możesz być zbyt agresywny lub zbyt pasywny. Połącz się ponownie ze swoją wewnętrzną siłą i pewnością siebie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dúvida profissional ou abuso de poder. Você pode ser agressivo demais ou passivo demais. Reconecte-se com sua força interior e confiança."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professionell självtvivel eller maktmissbruk. Du kan vara för aggressiv eller för passiv. Återknyt kontakten med din inre styrka och självförtroende."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Професійна невпевненість у собі або зловживання владою. Ви можете бути занадто агресивним або занадто пасивним. Возз'єднайтеся зі своєю внутрішньою силою та впевненістю."
          }
        }
      }
    },
    "interpretation.strength_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Innere Stärke und ruhiges Selbstvertrauen bringen beruflichen Erfolg. Deine Fähigkeit, Herausforderungen mit Anmut zu meistern, beeindruckt andere. Mut und Mitgefühl sind deine Superkräfte."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inner strength and quiet confidence bring professional success. Your ability to handle challenges with grace impresses others. Courage and compassion are your superpowers."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La fuerza interior y la confianza tranquila traen éxito profesional. Tu habilidad para manejar desafíos con gracia impresiona a los demás. El coraje y la compasión son tus superpoderes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La force intérieure et la confiance tranquille apportent le succès professionnel. Votre capacité à relever les défis avec grâce impressionne les autres. Le courage et la compassion sont vos super-pouvoirs."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La forza interiore e la fiducia tranquilla portano al successo professionale. La tua capacità di affrontare le sfide con grazia impressiona gli altri. Coraggio e compassione sono i tuoi superpoteri."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "内なる強さと穏やかな自信が職業上の成功をもたらします。優雅に課題を処理するあなたの能力は他の人に感銘を与えます。勇気と思いやりがあなたのスーパーパワーです。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Indre styrke og stille selvtillit gir profesjonell suksess. Din evne til å håndtere utfordringer med nåde imponerer andre. Mot og medfølelse er superkreftene dine."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wewnętrzna siła i cicha pewność siebie przynoszą sukces zawodowy. Twoja zdolność do radzenia sobie z wyzwaniami z wdziękiem imponuje innym. Odwaga i współczucie są twoimi supermocami."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Força interior e confiança tranquila trazem sucesso profissional. Sua capacidade de lidar com desafios com graça impressiona os outros. Coragem e compaixão são seus superpoderes."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inre styrka och tyst självförtroende ger professionell framgång. Din förmåga att hantera utmaningar med nåd imponerar på andra. Mod och medkänsla är dina superkrafter."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Внутрішня сила та тиха впевненість приносять професійний успіх. Ваша здатність вирішувати проблеми з гідністю вражає інших. Мужність і співчуття — ваші суперсили."
          }
        }
      }
    },
    "interpretation.strength_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Angst oder mangelnde Disziplin. Dir fehlt vielleicht das Selbstvertrauen in Geldangelegenheiten, oder du bist zu forsch. Finde deinen Kraftmittelpunkt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial fear or lack of discipline. You might lack confidence in money matters or be too forceful. Find your center of power."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Miedo financiero o falta de disciplina. Puede que te falte confianza en asuntos de dinero o seas demasiado agresivo. Encuentra tu centro de poder."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Peur financière ou manque de discipline. Vous manquez peut-être de confiance en matière d'argent ou êtes trop agressif. Trouvez votre centre de pouvoir."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Paura finanziaria o mancanza di disciplina. Potresti non avere fiducia in questioni di denaro o essere troppo energico. Trova il tuo centro di potere."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的な恐怖や規律の欠如。お金の問題に自信がないか、強引すぎるかもしれません。あなたの力の中心を見つけてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk frykt eller mangel på disiplin. Du mangler kanskje selvtillit i pengesaker eller er for aggressiv. Finn ditt maktsenter."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Strach finansowy lub brak dyscypliny. Może ci brakować pewności siebie w sprawach pieniężnych lub jesteś zbyt agresywny. Znajdź swoje centrum władzy."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Medo financeiro ou falta de disciplina. Você pode não ter confiança em questões de dinheiro ou ser agressivo demais. Encontre seu centro de poder."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomisk rädsla eller brist på disciplin. Du kanske saknar självförtroende i penningfrågor eller är för aggressiv. Hitta ditt kraftcentrum."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансовий страх або відсутність дисципліни. Вам може бракувати впевненості у фінансових питаннях, або ви занадто напористі. Знайдіть свій центр сили."
          }
        }
      }
    },
    "interpretation.strength_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzieller Mut und disziplinierte Zurückhaltung schaffen Erfolg. Du hast die innere Stärke, Versuchungen zu widerstehen und kluge Entscheidungen zu treffen. Geduld zahlt sich aus."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial courage and disciplined restraint create success. You have the inner strength to resist temptation and make wise choices. Patience pays off."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El valor financiero y la restricción disciplinada crean éxito. Tienes la fuerza interior para resistir la tentación y tomar decisiones sabias. La paciencia vale la pena."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le courage financier et la retenue disciplinée créent le succès. Vous avez la force intérieure de résister à la tentation et de faire des choix judicieux. La patience paie."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il coraggio finanziario e la disciplina creano successo. Hai la forza interiore per resistere alla tentazione e fare scelte sagge. La pazienza viene ripagata."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的な勇気と規律ある抑制が成功を生み出します。あなたには誘惑に抵抗し、賢明な選択をする内なる強さがあります。忍耐は報われます。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk mot og disiplinert tilbakeholdenhet skaper suksess. Du har den indre styrken til å motstå fristelser og ta kloke valg. Tålmodighet lønner seg."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odwaga finansowa i zdyscyplinowana powściągliwość tworzą sukces. Masz wewnętrzną siłę, by oprzeć się pokusie i podejmować mądre decyzje. Cierpliwość popłaca."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Coragem financeira e restrição disciplinada criam sucesso. Você tem força interior para resistir à tentação e fazer escolhas sábias. A paciência compensa."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomiskt mod och disciplinerad återhållsamhet skapar framgång. Du har den inre styrkan att motstå frestelser och göra kloka val. Tålamod lönar sig."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансова мужність і дисциплінована стриманість створюють успіх. У вас є внутрішня сила, щоб чинити опір спокусі та робити мудрий вибір. Терпіння винагороджується."
          }
        }
      }
    },
    "interpretation.strength_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Selbstzweifel, Schwäche oder Machtmissbrauch blockieren deinen Weg. Bist du zu forsch oder zu schüchtern? Verbinde dich wieder mit deinem inneren Mut."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Self-doubt, weakness, or misuse of power block your path. Are you being too forceful or too timid? Reconnect with your inner courage."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La duda, la debilidad o el abuso de poder bloquean tu camino. ¿Eres demasiado agresivo o demasiado tímido? Reconecta con tu coraje interior."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le doute de soi, la faiblesse ou l'abus de pouvoir bloquent votre chemin. Êtes-vous trop agressif ou trop timide ? Renouez avec votre courage intérieur."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il dubbio su se stessi, la debolezza o l'abuso di potere bloccano il tuo cammino. Sei troppo energico o troppo timido? Riconnettiti con il tuo coraggio interiore."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "自己不信、弱さ、または権力の乱用があなたの道を妨げます。あなたは強引すぎるのか、それとも臆病すぎるのか？内なる勇気と再びつながってください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Selvtvil, svakhet eller maktmisbruk blokkerer veien din. Er du for aggressiv eller for sjenert? Gjenopprett kontakten med ditt indre mot."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zwątpienie w siebie, słabość lub nadużywanie władzy blokują twoją ścieżkę. Czy jesteś zbyt agresywny czy zbyt nieśmiały? Połącz się ponownie ze swoją wewnętrzną odwagą."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Auto-dúvida, fraqueza ou abuso de poder bloqueiam seu caminho. Você é agressivo demais ou tímido demais? Reconecte-se com sua coragem interior."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Självtvivel, svaghet eller maktmissbruk blockerar din väg. Är du för aggressiv eller för blyg? Återknyt kontakten med ditt inre mod."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Невпевненість у собі, слабкість або зловживання владою блокують ваш шлях. Ви занадто агресивні чи занадто сором'язливі? Возз'єднайтеся зі своєю внутрішньою мужністю."
          }
        }
      }
    },
    "interpretation.strength_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Innere Stärke, Mut und Mitgefühl prägen diese Zeit. Du hast die Kraft, Herausforderungen durch sanfte Beharrlichkeit zu meistern. Selbstvertrauen ohne Arroganz."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inner strength, courage, and compassion define this time. You have the power to overcome challenges through gentle persistence. Confidence without arrogance."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La fuerza interior, el coraje y la compasión definen este momento. Tienes el poder de superar los desafíos a través de la persistencia suave. Confianza sin arrogancia."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La force intérieure, le courage et la compassion définissent cette période. Vous avez le pouvoir de surmonter les défis grâce à une persévérance douce. Confiance sans arrogance."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Forza interiore, coraggio e compassione definiscono questo momento. Hai il potere di superare le sfide attraverso una gentile persistenza. Fiducia senza arroganza."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "内なる強さ、勇気、思いやりがこの時期を定義します。優しい粘り強さによって課題を克服する力があなたにはあります。傲慢さのない自信。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Indre styrke, mot og medfølelse definerer denne tiden. Du har kraften til å overvinne utfordringer gjennom skånsom utholdenhet. Selvtillit uten arroganse."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wewnętrzna siła, odwaga i współczucie definiują ten czas. Masz moc, by pokonać wyzwania dzięki łagodnej wytrwałości. Pewność siebie bez arogancji."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Força interior, coragem e compaixão definem este momento. Você tem o poder de superar desafios através da persistência gentil. Confiança sem arrogância."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inre styrka, mod och medkänsla definierar denna tid. Du har kraften att övervinna utmaningar genom skonsam uthållighet. Självförtroende utan arrogans."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Внутрішня сила, мужність і співчуття визначають цей час. У вас є сила долати виклики за допомогою ніжної наполегливості. Впевненість без зарозумілості."
          }
        }
      }
    },
    "interpretation.strength_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gesundheitliche Rückschläge lösen Selbstzweifel aus. Du könntest dich zu sehr anstrengen oder nicht genug. Finde mitfühlende Disziplin dir selbst gegenüber."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Health setbacks trigger self-doubt. You might be pushing too hard or not hard enough. Find compassionate discipline with yourself."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los contratiempos de salud desencadenan dudas. Puede que te esfuerces demasiado o no lo suficiente. Encuentra una disciplina compasiva contigo mismo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les revers de santé déclenchent le doute de soi. Vous pourriez trop vous pousser ou pas assez. Trouvez une discipline compatissante envers vous-même."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gli insuccessi della salute innescano il dubbio su di te. Potresti spingerti troppo o non abbastanza. Trova una disciplina compassionevole verso te stesso."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "健康上の挫折が自己不信を引き起こします。あなたは頑張りすぎているか、十分に頑張っていないかもしれません。自分自身に対して思いやりのある規律を見つけてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Helsetilbakeslag utløser selvtvil. Du kan presse deg for hardt eller ikke hardt nok. Finn medfølende disiplin med deg selv."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niepowodzenia zdrowotne wyzwalają zwątpienie w siebie. Możesz naciskać zbyt mocno lub za słabo. Znajdź współczującą dyscyplinę wobec siebie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Contratempos de saúde desencadeiam dúvidas. Você pode estar se esforçando demais ou não o suficiente. Encontre disciplina compassiva consigo mesmo."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hälsomässiga bakslag utlöser självtvivel. Du kanske pressar dig för hårt eller inte tillräckligt. Hitta medkännande disciplin med dig själv."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Невдачі зі здоров'ям викликають невпевненість у собі. Ви можете занадто сильно тиснути на себе або недостатньо. Знайдіть співчутливу дисципліну по відношенню до себе."
          }
        }
      }
    },
    "interpretation.strength_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Innere Stärke überwindet gesundheitliche Herausforderungen. Dein Mut und deine sanfte Beharrlichkeit bei Wellness-Praktiken bringen Ergebnisse. Geist und Körper arbeiten zusammen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inner strength overcomes health challenges. Your courage and gentle persistence with wellness practices bring results. Mind and body work together."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La fuerza interior supera los desafíos de salud. Tu coraje y persistencia suave con las prácticas de bienestar traen resultados. La mente y el cuerpo trabajan juntos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La force intérieure surmonte les problèmes de santé. Votre courage et votre persévérance douce dans les pratiques de bien-être apportent des résultats. L'esprit et le corps travaillent ensemble."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La forza interiore supera le sfide della salute. Il tuo coraggio e la tua gentile persistenza nelle pratiche di benessere portano risultati. Mente e corpo lavorano insieme."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "内なる強さが健康上の課題を克服します。ウェルネス実践におけるあなたの勇気と優しい粘り強さが結果をもたらします。心と体が一緒に働きます。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Indre styrke overvinner helseutfordringer. Ditt mot og din skånsomme utholdenhet med velværepraksis gir resultater. Sinn og kropp jobber sammen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wewnętrzna siła pokonuje wyzwania zdrowotne. Twoja odwaga i łagodna wytrwałość w praktykach wellness przynoszą rezultaty. Umysł i ciało pracują razem."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Força interior supera desafios de saúde. Sua coragem e persistência gentil com práticas de bem-estar trazem resultados. Mente e corpo trabalham juntos."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inre styrka övervinner hälsoutmaningar. Ditt mod och din skonsamma uthållighet med välmåendepraktiker ger resultat. Sinne och kropp arbetar tillsammans."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Внутрішня сила долає проблеми зі здоров'ям. Ваша мужність і ніжна наполегливість в оздоровчих практиках приносять результати. Розум і тіло працюють разом."
          }
        }
      }
    },
    "interpretation.strength_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Selbstzweifel oder Unsicherheit schwächen Beziehungen. Du könntest zu forsch oder nicht durchsetzungsfähig genug sein. Finde deinen inneren Mut und die Balance."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Self-doubt or insecurity weakens relationships. You might be too forceful or not assertive enough. Find your inner courage and balance."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La duda o la inseguridad debilitan las relaciones. Puede que seas demasiado agresivo o no lo suficientemente asertivo. Encuentra tu coraje interior y equilibrio."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le doute de soi ou l'insécurité affaiblissent les relations. Vous êtes peut-être trop agressif ou pas assez affirmé. Trouvez votre courage intérieur et votre équilibre."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il dubbio su se stessi o l'insicurezza indeboliscono le relazioni. Potresti essere troppo energico o non abbastanza assertivo. Trova il tuo coraggio interiore e l'equilibrio."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "自己不信や不安が人間関係を弱めます。あなたは強引すぎるか、主張が足りないかもしれません。内なる勇気とバランスを見つけてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Selvtvil eller usikkerhet svekker relasjoner. Du kan være for kraftfull eller ikke selvsikker nok. Finn ditt indre mot og balanse."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zwątpienie w siebie lub niepewność osłabiają relacje. Możesz być zbyt agresywny lub nie dość asertywny. Znajdź swoją wewnętrzną odwagę i równowagę."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Auto-dúvida ou insegurança enfraquecem os relacionamentos. Você pode ser agressivo demais ou não assertivo o suficiente. Encontre sua coragem interior e equilíbrio."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Självtvivel eller osäkerhet försvagar relationer. Du kan vara för kraftfull eller inte tillräckligt assertiv. Hitta ditt inre mod och balans."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Невпевненість у собі або невпевненість послаблюють стосунки. Ви можете бути надто напористим або недостатньо впевненим. Знайдіть свою внутрішню мужність і рівновагу."
          }
        }
      }
    },
    "interpretation.strength_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mitfühlender Mut stärkt Beziehungen. Geduld, Verständnis und innere Stärke vertiefen die Liebe. Sanfte Kraft, nicht Gewalt, gewinnt Herzen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Compassionate courage strengthens relationships. Patience, understanding, and inner strength deepen love. Gentle power, not force, wins hearts."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El coraje compasivo fortalece las relaciones. La paciencia, la comprensión y la fuerza interior profundizan el amor. El poder suave, no la fuerza, gana corazones."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le courage compatissant renforce les relations. La patience, la compréhension et la force intérieure approfondissent l'amour. La puissance douce, non la force, gagne les cœurs."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il coraggio compassionevole rafforza le relazioni. Pazienza, comprensione e forza interiore approfondiscono l'amore. Il potere gentile, non la forza, conquista i cuori."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "思いやりのある勇気が人間関係を強化します。忍耐、理解、内なる強さが愛を深めます。力ではなく、優しい力が心をつかみます。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Medfølende mot styrker relasjoner. Tålmodighet, forståelse og indre styrke utdyper kjærligheten. Skånsom kraft, ikke makt, vinner hjerter."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Współczująca odwaga wzmacnia relacje. Cierpliwość, zrozumienie i siła wewnętrzna pogłębiają miłość. Łagodna siła, a nie przemoc, zdobywa serca."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Coragem compassiva fortalece relacionamentos. Paciência, compreensão e força interior aprofundam o amor. Poder gentil, não força, conquista corações."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Medkännande mod stärker relationer. Tålamod, förståelse och inre styrka fördjupar kärleken. Skonsam kraft, inte våld, vinner hjärtan."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Співчутлива мужність зміцнює стосунки. Терпіння, розуміння та внутрішня сила поглиблюють любов. Ніжна сила, а не насильство, підкорює серця."
          }
        }
      }
    },
    "interpretation.tapReveal" : {
