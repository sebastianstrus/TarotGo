        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Éviter l'introspection relationnelle ou un jugement sévère envers soi-même. Refus d'apprendre des schémas romantiques passés. Le doute de soi bloque la renaissance de l'amour."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Evitare l'autoriflessione relazionale o un duro auto-giudizio. Rifiuto di imparare dai modelli romantici passati. Il dubbio su se stessi blocca la rinascita dell'amore."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "関係の自己反省の回避や厳しい自己判断。過去の恋愛パターンから学ぶことを拒否する。自己不信が愛の再生を妨げます。"
          }
        },
        "nb" : {
          "stringUnit" : {
