    "interpretation.two_of_cups_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Berufliche Partnerschaften sind unausgeglichen oder angespannt. Mangel an gegenseitigem Respekt oder ungleicher Einsatz. Spannungen in Kooperationen müssen angegangen werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professional partnerships are unbalanced or strained. Lack of mutual respect or unequal effort. Tensions in collaborations need addressing."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las asociaciones profesionales están desequilibradas o tensas. Falta de respeto mutuo o esfuerzo desigual. Las tensiones en las colaboraciones deben abordarse."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les partenariats professionnels sont déséquilibrés ou tendus. Manque de respect mutuel ou effort inégal. Les tensions dans les collaborations doivent être résolues."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le partnership professionali sono sbilanciate o tese. Mancanza di rispetto reciproco o sforzo diseguale. Le tensioni nelle collaborazioni devono essere affrontate."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "プロフェッショナルなパートナーシップは不均衡または緊張しています。相互尊重の欠如や不平等な努力。コラボレーションの緊張に対処する必要があります。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profesjonelle partnerskap er ubalanserte eller anstrengte. Mangel på gjensidig respekt eller ulik innsats. Spenninger i samarbeid må adresseres."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Partnerstwa zawodowe są niezrównoważone lub napięte. Brak wzajemnego szacunku lub nierówny wysiłek. Napięcia we współpracy wymagają rozwiązania."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Parcerias profissionais estão desequilibradas ou tensas. Falta de respeito mútuo ou esforço desigual. Tensões nas colaborações precisam ser resolvidas."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professionella partnerskap är obalanserade eller ansträngda. Brist på ömsesidig respekt eller ojämn ansträngning. Spänningar i samarbeten måste hanteras."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Професійні партнерства незбалансовані або напружені. Відсутність взаємної поваги або нерівні зусилля. Напругу в співпраці потрібно вирішувати."
          }
        }
      }
    },
    "interpretation.two_of_cups_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erfolgreiche berufliche Partnerschaft oder Zusammenarbeit. Gegenseitiger Respekt und gemeinsame Ziele schaffen Harmonie. Diese Arbeitsbeziehung nützt beiden Parteien gleichermaßen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Successful professional partnership or collaboration. Mutual respect and shared goals create harmony. This working relationship benefits both parties equally."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Asociación o colaboración profesional exitosa. El respeto mutuo y los objetivos compartidos crean armonía. Esta relación laboral beneficia a ambas partes por igual."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Partenariat ou collaboration professionnelle réussi. Le respect mutuel et les objectifs partagés créent l'harmonie. Cette relation de travail profite également aux deux parties."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Partnership o collaborazione professionale di successo. Il rispetto reciproco e gli obiettivi condivisi creano armonia. Questo rapporto di lavoro avvantaggia entrambe le parti equamente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "成功したプロフェッショナルなパートナーシップやコラボレーション。相互尊重と共通の目標が調和を生み出します。この仕事上の関係は、双方に平等に利益をもたらします。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vellykket profesjonelt partnerskap eller samarbeid. Gjensidig respekt og felles mål skaper harmoni. Dette arbeidsforholdet kommer begge parter likt til gode."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Udane partnerstwo zawodowe lub współpraca. Wzajemny szacunek i wspólne cele tworzą harmonię. Ta relacja zawodowa przynosi korzyści obu stronom jednakowo."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Parceria ou colaboração profissional de sucesso. O respeito mútuo e os objetivos compartilhados criam harmonia. Este relacionamento de trabalho beneficia ambas as partes igualmente."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Framgångsrikt professionellt partnerskap eller samarbete. Ömsesidig respekt och delade mål skapar harmoni. Denna arbetsrelation gynnar båda parter lika."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Успішне професійне партнерство або співпраця. Взаємна повага та спільні цілі створюють гармонію. Ці робочі стосунки вигідні обом сторонам однаково."
          }
        }
      }
    },
    "interpretation.two_of_cups_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielles Ungleichgewicht in Partnerschaften. Eine Person gibt mehr als sie erhält. Geld schafft Spannungen in Beziehungen. Stelle Fairness bei gemeinsamen Ressourcen wieder her."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial imbalance in partnerships. One person gives more than receives. Money creates tension in relationships. Restore fairness in shared resources."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desequilibrio financiero en las asociaciones. Una persona da más de lo que recibe. El dinero crea tensión en las relaciones. Restablece la equidad en los recursos compartidos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Déséquilibre financier dans les partenariats. Une personne donne plus qu'elle ne reçoit. L'argent crée des tensions dans les relations. Rétablissez l'équité dans les ressources partagées."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Squilibrio finanziario nelle partnership. Una persona dà più di quanto riceve. Il denaro crea tensioni nelle relazioni. Ripristina l'equità nelle risorse condivise."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "パートナーシップにおける財政的不均衡。一方が受け取るよりも多く与えています。お金が人間関係に緊張を生み出します。共有リソースの公平性を回復しましょう。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk ubalanse i partnerskap. En person gir mer enn de mottar. Penger skaper spenninger i forhold. Gjenopprett rettferdighet i delte ressurser."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nierównowaga finansowa w partnerstwach. Jedna osoba daje więcej niż otrzymuje. Pieniądze powodują napięcia w związkach. Przywróć uczciwość we wspólnych zasobach."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desequilíbrio financeiro em parcerias. Uma pessoa dá mais do que recebe. O dinheiro cria tensão nos relacionamentos. Restaure a justiça nos recursos compartilhados."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomisk obalans i partnerskap. En person ger mer än de får. Pengar skapar spänningar i relationer. Återställ rättvisa i delade resurser."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансовий дисбаланс у партнерствах. Одна людина дає більше, ніж отримує. Гроші створюють напругу у стосунках. Відновіть справедливість у спільних ресурсах."
          }
        }
      }
    },
    "interpretation.two_of_cups_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Partnerschaften oder Vereinbarungen sind ausgewogen und fair. Gemeinsame Ressourcen arbeiten harmonisch zusammen. Gegenseitige finanzielle Ziele passen wunderbar zusammen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial partnerships or agreements are balanced and fair. Shared resources work harmoniously. Mutual financial goals align beautifully."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las asociaciones o acuerdos financieros son equilibrados y justos. Los recursos compartidos funcionan armoniosamente. Los objetivos financieros mutuos se alinean perfectamente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les partenariats ou accords financiers sont équilibrés et équitables. Les ressources partagées fonctionnent harmonieusement. Les objectifs financiers mutuels s'alignent parfaitement."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le partnership o gli accordi finanziari sono equilibrati ed equi. Le risorse condivise funzionano armoniosamente. Gli obiettivi finanziari reciproci si allineano perfettamente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "財政的なパートナーシップや合意はバランスが取れており公平です。共有されたリソースは調和的に機能します。相互の財政目標は美しく一致します。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomiske partnerskap eller avtaler er balanserte og rettferdige. Delte ressurser fungerer harmonisk. Gjensidige økonomiske mål stemmer vakkert overens."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Partnerstwa lub umowy finansowe są zrównoważone i uczciwe. Wspólne zasoby działają harmonijnie. Wzajemne cele finansowe pięknie się uzupełniają."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Parcerias ou acordos financeiros são equilibrados e justos. Recursos compartilhados funcionam harmoniosamente. Metas financeiras mútuas se alinham perfeitamente."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomiska partnerskap eller avtal är balanserade och rättvisa. Delade resurser fungerar harmoniskt. Ömsesidiga ekonomiska mål passar perfekt ihop."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансові партнерства або угоди є збалансованими та справедливими. Спільні ресурси працюють гармонійно. Взаємні фінансові цілі чудово узгоджуються."
          }
        }
      }
    },
    "interpretation.two_of_cups_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trennung, Ungleichgewicht oder zerbrochene Partnerschaften. Mangel an gegenseitigem Respekt oder Verständnis. Spannungen belasten die Beziehung. Stelle das Gleichgewicht wieder her oder erkenne, wann es Zeit ist loszulassen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Disconnection, imbalance, or broken partnerships. Lack of mutual respect or understanding. Tensions strain the relationship. Restore balance or recognize when to let go."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desconexión, desequilibrio o relaciones rotas. Falta de respeto mutuo o comprensión. Las tensiones tensan la relación. Restaura el equilibrio o reconoce cuándo es momento de soltar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Déconnexion, déséquilibre ou partenariats brisés. Manque de respect mutuel ou de compréhension. Les tensions pèsent sur la relation. Rétablissez l'équilibre ou sachez quand lâcher prise."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Disconnessione, squilibrio o partnership interrotte. Mancanza di rispetto reciproco o comprensione. Le tensioni mettono a dura prova la relazione. Ripristina l'equilibrio o riconosci quando è il momento di lasciar andare."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "断絶、不均衡、または壊れたパートナーシップ。相互尊重や理解の欠如。緊張が関係に負担をかけます。バランスを取り戻すか、手放す時を認識してください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fravær av kontakt, ubalanse eller ødelagte partnerskap. Mangel på gjensidig respekt eller forståelse. Spenninger belaster forholdet. Gjenopprett balanse eller kjenn når du skal slippe taket."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rozłączenie, brak równowagi lub zerwane partnerstwa. Brak wzajemnego szacunku lub zrozumienia. Napięcia obciążają związek. Przywróć równowagę lub rozpoznaj, kiedy odpuścić."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desconexão, desequilíbrio ou parcerias rompidas. Falta de respeito mútuo ou compreensão. Tensões prejudicam o relacionamento. Restaure o equilíbrio ou reconheça quando é hora de deixar ir."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Frånkoppling, obalans eller brutna partnerskap. Brist på ömsesidig respekt eller förståelse. Spänningar belastar relationen. Återställ balansen eller inse när det är dags att släppa taget."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Роз'єднання, дисбаланс або зруйновані партнерства. Відсутність взаємної поваги або розуміння. Напруга обтяжує стосунки. Відновіть баланс або визнайте, коли час відпустити."
          }
        }
      }
    },
    "interpretation.two_of_cups_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wunderschöne Partnerschaft und gegenseitige Verbindung. Ob romantisch, freundschaftlich oder beruflich – es geht um wahre Vereinigung. Balance, Respekt und gemeinsame Energie schaffen etwas Größeres als die Summe seiner Teile."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beautiful partnership and mutual connection. Whether romantic, friendship, or professional—this is about true union. Balance, respect, and shared energy create something greater than the sum of its parts."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hermosa asociación y conexión mutua. Ya sea romántica, de amistad o profesional, se trata de la unión verdadera. El equilibrio, el respeto y la energía compartida crean algo más grande que la suma de sus partes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beau partenariat et connexion mutuelle. Qu'il soit romantique, amical ou professionnel, il s'agit d'une véritable union. L'équilibre, le respect et l'énergie partagée créent quelque chose de plus grand que la somme de ses parties."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bellissima partnership e connessione reciproca. Che sia romantica, di amicizia o professionale, si tratta di vera unione. Equilibrio, rispetto ed energia condivisa creano qualcosa di più grande della somma delle sue parti."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "美しいパートナーシップと相互のつながり。恋愛、友情、ビジネスを問わず、これは真の結合についてです。バランス、尊重、共有されたエネルギーが、部分の合計以上の何かを生み出します。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vakkert partnerskap og gjensidig forbindelse. Enten det er romantisk, vennskapelig eller profesjonelt – dette handler om sann forening. Balanse, respekt og delt energi skaper noe større enn summen av delene."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Piękne partnerstwo i wzajemna więź. Niezależnie od tego, czy romantyczna, przyjacielska, czy zawodowa – chodzi o prawdziwe zjednoczenie. Równowaga, szacunek i wspólna energia tworzą coś większego niż suma jego części."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Linda parceria e conexão mútua. Seja romântica, de amizade ou profissional — isso é sobre união verdadeira. Equilíbrio, respeito e energia compartilhada criam algo maior do que a soma de suas partes."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vackert partnerskap och ömsesidig kontakt. Oavsett om det är romantiskt, vänskapligt eller professionellt – det handlar om sann förening. Balans, respekt och delad energi skapar något större än summan av dess delar."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Чудове партнерство та взаємний зв'язок. Будь то романтичний, дружній чи професійний – це про справжнє єднання. Баланс, повага та спільна енергія створюють щось більше, ніж сума її частин."
          }
        }
      }
    },
    "interpretation.two_of_cups_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Körper-Geist-Trennung oder unausgewogener Ansatz zur Gesundheit. Unterschiedliche Gesundheitsziele mit dem Partner. Notwendigkeit eines besseren Gleichgewichts im Wellness-Ansatz."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mind-body disconnection or imbalanced approach to health. Conflicting health goals with partner. Need for better balance in wellness approach."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desconexión mente-cuerpo o enfoque desequilibrado de la salud. Objetivos de salud conflictivos con la pareja. Necesidad de un mejor equilibrio en el enfoque de bienestar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Déconnexion corps-esprit ou approche déséquilibrée de la santé. Objectifs de santé conflictuels avec le partenaire. Nécessité d'un meilleur équilibre dans l'approche du bien-être."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Disconnessione mente-corpo o approccio squilibrato alla salute. Obiettivi di salute in conflitto con il partner. Necessità di un migliore equilibrio nell'approccio al benessere."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "心身の断絶または健康への不均衡なアプローチ。パートナーとの健康目標の対立。ウェルネスアプローチにおけるより良いバランスの必要性。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kropp-sinn-frakobling eller ubalansert tilnærming til helse. Motstridende helsemål med partner. Behov for bedre balanse i velværetilnærmingen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rozłączenie umysł-ciało lub niezrównoważone podejście do zdrowia. Sprzeczne cele zdrowotne z partnerem. Potrzeba lepszej równowagi w podejściu do dobrego samopoczucia."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desconexão mente-corpo ou abordagem desequilibrada para a saúde. Objetivos de saúde conflitantes com o parceiro. Necessidade de melhor equilíbrio na abordagem de bem-estar."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kropp-sinne-frånkoppling eller obalanserad syn på hälsa. Motstridiga hälsomål med partner. Behov av bättre balans i välbefinnandeansatsen."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Роз'єднання розуму та тіла або незбалансований підхід до здоров'я. Суперечливі цілі щодо здоров'я з партнером. Потреба в кращому балансі в оздоровчому підході."
          }
        }
      }
    },
    "interpretation.two_of_cups_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Verbindung von Geist und Körper wird gestärkt. Emotionale und körperliche Gesundheit sind im Einklang. Partnerschaft oder Unterstützung auf deinem Gesundheitsweg nützt dir sehr."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mind-body connection strengthens. Emotional and physical health are in harmony. Partnership or support in your health journey benefits you greatly."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La conexión mente-cuerpo se fortalece. La salud emocional y física están en armonía. La asociación o el apoyo en tu viaje de salud te beneficia enormemente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La connexion corps-esprit se renforce. La santé émotionnelle et physique sont en harmonie. Le partenariat ou le soutien dans votre parcours de santé vous est très bénéfique."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La connessione mente-corpo si rafforza. La salute emotiva e fisica sono in armonia. Il supporto o la partnership nel tuo percorso di salute ti avvantaggia notevolmente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "心と体のつながりが強化されます。感情的および身体的健康が調和しています。あなたの健康の旅におけるパートナーシップやサポートは大きな利益をもたらします。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kropp-sinn-forbindelsen styrkes. Emosjonell og fysisk helse er i harmoni. Partnerskap eller støtte i helsereisen din er til stor nytte for deg."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Połączenie umysł-ciało się wzmacnia. Zdrowie emocjonalne i fizyczne są w harmonii. Partnerstwo lub wsparcie w twojej podróży zdrowotnej bardzo ci pomaga."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A conexão mente-corpo se fortalece. A saúde emocional e física estão em harmonia. Parceria ou apoio em sua jornada de saúde beneficia você enormemente."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kropp-sinne-kopplingen stärks. Emotionell och fysisk hälsa är i harmoni. Partnerskap eller stöd i din hälsoresa gynnar dig mycket."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Зв'язок розуму та тіла зміцнюється. Емоційне та фізичне здоров'я в гармонії. Партнерство або підтримка у вашій оздоровчій подорожі приносять велику користь."
          }
        }
      }
    },
    "interpretation.two_of_cups_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trennung oder Ungleichgewicht in der Partnerschaft. Eine Person könnte mehr investiert sein als die andere. Kommunikation bricht zusammen. Arbeite daran, das Gleichgewicht wiederherzustellen oder überlege, ob das richtig ist."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Disconnection or imbalance in partnership. One person may be more invested than the other. Communication breaks down. Work to restore balance or consider if this is right."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desconexión o desequilibrio en la pareja. Una persona puede estar más involucrada que la otra. La comunicación se rompe. Trabaja para restaurar el equilibrio o considera si esto es correcto."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Déconnexion ou déséquilibre dans le partenariat. Une personne peut être plus investie que l'autre. La communication s'effondre. Travaillez à rétablir l'équilibre ou réfléchissez si c'est juste."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Disconnessione o squilibrio nella partnership. Una persona potrebbe essere più investita dell'altra. La comunicazione si interrompe. Lavora per ripristinare l'equilibrio o considera se è giusto."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "パートナーシップにおける断絶や不均衡。一方が他方よりも多くの投資をしているかもしれません。コミュニケーションが途絶えます。バランスを回復するか、これが正しいかどうかを検討してください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ubalanse eller ubalanse i partnerskap. En person kan være mer investert enn den andre. Kommunikasjon bryter sammen. Arbeid for å gjenopprette balanse eller vurder om dette er riktig."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rozłączenie lub brak równowagi w partnerstwie. Jedna osoba może być bardziej zaangażowana niż druga. Komunikacja się załamuje. Pracuj nad przywróceniem równowagi lub zastanów się, czy to jest właściwe."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desconexão ou desequilíbrio na parceria. Uma pessoa pode estar mais investida do que a outra. A comunicação se desfaz. Trabalhe para restaurar o equilíbrio ou considere se isso é certo."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Frånkoppling eller obalans i partnerskapet. En person kan vara mer investerad än den andra. Kommunikationen bryter samman. Arbeta för att återställa balansen eller överväg om detta är rätt."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Роз'єднання або дисбаланс у партнерстві. Одна людина може бути більш зацікавленою, ніж інша. Спілкування руйнується. Попрацюйте над відновленням балансу або подумайте, чи це правильно."
          }
        }
      }
    },
    "interpretation.two_of_cups_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tiefe gegenseitige Verbindung und Partnerschaft. Es geht um wahre Vereinigung – ausgeglichen, harmonisch und gegenseitig erfüllend. Ob neu oder etabliert, diese Beziehung hat echtes Potenzial."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deep mutual connection and partnership. This is about true union—balanced, harmonious, and mutually fulfilling. Whether new or established, this relationship has real potential."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conexión mutua profunda y asociación. Se trata de la unión verdadera: equilibrada, armoniosa y mutuamente satisfactoria. Ya sea nueva o establecida, esta relación tiene un potencial real."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Connexion mutuelle profonde et partenariat. Il s'agit d'une véritable union - équilibrée, harmonieuse et mutuellement épanouissante. Nouvelle ou établie, cette relation a un réel potentiel."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profonda connessione reciproca e partnership. Si tratta di una vera unione: equilibrata, armoniosa e reciprocamente soddisfacente. Che sia nuova o consolidata, questa relazione ha un vero potenziale."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "深い相互のつながりとパートナーシップ。真の結合—バランスが取れ、調和し、互いに満たし合うことです。新しい関係であれ、長く続く関係であれ、この関係には本当の可能性があります。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dyp gjensidig forbindelse og partnerskap. Dette handler om sann forening – balansert, harmonisk og gjensidig tilfredsstillende. Enten det er nytt eller etablert, har dette forholdet reelt potensial."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Głęboka wzajemna więź i partnerstwo. Chodzi o prawdziwe zjednoczenie – zrównoważone, harmonijne i wzajemnie satysfakcjonujące. Niezależnie od tego, czy nowy, czy ugruntowany, ten związek ma realny potencjał."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conexão mútua profunda e parceria. Isso é sobre união verdadeira — equilibrada, harmoniosa e mutuamente satisfatória. Seja nova ou estabelecida, este relacionamento tem potencial real."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Djup ömsesidig kontakt och partnerskap. Det handlar om sann förening – balanserad, harmonisk och ömsesidigt tillfredsställande. Oavsett om det är nytt eller etablerat, har detta förhållande verklig potential."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Глибокий взаємний зв'язок і партнерство. Це про справжнє єднання – збалансоване, гармонійне та взаємозадовільне. Нові чи вже існуючі, ці стосунки мають реальний потенціал."
          }
        }
      }
    },
    "interpretation.two_of_pentacles_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Berufliche Überforderung und Ungleichgewicht. Zu viele Arbeitsverantwortlichkeiten. Desorganisation beeinträchtigt die Karriere. Stress durch zu viel Jonglieren. Prioritäten setzen ist nötig."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professional overwhelm and imbalance. Too many work responsibilities. Disorganization affects career. Stress from juggling too much. Need to prioritize."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ago bio profesional y desequilibrio. Demasiadas responsabilidades laborales. La desorganización afecta la carrera. Estrés por tener que hacer malabares con demasiadas cosas. Necesitas priorizar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Accablement professionnel et déséquilibre. Trop de responsabilités professionnelles. La désorganisation affecte la carrière. Stress dû à la gestion de trop de choses. Besoin de prioriser."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sovraccarico professionale e squilibrio. Troppe responsabilità lavorative. La disorganizzazione influisce sulla carriera. Stress dovuto al destreggiarsi tra troppe cose. Necessità di dare priorità."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "仕事上の圧倒と不均衡。あまりにも多くの仕事上の責任。無秩序がキャリアに影響。多すぎることをこなすストレス。優先順位を決める必要がある。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profesjonell overveldelse og ubalanse. For mange arbeidsoppgaver. Desorganisering påvirker karrieren. Stress av å balansere for mye. Må prioritere."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zawodowe przytłoczenie i nierównowaga. Zbyt wiele obowiązków służbowych. Dezorganizacja wpływa na karierę. Stres związany z żonglowaniem zbyt wieloma rzeczami. Potrzeba ustalenia priorytetów."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sobrecarga profissional e desequilíbrio. Muitas responsabilidades de trabalho. Desorganização afeta a carreira. Estresse por conciliar muitas coisas. Precisa priorizar."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professionell överväldigande och obalans. För många arbetsuppgifter. Desorganisation påverkar karriären. Stress av att balansera för mycket. Behöver prioritera."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Професійне перевантаження та дисбаланс. Занадто багато робочих обов'язків. Дезорганізація впливає на кар'єру. Стрес через балансування з багатьма речами. Потрібно визначити пріоритети."
          }
        }
      }
    },
    "interpretation.two_of_pentacles_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erfolgreiche Bewältigung mehrerer beruflicher Verantwortlichkeiten. Anpassungsfähigkeit dient Ihrer Karriere. Flexibler Umgang mit beruflichen Herausforderungen. Sie jonglieren und haben Erfolg."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Successfully managing multiple professional responsibilities. Adaptability serves your career well. Flexible approach to work challenges. You're juggling and succeeding."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manejando con éxito múltiples responsabilidades profesionales. La adaptabilidad beneficia tu carrera. Enfoque flexible ante los desafíos laborales. Estás haciendo malabares y teniendo éxito."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gérer avec succès de multiples responsabilités professionnelles. L'adaptabilité sert bien votre carrière. Approche flexible face aux défis professionnels. Vous jonglez et réussissez."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gestire con successo molteplici responsabilità professionali. L'adattabilità serve bene la tua carriera. Approccio flessibile alle sfide lavorative. Stai destreggiandoti e riuscendoci."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "複数の職業上の責任をうまく管理する。適応性がキャリアに役立つ。仕事の課題に対する柔軟なアプローチ。うまくこなし、成功している。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Håndtere flere profesjonelle ansvarsområder suksessfullt. Tilpasningsevne tjener karrieren din godt. Fleksibel tilnærming til jobbutfordringer. Du balanserer og lykkes."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Z powodzeniem zarządzanie wieloma obowiązkami zawodowymi. Zdolność adaptacji służy Twojej karierze. Elastyczne podejście do wyzwań w pracy. Żonglujesz i odnosisz sukcesy."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gerenciando com sucesso múltiplas responsabilidades profissionais. Adaptabilidade serve bem à sua carreira. Abordagem flexível aos desafios do trabalho. Você está conciliando e tendo sucesso."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hantera flera professionella ansvarsområden framgångsrikt. Anpassningsförmåga tjänar din karriär väl. Flexibelt förhållningssätt till arbetsutmaningar. Du balanserar och lyckas."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Успішне управління багатьма професійними обов'язками. Адаптивність добре служить вашій кар'єрі. Гнучкий підхід до робочих викликів. Ви балансуєте і досягаєте успіху."
          }
        }
      }
    },
    "interpretation.two_of_pentacles_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielles Ungleichgewicht und Überforderung. Erfolgloses Jonglieren mit zu vielen finanziellen Anforderungen. Unorganisierte Finanzen verursachen Stress. Besseres Budget und Prioritäten nötig."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial imbalance and overwhelm. Juggling too many money demands unsuccessfully. Disorganized finances create stress. Need better budget and priorities."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desequilibrio y agobio financiero. Manejando sin éxito demasiadas demandas económicas. Las finanzas desorganizadas generan estrés. Necesitas un mejor presupuesto y prioridades."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Déséquilibre financier et accablement. Gérer sans succès trop d'exigences financières. Des finances désorganisées créent du stress. Un meilleur budget et des priorités sont nécessaires."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Squilibrio finanziario e sovraccarico. Destreggiarsi senza successo tra troppe richieste di denaro. Finanze disorganizzate creano stress. Necessario un budget migliore e priorità."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的不均衡と圧倒。あまりにも多くの金銭的要求をうまく処理できない。無秩序な財務がストレスを生む。より良い予算と優先順位が必要。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk ubalanse og overveldelse. Håndtere for mange pengekrav uten hell. Uorganisert økonomi skaper stress. Trenger bedre budsjett og prioriteringer."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nierównowaga finansowa i przytłoczenie. Nieudane żonglowanie zbyt wieloma wymaganiami pieniężnymi. Niezorganizowane finanse powodują stres. Potrzeba lepszego budżetu i priorytetów."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desequilíbrio financeiro e sobrecarga. Conciliando muitas demandas financeiras sem sucesso. Finanças desorganizadas criam estresse. Melhor orçamento e prioridades necessários."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomisk obalans och överväldigande. Hantera för många ekonomiska krav utan framgång. Oorganiserad ekonomi skapar stress. Behöver bättre budget och prioriteringar."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансовий дисбаланс та перевантаження. Невдале балансування з багатьма грошовими вимогами. Неорганізовані фінанси створюють стрес. Потрібен кращий бюджет та пріоритети."
          }
        }
      }
    },
    "interpretation.two_of_pentacles_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erfolgreicher Ausgleich finanzieller Anforderungen. Flexibles Geldmanagement nützt Ihnen. Geschickter Umgang mit Ressourcen. Anpassungsfähiger Ansatz für finanzielle Herausforderungen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Successfully balancing financial demands. Flexible money management serves you. Juggling resources wisely. Adaptable approach to financial challenges."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Equilibrando con éxito las demandas financieras. Una gestión financiera flexible te beneficia. Manejando los recursos con sabiduría. Enfoque adaptable a los desafíos financieros."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Équilibrer avec succès les demandes financières. Une gestion financière flexible vous sert. Gérer les ressources avec sagesse. Approche adaptable aux défis financiers."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bilanciare con successo le richieste finanziarie. Una gestione flessibile del denaro ti serve. Gestire le risorse con saggezza. Approccio adattabile alle sfide finanziarie."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的な要求をうまくバランスさせる。柔軟な資金管理が役立つ。リソースを賢くやりくりする。経済的課題への適応的アプローチ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Balansere økonomiske krav suksessfullt. Fleksibel pengeforvaltning tjener deg. Håndtere ressurser klokt. Tilpasningsdyktig tilnærming til økonomiske utfordringer."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Z powodzeniem równoważenie wymagań finansowych. Elastyczne zarządzanie pieniędzmi służy Ci. Mądre żonglowanie zasobami. Adaptacyjne podejście do wyzwań finansowych."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Equilibrando com sucesso as demandas financeiras. Gestão de dinheiro flexível serve a você. Conciliando recursos com sabedoria. Abordagem adaptável aos desafios financeiros."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Balansera ekonomiska krav framgångsrikt. Flexibel pengehantering tjänar dig. Hantera resurser klokt. Anpassningsbart förhållningssätt till ekonomiska utmaningar."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Успішне балансування фінансових вимог. Гнучке управління грошима служить вам. Мудре балансування ресурсами. Адаптивний підхід до фінансових викликів."
          }
        }
      }
    },
    "interpretation.two_of_pentacles_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ungleichgewicht, Überforderung und zu viel Jonglieren. Sie lassen Dinge fallen und sind gestresst. Desorganisation schafft Chaos. Zeit, Prioritäten zu setzen und einige Dinge loszulassen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Imbalance, overwhelm, and too much juggling. You're dropping balls and feeling stressed. Disorganization creates chaos. Time to prioritize and let some things go."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desequilibrio, agobio y demasiados malabares. Estás dejando caer cosas y sintiéndote estresado. La desorganización crea caos. Es momento de priorizar y dejar ir algunas cosas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Déséquilibre, accablement et trop de jonglerie. Vous laissez tomber des choses et vous êtes stressé. La désorganisation crée le chaos. Il est temps de prioriser et de lâcher prise sur certaines choses."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Squilibrio, sovraccarico e troppi impegni. Stai lasciando cadere le cose e ti senti stressato. La disorganizzazione crea caos. È tempo di dare priorità e lasciare andare alcune cose."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "不均衡、圧倒、あまりにも多くのことをこなす。物事を落とし、ストレスを感じている。無秩序が混乱を生む。優先順位を決め、いくつかのことを手放す時。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ubalanse, overveldelse og for mye balansering. Du mister baller og føler deg stresset. Desorganisering skaper kaos. På tide å prioritere og gi slipp på noen ting."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nierównowaga, przytłoczenie i zbyt wiele żonglowania. Upuszczasz piłeczki i czujesz się zestresowany. Dezorganizacja tworzy chaos. Czas ustalić priorytety i odpuścić niektóre rzeczy."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desequilíbrio, sobrecarga e muita conciliação. Você está deixando as coisas caírem e se sentindo estressado. A desorganização cria caos. Hora de priorizar e deixar algumas coisas de lado."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Obalans, överväldigande och för mycket balanserande. Du tappar bollar och känner dig stressad. Desorganisation skapar kaos. Dags att prioritera och släppa taget om vissa saker."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Дисбаланс, перевантаження та надто багато балансування. Ви впускаєте м'ячі та відчуваєте стрес. Дезорганізація створює хаос. Час визначити пріоритети та відпустити деякі речі."
          }
        }
      }
    },
    "interpretation.two_of_pentacles_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gleichgewicht, Anpassungsfähigkeit und erfolgreiches Jonglieren von Prioritäten. Sie bewältigen mehrere Anforderungen mit Anmut und Flexibilität. Das Leben ist hektisch, aber Sie kommen gut damit zurecht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Balance, adaptability, and juggling priorities successfully. You're managing multiple demands with grace and flexibility. Life is busy but you're handling it well."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Equilibrio, adaptabilidad y manejo exitoso de prioridades. Estás gestionando múltiples demandas con gracia y flexibilidad. La vida es ajetreada pero la estás llevando bien."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Équilibre, adaptabilité et gestion réussie des priorités. Vous gérez de multiples demandes avec grâce et flexibilité. La vie est mouvementée mais vous la gérez bien."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Equilibrio, adattabilità e gestione riuscita delle priorità. Stai gestendo molteplici richieste con grazia e flessibilità. La vita è frenetica ma la stai gestendo bene."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "バランス、適応性、優先事項のうまいやりくり。複数の要求を優雅に柔軟に管理している。生活は忙しいがうまく対処している。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Balans, tilpasningsevne og vellykket balansering av prioriteringer. Du håndterer flere krav med eleganse og fleksibilitet. Livet er travelt, men du håndterer det godt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Równowaga, zdolność adaptacji i skuteczne żonglowanie priorytetami. Zarządzasz wieloma wymaganiami z gracją i elastycznością. Życie jest zabiegane, ale dobrze sobie z nim radzisz."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Equilíbrio, adaptabilidade e conciliação bem-sucedida de prioridades. Você está gerenciando múltiplas demandas com graça e flexibilidade. A vida é agitada, mas você está lidando bem."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Balans, anpassningsförmåga och framgångsrik hantering av prioriteringar. Du hanterar flera krav med nåd och flexibilitet. Livet är hektiskt men du hanterar det bra."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Баланс, адаптивність та успішне балансування пріоритетів. Ви керуєте багатьма вимогами з грацією та гнучкістю. Життя напружене, але ви добре з ним справляєтеся."
          }
        }
      }
    },
    "interpretation.two_of_pentacles_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Gesundheit leidet unter dem Ungleichgewicht des Lebens. Zu überfordert, um sich um den Körper zu kümmern. Stress durch das Jonglieren von allem beeinträchtigt das Wohlbefinden. Selbstfürsorge muss priorisiert werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Health suffers from life imbalance. Too overwhelmed to care for body. Stress from juggling everything affects wellness. Need to prioritize self-care."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La salud sufre por el desequilibrio vital. Demasiado abrumado para cuidar el cuerpo. El estrés por tener que hacer malabares con todo afecta el bienestar. Necesitas priorizar el cuidado personal."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La santé souffre du déséquilibre de la vie. Trop dépassé pour prendre soin du corps. Le stress dû à la gestion de tout affecte le bien-être. Besoin de prioriser les soins personnels."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La salute soffre per lo squilibrio della vita. Troppo sopraffatto per prendersi cura del corpo. Lo stress del destreggiarsi tra tutto influisce sul benessere. Necessità di dare priorità alla cura di sé."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "生活の不均衡から健康が損なわれる。体のケアができるほど圧倒されすぎている。すべてをこなすストレスが健康に影響。セルフケアを優先する必要がある。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Helsen lider under livsubalanse. For overveldet til å ta vare på kroppen. Stress fra å balansere alt påvirker velvære. Må prioritere egenomsorg."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zdrowie cierpi z powodu braku równowagi życiowej. Zbyt przytłoczony, aby dbać o ciało. Stres związany z żonglowaniem wszystkim wpływa na samopoczucie. Potrzeba priorytetowego traktowania dbania o siebie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A saúde sofre com o desequilíbrio da vida. Muito sobrecarregado para cuidar do corpo. O estresse de conciliar tudo afeta o bem-estar. Precisa priorizar o autocuidado."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hälsan lider av livets obalans. För överväldigad för att ta hand om kroppen. Stress av att balansera allt påverkar välbefinnandet. Behöver prioritera egenvård."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Здоров'я страждає від життєвого дисбалансу. Занадто перевантажений, щоб піклуватися про тіло. Стрес від балансування всього впливає на благополуччя. Потрібно пріоритезувати турботу про себе."
          }
        }
      }
    },
    "interpretation.two_of_pentacles_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erfolgreicher Ausgleich zwischen Gesundheit und Lebensanforderungen. Flexibler Wellness-Ansatz funktioniert. Körperliche Bedürfnisse trotz hektischem Leben managen. Anpassungsfähigkeit unterstützt das Wohlbefinden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Successfully balancing health with life demands. Flexible wellness approach works. Managing physical needs despite busy life. Adaptability supports wellbeing."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Equilibrando con éxito la salud con las demandas de la vida. Un enfoque flexible de bienestar funciona. Manejando las necesidades físicas a pesar de una vida ajetreada. La adaptabilidad apoya el bienestar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Équilibrer avec succès la santé avec les exigences de la vie. Une approche flexible du bien-être fonctionne. Gérer les besoins physiques malgré une vie bien remplie. L'adaptabilité soutient le bien-être."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bilanciare con successo la salute con le esigenze della vita. Un approccio flessibile al benessere funziona. Gestire i bisogni fisici nonostante la vita frenetica. L'adattabilità supporta il benessere."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "健康と生活の要求をうまくバランスさせる。柔軟なウェルネスアプローチが機能する。忙しい生活にもかかわらず身体のニーズを管理する。適応性が健康をサポートする。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Balansere helse med livskrav på en god måte. Fleksibel velværetilnærming fungerer. Håndtere fysiske behov til tross for travel hverdag. Tilpasningsevne støtter velvære."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Z powodzeniem równoważenie zdrowia z wymaganiami życia. Elastyczne podejście do wellness działa. Zarządzanie potrzebami fizycznymi pomimo zabieganego życia. Zdolność adaptacji wspiera dobre samopoczucie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Equilibrando com sucesso a saúde com as demandas da vida. Abordagem flexível de bem-estar funciona. Gerenciando as necessidades físicas apesar da vida agitada. Adaptabilidade apoia o bem-estar."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Balansera hälsa med livskrav framgångsrikt. Flexibelt hälso- och välmående tillvägagångssätt fungerar. Hantera fysiska behov trots hektiskt liv. Anpassningsförmåga stödjer välbefinnandet."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Успішне балансування здоров'я з життєвими вимогами. Гнучкий оздоровчий підхід працює. Управління фізичними потребами, незважаючи на напружене життя. Адаптивність підтримує благополуччя."
          }
        }
      }
    },
    "interpretation.two_of_pentacles_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ungleichgewicht in der Beziehung aufgrund der Anforderungen des Lebens. Zu viele Verantwortlichkeiten belasten die Liebe. Überfordert durch das Jonglieren von Partnerschaft und allem anderen. Etwas muss nachgeben."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Relationship imbalance due to life demands. Too many responsibilities strain love. Overwhelmed by juggling partnership and everything else. Something must give."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desequilibrio en la relación debido a las exigencias de la vida. Demasiadas responsabilidades tensionan el amor. Abrumado por tener que compaginar la sociedad con todo lo demás. Algo tiene que ceder."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Déséquilibre relationnel dû aux exigences de la vie. Trop de responsabilités pèsent sur l'amour. Dépassé par la gestion du partenariat et de tout le reste. Quelque chose doit céder."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Squilibrio nella relazione a causa delle esigenze della vita. Troppe responsabilità mettono a dura prova l'amore. Sopraffatto dal destreggiarsi tra partnership e tutto il resto. Qualcosa deve cedere."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "生活の要求による関係の不均衡。あまりにも多くの責任が愛を圧迫する。パートナーシップとその他すべての両立に圧倒される。何かが壊れなければならない。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ubalanse i forholdet på grunn av livskrav. For mange ansvarsområder belaster kjærligheten. Overveldet av å balansere partnerskap og alt annet. Noe må vike."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nierównowaga w związku z powodu wymagań życiowych. Zbyt wiele obowiązków obciąża miłość. Przytłoczony żonglowaniem partnerstwem i wszystkim innym. Coś musi ustąpić."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desequilíbrio no relacionamento devido às demandas da vida. Muitas responsabilidades sobrecarregam o amor. Sobrecarregado por conciliar parceria e tudo o mais. Algo precisa ceder."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ob balans i relationen på grund av livskrav. För många ansvarsområden belastar kärleken. Överväldigad av att balansera partnerskapet och allt annat. Något måste ge vika."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Дисбаланс у стосунках через життєві вимоги. Занадто багато обов'язків обтяжують любов. Перевантаженість поєднанням партнерства та всього іншого. Щось має поступитися."
          }
        }
      }
    },
    "interpretation.two_of_pentacles_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beziehung mit anderen Lebensanforderungen in Einklang bringen. Liebe und Verantwortlichkeiten erfolgreich unter einen Hut bringen. Anpassungsfähigkeit in der Partnerschaft. Romantik trotz Hektik am Leben erhalten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Balancing relationship with other life demands. Juggling love and responsibilities successfully. Adaptability in partnership. Keeping romance alive despite busyness."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Equilibrando la relación con otras demandas de la vida. Manejando el amor y las responsabilidades con éxito. Adaptabilidad en la sociedad. Manteniendo viva la pasión a pesar del ajetreo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Équilibrer la relation avec les autres exigences de la vie. Gérer l'amour et les responsabilités avec succès. Adaptabilité dans le partenariat. Garder la romance vivante malgré l'agitation."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bilanciare la relazione con le altre esigenze della vita. Gestire con successo amore e responsabilità. Adattabilità nella partnership. Mantenere viva la passione nonostante il trambusto."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "関係性と他の生活の要求のバランスを取る。愛と責任をうまく両立させる。パートナーシップにおける適応性。忙しさにもかかわらずロマンスを維持する。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Balansere forholdet med andre livskrav. Håndtere kjærlighet og ansvar suksessfullt. Tilpasningsevne i partnerskap. Holde romantikken i live til tross for hektisk hverdag."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Równoważenie związku z innymi wymaganiami życiowymi. Z powodzeniem żonglowanie miłością i obowiązkami. Zdolność adaptacji w partnerstwie. Utrzymywanie romantyzmu przy życiu pomimo zabiegania."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Equilibrando o relacionamento com outras demandas da vida. Conciliando amor e responsabilidades com sucesso. Adaptabilidade na parceria. Mantendo o romance vivo apesar da correria."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Balansera relationen med andra livskrav. Hantera kärlek och ansvar framgångsrikt. Anpassningsförmåga i partnerskapet. Hålla romantiken vid liv trots hektisk tillvaro."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Балансування стосунків з іншими життєвими вимогами. Успішне поєднання любові та обов'язків. Адаптивність у партнерстві. Збереження романтики, незважаючи на метушню."
          }
        }
      }
    },
    "interpretation.two_of_swords_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriere-Unentschlossenheit verschlimmert sich oder beruflicher Stillstand bricht. Verzögerte Arbeitsentscheidungen oder endlich kommt der Durchbruch. Wähle den Weg nach vorne."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Career indecision worsens or professional stalemate breaks. Delayed work decisions or breakthrough finally comes. Choose path forward."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La indecisión profesional empeora o se rompe el estancamiento profesional. Decisiones laborales retrasadas o finalmente llega el avance. Elige el camino a seguir."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'indécision professionnelle s'aggrave ou l'impasse professionnelle se brise. Décisions de travail retardées ou percée enfin. Choisissez la voie à suivre."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'indecisione sulla carriera peggiora o lo stallo professionale si rompe. Decisioni lavorative ritardate o finalmente arriva la svolta. Scegli la strada da seguire."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャリアの優柔不断が悪化するか、仕事上の膠着状態が打破される。遅れた仕事の決断、またはついにブレイクスルーが訪れる。前進する道を選べ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriere-ubesluttsomhet forverres eller profesjonell stagnasjon bryter. Forsinkede jobbbeslutninger eller gjennombrudd kommer endelig. Velg veien videre."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niezdecydowanie zawodowe się pogłębia lub zawodowy zastój zostaje przełamany. Opóźnione decyzje zawodowe lub wreszcie przełom. Wybierz drogę naprzód."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Indecisão de carreira piora ou estagnação profissional se rompe. Decisões de trabalho atrasadas ou avanço finalmente chega. Escolha o caminho a seguir."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriärobeslutsamhet förvärras eller professionell stagnation bryter. Försenade arbetsbeslut eller genombrott kommer äntligen. Välj vägen framåt."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Кар'єрна нерішучість посилюється або професійний застій руйнується. Відкладені робочі рішення або нарешті настає прорив. Оберіть шлях вперед."
          }
        }
      }
    },
    "interpretation.two_of_swords_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schwierige berufliche Entscheidung oder Karriere-Stillstand. Vermeidung der Wahrheit am Arbeitsplatz. Zwischen Joboptionen feststecken. Informationen für die Entscheidung benötigt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Difficult professional decision or career stalemate. Avoiding work truth. Stuck between job choices. Information needed for decision."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Decisión profesional difícil o estancamiento profesional. Evitar la verdad laboral. Atascado entre opciones de trabajo. Se necesita información para decidir."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Décision professionnelle difficile ou impasse professionnelle. Éviter la vérité du travail. Coincé entre des choix d'emploi. Informations nécessaires pour la décision."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Difficile decisione professionale o stallo della carriera. Evitare la verità sul lavoro. Bloccato tra scelte lavorative. Informazioni necessarie per la decisione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "難しい仕事上の決断またはキャリアの膠着状態。仕事の真実を避ける。仕事の選択肢の間で行き詰まる。決断のために情報が必要。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vanskelig profesjonell beslutning eller karrierestagnasjon. Unngå jobbsannhet. Fast mellom jobbvalg. Informasjon trengs for beslutning."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trudna decyzja zawodowa lub zastój w karierze. Unikanie prawdy o pracy. Uwięziony między wyborami pracy. Potrzebne informacje do decyzji."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Decisão profissional difícil ou estagnação na carreira. Evitar a verdade do trabalho. Preso entre opções de emprego. Informações necessárias para a decisão."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Svårt professionellt beslut eller karriärstagnation. Undvika arbetssanning. Fast mellan jobbval. Information behövs för beslut."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Складне професійне рішення або кар'єрний застій. Уникнення правди про роботу. Застряг між варіантами роботи. Потрібна інформація для прийняття рішення."
          }
        }
      }
    },
    "interpretation.two_of_swords_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Unentschlossenheit verschlimmert sich oder Geld-Durchbruch kommt. Überwältigende finanzielle Entscheidungen oder endlich entscheiden. Stelle dich der Wahrheit."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial indecision worsens or money breakthrough comes. Overwhelming financial choices or finally deciding. Face truth."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La indecisión financiera empeora o llega un avance económico. Opciones financieras abrumadoras o finalmente decidir. Enfrenta la verdad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'indécision financière s'aggrave ou une percée monétaire arrive. Des choix financiers accablants ou enfin décider. Faites face à la vérité."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'indecisione finanziaria peggiora o arriva la svolta monetaria. Scelte finanziarie opprimenti o finalmente decidere. Affronta la verità."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "金銭的な優柔不断が悪化するか、お金のブレイクスルーが訪れる。圧倒的な金銭的選択肢、またはついに決断する。真実と向き合え。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk ubesluttsomhet forverres eller pengegjennombrudd kommer. Overveldende økonomiske valg eller endelig bestemme seg. Møt sannheten."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niezdecydowanie finansowe się pogłębia lub nadchodzi przełom finansowy. Przytłaczające wybory finansowe lub wreszcie podjęcie decyzji. Zmierz się z prawdą."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Indecisão financeira piora ou avanço financeiro chega. Escolhas financeiras esmagadoras ou finalmente decidir. Enfrente a verdade."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finansiell obeslutsamhet förvärras eller pengagenombrott kommer. Överväldigande finansiella val eller äntligen bestämma sig. Möt sanningen."
          }
        },
        "uk" : {
