          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "計画、未来のビジョン、進歩、そして決断。あなたは世界を手にした状態で岐路に立っている。あなたの道を選び、旅に身を捧げなさい。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Planlegging, fremtidsvisjon, fremgang og beslutninger. Du er ved et veiskille med verden i hendene dine. Velg din vei og forplikt deg til reisen."
