        }
      }
    },
    "interpretation.page_of_pentacles_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Neue Chance, Lernen, Ehrgeiz und praktische Verwirklichung. Sie stehen am Anfang von etwas Solidern. Bleiben Sie konzentriert und fleißig. Studieren Sie und wachsen Sie."
          }
        },
        "en" : {
