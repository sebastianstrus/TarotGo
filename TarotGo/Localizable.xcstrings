        }
      }
    },
    "interpretation.temperance_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Extreme oder ein unausgewogenes Ressourcenmanagement. Übermäßige Ausgaben oder Horten. Finde den Mittelweg im Umgang mit Geld."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial extremes or imbalanced resource management. Excessive spending or hoarding. Find the middle way with money."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Extremos financieros o gestión de recursos desequilibrada. Gastos excesivos o acaparamiento. Encuentra el camino medio con el dinero."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Extrêmes financiers ou gestion déséquilibrée des ressources. Dépenses excessives ou thésaurisation. Trouvez la voie médiane avec l'argent."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estremi finanziari o gestione delle risorse sbilanciata. Spese eccessive o accumulo. Trova la via di mezzo con il denaro."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的な極端さや不均衡なリソース管理。過剰な支出やため込み。お金の中間の道を見つけてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomiske ekstremer eller ubalansert ressursforvaltning. Overdreven utgifter eller hamstring. Finn midtveien med penger."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Skrajności finansowe lub niezrównoważone zarządzanie zasobami. Nadmierne wydatki lub gromadzenie. Znajdź złoty środek z pieniędzmi."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Extremos financeiros ou gestão de recursos desequilibrada. Gastos excessivos ou acumulação. Encontre o meio termo com o dinheiro."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomiska extremer eller obalanserad resurshantering. Överdrivna utgifter eller hamstring. Hitta mittvägen med pengar."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансові крайнощі або незбалансоване управління ресурсами. Надмірні витрати або накопичення. Знайдіть золоту середину з грошима."
          }
        }
      }
    },
    "interpretation.temperance_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ein ausgewogener Finanzansatz bringt Stabilität. Mäßiges Ausgeben und Sparen schaffen Harmonie. Geduldiger Vermögensaufbau durch stetige Anstrengung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Balanced financial approach brings stability. Moderate spending and saving create harmony. Patient wealth-building through steady effort."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un enfoque financiero equilibrado brinda estabilidad. Gastar y ahorrar con moderación crea armonía. Construcción de riqueza paciente a través del esfuerzo constante."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une approche financière équilibrée apporte la stabilité. Dépenser et épargner avec modération crée l'harmonie. Construire patiemment sa richesse grâce à un effort constant."
