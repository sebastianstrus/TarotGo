    "Image not found: %@" : {
      "comment" : "A label that appears when the system can't find an image for a tarot card. The argument is the name of the card.",
      "isCommentAutoGenerated" : true
    },
    "interpretation.ace_of_cups_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Berufliche Möglichkeiten bieten keine emotionale Erfüllung. Dein Herz steckt nicht in deiner Arbeit. Kreativität fühlt sich blockiert an. Verbinde dich wieder mit dem, was dir in deiner Karriere Freude bereitet."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professional opportunities lack emotional fulfillment. Your heart isn't in your work. Creativity feels blocked. Reconnect with what brings you joy in your career."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las oportunidades profesionales carecen de satisfacción emocional. Tu corazón no está en tu trabajo. La creatividad se siente bloqueada. Reconecta con lo que te trae alegría en tu carrera."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les opportunités professionnelles manquent d'épanouissement émotionnel. Votre cœur n'est pas dans votre travail. La créativité semble bloquée. Renouez avec ce qui vous apporte de la joie dans votre carrière."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le opportunità professionali mancano di soddisfazione emotiva. Il tuo cuore non è nel tuo lavoro. La creatività sembra bloccata. Riconnettiti con ciò che ti porta gioia nella carriera."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "仕事の機会に感情的な充実感が欠けています。心が仕事にありません。創造性がブロックされていると感じます。キャリアに喜びをもたらすものと再びつながりましょう。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jobbmuligheter mangler emosjonell tilfredsstillelse. Hjertet ditt er ikke i arbeidet. Kreativiteten føles blokkert. Gjenopprett kontakten med det som gir deg glede i karrieren."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Możliwości zawodowe nie dają emocjonalnego spełnienia. Twoje serce nie jest w twojej pracy. Kreatywność jest zablokowana. Połącz się ponownie z tym, co przynosi ci radość w karierze."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As oportunidades profissionais carecem de realização emocional. Seu coração não está no seu trabalho. A criatividade parece bloqueada. Reconecte-se com o que traz alegria na sua carreira."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yrkesmöjligheter saknar känslomässig tillfredsställelse. Ditt hjärta är inte i ditt arbete. Kreativiteten känns blockerad. Återknyt kontakten med det som ger dig glädje i din karriär."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Професійним можливостям бракує емоційного задоволення. Ваше серце не в роботі. Творчість заблокована. Відновіть зв'язок із тим, що приносить вам радість у кар'єрі."
          }
        }
      }
    },
    "interpretation.ace_of_cups_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine erfüllende neue berufliche Möglichkeit, die deine Seele nährt. Diese Arbeit entspricht deiner Leidenschaft und bringt emotionale Zufriedenheit. Folge dem, was sich in deinem Herzen richtig anfühlt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A fulfilling new professional opportunity that feeds your soul. This work aligns with your passion and brings emotional satisfaction. Follow what feels right in your heart."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una nueva oportunidad profesional gratificante que alimenta tu alma. Este trabajo se alinea con tu pasión y brinda satisfacción emocional. Sigue lo que sientes en tu corazón."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une nouvelle opportunité professionnelle épanouissante qui nourrit votre âme. Ce travail correspond à votre passion et apporte une satisfaction émotionnelle. Suivez ce qui vous semble juste dans votre cœur."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una nuova opportunità professionale appagante che nutre la tua anima. Questo lavoro si allinea con la tua passione e porta soddisfazione emotiva. Segui ciò che senti giusto nel cuore."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "魂を満たす充実した新しい仕事の機会。この仕事はあなたの情熱と一致し、感情的な満足をもたらします。心が正しいと感じることに従いましょう。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En givende ny jobbmulighet som nærer sjelen din. Dette arbeidet stemmer overens med lidenskapen din og gir emosjonell tilfredsstillelse. Følg det som føles riktig i hjertet ditt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nowa, satysfakcjonująca możliwość zawodowa, która odżywia twoją duszę. Ta praca jest zgodna z twoją pasją i przynosi emocjonalne zadowolenie. Podążaj za tym, co czujesz w sercu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uma nova oportunidade profissional gratificante que alimenta sua alma. Este trabalho está alinhado com sua paixão e traz satisfação emocional. Siga o que parece certo no seu coração."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En givande ny yrkesmöjlighet som nära din själ. Detta arbete är i linje med din passion och ger känslomässig tillfredsställelse. Följ det som känns rätt i ditt hjärta."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Нова професійна можливість, яка живить вашу душу. Ця робота відповідає вашій пристрасті та приносить емоційне задоволення. Слідуйте тому, що відчуваєте серцем."
          }
        }
      }
    },
    "interpretation.ace_of_cups_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Entscheidungen haben kein Herz oder emotionale Befriedigung. Geld mag kommen, bringt aber keine Freude. Blockierte Fülle durch verschlossenes Herz. Öffne dich für den Empfang."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial decisions lack heart or emotional satisfaction. Money might be coming but brings no joy. Blocked abundance due to closed heart. Open to receive."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las decisiones financieras carecen de corazón o satisfacción emocional. Puede que llegue dinero, pero no trae alegría. Abundancia bloqueada por un corazón cerrado. Ábrete a recibir."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les décisions financières manquent de cœur ou de satisfaction émotionnelle. L'argent peut arriver mais n'apporte aucune joie. Abondance bloquée par un cœur fermé. Ouvrez-vous pour recevoir."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le decisioni finanziarie mancano di cuore o soddisfazione emotiva. I soldi possono arrivare ma non portano gioia. Abbondanza bloccata a causa del cuore chiuso. Apri per ricevere."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的な決断に心や感情的な満足が欠けています。お金は入ってくるかもしれませんが、喜びはありません。閉ざされた心による豊かさのブロック。受け取る心を開きましょう。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomiske beslutninger mangler hjerte eller emosjonell tilfredsstillelse. Penger kan komme, men gir ingen glede. Blokkert overflod på grunn av lukket hjerte. Åpne for å motta."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Decyzjom finansowym brakuje serca lub satysfakcji emocjonalnej. Pieniądze mogą przychodzić, ale nie przynoszą radości. Zablokowana obfitość z powodu zamkniętego serca. Otwórz się, aby otrzymać."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Decisões financeiras carecem de coração ou satisfação emocional. O dinheiro pode estar chegando, mas não traz alegria. Abundância bloqueada devido ao coração fechado. Abra-se para receber."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomiska beslut saknar hjärta eller känslomässig tillfredsställelse. Pengar kan komma in men ger ingen glädje. Blockerat överflöd på grund av stängt hjärta. Öppna dig för att ta emot."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансовим рішенням бракує серця чи емоційного задоволення. Гроші можуть надходити, але не приносять радості. Блокування достатку через закрите серце. Відкрийтеся, щоб отримувати."
          }
        }
      }
    },
    "interpretation.ace_of_cups_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Möglichkeiten, die mit deinen Werten übereinstimmen, bringen Freude. Geld fließt, wenn du emotional mit deiner Arbeit im Einklang bist. Fülle durch herzliche Anstrengung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial opportunities that align with your values bring joy. Money flows when you're emotionally aligned with your work. Abundance through heartfelt effort."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las oportunidades financieras que se alinean con tus valores traen alegría. El dinero fluye cuando estás emocionalmente alineado con tu trabajo. Abundancia a través del esfuerzo sincero."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les opportunités financières alignées sur vos valeurs apportent de la joie. L'argent coule lorsque vous êtes émotionnellement en phase avec votre travail. Abondance grâce à un effort sincère."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le opportunità finanziarie in linea con i tuoi valori portano gioia. Il denaro scorre quando sei emotivamente allineato con il tuo lavoro. Abbondanza attraverso lo sforzo sincero."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "自分の価値観に合った経済的機会が喜びをもたらします。仕事と感情が一致しているとき、お金は流れます。心からの努力による豊かさ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomiske muligheter som er i tråd med verdiene dine bringer glede. Penger flyter når du er følelsesmessig tilpasset arbeidet ditt. Overflod gjennom hjertevarm innsats."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Możliwości finansowe zgodne z twoimi wartościami przynoszą radość. Pieniądze płyną, gdy jesteś emocjonalnie dostrojony do swojej pracy. Obfitość poprzez serdeczny wysiłek."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oportunidades financeiras alinhadas com seus valores trazem alegria. O dinheiro flui quando você está emocionalmente alinhado com seu trabalho. Abundância através do esforço sincero."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomiska möjligheter som överensstämmer med dina värderingar ger glädje. Pengar flödar när du är känslomässigt anpassad till ditt arbete. Överflöd genom hjärtlig ansträngning."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансові можливості, що відповідають вашим цінностям, приносять радість. Гроші течуть, коли ви емоційно налаштовані на свою роботу. Достаток через щирі зусилля."
          }
        }
      }
    },
    "interpretation.ace_of_cups_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Emotionale Blockade oder verschlossenes Herz. Alte Wunden verhindern, dass du vollständig fühlst. Unterdrückte Emotionen müssen freigesetzt werden. Öffne dich für die Liebe, die verfügbar ist."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Emotional blockage or closed heart. Past wounds prevent you from fully feeling. Repressed emotions need release. Open yourself to receive the love that's available."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bloqueo emocional o corazón cerrado. Las heridas pasadas te impiden sentir plenamente. Las emociones reprimidas necesitan liberación. Ábrete para recibir el amor que está disponible."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Blocage émotionnel ou cœur fermé. Les blessures passées vous empêchent de ressentir pleinement. Les émotions refoulées ont besoin d'être libérées. Ouvrez-vous pour recevoir l'amour disponible."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Blocco emotivo o cuore chiuso. Le ferite passate ti impediscono di sentire appieno. Le emozioni represse hanno bisogno di essere rilasciate. Apriti a ricevere l'amore disponibile."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "感情のブロックや閉ざされた心。過去の傷があなたを完全に感じることを妨げています。抑圧された感情を解放する必要があります。利用可能な愛を受け取るために自分を開きましょう。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Emosjonell blokkering eller lukket hjerte. Tidligere sår hindrer deg i å føle fullt ut. Undertrykte følelser trenger frigjøring. Åpne deg for å motta kjærligheten som er tilgjengelig."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Blokada emocjonalna lub zamknięte serce. Przeszłe rany uniemożliwiają ci pełne odczuwanie. Stłumione emocje wymagają uwolnienia. Otwórz się na miłość, która jest dostępna."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bloqueio emocional ou coração fechado. Feridas passadas impedem que você sinta plenamente. Emoções reprimidas precisam ser liberadas. Abra-se para receber o amor que está disponível."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Känslomässig blockering eller stängt hjärta. Tidigare sår hindrar dig från att känna fullt ut. Undertryckta känslor behöver frigöras. Öppna dig för att ta emot den kärlek som finns tillgänglig."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Емоційна блокада або закрите серце. Минулі рани заважають вам повністю відчувати. Пригнічені емоції потребують вивільнення. Відкрийтеся, щоб отримати доступну любов."
          }
        }
      }
    },
    "interpretation.ace_of_cups_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ein neuer Beginn in deinem Gefühlsleben. Liebe, Freude und kreative Inspiration fließen über. Dein Herz ist offen und bereit. Dies ist eine schöne Zeit des emotionalen Erwachens und der spirituellen Verbindung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A new beginning in your emotional life. Love, joy, and creative inspiration overflow. Your heart is open and ready. This is a beautiful time of emotional awakening and spiritual connection."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un nuevo comienzo en tu vida emocional. El amor, la alegría y la inspiración creativa fluyen. Tu corazón está abierto y listo. Este es un hermoso momento de despertar emocional y conexión espiritual."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un nouveau départ dans votre vie émotionnelle. L'amour, la joie et l'inspiration créative débordent. Votre cœur est ouvert et prêt. C'est un beau moment d'éveil émotionnel et de connexion spirituelle."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un nuovo inizio nella tua vita emotiva. Amore, gioia e ispirazione creativa traboccano. Il tuo cuore è aperto e pronto. Questo è un bellissimo momento di risveglio emotivo e connessione spirituale."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたの感情生活の新たな始まり。愛、喜び、創造的なインスピレーションがあふれ出します。あなたの心は開かれ、準備ができています。これは感情的な目覚めと精神的なつながりの美しい時です。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En ny begynnelse i ditt følelsesliv. Kjærlighet, glede og kreativ inspirasjon flyter over. Hjertet ditt er åpent og klart. Dette er en vakker tid med emosjonell oppvåkning og åndelig forbindelse."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nowy początek w twoim życiu emocjonalnym. Miłość, radość i twórcza inspiracja przepełniają. Twoje serce jest otwarte i gotowe. To piękny czas emocjonalnego przebudzenia i duchowego połączenia."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um novo começo em sua vida emocional. Amor, alegria e inspiração criativa transbordam. Seu coração está aberto e pronto. Este é um lindo momento de despertar emocional e conexão espiritual."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En ny början i ditt känsloliv. Kärlek, glädje och kreativ inspiration flödar över. Ditt hjärta är öppet och redo. Detta är en vacker tid av känslomässigt uppvaknande och andlig kontakt."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Новий початок у вашому емоційному житті. Любов, радість і творче натхнення переповнюють. Ваше серце відкрите і готове. Це прекрасний час емоційного пробудження та духовного зв'язку."
          }
        }
      }
    },
    "interpretation.ace_of_cups_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Emotionale Blockaden beeinflussen die körperliche Gesundheit. Unterdrückte Gefühle manifestieren sich im Körper. Dein Herz braucht Aufmerksamkeit und Heilung. Loslassen, um den Fluss wiederherzustellen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Emotional blockages affect physical health. Suppressed feelings manifest in the body. Your heart needs attention and healing. Release to restore flow."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los bloqueos emocionales afectan la salud física. Los sentimientos reprimidos se manifiestan en el cuerpo. Tu corazón necesita atención y curación. Libera para restaurar el flujo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les blocages émotionnels affectent la santé physique. Les sentiments refoulés se manifestent dans le corps. Votre cœur a besoin d'attention et de guérison. Libérez-vous pour restaurer le flux."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I blocchi emotivi influenzano la salute fisica. I sentimenti repressi si manifestano nel corpo. Il tuo cuore ha bisogno di attenzione e guarigione. Rilascia per ripristinare il flusso."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "感情のブロックが身体の健康に影響を与えます。抑圧された感情が身体に現れます。あなたの心は注意と癒しを必要としています。手放して流れを回復させましょう。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Emosjonelle blokkeringer påvirker fysisk helse. Undertrykte følelser manifesterer seg i kroppen. Hjertet ditt trenger oppmerksomhet og helbredelse. Slipp tak for å gjenopprette flyten."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Blokady emocjonalne wpływają na zdrowie fizyczne. Tłumione uczucia manifestują się w ciele. Twoje serce potrzebuje uwagi i uzdrowienia. Uwolnij, aby przywrócić przepływ."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bloqueios emocionais afetam a saúde física. Sentimentos reprimidos se manifestam no corpo. Seu coração precisa de atenção e cura. Libere para restaurar o fluxo."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Känslomässiga blockeringar påverkar den fysiska hälsan. Undertryckta känslor manifesterar sig i kroppen. Ditt hjärta behöver uppmärksamhet och läkning. Släpp för att återställa flödet."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Емоційні блокади впливають на фізичне здоров'я. Пригнічені почуття проявляються в тілі. Ваше серце потребує уваги та зцілення. Відпустіть, щоб відновити потік."
          }
        }
      }
    },
    "interpretation.ace_of_cups_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Emotionale Heilung beginnt. Dein Herz und Geist sind bereit zu heilen. Neue Wellness-Praktiken, die deinen emotionalen Körper nähren. Selbstliebe unterstützt die körperliche Gesundheit."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Emotional healing begins. Your heart and spirit are ready to heal. New wellness practices that nurture your emotional body. Self-love supports physical health."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La curación emocional comienza. Tu corazón y espíritu están listos para sanar. Nuevas prácticas de bienestar que nutren tu cuerpo emocional. El amor propio apoya la salud física."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La guérison émotionnelle commence. Votre cœur et votre esprit sont prêts à guérir. De nouvelles pratiques de bien-être qui nourrissent votre corps émotionnel. L'amour de soi soutient la santé physique."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inizia la guarigione emotiva. Il tuo cuore e spirito sono pronti a guarire. Nuove pratiche di benessere che nutrono il tuo corpo emotivo. L'amor proprio supporta la salute fisica."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "感情的な癒しが始まります。あなたの心と精神は癒される準備ができています。感情的な体を育む新しいウェルネス習慣。自己愛が身体の健康を支えます。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Emosjonell helbredelse begynner. Hjertet og sjelen din er klare til å helbrede. Nye velværepraksiser som nærer din emosjonelle kropp. Selvkjærlighet støtter fysisk helse."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rozpoczyna się emocjonalne uzdrawianie. Twoje serce i duch są gotowe do uzdrowienia. Nowe praktyki wellness, które odżywiają twoje ciało emocjonalne. Miłość własna wspiera zdrowie fizyczne."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A cura emocional começa. Seu coração e espírito estão prontos para curar. Novas práticas de bem-estar que nutrem seu corpo emocional. O amor próprio apoia a saúde física."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Känslomässig läkning börjar. Ditt hjärta och själ är redo att läka. Nya hälsopraktiker som nära din känslomässiga kropp. Självkärlek stödjer fysisk hälsa."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Починається емоційне зцілення. Ваше серце і дух готові зцілюватися. Нові оздоровчі практики, які живлять ваше емоційне тіло. Любов до себе підтримує фізичне здоров'я."
          }
        }
      }
    },
    "interpretation.ace_of_cups_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Emotionale Blockade in der Liebe. Du könntest dein Herz aufgrund vergangener Schmerzen verschließen. Angst vor Verletzlichkeit verhindert neue Liebe. Lasse alte Wunden los, um Raum für neue Gefühle zu schaffen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Emotional blockage in love. You may be closing your heart due to past pain. Fear of vulnerability prevents new love from entering. Release old wounds to make space for new feelings."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bloqueo emocional en el amor. Puede que estés cerrando tu corazón debido a dolores pasados. El miedo a la vulnerabilidad impide que entre un nuevo amor. Libera viejas heridas para hacer espacio a nuevos sentimientos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Blocage émotionnel en amour. Vous fermez peut-être votre cœur à cause de douleurs passées. La peur de la vulnérabilité empêche un nouvel amour d'entrer. Libérez les vieilles blessures pour faire place à de nouveaux sentiments."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Blocco emotivo in amore. Potresti chiudere il tuo cuore a causa di dolori passati. La paura della vulnerabilità impedisce l'ingresso di nuovi amori. Lascia andare le vecchie ferite per fare spazio a nuovi sentimenti."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "恋愛における感情の閉塞。過去の痛みから心を閉ざしているかもしれません。傷つく恐れが新しい愛を遠ざけています。古い傷を手放し、新しい感情のためのスペースを作りましょう。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Emosjonell blokkering i kjærlighet. Du kan stenge hjertet ditt på grunn av tidligere smerte. Frykt for sårbarhet hindrer ny kjærlighet i å komme inn. Slipp gamle sår for å gi rom for nye følelser."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Blokada emocjonalna w miłości. Możesz zamykać swoje serce z powodu przeszłego bólu. Strach przed bezbronnością uniemożliwia wejście nowej miłości. Uwolnij stare rany, aby zrobić miejsce na nowe uczucia."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bloqueio emocional no amor. Você pode estar fechando seu coração devido a dores passadas. O medo da vulnerabilidade impede que um novo amor entre. Libere feridas antigas para abrir espaço para novos sentimentos."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Känslomässig blockering i kärlek. Du kanske stänger ditt hjärta på grund av tidigare smärta. Rädsla för sårbarhet hindrar ny kärlek från att komma in. Släpp gamla sår för att ge plats åt nya känslor."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Емоційна блокада в коханні. Ви можете закривати своє серце через минулі болі. Страх вразливості перешкоджає новому коханню. Відпустіть старі рани, щоб звільнити місце для нових почуттів."
          }
        }
      }
    },
    "interpretation.ace_of_cups_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ein neuer emotionaler Beginn in der Liebe. Wenn du Single bist, bist du offen für Liebe. In einer Partnerschaft vertiefen erneuerte Gefühle eure Verbindung. Dein Herz ist voller Liebe und bereit zu geben und zu empfangen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A new emotional beginning in love. If single, you're open to receiving love. If partnered, renewed feelings deepen your connection. Your heart is overflowing with love and ready to give and receive."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un nuevo comienzo emocional en el amor. Si estás soltero, estás abierto a recibir amor. Si tienes pareja, los sentimientos renovados profundizan su conexión. Tu corazón rebosa amor y está listo para dar y recibir."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un nouveau départ émotionnel en amour. Si vous êtes célibataire, vous êtes ouvert à recevoir l'amour. En couple, des sentiments renouvelés approfondissent votre connexion. Votre cœur déborde d'amour, prêt à donner et recevoir."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un nuovo inizio emotivo in amore. Se sei single, sei aperto a ricevere amore. Se hai un partner, sentimenti rinnovati approfondiscono la connessione. Il tuo cuore trabocca d'amore ed è pronto a dare e ricevere."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "恋愛における新たな感情の始まり。独身なら、愛を受け入れる準備ができています。パートナーがいるなら、新たな気持ちが絆を深めます。あなたの心は愛にあふれ、与え受け取る準備ができています。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En ny emosjonell begynnelse i kjærlighet. Hvis du er singel, er du åpen for å motta kjærlighet. I et forhold vil fornyede følelser utdype forbindelsen. Hjertet ditt er fylt av kjærlighet og klart til å gi og motta."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nowy emocjonalny początek w miłości. Jeśli jesteś singlem, jesteś otwarty na miłość. W związku odnowione uczucia pogłębiają więź. Twoje serce przepełnia miłość, gotowe dawać i otrzymywać."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um novo começo emocional no amor. Se solteiro, você está aberto a receber amor. Se comprometido, sentimentos renovados aprofundam sua conexão. Seu coração transborda amor e está pronto para dar e receber."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En ny känslomässig början i kärlek. Om du är singel är du öppen för att ta emot kärlek. I ett förhållande fördjupar förnyade känslor er kontakt. Ditt hjärta flödar över av kärlek och är redo att ge och ta emot."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Новий емоційний початок у коханні. Якщо ви самотні, ви відкриті до кохання. У стосунках оновлені почуття поглиблюють зв'язок. Ваше серце переповнене любов'ю і готове давати та отримувати."
          }
        }
      }
    },
    "interpretation.ace_of_pentacles_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verpasste Karrierechance oder schlechte berufliche Planung. Berufsaussichten zerschlagen sich. Finanzielle Instabilität bei der Arbeit. Bessere Vorbereitung und Timing nötig."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Career opportunity missed or poor professional planning. Job prospects don't pan out. Financial instability in work. Need better preparation and timing."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oportunidad profesional perdida o mala planificación laboral. Las perspectivas laborales no se concretan. Inestabilidad financiera en el trabajo. Se necesita mejor preparación y momento."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opportunité de carrière manquée ou mauvaise planification professionnelle. Les perspectives d'emploi ne se concrétisent pas. Instabilité financière au travail. Une meilleure préparation et un meilleur timing sont nécessaires."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opportunità di carriera persa o cattiva pianificazione professionale. Le prospettive di lavoro non si concretizzano. Instabilità finanziaria sul lavoro. Necessaria migliore preparazione e tempismo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "逃したキャリアチャンスまたは不十分な職業計画。仕事の見通しがうまくいかない。仕事における経済的不安定。より良い準備とタイミングが必要。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gått glipp av en karrieremulighet eller dårlig profesjonell planlegging. Jobbutsikter går ikke som håpet. Økonomisk ustabilitet i arbeidet. Trenger bedre forberedelse og timing."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utracona szansa kariery lub złe planowanie zawodowe. Perspektywy pracy nie wypalają. Niestabilność finansowa w pracy. Potrzeba lepszego przygotowania i wyczucia czasu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oportunidade de carreira perdida ou mau planejamento profissional. Perspectivas de trabalho não se concretizam. Instabilidade financeira no trabalho. Melhor preparação e timing necessários."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Missad karriärmöjlighet eller dålig professionell planering. Jobbutsikter går inte i uppfyllelse. Ekonomisk instabilitet i arbetet. Behöver bättre förberedelser och timing."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Втрачена кар'єрна можливість або погане професійне планування. Перспективи роботи не справджуються. Фінансова нестабільність на роботі. Потрібна краща підготовка та час."
          }
        }
      }
    },
    "interpretation.ace_of_pentacles_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ausgezeichnete neue Karrierechance mit echtem Potenzial. Solides Jobangebot oder Geschäftsvorhaben. Materieller Erfolg in Reichweite. Professionelle Verwirklichung beginnt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Excellent new career opportunity with real potential. Solid job offer or business venture. Material success within reach. Professional manifestation begins."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Excelente oportunidad laboral con potencial real. Oferta de trabajo sólida o negocio. El éxito material está al alcance. Comienza la manifestación profesional."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Excellente opportunité de carrière avec un réel potentiel. Offre d'emploi solide ou entreprise. Succès matériel à portée de main. La manifestation professionnelle commence."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eccellente opportunità di carriera con reale potenziale. Offerta di lavoro solida o impresa commerciale. Successo materiale a portata di mano. Inizia la manifestazione professionale."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "本当の可能性を秘めた素晴らしいキャリアチャンス。確かな仕事のオファーまたはビジネスベンチャー。物質的な成功が目前に。プロとしての顕現が始まる。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utmerket ny karrieremulighet med reelt potensial. Solid jobbtilbud eller forretningssatsing. Materiell suksess innen rekkevidde. Profesjonell manifestasjon begynner."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Doskonała nowa szansa kariery z realnym potencjałem. Solidna oferta pracy lub przedsięwzięcie biznesowe. Sukces materialny w zasięgu ręki. Rozpoczyna się zawodowa manifestacja."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Excelente nova oportunidade de carreira com potencial real. Oferta de trabalho sólida ou empreendimento comercial. Sucesso material ao alcance. Manifestação profissional começa."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utmärkt ny karriärmöjlighet med verklig potential. Gediget jobberbjudande eller affärssatsning. Materiell framgång inom räckhåll. Professionell manifestation börjar."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Чудова нова кар'єрна можливість з реальним потенціалом. Солідна пропозиція роботи або бізнес-проєкт. Матеріальний успіх у межах досяжності. Професійна реалізація починається."
          }
        }
      }
    },
    "interpretation.ace_of_pentacles_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Chance verpasst oder schlechte Geldplanung. Investitionen gehen nicht auf. Eine Knappheitsmentalität blockiert den Wohlstand. Gier untergräbt den Wohlstand. Überdenken Sie Ihren Ansatz."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial opportunity lost or poor money planning. Investments don't work out. Scarcity mindset blocks abundance. Greed undermines prosperity. Reassess approach."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oportunidad financiera perdida o mala planificación del dinero. Las inversiones no funcionan. La mentalidad de escasez bloquea la abundancia. La codicia socava la prosperidad. Reevaluar el enfoque."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opportunité financière perdue ou mauvaise planification monétaire. Les investissements ne fonctionnent pas. La mentalité de rareté bloque l'abondance. La cupidité nuit à la prospérité. Réévaluez votre approche."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opportunità finanziaria persa o cattiva pianificazione del denaro. Gli investimenti non funzionano. La mentalità di scarsità blocca l'abbondanza. L'avidità mina la prosperità. Rivaluta l'approccio."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "逃した経済的機会または不十分な資金計画。投資がうまくいかない。不足マインドセットが豊かさを妨げる。貪欲さが繁栄を損なう。アプローチを再評価する。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finansiell mulighet gått tapt eller dårlig pengeplanlegging. Investeringer går ikke som håpet. Knapphetstenkning blokkerer overflod. Grådighet undergraver velstand. Vurder tilnærmingen på nytt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utracona szansa finansowa lub złe planowanie pieniędzy. Inwestycje nie wypalają. Mentalność niedoboru blokuje obfitość. Chciwość podważa dobrobyt. Przeanalizuj podejście."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oportunidade financeira perdida ou mau planejamento financeiro. Investimentos não dão certo. Mentalidade de escassez bloqueia a abundância. Ganância prejudica a prosperidade. Reavalie a abordagem."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Förlorad ekonomisk möjlighet eller dålig planering av pengar. Investeringar går inte som planerat. Bristtänkande blockerar överflöd. Girighet undergräver välstånd. Omvärdera tillvägagångssättet."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Втрачена фінансова можливість або погане планування грошей. Інвестиції не спрацьовують. Менталітет дефіциту блокує достаток. Жадібність підриває процвітання. Перегляньте підхід."
          }
        }
      }
    },
    "interpretation.ace_of_pentacles_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Neue finanzielle Chance und materielle Verwirklichung. Ausgezeichnete Zeit für Investitionen und Geldgeschäfte. Der Wohlstand beginnt zu fließen. Der Wohlstand ist greifbar und real."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "New financial opportunity and material manifestation. Excellent time for investments and money ventures. Abundance begins to flow. Prosperity is tangible and real."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nueva oportunidad financiera y manifestación material. Excelente momento para inversiones y negocios. La abundancia comienza a fluir. La prosperidad es tangible y real."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nouvelle opportunité financière et manifestation matérielle. Excellent moment pour les investissements et les entreprises. L'abondance commence à circuler. La prospérité est tangible et réelle."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nuova opportunità finanziaria e manifestazione materiale. Ottimo momento per investimenti e iniziative economiche. L'abbondanza inizia a fluire. La prosperità è tangibile e reale."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "新しい経済的機会と物質的な顕現。投資や金銭的な事業に最適な時期。豊かさが流れ始める。繁栄は具体的で現実的。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ny finansiell mulighet og materiell manifestasjon. Utmerket tid for investeringer og pengeprosjekter. Overflod begynner å flyte. Velstand er håndgripelig og reell."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nowa szansa finansowa i materialna manifestacja. Doskonały czas na inwestycje i przedsięwzięcia pieniężne. Obfitość zaczyna płynąć. Dobrobyt jest namacalny i realny."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nova oportunidade financeira e manifestação material. Excelente momento para investimentos e negócios. A abundância começa a fluir. A prosperidade é tangível e real."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ny ekonomisk möjlighet och materiell manifestation. Utmärkt tid för investeringar och penningprojekt. Överflöd börjar flöda. Välstånd är påtagligt och verkligt."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Нова фінансова можливість та матеріальна реалізація. Чудовий час для інвестицій та грошових починань. Достаток починає текти. Процвітання відчутне та реальне."
          }
        }
      }
    },
    "interpretation.ace_of_pentacles_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verpasste Chancen, schlechte Planung oder Mangeldenken. Die materielle Verwirklichung ist blockiert. Gier oder mangelnde Vorbereitung untergraben den Erfolg. Kommen Sie zur Ruhe und versuchen Sie es erneut."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lost opportunities, poor planning, or scarcity thinking. Material manifestation is blocked. Greed or lack of preparation undermines success. Get grounded and try again."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oportunidades perdidas, mala planificación o pensamiento de escasez. La manifestación material está bloqueada. La codicia o la falta de preparación socavan el éxito. Conéctate con la tierra y vuelve a intentarlo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opportunités perdues, mauvaise planification ou pensée de pénurie. La manifestation matérielle est bloquée. La cupidité ou le manque de préparation nuisent au succès. Restez ancré et réessayez."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opportunità perse, cattiva pianificazione o pensiero di scarsità. La manifestazione materiale è bloccata. L'avidità o la mancanza di preparazione minano il successo. Resta con i piedi per terra e riprova."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "逃した機会、不十分な計画、または不足思考。物質的な顕現が妨げられている。貪欲さや準備不足が成功を損なう。地に足をつけてもう一度試す。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gåtte muligheter tapt, dårlig planlegging eller knapphetstenkning. Materiell manifestasjon er blokkert. Grådighet eller mangel på forberedelse undergraver suksess. Jord deg selv og prøv igjen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utracone szanse, złe planowanie lub myślenie o niedoborze. Materialna manifestacja jest zablokowana. Chciwość lub brak przygotowania podważają sukces. Uziemij się i spróbuj ponownie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oportunidades perdidas, mau planejamento ou pensamento de escassez. Manifestação material está bloqueada. Ganância ou falta de preparação prejudicam o sucesso. Aterre-se e tente novamente."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Förlorade möjligheter, dålig planering eller bristtänkande. Materiell manifestation blockeras. Girighet eller brist på förberedelser undergräver framgång. Jorda dig själv och försök igen."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Втрачені можливості, погане планування або мислення дефіциту. Матеріальна реалізація заблокована. Жадібність або відсутність підготовки підривають успіх. Опустіться на землю та спробуйте знову."
          }
        }
      }
    },
    "interpretation.ace_of_pentacles_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Neue materielle Chance und Verwirklichung. Dies ist der Same des weltlichen Wohlstands – ob finanziell, physisch oder praktisch. Der Beginn von etwas Solidern und Dauerhaftem."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "New material opportunity and manifestation. This is the seed of real-world abundance—whether financial, physical, or practical. The beginning of something solid and lasting."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nueva oportunidad material y manifestación. Esta es la semilla de la abundancia en el mundo real, ya sea financiera, física o práctica. El comienzo de algo sólido y duradero."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nouvelle opportunité matérielle et manifestation. C'est la graine de l'abondance dans le monde réel – qu'elle soit financière, physique ou pratique. Le début de quelque chose de solide et de durable."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nuova opportunità materiale e manifestazione. Questo è il seme dell'abbondanza nel mondo reale – sia finanziaria, fisica o pratica. L'inizio di qualcosa di solido e duraturo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "新たな物質的機会と顕現。これは現実世界の豊かさの種です（経済的、身体的、実用的に関わらず）。確かで永続的な何かの始まり。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ny materiell mulighet og manifestasjon. Dette er frøet til virkelighetens overflod – enten det er økonomisk, fysisk eller praktisk. Begynnelsen på noe solid og varig."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nowa materialna szansa i manifestacja. To jest ziarno doczesnej obfitości – finansowej, fizycznej lub praktycznej. Początek czegoś solidnego i trwałego."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nova oportunidade material e manifestação. Esta é a semente da abundância no mundo real – seja financeira, física ou prática. O começo de algo sólido e duradouro."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ny materiell möjlighet och manifestation. Detta är fröet till verklighetens överflöd – vare sig det är finansiellt, fysiskt eller praktiskt. Början på något solidt och varaktigt."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Нова матеріальна можливість та реалізація. Це насінина реального достатку – фінансового, фізичного чи практичного. Початок чогось міцного та тривалого."
          }
        }
      }
    },
    "interpretation.ace_of_pentacles_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gesundheitschance verpasst oder schlechte Wellness-Planung. Körperliche Bemühungen bringen keine Ergebnisse. Bessere gesundheitliche Grundlage und praktischer Ansatz nötig."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Health opportunity missed or poor wellness planning. Physical efforts don't yield results. Need better health foundation and practical approach."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oportunidad de salud perdida o mala planificación del bienestar. Los esfuerzos físicos no dan resultados. Se necesita una mejor base de salud y un enfoque práctico."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opportunité de santé manquée ou mauvaise planification du bien-être. Les efforts physiques ne donnent pas de résultats. Une meilleure base de santé et une approche pratique sont nécessaires."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opportunità di salute persa o cattiva pianificazione del benessere. Gli sforzi fisici non danno risultati. Necessaria una migliore base di salute e un approccio pratico."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "逃した健康の機会または不十分なウェルネス計画。身体的な努力が実を結ばない。より良い健康基盤と実践的なアプローチが必要。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Helseanledning gått tapt eller dårlig velværeplanlegging. Fysisk innsats gir ikke resultater. Trenger bedre helsegrunnlag og praktisk tilnærming."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utracona okazja zdrowotna lub złe planowanie wellness. Fizyczne wysiłki nie przynoszą rezultatów. Potrzeba lepszej podstawy zdrowotnej i praktycznego podejścia."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oportunidade de saúde perdida ou mau planejamento de bem-estar. Esforços físicos não produzem resultados. Melhor base de saúde e abordagem prática necessárias."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Missad hälsochans eller dålig hälso- och välmåendeplanering. Fysiska ansträngningar ger inte resultat. Behöver bättre hälsogrund och praktiskt tillvägagångssätt."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Втрачена можливість для здоров'я або погане оздоровче планування. Фізичні зусилля не дають результатів. Потрібна краща основа для здоров'я та практичний підхід."
          }
        }
      }
    },
    "interpretation.ace_of_pentacles_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Neuer gesundheitlicher Beginn mit greifbaren Ergebnissen. Der Körper reagiert gut auf Wellness-Bemühungen. Körperliche Manifestation der Heilung. Solide Grundlage für langfristige Gesundheit."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "New health beginning with tangible results. Body responds well to wellness efforts. Physical manifestation of healing. Solid foundation for long-term health."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nuevo comienzo de salud con resultados tangibles. El cuerpo responde bien a los esfuerzos de bienestar. Manifestación física de la curación. Base sólida para la salud a largo plazo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nouveau départ en santé avec des résultats tangibles. Le corps répond bien aux efforts de bien-être. Manifestation physique de la guérison. Base solide pour une santé à long terme."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nuovo inizio per la salute con risultati tangibili. Il corpo risponde bene agli sforzi di benessere. Manifestazione fisica della guarigione. Solida base per la salute a lungo termine."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "目に見える結果をもたらす新たな健康の始まり。身体がウェルネスへの取り組みに良く反応する。癒しの身体的顕現。長期的な健康のための確かな基盤。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ny helsestart med konkrete resultater. Kroppen responderer godt på velværeinnsats. Fysisk manifestasjon av helbredelse. Solid grunnlag for langsiktig helse."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nowy początek zdrowia z namacalnymi rezultatami. Ciało dobrze reaguje na wysiłki wellness. Fizyczna manifestacja uzdrowienia. Solidna podstawa dla długoterminowego zdrowia."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Novo começo de saúde com resultados tangíveis. O corpo responde bem aos esforços de bem-estar. Manifestação física da cura. Base sólida para a saúde a longo prazo."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ny hälsostart med påtagliga resultat. Kroppen svarar bra på hälsoinsatser. Fysisk manifestation av läkning. Solid grund för långsiktig hälsa."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Новий початок для здоров'я з відчутними результатами. Тіло добре реагує на оздоровчі зусилля. Фізичний прояв зцілення. Міцна основа для довгострокового здоров'я."
          }
        }
      }
    },
    "interpretation.ace_of_pentacles_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verpasste romantische Gelegenheit oder schlechte Planung in der Liebe. Der Beziehung fehlt eine materielle Grundlage. Finanzielle Instabilität beeinträchtigt die Partnerschaft. Gier schadet der Verbindung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Romantic opportunity missed or poor planning in love. Relationship lacks material foundation. Financial instability affects partnership. Greed damages connection."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oportunidad romántica perdida o mala planificación en el amor. La relación carece de base material. La inestabilidad financiera afecta la sociedad. La codicia daña la conexión."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opportunité romantique manquée ou mauvaise planification en amour. La relation manque de fondement matériel. L'instabilité financière affecte le partenariat. La cupidité nuit à la connexion."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opportunità romantica persa o scarsa pianificazione in amore. Relazione priva di fondamenta materiali. L'instabilità finanziaria influisce sulla partnership. L'avidità danneggia la connessione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "逃した恋愛チャンスまたは愛における計画不足。関係に物質的な基盤が欠けている。経済的不安定がパートナーシップに影響。貪欲さが絆を損なう。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gått glipp av en romantisk mulighet eller dårlig planlegging i kjærlighet. Forholdet mangler materiell grunnmur. Økonomisk ustabilitet påvirker partnerskapet. Grådighet skader forbindelsen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utracona okazja romantyczna lub złe planowanie w miłości. Związkowi brakuje materialnych podstaw. Niestabilność finansowa wpływa na partnerstwo. Chciwość niszczy więź."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oportunidade romântica perdida ou mau planejamento no amor. Relacionamento carece de base material. Instabilidade financeira afeta a parceria. Ganância prejudica a conexão."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Missad romantisk möjlighet eller dålig planering i kärlek. Relationen saknar materiell grund. Ekonomisk instabilitet påverkar partnerskapet. Girighet skadar anslutningen."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Втрачена романтична можливість або погане планування в любові. Стосункам бракує матеріальної основи. Фінансова нестабільність впливає на партнерство. Жадібність руйнує зв'язок."
          }
        }
      }
    },
    "interpretation.ace_of_pentacles_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Neue Beziehung mit solider Perspektive und realer Stabilität. Liebe, die in der Realität und praktischer Hingabe verwurzelt ist. Materielle Sicherheit unterstützt die emotionale Verbindung. Greifbare Anfänge."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "New relationship with solid potential and real-world stability. Love grounded in reality and practical commitment. Material security supports emotional connection. Tangible beginnings."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nueva relación con potencial sólido y estabilidad real. Amor arraigado en la realidad y compromiso práctico. La seguridad material apoya la conexión emocional. Comienzos tangibles."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nouvelle relation avec un solide potentiel et une stabilité concrète. Amour ancré dans la réalité et l'engagement pratique. La sécurité matérielle soutient la connexion émotionnelle. Débuts tangibles."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nuova relazione con solido potenziale e stabilità reale. Amore radicato nella realtà e nell'impegno pratico. La sicurezza materiale supporta la connessione emotiva. Inizi tangibili."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "確かな可能性と現実的な安定性を備えた新しい関係。現実と実践的なコミットメントに根ざした愛。物質的な安定が感情的なつながりを支える。具体的な始まり。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nytt forhold med solid potensial og reell stabilitet. Kjærlighet forankret i virkelighet og praktisk forpliktelse. Materiell sikkerhet støtter følelsesmessig tilknytning. Konkrete begynnelser."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nowy związek z solidnym potencjałem i rzeczywistą stabilnością. Miłość zakorzeniona w rzeczywistości i praktycznym zaangażowaniu. Bezpieczeństwo materialne wspiera więź emocjonalną. Namacalne początki."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Novo relacionamento com potencial sólido e estabilidade real. Amor enraizado na realidade e compromisso prático. Segurança material apoia a conexão emocional. Começos tangíveis."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ny relation med solid potential och verklig stabilitet. Kärlek förankrad i verkligheten och praktiskt engagemang. Materiell säkerhet stödjer emotionell koppling. Påtagliga början."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Нові стосунки з міцним потенціалом та реальною стабільністю. Любов, що ґрунтується на реальності та практичній відданості. Матеріальна безпека підтримує емоційний зв'язок. Відчутні починання."
          }
        }
      }
    },
    "interpretation.ace_of_swords_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriere-Verwirrung und berufliche Missverständnisse. Chaotisches Denken beeinträchtigt die Arbeit. Mangelnde Klarheit blockiert den Aufstieg. Geistiger Nebel verhindert den Durchbruch."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Career confusion and professional miscommunication. Chaotic thinking affects work. Lack of clarity blocks advancement. Mental fog prevents breakthrough."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confusión profesional y mala comunicación laboral. El pensamiento caótico afecta el trabajo. La falta de claridad bloquea el avance. La niebla mental impide el progreso."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confusion professionnelle et mauvaise communication au travail. Une pensée chaotique affecte le travail. Le manque de clarté bloque l'avancement. Le brouillard mental empêche la percée."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confusione professionale e incomprensioni lavorative. Il pensiero caotico influisce sul lavoro. La mancanza di chiarezza blocca l'avanzamento. La nebbia mentale impedisce la svolta."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャリアの混乱と仕事上の誤解。混沌とした思考が仕事に影響。明確さの欠如が前進を妨げる。精神的な曇りがブレイクスルーを妨げる。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriereforvirring og profesjonell miskommunikasjon. Kaotisk tenkning påvirker arbeidet. Mangel på klarhet blokkerer fremgang. Mental tåke hindrer gjennombrudd."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zamieszanie zawodowe i profesjonalne nieporozumienia. Chaotyczne myślenie wpływa na pracę. Brak jasności blokuje awans. Mentalna mgła uniemożliwia przełom."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confusão profissional e falta de comunicação no trabalho. Pensamento caótico afeta o trabalho. Falta de clareza bloqueia o avanço. Névoa mental impede o progresso."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriärförvirring och professionella missförstånd. Kaotiskt tänkande påverkar arbetet. Brist på klarhet blockerar framsteg. Mental dimma förhindrar genombrott."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Кар'єрна плутанина та професійні непорозуміння. Хаотичне мислення впливає на роботу. Відсутність ясності блокує просування. Розумовий туман перешкоджає прориву."
          }
        }
      }
    },
    "interpretation.ace_of_swords_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beruflicher Durchbruch und geistige Klarheit. Neue Ideen und klares Denken fördern die Karriere. Wahrheit und Kommunikation bringen Erfolg. Intellektueller Sieg bei der Arbeit."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professional breakthrough and mental clarity. New ideas and clear thinking advance career. Truth and communication bring success. Intellectual victory at work."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avance profesional y claridad mental. Nuevas ideas y pensamiento claro impulsan la carrera. La verdad y la comunicación traen éxito. Victoria intelectual en el trabajo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Percée professionnelle et clarté mentale. Nouvelles idées et pensée claire font avancer la carrière. Vérité et communication apportent le succès. Victoire intellectuelle au travail."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Svolta professionale e chiarezza mentale. Nuove idee e pensiero chiaro fanno avanzare la carriera. Verità e comunicazione portano successo. Vittoria intellettuale sul lavoro."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "仕事上のブレイクスルーと精神的な明晰さ。新しいアイデアと明確な思考がキャリアを前進させる。真実とコミュニケーションが成功をもたらす。仕事における知的勝利。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profesjonelt gjennombrudd og mental klarhet. Nye ideer og klar tenkning fremmer karrieren. Sannhet og kommunikasjon bringer suksess. Intellektuell seier på jobb."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profesjonalny przełom i mentalna jasność. Nowe pomysły i jasne myślenie rozwijają karierę. Prawda i komunikacja przynoszą sukces. Intelektualne zwycięstwo w pracy."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avanço profissional e clareza mental. Novas ideias e pensamento claro impulsionam a carreira. Verdade e comunicação trazem sucesso. Vitória intelectual no trabalho."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professionellt genombrott och mental klarhet. Nya idéer och tydligt tänkande främjar karriären. Sanning och kommunikation ger framgång. Intellektuell seger på jobbet."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Професійний прорив і розумова ясність. Нові ідеї та чітке мислення просувають кар'єру. Правда та комунікація приносять успіх. Інтелектуальна перемога на роботі."
          }
        }
      }
    },
    "interpretation.ace_of_swords_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Verwirrung und mangelnde Klarheit über Geld. Chaotisches Denken über Ressourcen. Missverständnisse beeinträchtigen die Finanzen. Geistiger Nebel blockiert Wohlstand."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial confusion and lack of money clarity. Chaotic thinking about resources. Miscommunication affects finances. Mental fog blocks prosperity."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confusión financiera y falta de claridad sobre el dinero. Pensamiento caótico sobre los recursos. La mala comunicación afecta las finanzas. La niebla mental bloquea la prosperidad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confusion financière et manque de clarté sur l'argent. Pensée chaotique sur les ressources. Une mauvaise communication affecte les finances. Le brouillard mental bloque la prospérité."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confusione finanziaria e mancanza di chiarezza sul denaro. Pensiero caotico sulle risorse. L'incomprensione influisce sulle finanze. La nebbia mentale blocca la prosperità."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "金銭的な混乱とお金に関する明確さの欠如。リソースについての混沌とした思考。誤解が財政に影響。精神的な曇りが繁栄を妨げる。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk forvirring og mangel på pengeklarhet. Kaotisk tenkning om ressurser. Misforståelser påvirker økonomien. Mental tåke blokkerer velstand."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finansowe zamieszanie i brak jasności co do pieniędzy. Chaotyczne myślenie o zasobach. Nieporozumienia wpływają na finanse. Mentalna mgła blokuje dobrobyt."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confusão financeira e falta de clareza sobre dinheiro. Pensamento caótico sobre recursos. Falta de comunicação afeta as finanças. Névoa mental bloqueia a prosperidade."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finansiell förvirring och brist på klarhet om pengar. Kaotiskt tänkande om resurser. Missförstånd påverkar ekonomin. Mental dimma blockerar välstånd."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансова плутанина та відсутність ясності щодо грошей. Хаотичне мислення про ресурси. Непорозуміння впливають на фінанси. Розумовий туман блокує процвітання."
          }
        }
      }
    },
    "interpretation.ace_of_swords_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Klarheit und Durchbruch. Klares Denken über Geld. Neue Ideen bringen Wohlstand. Die Wahrheit über Ressourcen stärkt dich. Mentaler Ansatz für Wohlstand."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial clarity and breakthrough. Clear thinking about money. New ideas bring prosperity. Truth about resources empowers you. Mental approach to wealth."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Claridad financiera y avance. Pensamiento claro sobre el dinero. Nuevas ideas traen prosperidad. La verdad sobre los recursos te empodera. Enfoque mental hacia la riqueza."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clarté financière et percée. Pensée claire sur l'argent. De nouvelles idées apportent la prospérité. La vérité sur les ressources vous responsabilise. Approche mentale de la richesse."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chiarezza finanziaria e svolta. Pensiero chiaro sul denaro. Nuove idee portano prosperità. La verità sulle risorse ti dà potere. Approccio mentale alla ricchezza."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "金銭的な明晰さとブレイクスルー。お金についての明確な思考。新しいアイデアが繁栄をもたらす。リソースについての真実があなたを力づける。富への精神的なアプローチ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk klarhet og gjennombrudd. Klar tenkning om penger. Nye ideer bringer velstand. Sannheten om ressurser styrker deg. Mental tilnærming til rikdom."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finansowa jasność i przełom. Jasne myślenie o pieniądzach. Nowe pomysły przynoszą dobrobyt. Prawda o zasobach daje ci siłę. Mentalne podejście do bogactwa."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clareza financeira e avanço. Pensamento claro sobre dinheiro. Novas ideias trazem prosperidade. A verdade sobre recursos te fortalece. Abordagem mental da riqueza."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finansiell klarhet och genombrott. Tydligt tänkande om pengar. Nya idéer ger välstånd. Sanningen om resurser stärker dig. Mental inställning till rikedom."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансова ясність і прорив. Чітке мислення про гроші. Нові ідеї приносять процвітання. Правда про ресурси дає вам силу. Розумовий підхід до багатства."
          }
        }
      }
    },
    "interpretation.ace_of_swords_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verwirrung, Chaos, mangelnde Klarheit und Missverständnisse. Dein Denken ist durcheinander. Die Wahrheit ist verschleiert. Der geistige Durchbruch ist blockiert. Suche Klarheit, bevor du handelst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confusion, chaos, lack of clarity, and miscommunication. Your thinking is muddled. Truth is obscured. Mental breakthrough is blocked. Seek clarity before acting."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confusión, caos, falta de claridad y mala comunicación. Tu pensamiento está confuso. La verdad está oscurecida. El avance mental está bloqueado. Busca claridad antes de actuar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confusion, chaos, manque de clarté et mauvaise communication. Votre pensée est embrouillée. La vérité est obscurcie. La percée mentale est bloquée. Cherchez la clarté avant d'agir."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confusione, caos, mancanza di chiarezza e incomprensioni. Il tuo pensiero è confuso. La verità è oscurata. La svolta mentale è bloccata. Cerca chiarezza prima di agire."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "混乱、混沌、明確さの欠如、誤解。あなたの思考は混乱している。真実は曇らされている。精神的なブレイクスルーは妨げられている。行動する前に明確さを求めて。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Forvirring, kaos, mangel på klarhet og misforståelser. Tankene dine er rotete. Sannheten er skjult. Mentalt gjennombrudd er blokkert. Søk klarhet før du handler."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zamieszanie, chaos, brak jasności i nieporozumienia. Twoje myślenie jest zagmatwane. Prawda jest przesłonięta. Mentalny przełom jest zablokowany. Szukaj jasności przed działaniem."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confusão, caos, falta de clareza e falta de comunicação. Seu pensamento está confuso. A verdade está obscurecida. O avanço mental está bloqueado. Busque clareza antes de agir."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Förvirring, kaos, brist på klarhet och missförstånd. Ditt tänkande är rörigt. Sanningen är skymd. Mentalt genombrott är blockerat. Sök klarhet innan du agerar."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Плутанина, хаос, відсутність ясності та непорозуміння. Ваше мислення заплутане. Правда затемнена. Розумовий прорив заблоковано. Шукайте ясності перед дією."
          }
        }
      }
    },
    "interpretation.ace_of_swords_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Durchbruch, Klarheit, neue Ideen und geistige Kraft. Der Nebel lichtet sich und du siehst die Wahrheit klar. Scharfes Denken durchdringt die Verwirrung. Dies ist dein Moment des intellektuellen Sieges."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Breakthrough, clarity, new ideas, and mental power. The fog lifts and you see truth clearly. Sharp thinking cuts through confusion. This is your moment of intellectual victory."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avance, claridad, nuevas ideas y poder mental. La niebla se levanta y ves la verdad con claridad. El pensamiento agudo corta la confusión. Este es tu momento de victoria intelectual."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Percée, clarté, nouvelles idées et puissance mentale. Le brouillard se lève et vous voyez la vérité clairement. Une pensée acérée traverse la confusion. C'est votre moment de victoire intellectuelle."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Svolta, chiarezza, nuove idee e potere mentale. La nebbia si solleva e vedi la verità chiaramente. Il pensiero acuto taglia la confusione. Questo è il tuo momento di vittoria intellettuale."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ブレイクスルー、明晰さ、新しいアイデア、そして精神的な力。霧が晴れ、真実がはっきり見える。鋭い思考が混乱を断ち切る。これがあなたの知的勝利の瞬間です。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gjennombrudd, klarhet, nye ideer og mental kraft. Tåken letter og du ser sannheten klart. Skarp tenkning skjærer gjennom forvirring. Dette er ditt øyeblikk for intellektuell seier."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przełom, jasność, nowe pomysły i siła umysłu. Mgła unosi się i widzisz prawdę wyraźnie. Ostre myślenie przecina zamieszanie. To twoja chwila intelektualnego zwycięstwa."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avanço, clareza, novas ideias e poder mental. O nevoeiro se levanta e você vê a verdade claramente. Pensamento aguçado corta a confusão. Este é o seu momento de vitória intelectual."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Genombrott, klarhet, nya idéer och mental kraft. Dimman lyfter och du ser sanningen tydligt. Skarpt tänkande skär igenom förvirring. Detta är ditt ögonblick av intellektuell seger."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Прорив, ясність, нові ідеї та розумова сила. Туман розсіюється, і ви бачите правду чітко. Гостре мислення розрізає плутанину. Це ваш момент інтелектуальної перемоги."
          }
        }
      }
    },
    "interpretation.ace_of_swords_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gesundheitliche Verwirrung und unklare Symptome. Geistiges Chaos beeinträchtigt das Wohlbefinden. Missverständnisse mit Anbietern. Mangelnde Klarheit blockiert die Heilung."
          }
        },
        "en" : {
