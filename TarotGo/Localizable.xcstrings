        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Szybkość zdrowotna i działanie wellness. Szybki rozwój uzdrawiania. Szybki postęp fizyczny. Impuls w regeneracji ciała."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Velocidade da saúde e ação de bem-estar. Desenvolvimentos rápidos de cura. Progresso físico rápido. Impulso na recuperação do corpo."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hälsofart och välmående aktivitet. Snabb läkningsutveckling. Snabb fysisk framsteg. Fart i kroppsåterhämtning."
