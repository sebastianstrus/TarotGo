        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desgosto financeiro e dor financeira. Traição ou perda envolvendo recursos. A verdade sobre as finanças dói. A dor sobre o dinheiro é válida."
