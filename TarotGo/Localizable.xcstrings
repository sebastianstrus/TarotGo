        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ansiedad financiera y preocupación por el dinero. Pesadillas sobre recursos. Miedo abrumador por las finanzas. Tu mente te atormenta. Busca apoyo."
