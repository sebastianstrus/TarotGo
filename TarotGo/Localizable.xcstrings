        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Más notícias de saúde ou imaturidade emocional afetando o bem-estar. Escapismo bloqueia o progresso da saúde. Ignorar mensagens intuitivas do corpo."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
