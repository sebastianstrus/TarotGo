        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Równowaga zawodowa i cierpliwy postęp przynoszą sukces. Umiejętnie łącz różne elementy swojej pracy. Umiar i harmonia w twoim podejściu."
          }
