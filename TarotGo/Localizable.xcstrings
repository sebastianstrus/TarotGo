        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Désespoir professionnel ou déconnexion des rêves de carrière. La négativité bloque les opportunités. Renouez avec l'espoir et l'inspiration."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Disperazione professionale o disconnessione dai sogni di carriera. La negatività blocca le opportunità. Riconnettiti con speranza e ispirazione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "職業上の絶望またはキャリアの夢からの断絶。否定性が機会を妨げます。希望とインスピレーションと再びつながってください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profesjonell fortvilelse eller frakobling fra karrieredrømmer. Negativitet blokkerer muligheter. Gjenopprett forbindelsen med håp og inspirasjon."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rozpacz zawodowa lub odłączenie od marzeń o karierze. Negatywność blokuje możliwości. Połącz się ponownie z nadzieją i inspiracją."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desespero profissional ou desconexão dos sonhos de carreira. A negatividade bloqueia oportunidades. Reconecte-se com esperança e inspiração."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professionell förtvivlan eller frånkoppling från karriärdrömmar. Negativitet blockerar möjligheter. Återknyt kontakten med hopp och inspiration."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Професійний розпач або роз'єднання з кар'єрними мріями. Негатив блокує можливості. Возз'єднайтеся з надією та натхненням."
          }
        }
      }
    },
    "interpretation.the_star_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Berufliche Hoffnung und Inspiration nach Schwierigkeiten. Deine beruflichen Träume sind gültig – glaube daran. Göttliche Führung erleuchtet deinen Weg nach vorne."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Career hope and inspiration after difficulty. Your professional dreams are valid—keep faith. Divine guidance lights your path forward."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esperanza e inspiración profesional después de la dificultad. Tus sueños profesionales son válidos, mantén la fe. La guía divina ilumina tu camino a seguir."
