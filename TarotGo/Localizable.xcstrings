          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Decisioni finanziarie intuitive e approccio premuroso alle risorse. Prosperità attraverso il lavoro compassionevole. La sicurezza emotiva permette di dare generosamente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "直感的な財政判断と思いやりのある資源へのアプローチ。思いやりのある仕事による繁栄。感情的安定が寛大な施しを可能にする。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Intuitive økonomiske beslutninger og omsorgsfull tilnærming til ressurser. Velstand gjennom medfølende arbeid. Emosjonell trygghet tillater sjenerøs giving."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Intuicyjne decyzje finansowe i troskliwe podejście do zasobów. Dobrobyt poprzez współczującą pracę. Bezpieczeństwo emocjonalne pozwala na hojne dawanie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Decisões financeiras intuitivas e abordagem carinhosa aos recursos. Prosperidade através do trabalho compassivo. Segurança emocional permite dar generosamente."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Intuitiva ekonomiska beslut och omtänksam inställning till resurser. Välstånd genom medkännande arbete. Känslomässig trygghet tillåter generöst givande."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Інтуїтивні фінансові рішення та турботливий підхід до ресурсів. Процвітання через співчутливу роботу. Емоційна безпека дозволяє щедро давати."
          }
        }
      }
    },
    "interpretation.queen_of_cups_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Emotionale Unsicherheit, Koabhängigkeit oder Märtyrertum. Du bist überwältigt von Gefühlen – deinen und denen anderer. Schlechte Grenzen entziehen dir Energie. Setze zuerst deine eigene Sauerstoffmaske auf."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Emotional insecurity, codependency, or martyrdom. You're overwhelmed by feelings—yours and others'. Poor boundaries drain you. Put on your own oxygen mask first."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inseguridad emocional, codependencia o martirio. Estás abrumado por los sentimientos, los tuyos y los de los demás. Los malos límites te agotan. Ponte tu propia máscara de oxígeno primero."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Insécurité émotionnelle, codépendance ou martyre. Vous êtes submergé par les sentiments, les vôtres et ceux des autres. De mauvaises limites vous épuisent. Mettez d'abord votre propre masque à oxygène."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Insicurezza emotiva, codipendenza o martirio. Sei sopraffatto dai sentimenti, tuoi e altrui. Confini scadenti ti prosciugano. Metti prima la tua maschera di ossigeno."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "感情的不安、共依存、殉教者気質。あなたは自分と他人の感情に圧倒されている。境界線の欠如があなたを消耗させる。まず自分の酸素マスクをつけなさい。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Emosjonell usikkerhet, medavhengighet eller martyrium. Du er overveldet av følelser – dine og andres. Dårlige grenser tapper deg. Ta på din egen oksygenmaske først."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niepewność emocjonalna, współuzależnienie lub męczeństwo. Jesteś przytłoczony uczuciami – swoimi i innych. Słabe granice cię wyczerpują. Załóż najpierw własną maskę tlenową."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Insegurança emocional, codependência ou martírio. Você está sobrecarregado por sentimentos – seus e dos outros. Limites ruins drenam você. Coloque sua própria máscara de oxigênio primeiro."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Känslomässig osäkerhet, medberoende eller martyrium. Du är överväldigad av känslor – dina och andras. Dåliga gränser dränerar dig. Sätt på din egen syrgasmask först."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Емоційна невпевненість, співзалежність або мучеництво. Ви перевантажені почуттями — своїми та чужими. Погані межі виснажують вас. Спочатку надягніть власну кисневу маску."
          }
        }
      }
    },
    "interpretation.queen_of_cups_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Emotionale Reife, Mitgefühl, Intuition und Fürsorge. Du bist tief mit deinen Gefühlen und denen anderer verbunden. Deine emotionale Intelligenz ist deine Superkraft. Führe mit Liebe."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Emotional maturity, compassion, intuition, and caring. You're deeply connected to your feelings and others'. Your emotional intelligence is your superpower. Lead with love."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Madurez emocional, compasión, intuición y cariño. Estás profundamente conectado con tus sentimientos y los de los demás. Tu inteligencia emocional es tu superpoder. Lidera con amor."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maturité émotionnelle, compassion, intuition et attention. Vous êtes profondément connecté à vos sentiments et à ceux des autres. Votre intelligence émotionnelle est votre superpouvoir. Menez avec amour."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maturità emotiva, compassione, intuizione e cura. Sei profondamente connesso ai tuoi sentimenti e a quelli degli altri. La tua intelligenza emotiva è il tuo superpotere. Guida con amore."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "感情的成熟、思いやり、直感、気配り。あなたは自分と他人の感情に深くつながっている。あなたの感情的知性はあなたのスーパーパワーです。愛をもって導け。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Emosjonell modenhet, medfølelse, intuisjon og omsorg. Du er dypt knyttet til dine følelser og andres. Din emosjonelle intelligens er superkraften din. Led med kjærlighet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dojrzałość emocjonalna, współczucie, intuicja i troska. Jesteś głęboko związany ze swoimi uczuciami i uczuciami innych. Twoja inteligencja emocjonalna jest twoją supermocą. Prowadź z miłością."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maturidade emocional, compaixão, intuição e cuidado. Você está profundamente conectado aos seus sentimentos e aos dos outros. Sua inteligência emocional é seu superpoder. Lidere com amor."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Känslomässig mognad, medkänsla, intuition och omtanke. Du är djupt ansluten till dina känslor och andras. Din emotionella intelligens är din superkraft. Leda med kärlek."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Емоційна зрілість, співчуття, інтуїція та турбота. Ви глибоко пов'язані зі своїми почуттями та почуттями інших. Ваш емоційний інтелект — це ваша суперсила. Ведіть з любов'ю."
          }
        }
      }
    },
    "interpretation.queen_of_cups_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gesundheitliche Überforderung oder emotionale Überflutung beeinträchtigt das Wohlbefinden. Schlechte Selbstfürsorge durch die Fürsorge für andere. Bedarf an Grenzen und persönlichem Gesundheitsfokus."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Health overwhelm or emotional flooding affecting wellness. Poor self-care due to caring for others. Need for boundaries and personal health focus."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Agobio de salud o inundación emocional que afecta el bienestar. Mal autocuidado debido al cuidado de los demás. Necesidad de límites y enfoque en la salud personal."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dépassement de la santé ou submersion émotionnelle affectant le bien-être. Mauvaise estime de soi due au souci des autres. Besoin de limites et d'une attention personnelle à la santé."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sovraccarico di salute o inondazione emotiva che influisce sul benessere. Scarsa cura di sé a causa della cura degli altri. Necessità di confini e focus sulla salute personale."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "健康への圧倒や感情的な氾濫が健康に影響。他人の世話による自己管理不足。境界線と個人の健康への集中が必要。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Helseoverveldelse eller følelsesmessig flom som påvirker velvære. Dårlig egenomsorg på grunn av omsorg for andre. Behov for grenser og personlig helsefokus."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przeciążenie zdrowotne lub zalew emocji wpływający na samopoczucie. Słaba samoopieka z powodu opieki nad innymi. Potrzeba granic i skupienia się na zdrowiu osobistym."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sobrecarga de saúde ou inundação emocional afetando o bem-estar. Mau autocuidado devido a cuidar dos outros. Necessidade de limites e foco na saúde pessoal."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hälsoöverväldigande eller känslomässig översvämning som påverkar välmåendet. Dålig egenvård på grund av att ta hand om andra. Behov av gränser och personligt hälsofokus."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Перевантаження здоров'ям або емоційне затоплення, що впливає на самопочуття. Поганий самодогляд через турботу про інших. Потреба в межах та особистому фокусі на здоров'я."
          }
        }
      }
    },
    "interpretation.queen_of_cups_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Emotional sicherer Ansatz für die Gesundheit. Intuitives Verständnis der Bedürfnisse deines Körpers. Mitfühlende Selbstfürsorge. Emotionale Heilung unterstützt körperliches Wohlbefinden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Emotionally secure approach to health. Intuitive understanding of your body's needs. Compassionate self-care. Emotional healing supports physical wellness."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enfoque de salud emocionalmente seguro. Comprensión intuitiva de las necesidades de tu cuerpo. Autocuidado compasivo. La sanación emocional apoya el bienestar físico."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Approche de la santé émotionnellement sûre. Compréhension intuitive des besoins de votre corps. Soins personnels compatissants. La guérison émotionnelle soutient le bien-être physique."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Approccio alla salute emotivamente sicuro. Comprensione intuitiva dei bisogni del tuo corpo. Cura di sé compassionevole. La guarigione emotiva supporta il benessere fisico."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "感情的に安全な健康法。身体のニーズに対する直感的理解。思いやりのあるセルフケア。感情的癒しが身体の健康を支える。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Følelsesmessig trygg tilnærming til helse. Intuitiv forståelse av kroppens behov. Medfølende egenomsorg. Emosjonell helbredelse støtter fysisk velvære."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Emocjonalnie bezpieczne podejście do zdrowia. Intuicyjne rozumienie potrzeb swojego ciała. Współczująca samoopieka. Uzdrowienie emocjonalne wspiera dobre samopoczucie fizyczne."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abordagem emocionalmente segura para a saúde. Compreensão intuitiva das necessidades do seu corpo. Autocuidado compassivo. Cura emocional apoia o bem-estar físico."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Känslomässigt trygg inställning till hälsa. Intuitiv förståelse för din kropps behov. Medkännande egenvård. Känslomässig läkning stödjer fysiskt välmående."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Емоційно безпечний підхід до здоров'я. Інтуїтивне розуміння потреб вашого тіла. Співчутливий самодогляд. Емоційне зцілення підтримує фізичне благополуччя."
          }
        }
      }
    },
    "interpretation.queen_of_cups_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Emotionale Unsicherheit in Beziehungen. Koabhängigkeit oder Märtyrertum beeinflusst die Liebe. Von den Emotionen anderer überwältigt. Bedarf an besseren Grenzen und Selbstfürsorge."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Emotional insecurity in relationships. Codependency or martyrdom affects love. Overwhelmed by others' emotions. Need for better boundaries and self-care."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inseguridad emocional en las relaciones. La codependencia o el martirio afectan al amor. Abrumado por las emociones de los demás. Necesidad de mejores límites y autocuidado."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Insécurité émotionnelle dans les relations. La codépendance ou le martyre affecte l'amour. Débordé par les émotions des autres. Besoin de meilleures limites et de soins personnels."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Insicurezza emotiva nelle relazioni. La codipendenza o il martirio influenzano l'amore. Sopraffatto dalle emozioni altrui. Necessità di migliori confini e cura di sé."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "人間関係における感情的不安。共依存や殉教者のような態度が愛に影響。他人の感情に圧倒される。より良い境界線とセルフケアが必要。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Emosjonell usikkerhet i relasjoner. Medavhengighet eller martyrium påvirker kjærligheten. Overveldet av andres følelser. Behov for bedre grenser og egenomsorg."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niepewność emocjonalna w związkach. Współuzależnienie lub męczeństwo wpływa na miłość. Przytłoczony emocjami innych. Potrzeba lepszych granic i samoopieki."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Insegurança emocional nos relacionamentos. Codependência ou martírio afeta o amor. Sobrecarregado pelas emoções dos outros. Necessidade de melhores limites e autocuidado."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Känslomässig osäkerhet i relationer. Medberoende eller martyrium påverkar kärleken. Överväldigad av andras känslor. Behov av bättre gränser och egenvård."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Емоційна невпевненість у стосунках. Співзалежність або мучеництво впливають на любов. Перевантаження емоціями інших. Потреба в кращих межах і самодогляді."
          }
        }
      }
    },
    "interpretation.queen_of_cups_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Emotional reife, intuitive und zutiefst fürsorgliche Liebe. Du oder dein Partner verkörpert mitfühlendes Verständnis. Emotionale Sicherheit ermöglicht Verletzlichkeit. Nährende Liebe fließt frei."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Emotionally mature, intuitive, and deeply caring love. You or your partner embody compassionate understanding. Emotional security allows vulnerability. Nurturing love flows freely."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Amor emocionalmente maduro, intuitivo y profundamente afectuoso. Tú o tu pareja encarnan la comprensión compasiva. La seguridad emocional permite la vulnerabilidad. El amor nutritivo fluye libremente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Amour émotionnellement mature, intuitif et profondément attentionné. Vous ou votre partenaire incarnez une compréhension compatissante. La sécurité émotionnelle permet la vulnérabilité. Un amour nourrissant coule librement."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Amore emotivamente maturo, intuitivo e profondamente premuroso. Tu o il tuo partner incarnate una comprensione compassionevole. La sicurezza emotiva permette la vulnerabilità. Un amore nutriente scorre liberamente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "感情的成熟、直感的、深い思いやりのある愛。あなたまたはパートナーが共感的理解を体現。感情的安定が弱さを見せることを可能にする。育む愛が自由に流れる。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Følelsesmessig moden, intuitiv og dypt omsorgsfull kjærlighet. Du eller partneren din legemliggjør medfølende forståelse. Emosjonell trygghet tillater sårbarhet. Nærende kjærlighet flyter fritt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Miłość dojrzała emocjonalnie, intuicyjna i głęboko troskliwa. Ty lub twój partner ucieleśniacie współczujące zrozumienie. Bezpieczeństwo emocjonalne pozwala na wrażliwość. Troskliwa miłość płynie swobodnie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Amor emocionalmente maduro, intuitivo e profundamente carinhoso. Você ou seu parceiro incorporam compreensão compassiva. Segurança emocional permite vulnerabilidade. Amor nutritivo flui livremente."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Känslomässigt mogen, intuitiv och djupt omtänksam kärlek. Du eller din partner förkroppsligar medkännande förståelse. Känslomässig trygghet tillåter sårbarhet. Närande kärlek flödar fritt."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Емоційно зріле, інтуїтивне та глибоко турботливе кохання. Ви або ваш партнер втілюєте співчутливе розуміння. Емоційна безпека дозволяє вразливість. Живильна любов тече вільно."
          }
        }
      }
    },
    "interpretation.queen_of_pentacles_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vernachlässigung der Selbstfürsorge durch Arbeitsanforderungen oder erdrückende Kollegen. Das Ungleichgewicht zwischen Arbeit und Zuhause schafft Probleme. Berufliche Eifersucht oder Materialismus beeinträchtigen die Karriere."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Self-care neglect from work demands or smothering colleagues. Work-home imbalance creates problems. Professional jealousy or materialism affects career."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abandono del autocuidado por las exigencias del trabajo o compañeros asfixiantes. El desequilibrio entre el trabajo y el hogar crea problemas. Los celos profesionales o el materialismo afectan la carrera."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Négligence des soins personnels en raison des exigences du travail ou de collègues étouffants. Le déséquilibre entre le travail et la maison crée des problèmes. La jalousie professionnelle ou le matérialisme affectent la carrière."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trascurare la cura di sé a causa delle richieste del lavoro o colleghi soffocanti. Lo squilibrio tra lavoro e casa crea problemi. La gelosia professionale o il materialismo influiscono sulla carriera."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "仕事の要求や過保護な同僚によるセルフケアの怠慢。仕事と家庭の不均衡が問題を生む。職業上の嫉妬や物質主義がキャリアに影響する。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Forsømmelse av egenomsorg på grunn av arbeidskrav eller overbeskyttende kolleger. Ubalanse mellom arbeid og hjem skaper problemer. Profesjonell sjalusi eller materialisme påvirker karrieren."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zaniedbanie samoopieki z powodu wymagań pracy lub przytłaczających współpracowników. Brak równowagi między pracą a domem stwarza problemy. Zazdrość zawodowa lub materializm wpływają na karierę."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Negligência do autocuidado devido às demandas de trabalho ou colegas sufocantes. Desequilíbrio entre trabalho e lar cria problemas. Ciúmes profissional ou materialismo afetam a carreira."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Försummelse av egenvård på grund av arbetskrav eller kvävande kollegor. Obalans mellan arbete och hem skapar problem. Professionell avundsjuka eller materialism påverkar karriären."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Нехтування самообслуговуванням через робочі вимоги або колег, які душать. Дисбаланс між роботою та домом створює проблеми. Професійна ревнощі або матеріалізм впливають на кар'єру."
          }
        }
      }
    },
    "interpretation.queen_of_pentacles_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fürsorglicher, praktischer professioneller Ansatz. Bodenständige Führung und Fürsorge für das Team. Ihre Bodenständigkeit schafft Sicherheit am Arbeitsplatz. Erfolg durch Fürsorge."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nurturing, practical professional approach. Down-to-earth leadership and providing for team. Your groundedness creates workplace security. Success through caring."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enfoque profesional cariñoso y práctico. Liderazgo con los pies en la tierra y proveer para el equipo. Tu arraigo crea seguridad en el lugar de trabajo. Éxito a través del cuidado."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Approche professionnelle bienveillante et pratique. Leadership terre-à-terre et soutien à l'équipe. Votre ancrage crée la sécurité au travail. Succès grâce à l'attention."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Approccio professionale nutriente e pratico. Leadership con i piedi per terra e supporto al team. La tua concretezza crea sicurezza sul posto di lavoro. Successo attraverso la cura."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "養育的で実用的な専門的アプローチ。地に足のついたリーダーシップとチームへの提供。あなたの地に足のついた姿勢が職場の安全を生み出す。思いやりを通じた成功。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Omsorgsfull, praktisk profesjonell tilnærming. Jordnær ledelse og forsørgelse av teamet. Din jordnærhet skaper trygghet på arbeidsplassen. Suksess gjennom omsorg."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opiekuńcze, praktyczne podejście zawodowe. Przyziemne przywództwo i zapewnianie zespołowi. Twoja uziemienie tworzy bezpieczeństwo w miejscu pracy. Sukces poprzez troskę."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abordagem profissional nutritiva e prática. Liderança pé no chão e provedora da equipe. Sua base cria segurança no local de trabalho. Sucesso através do cuidado."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Omhändertagande, praktiskt professionellt förhållningssätt. Jordnär ledarskap och försörjning av teamet. Din jordnärhet skapar arbetsplatssäkerhet. Framgång genom omtanke."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Піклувальний, практичний професійний підхід. Приземлене лідерство та забезпечення команди. Ваша приземленість створює безпеку на робочому місці. Успіх через турботу."
          }
        }
      }
    },
    "interpretation.queen_of_pentacles_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vernachlässigung der finanziellen Selbstfürsorge oder Geldbesessenheit. Materialismus über das Wohlbefinden. Eifersucht auf den Reichtum anderer. Das Ungleichgewicht zwischen Arbeit und Leben wirkt sich auf die Finanzen aus."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial self-care neglect or money obsession. Materialism over wellbeing. Jealousy about others' wealth. Work-life imbalance affects finances."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abandono del autocuidado financiero u obsesión por el dinero. Materialismo por encima del bienestar. Celos por la riqueza de los demás. El desequilibrio entre la vida laboral y personal afecta las finanzas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Négligence des soins personnels financiers ou obsession de l'argent. Matérialisme plutôt que bien-être. Jalousie face à la richesse des autres. Le déséquilibre entre vie professionnelle et vie privée affecte les finances."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trascurare la cura di sé finanziaria o ossessione del denaro. Materialismo sul benessere. Gelosia per la ricchezza altrui. Lo squilibrio tra lavoro e vita privata influisce sulle finanze."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的なセルフケアの怠慢またはお金への執着。幸福よりも物質主義。他人の富への嫉妬。ワークライフバランスの不均衡が経済に影響する。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Forsømmelse av økonomisk egenomsorg eller pengebesettelse. Materialisme fremfor velvære. Sjalusi over andres rikdom. Ubalanse mellom arbeid og liv påvirker økonomien."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zaniedbanie samoopieki finansowej lub obsesja na punkcie pieniędzy. Materializm kosztem dobrego samopoczucia. Zazdrość o bogactwo innych. Brak równowagi między pracą a życiem wpływa na finanse."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Negligência do autocuidado financeiro ou obsessão por dinheiro. Materialismo sobre o bem-estar. Ciúmes da riqueza dos outros. Desequilíbrio entre trabalho e vida afeta as finanças."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Försummelse av ekonomisk egenvård eller pengebesatthet. Materialism framför välbefinnande. Avundsjuka över andras rikedom. Obalans mellan arbete och liv påverkar ekonomin."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Нехтування фінансовим самообслуговуванням або одержимість грошима. Матеріалізм над добробутом. Ревнощі до багатства інших. Дисбаланс між роботою та життям впливає на фінанси."
          }
        }
      }
    },
    "interpretation.queen_of_pentacles_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fürsorglicher, praktischer Umgang mit Geld. Bodenständiger Wohlstand und finanzielle Fürsorge. Geerdete Großzügigkeit schafft Fülle. Reichtum mit Wärme."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nurturing, practical approach to money. Down-to-earth prosperity and financial providing. Grounded generosity creates abundance. Wealth with warmth."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enfoque del dinero cariñoso y práctico. Prosperidad con los pies en la tierra y provisión financiera. La generosidad arraigada crea abundancia. Riqueza con calidez."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Approche bienveillante et pratique de l'argent. Prospérité terre-à-terre et soutien financier. La générosité ancrée crée l'abondance. Richesse avec chaleur."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Approccio nutriente e pratico al denaro. Prosperità con i piedi per terra e supporto finanziario. La generosità con i piedi per terra crea abbondanza. Ricchezza con calore."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "お金に対する養育的で実用的なアプローチ。地に足のついた繁栄と経済的提供。地に足のついた寛大さが豊かさを生み出す。温かみのある富。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Omsorgsfull, praktisk tilnærming til penger. Jordnær velstand og økonomisk forsørgelse. Jordnær sjenerøsitet skaper overflod. Rikdom med varme."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opiekuńcze, praktyczne podejście do pieniędzy. Przyziemny dobrobyt i finansowe zabezpieczenie. Uziemiona hojność tworzy obfitość. Bogactwo z ciepłem."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abordagem nutritiva e prática ao dinheiro. Prosperidade pé no chão e provisão financeira. Generosidade fundamentada cria abundância. Riqueza com calor."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Omhändertagande, praktiskt förhållningssätt till pengar. Jordnär välstånd och ekonomisk försörjning. Jordnär generositet skapar överflöd. Rikedom med värme."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Піклувальний, практичний підхід до грошей. Приземлене процвітання та фінансове забезпечення. Приземлена щедрість створює достаток. Багатство з теплом."
          }
        }
      }
    },
    "interpretation.queen_of_pentacles_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vernachlässigung der Selbstfürsorge, Ungleichgewicht zwischen Arbeit und Zuhause, Erdrücken oder Eifersucht. Sie geben entweder zu viel oder sind besessen von materiellen Angelegenheiten. Stellen Sie das Gleichgewicht wieder her."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Self-care neglect, work-home imbalance, smothering, or jealousy. You're either giving too much or obsessing over material concerns. Restore balance."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abandono del autocuidado, desequilibrio entre el trabajo y el hogar, asfixia o celos. O estás dando demasiado o estás obsesionado con las preocupaciones materiales. Restablece el equilibrio."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Négligence des soins personnels, déséquilibre entre le travail et la maison, étouffement ou jalousie. Vous donnez soit trop, soit vous êtes obsédé par les préoccupations matérielles. Rétablir l'équilibre."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trascurare la cura di sé, squilibrio tra lavoro e casa, soffocamento o gelosia. O stai dando troppo o sei ossessionato dalle preoccupazioni materiali. Ripristina l'equilibrio."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "セルフケアの怠慢、仕事と家庭の不均衡、過保護、または嫉妬。あなたは与えすぎているか、物質的な問題に執着している。バランスを回復せよ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Forsømmelse av egenomsorg, ubalanse mellom arbeid og hjem, overbeskyttelse eller sjalusi. Du gir enten for mye eller er besatt av materielle bekymringer. Gjenopprett balansen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zaniedbanie samoopieki, brak równowagi między pracą a domem, przytłaczanie lub zazdrość. Albo dajesz za dużo, albo jesteś obsesyjny na punkcie spraw materialnych. Przywróć równowagę."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Negligência do autocuidado, desequilíbrio entre trabalho e lar, sufocamento ou ciúmes. Você ou está dando demais ou está obcecado por preocupações materiais. Restaure o equilíbrio."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Försummelse av egenvård, obalans mellan arbete och hem, kvävande eller avundsjuka. Du ger antingen för mycket eller är besatt av materiella bekymmer. Återställ balansen."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Нехтування самообслуговуванням, дисбаланс між роботою та домом, надмірна турбота або ревнощі. Ви або даєте занадто багато, або одержимі матеріальними проблемами. Відновіть баланс."
          }
        }
      }
    },
    "interpretation.queen_of_pentacles_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fürsorglich, praktisch, versorgend und bodenständig. Sie schaffen Sicherheit durch geerdete Fürsorge. Finanzieller und emotionaler Wohlstand fließen aus Ihrer Wärme. Zuhause und Arbeit harmonieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nurturing, practical, providing, and down-to-earth. You create security through grounded care. Financial and emotional abundance flow from your warmth. Home and work harmonize."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cariñosa, práctica, proveedora y con los pies en la tierra. Creas seguridad a través del cuidado con los pies en la tierra. La abundancia financiera y emocional fluye de tu calidez. El hogar y el trabajo armonizan."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bienveillante, pratique, pourvoyeuse et terre-à-terre. Vous créez la sécurité grâce à des soins ancrés. L'abondance financière et émotionnelle découle de votre chaleur. La maison et le travail s'harmonisent."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nutriente, pratica, provvidente e con i piedi per terra. Crea sicurezza attraverso una cura con i piedi per terra. L'abbondanza finanziaria ed emotiva scorre dalla tua calore. Casa e lavoro si armonizzano."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "養育的、実用的、提供者、そして地に足がついている。あなたは地に足のついたケアを通じて安全を生み出す。あなたの温かさから経済的・感情的な豊かさが流れる。家と仕事が調和する。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Omsorgsfull, praktisk, forsørgende og jordnær. Du skaper trygghet gjennom jordnær omsorg. Økonomisk og følelsesmessig overflod flyter fra din varme. Hjem og arbeid harmonerer."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opiekuńcza, praktyczna, zapewniająca i przyziemna. Tworzysz bezpieczeństwo poprzez uziemioną opiekę. Obfitość finansowa i emocjonalna płynie z twojego ciepła. Dom i praca harmonizują."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nutritiva, prática, provedora e pé no chão. Você cria segurança através de cuidados fundamentados. Abundância financeira e emocional flui do seu calor. Lar e trabalho harmonizam."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Omhändertagande, praktisk, försörjande och jordnär. Du skapar trygghet genom jordnär omsorg. Ekonomisk och känslomässig överflöd flyter från din värme. Hem och arbete harmoniserar."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Піклувальна, практична, забезпечуюча та приземлена. Ви створюєте безпеку через приземлену турботу. Фінансовий та емоційний достаток тече з вашого тепла. Дім і робота гармонізують."
          }
        }
      }
    },
    "interpretation.queen_of_pentacles_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vernachlässigung der Selbstfürsorge durch die Fürsorge für andere. Ungleichgewicht zwischen Arbeit und Gesundheit. Erdrückende Sorgen um den Körper. Praktische Grenzen für die Selbstfürsorge sind nötig."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Self-care neglect from caring for others. Work-health imbalance. Smothering concerns about body. Need practical self-care boundaries."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abandono del autocuidado por cuidar de los demás. Desequilibrio entre trabajo y salud. Preocupaciones asfixiantes por el cuerpo. Se necesitan límites prácticos de autocuidado."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Négligence des soins personnels due aux soins des autres. Déséquilibre entre travail et santé. Préoccupations étouffantes concernant le corps. Besoin de limites pratiques en matière d'autosoins."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trascurare la cura di sé per prendersi cura degli altri. Squilibrio tra lavoro e salute. Preoccupazioni soffocanti per il corpo. Necessità di confini pratici per la cura di sé."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "他人の世話をすることでセルフケアを怠る。仕事と健康の不均衡。身体への過度な心配。実用的なセルフケアの境界線が必要。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Forsømmelse av egenomsorg på grunn av omsorg for andre. Ubalanse mellom arbeid og helse. Overbeskyttende bekymringer for kroppen. Trenger praktiske egenomsorgsgrenser."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zaniedbanie samoopieki z powodu opieki nad innymi. Brak równowagi między pracą a zdrowiem. Przytłaczające zmartwienia dotyczące ciała. Potrzeba praktycznych granic samoopieki."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Negligência do autocuidado por cuidar dos outros. Desequilíbrio entre trabalho e saúde. Preocupações sufocantes sobre o corpo. Limites práticos de autocuidado necessários."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Försummelse av egenvård på grund av att ta hand om andra. Obalans mellan arbete och hälsa. Kvävande oro för kroppen. Behöver praktiska egenvårdsgränser."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Нехтування самообслуговуванням через турботу про інших. Дисбаланс між роботою та здоров'ям. Надмірне занепокоєння тілом. Потрібні практичні межі самообслуговування."
          }
        }
      }
    },
    "interpretation.queen_of_pentacles_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fürsorglicher, praktischer Ansatz für das Wohlbefinden. Bodenständige Selbstfürsorge und körperbewusste Entscheidungen. Geerdete Gesundheitspraktiken. Für die Bedürfnisse Ihres Körpers sorgen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nurturing, practical approach to wellness. Down-to-earth self-care and body-wise decisions. Grounded health practices. Providing for your body's needs."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enfoque de bienestar cariñoso y práctico. Autocuidado con los pies en la tierra y decisiones corporales inteligentes. Prácticas de salud arraigadas. Atendiendo las necesidades de tu cuerpo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Approche bienveillante et pratique du bien-être. Autosoins terre-à-terre et décisions corporelles judicieuses. Pratiques de santé ancrées. Répondre aux besoins de votre corps."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Approccio nutriente e pratico al benessere. Cura di sé con i piedi per terra e decisioni consapevoli del corpo. Pratiche sanitarie con i piedi per terra. Provvedere ai bisogni del tuo corpo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "養育的で実用的なウェルネスアプローチ。地に足のついたセルフケアと身体に賢い決断。地に足のついた健康習慣。身体のニーズに応える。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Omsorgsfull, praktisk tilnærming til velvære. Jordnær egenomsorg og kroppsvise beslutninger. Jordnær helsepraksis. Å dekke kroppens behov."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opiekuńcze, praktyczne podejście do wellness. Przyziemna samoopieka i mądre decyzje dotyczące ciała. Uziemione praktyki zdrowotne. Zapewnianie potrzebom twojego ciała."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abordagem nutritiva e prática ao bem-estar. Autocuidado pé no chão e decisões corporais sábias. Práticas de saúde fundamentadas. Provendo as necessidades do seu corpo."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Omhändertagande, praktiskt förhållningssätt till hälsa och välmående. Jordnär egenvård och kroppskloka beslut. Jordnär hälsopraxis. Att tillgodose din kropps behov."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Піклувальний, практичний підхід до оздоровлення. Приземлене самообслуговування та тілесно-мудрі рішення. Приземлені оздоровчі практики. Забезпечення потреб вашого тіла."
          }
        }
      }
    },
    "interpretation.queen_of_pentacles_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vernachlässigung der Selbstfürsorge in der Beziehung oder erdrückende Partnerschaft. Ungleichgewicht zwischen Arbeit und Zuhause beeinträchtigt die Liebe. Eifersucht oder Materialismus schaden der Partnerschaft. Bessere Grenzen sind nötig."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Self-care neglect in relationship or smothering partner. Work-home imbalance affects love. Jealousy or materialism damages partnership. Need better boundaries."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abandono del autocuidado en la relación o pareja asfixiante. El desequilibrio entre el trabajo y el hogar afecta al amor. Los celos o el materialismo dañan la sociedad. Se necesitan mejores límites."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Négligence des soins personnels dans la relation ou partenaire étouffant. Le déséquilibre entre le travail et la maison affecte l'amour. La jalousie ou le matérialisme nuisent au partenariat. Besoin de meilleures limites."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trascurare la cura di sé nella relazione o partner soffocante. Lo squilibrio tra lavoro e casa influisce sull'amore. La gelosia o il materialismo danneggiano la partnership. Necessità di migliori confini."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "関係におけるセルフケアの怠慢またはパートナーを過保護にすること。仕事と家庭の不均衡が愛に影響。嫉妬や物質主義がパートナーシップを損なう。より良い境界線が必要。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Forsømmelse av egenomsorg i forholdet eller overbeskyttende partner. Ubalanse mellom arbeid og hjem påvirker kjærligheten. Sjalusi eller materialisme skader partnerskapet. Trenger bedre grenser."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zaniedbanie samoopieki w związku lub przytłaczanie partnera. Brak równowagi między pracą a domem wpływa na miłość. Zazdrość lub materializm szkodzą partnerstwu. Potrzeba lepszych granic."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Negligência do autocuidado no relacionamento ou parceiro sufocante. Desequilíbrio entre trabalho e lar afeta o amor. Ciúmes ou materialismo prejudicam a parceria. Melhores limites necessários."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Försummelse av egenvård i relationen eller kvävande partner. Obalans mellan arbete och hem påverkar kärleken. Avundsjuka eller materialism skadar partnerskapet. Behöver bättre gränser."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Нехтування самообслуговуванням у стосунках або партнер, який душить. Дисбаланс між роботою та домом впливає на любов. Ревнощі або матеріалізм шкодять партнерству. Потрібні кращі межі."
          }
        }
      }
    },
    "interpretation.queen_of_pentacles_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
