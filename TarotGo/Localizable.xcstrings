        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'équilibre, la modération et la patience guident votre chemin. Combinez habilement les contraires. L'harmonie vient par la voie médiane. Faites confiance au timing divin."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Equilibrio, moderazione e pazienza guidano il tuo cammino. Combina abilmente gli opposti. L'armonia arriva attraverso la via di mezzo. Fidati del tempismo divino."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "バランス、節度、忍耐があなたの道を導きます。対立するものを巧みに組み合わせてください。調和は中間の道を通してやって来ます。神のタイミングを信頼してください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Balanse, måtehold og tålmodighet veileder veien din. Kombiner motsetninger dyktig. Harmoni kommer gjennom midtveien. Stol på guddommelig timing."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Równowaga, umiar i cierpliwość kierują twoją ścieżką. Umiejętnie łącz przeciwieństwa. Harmonia przychodzi poprzez złoty środek. Ufaj boskiemu wyczuciu czasu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Equilíbrio, moderação e paciência guiam seu caminho. Combine opostos habilmente. A harmonia vem através do meio termo. Confie no tempo divino."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Balans, måttfullhet och tålamod vägleder din väg. Kombinera motsatser skickligt. Harmoni kommer genom mittvägen. Lita på gudomlig timing."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Баланс, помірність і терпіння спрямовують ваш шлях. Вміло поєднуйте протилежності. Гармонія приходить через середину. Довіряйте божественному часу."
          }
        }
      }
    },
    "interpretation.temperance_health_reversed" : {
