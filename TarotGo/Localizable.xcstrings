          }
        }
      }
    },
    "interpretation.page_of_pentacles_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gesundheitliche Prokrastination oder schlechte Wellness-Planung. Verpasste Gesundheitschance. Mangel an körperlichem Fortschritt. Bessere Gesundheitsbildung und Handeln sind nötig."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
