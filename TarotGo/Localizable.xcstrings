          }
        }
      }
    },
    "interpretation.the_moon_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Illusion, Intuition, Angst und unbewusste Kräfte. Nicht alles ist so, wie es scheint. Vertraue deinem inneren Wissen, um Unsicherheit und Geheimnisse zu navigieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Illusion, intuition, anxiety, and subconscious forces. Not everything is as it seems. Trust your inner knowing to navigate uncertainty and mystery."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ilusión, intuición, ansiedad y fuerzas subconscientes. No todo es lo que parece. Confía en tu conocimiento interno para navegar la incertidumbre y el misterio."
