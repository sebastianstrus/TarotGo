        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uzdrowienie i odnowa zdrowia. Po chorobie powraca nadzieja. Duchowe praktyki lecznicze wspomagają powrót do zdrowia. Twoje ciało się regeneruje."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cura e renovação da saúde. Após a doença, a esperança retorna. Práticas de cura espiritual apoiam a recuperação. Seu corpo está se regenerando."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hälsoläkning och förnyelse. Efter sjukdom återvänder hoppet. Andliga läkningsmetoder stödjer återhämtning. Din kropp regenererar."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Оздоровче зцілення та оновлення. Після хвороби повертається надія. Духовні практики зцілення підтримують одужання. Ваше тіло регенерує."
          }
        }
      }
    },
    "interpretation.the_star_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hoffnungslosigkeit oder Trennung in der Liebe. Pessimismus blockiert romantische Möglichkeiten. Verbinde dich wieder mit dem Glauben an das Potenzial der Liebe."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hopelessness or disconnection in love. Pessimism blocks romantic possibility. Reconnect with faith in love's potential."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desesperanza o desconexión en el amor. El pesimismo bloquea las posibilidades románticas. Reconecta con la fe en el potencial del amor."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Désespoir ou déconnexion en amour. Le pessimisme bloque les possibilités romantiques. Renouez avec la foi dans le potentiel de l'amour."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Speranza o disconnessione in amore. Il pessimismo blocca le possibilità romantiche. Riconnettiti con la fede nel potenziale dell'amore."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "恋愛における絶望や断絶。悲観主義がロマンスの可能性を妨げます。愛の可能性への信仰と再びつながってください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Håpløshet eller frakobling i kjærlighet. Pessimisme blokkerer romantiske muligheter. Gjenopprett forbindelsen med troen på kjærlighetens potensial."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beznadziejność lub odłączenie w miłości. Pesymizm blokuje romantyczne możliwości. Połącz się ponownie z wiarą w potencjał miłości."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desesperança ou desconexão no amor. O pessimismo bloqueia as possibilidades românticas. Reconecte-se com a fé no potencial do amor."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hopplöshet eller frånkoppling i kärlek. Pessimism blockerar romantiska möjligheter. Återknyt kontakten med tron på kärlekens potential."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Безнадія або роз'єднання в коханні. Песимізм блокує романтичні можливості. Возз'єднайтеся з вірою в потенціал кохання."
          }
        }
      }
    },
    "interpretation.the_star_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hoffnung, Heilung und Erneuerung in der Liebe. Nach schwierigen Zeiten kehrt der Optimismus zurück. Eine spirituell verbundene Verbindung oder ein neuer Glaube an die Romantik. Du wirst zur wahren Liebe geführt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hope, healing, and renewal in love. After difficulty, optimism returns. A spiritually aligned connection or renewed faith in romance. You're being guided toward true love."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esperanza, curación y renovación en el amor. Después de la dificultad, regresa el optimismo. Una conexión espiritualmente alineada o una fe renovada en el romance. Estás siendo guiado hacia el amor verdadero."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Espoir, guérison et renouveau en amour. Après les difficultés, l'optimisme revient. Une connexion spirituellement alignée ou une foi renouvelée dans la romance. Vous êtes guidé vers le véritable amour."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Speranza, guarigione e rinnovamento nell'amore. Dopo le difficoltà, l'ottimismo ritorna. Una connessione spiritualmente allineata o una rinnovata fede nel romanticismo. Sei guidato verso il vero amore."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "恋愛における希望、癒し、再生。困難の後、楽観主義が戻ってきます。精神的に調和したつながり、または恋愛に対する新たな信仰。あなたは真実の愛へと導かれています。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Håp, helbredelse og fornyelse i kjærlighet. Etter vanskeligheter kommer optimismen tilbake. En åndelig tilpasset forbindelse eller fornyet tro på romantikk. Du blir ledet mot sann kjærlighet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nadzieja, uzdrowienie i odnowa w miłości. Po trudnościach wraca optymizm. Duchowo dostrojone połączenie lub odnowiona wiara w romans. Jesteś prowadzony ku prawdziwej miłości."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esperança, cura e renovação no amor. Após a dificuldade, o otimismo retorna. Uma conexão espiritualmente alinhada ou fé renovada no romance. Você está sendo guiado em direção ao amor verdadeiro."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hopp, läkning och förnyelse i kärlek. Efter svårigheter återvänder optimismen. En andligt anpassad anslutning eller förnyad tro på romantik. Du leds mot sann kärlek."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Надія, зцілення та оновлення в коханні. Після труднощів оптимізм повертається. Духовно узгоджений зв'язок або оновлена віра в романтику. Вас ведуть до справжнього кохання."
          }
        }
      }
    },
    "interpretation.the_sun_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vorübergehende berufliche Rückschläge oder getrübte Berufsfreude. Pessimismus in Bezug auf die Arbeit trübt deine Sicht. Denke daran, dass dies vorübergehend ist – der Erfolg wird zurückkehren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Temporary career setbacks or dimmed professional joy. Pessimism about work clouds your vision. Remember this is temporary—success returns."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reveses profesionales temporales o alegría profesional empañada. El pesimismo sobre el trabajo nubla tu visión. Recuerda que esto es temporal, el éxito regresa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Revers professionnels temporaires ou joie professionnelle ternie. Le pessimisme concernant le travail obscurcit votre vision. Rappelez-vous que c'est temporaire – le succès revient."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Battute d'arresto professionali temporanee o gioia professionale offuscata. Il pessimismo sul lavoro offusca la tua visione. Ricorda che questo è temporaneo – il successo tornerà."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一時的なキャリアの挫折や職業上の喜びの低下。仕事に対する悲観主義があなたの視界を曇らせます。これは一時的なものであることを忘れないでください – 成功は戻ってきます。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Midlertidige karrieretilbakeslag eller dempet jobbglede. Pessimisme om arbeid tilslører synet ditt. Husk at dette er midlertidig – suksess kommer tilbake."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tymczasowe niepowodzenia zawodowe lub przyćmiona radość z pracy. Pesymizm dotyczący pracy zaciemnia twój wzrok. Pamiętaj, że to tymczasowe – sukces powróci."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Contratempos temporários na carreira ou alegria profissional diminuída. O pessimismo sobre o trabalho obscurece sua visão. Lembre-se de que isso é temporário – o sucesso retorna."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tillfälliga karriärmotgångar eller dämpad arbetsglädje. Pessimism om arbete grumlar din syn. Kom ihåg att detta är tillfälligt – framgången återvänder."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Тимчасові кар'єрні невдачі або приглушена професійна радість. Песимізм щодо роботи затьмарює ваш погляд. Пам'ятайте, що це тимчасово – успіх повернеться."
          }
        }
      }
    },
    "interpretation.the_sun_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beruflicher Erfolg und Anerkennung leuchten hell. Deine Arbeit bringt Freude und Auszeichnungen. Berufliche Vitalität und positive Energie ziehen Chancen an."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Career success and recognition shine brightly. Your work brings joy and accolades. Professional vitality and positive energy attract opportunities."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El éxito y el reconocimiento profesional brillan intensamente. Tu trabajo trae alegría y reconocimientos. La vitalidad profesional y la energía positiva atraen oportunidades."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le succès et la reconnaissance professionnels brillent de mille feux. Votre travail apporte joie et distinctions. La vitalité professionnelle et l'énergie positive attirent les opportunités."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il successo professionale e il riconoscimento brillano intensamente. Il tuo lavoro porta gioia e riconoscimenti. La vitalità professionale e l'energia positiva attirano opportunità."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャリアの成功と評価が明るく輝いています。あなたの仕事は喜びと称賛をもたらします。職業的な活力とポジティブなエネルギーが機会を引き寄せます。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karrieresuksess og anerkjennelse skinner sterkt. Arbeidet ditt gir glede og utmerkelser. Profesjonell vitalitet og positiv energi tiltrekker muligheter."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sukces zawodowy i uznanie świecą jasno. Twoja praca przynosi radość i wyróżnienia. Witalność zawodowa i pozytywna energia przyciągają możliwości."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sucesso profissional e reconhecimento brilham intensamente. Seu trabalho traz alegria e elogios. Vitalidade profissional e energia positiva atraem oportunidades."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriärframgång och erkännande lyser starkt. Ditt arbete ger glädje och utmärkelser. Professionell vitalitet och positiv energi lockar möjligheter."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Кар'єрний успіх і визнання яскраво сяють. Ваша робота приносить радість і похвалу. Професійна життєва сила та позитивна енергія приваблюють можливості."
          }
        }
      }
    },
    "interpretation.the_sun_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vorübergehende finanzielle Enttäuschungen oder unrealistische Gelderwartungen. Traurigkeit über Ressourcen trübt das Urteilsvermögen. Die Sonne wird wieder scheinen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Temporary financial disappointments or unrealistic money expectations. Sadness about resources clouds judgment. The sun will shine again."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Decepciones financieras temporales o expectativas de dinero poco realistas. La tristeza por los recursos nubla el juicio. El sol volverá a brillar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Déceptions financières temporaires ou attentes monétaires irréalistes. La tristesse face aux ressources obscurcit le jugement. Le soleil brillera à nouveau."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Delusioni finanziarie temporanee o aspettative monetarie irrealistiche. La tristezza per le risorse offusca il giudizio. Il sole tornerà a splendere."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一時的な経済的失望や非現実的なお金への期待。リソースへの悲しみが判断を曇らせます。太陽は再び輝くでしょう。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Midlertidige økonomiske skuffelser eller urealistiske pengeforventninger. Tristhet over ressurser tilslører dømmekraften. Solen vil skinne igjen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tymczasowe rozczarowania finansowe lub nierealistyczne oczekiwania pieniężne. Smutek z powodu zasobów zaciemnia osąd. Słońce znów zaświeci."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Decepções financeiras temporárias ou expectativas irreais de dinheiro. A tristeza sobre os recursos obscurece o julgamento. O sol brilhará novamente."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tillfälliga ekonomiska besvikelser eller orealistiska penningförväntningar. Sorg över resurser grumlar omdömet. Solen kommer att skina igen."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Тимчасові фінансові розчарування або нереалістичні грошові очікування. Сум через ресурси затьмарює судження. Сонце знову засяє."
          }
        }
      }
    },
    "interpretation.the_sun_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzieller Erfolg und Wohlstand. Geld fließt mit Freude und Leichtigkeit. Deine positive Energie zieht Wohlstand an. Feiere deine Erfolge."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial success and abundance. Money flows with joy and ease. Your positive energy attracts prosperity. Celebrate your wins."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Éxito financiero y abundancia. El dinero fluye con alegría y facilidad. Tu energía positiva atrae la prosperidad. Celebra tus triunfos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Succès financier et abondance. L'argent coule avec joie et facilité. Votre énergie positive attire la prospérité. Célébrez vos victoires."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Successo finanziario e abbondanza. Il denaro scorre con gioia e facilità. La tua energia positiva attira prosperità. Celebra le tue vittorie."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的成功と豊かさ。お金は喜びとともに楽に流れます。あなたのポジティブなエネルギーが繁栄を引き寄せます。あなたの勝利を祝いましょう。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk suksess og overflod. Penger flyter med glede og letthet. Din positive energi tiltrekker velstand. Feir seirene dine."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sukces finansowy i obfitość. Pieniądze płyną z radością i łatwością. Twoja pozytywna energia przyciąga dobrobyt. Świętuj swoje zwycięstwa."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sucesso financeiro e abundância. O dinheiro flui com alegria e facilidade. Sua energia positiva atrai prosperidade. Comemore suas vitórias."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomisk framgång och överflöd. Pengar flödar med glädje och lätthet. Din positiva energi lockar välstånd. Fira dina vinster."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансовий успіх і достаток. Гроші течуть з радістю та легкістю. Ваша позитивна енергія приваблює процвітання. Відзначайте свої перемоги."
          }
        }
      }
    },
    "interpretation.the_sun_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dein inneres Licht wird vorübergehend durch Traurigkeit, Pessimismus oder Rückschläge getrübt. Das hält nicht ewig an. Mit welcher kleinen Freude kannst du dich heute verbinden? Die Sonne ist immer noch da, auch hinter den Wolken."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your inner light is temporarily dimmed by sadness, pessimism, or setbacks. This doesn't last forever. What small joy can you connect with today? The sun is still there, even behind the clouds."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu luz interior está temporalmente apagada por la tristeza, el pesimismo o los contratiempos. Esto no dura para siempre. ¿Con qué pequeña alegría puedes conectarte hoy? El sol todavía está allí, incluso detrás de las nubes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre lumière intérieure est temporairement obscurcie par la tristesse, le pessimisme ou les revers. Cela ne dure pas éternellement. À quelle petite joie pouvez-vous vous connecter aujourd'hui ? Le soleil est toujours là, même derrière les nuages."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La tua luce interiore è temporaneamente offuscata da tristezza, pessimismo o battute d'arresto. Questo non dura per sempre. A quale piccola gioia puoi connetterti oggi? Il sole è ancora lì, anche dietro le nuvole."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたの内なる光は、悲しみ、悲観主義、または挫折によって一時的に曇らされています。これは永遠に続くものではありません。今日、どんな小さな喜びにつながることができますか？雲の後ろにも、太陽はまだそこにあります。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ditt indre lys er midlertidig dempet av tristhet, pessimisme eller tilbakeslag. Dette varer ikke evig. Hvilken liten glede kan du koble deg til i dag? Solen er fortsatt der, selv bak skyene."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Twoje wewnętrzne światło jest tymczasowo przyćmione przez smutek, pesymizm lub niepowodzenia. To nie trwa wiecznie. Z jaką małą radością możesz się dziś połączyć? Słońce wciąż tam jest, nawet za chmurami."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sua luz interior está temporariamente obscurecida por tristeza, pessimismo ou contratempos. Isso não dura para sempre. Com que pequena alegria você pode se conectar hoje? O sol ainda está lá, mesmo atrás das nuvens."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ditt inre ljus är tillfälligt dämpat av sorg, pessimism eller bakslag. Detta varar inte för evigt. Vilken liten glädje kan du koppla dig till idag? Solen finns fortfarande där, även bakom molnen."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ваше внутрішнє світло тимчасово затьмарене смутком, песимізмом або невдачами. Це не триває вічно. З якою маленькою радістю ви можете з'єднатися сьогодні? Сонце все ще там, навіть за хмарами."
          }
        }
      }
    },
    "interpretation.the_sun_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erfolg, Freude und Vitalität gehören dir. Dies ist eine der positivsten Karten im Deck. Was auch immer du tust, es ist mit der Gunst des Universums gesegnet. Feiere deine Erfolge und teile dein Licht mit anderen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Success, joy, and vitality are yours. This is one of the most positive cards in the deck. Whatever you're working on is blessed with the universe's favor. Celebrate your wins and share your light with others."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El éxito, la alegría y la vitalidad son tuyos. Esta es una de las cartas más positivas de la baraja. Todo lo que estás haciendo está bendecido con el favor del universo. Celebra tus triunfos y comparte tu luz con los demás."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le succès, la joie et la vitalité sont vôtres. C'est l'une des cartes les plus positives du jeu. Tout ce sur quoi vous travaillez est béni par la faveur de l'univers. Célébrez vos victoires et partagez votre lumière avec les autres."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Successo, gioia e vitalità sono tuoi. Questa è una delle carte più positive del mazzo. Qualunque cosa tu stia facendo è benedetta dal favore dell'universo. Celebra le tue vittorie e condividi la tua luce con gli altri."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "成功、喜び、活力はあなたのものです。これはデッキの中で最もポジティブなカードの一つです。あなたが取り組んでいることは何でも、宇宙の好意に祝福されています。あなたの勝利を祝い、あなたの光を他の人と共有してください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Suksess, glede og vitalitet er dine. Dette er et av de mest positive kortene i kortstokken. Uansett hva du jobber med, er velsignet med universets gunst. Feir seirene dine og del lyset ditt med andre."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sukces, radość i witalność są twoje. To jedna z najbardziej pozytywnych kart w talii. Cokolwiek robisz, jest błogosławione przychylnością wszechświata. Świętuj swoje zwycięstwa i dziel się swoim światłem z innymi."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sucesso, alegria e vitalidade são seus. Esta é uma das cartas mais positivas do baralho. Tudo o que você está trabalhando é abençoado com o favor do universo. Comemore suas vitórias e compartilhe sua luz com os outros."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Framgång, glädje och vitalitet är dina. Detta är ett av de mest positiva korten i leken. Oavsett vad du arbetar med är välsignat med universums gunst. Fira dina segrar och dela ditt ljus med andra."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Успіх, радість і життєва сила – ваші. Це одна з найпозитивніших карт у колоді. Що б ви не робили, це благословенне прихильністю Всесвіту. Відзначайте свої перемоги та діліться своїм світлом з іншими."
          }
        }
      }
    },
    "interpretation.the_sun_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vorübergehende gesundheitliche Rückschläge oder niedrige Energie. Pessimismus in Bezug auf das Wohlbefinden. Denke daran, dass deine Vitalität zurückkehren wird – das ist nur eine vorübergehende Wolke."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Temporary health setbacks or low energy. Pessimism about wellness. Remember your vitality will return—this is just a passing cloud."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reveses de salud temporales o baja energía. Pesimismo sobre el bienestar. Recuerda que tu vitalidad regresará, esto es solo una nube pasajera."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Revers de santé temporaires ou faible énergie. Pessimisme concernant le bien-être. Rappelez-vous que votre vitalité reviendra – ce n'est qu'un nuage passager."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Battute d'arresto sanitarie temporanee o bassa energia. Pessimismo sul benessere. Ricorda che la tua vitalità tornerà – questa è solo una nuvola passeggera."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一時的な健康の後退や低エネルギー。健康への悲観主義。あなたの活力は戻ってくることを忘れないでください – これはただの通り過ぎる雲です。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Midlertidige helsetilbakeslag eller lav energi. Pessimisme om velvære. Husk at vitaliteten din kommer tilbake – dette er bare en forbigående sky."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tymczasowe niepowodzenia zdrowotne lub niska energia. Pesymizm dotyczący dobrego samopoczucia. Pamiętaj, że twoja witalność powróci – to tylko przelotna chmura."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Contratempos temporários de saúde ou baixa energia. Pessimismo sobre o bem-estar. Lembre-se de que sua vitalidade retornará – isso é apenas uma nuvem passageira."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tillfälliga hälsomässiga bakslag eller låg energi. Pessimism om välbefinnande. Kom ihåg att din vitalitet kommer att återvända – detta är bara ett förbigående moln."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Тимчасові невдачі зі здоров'ям або низька енергія. Песимізм щодо благополуччя. Пам'ятайте, що ваша життєва сила повернеться – це лише хмара, що минає."
          }
        }
      }
    },
    "interpretation.the_sun_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lebendige Gesundheit und Vitalität. Dein Körper strahlt Wohlbefinden und Freude aus. Das Energieniveau ist hoch. Feiere, wie gut du dich fühlst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vibrant health and vitality. Your body radiates wellness and joy. Energy levels are high. Celebrate feeling good."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Salud vibrante y vitalidad. Tu cuerpo irradia bienestar y alegría. Los niveles de energía son altos. Celebra sentirte bien."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Santé et vitalité vibrantes. Votre corps respire le bien-être et la joie. Les niveaux d'énergie sont élevés. Célébrez le fait de vous sentir bien."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Salute vibrante e vitalità. Il tuo corpo emana benessere e gioia. I livelli di energia sono alti. Celebra il sentirti bene."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "活気に満ちた健康と活力。あなたの体は健康と喜びを放っています。エネルギーレベルは高いです。気分が良いことを祝いましょう。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Levende helse og vitalitet. Kroppen din utstråler velvære og glede. Energinivåene er høye. Feir å føle deg bra."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Żywe zdrowie i witalność. Twoje ciało promieniuje dobrym samopoczuciem i radością. Poziomy energii są wysokie. Świętuj dobre samopoczucie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Saúde vibrante e vitalidade. Seu corpo irradia bem-estar e alegria. Os níveis de energia estão altos. Comemore sentir-se bem."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Levande hälsa och vitalitet. Din kropp utstrålar välbefinnande och glädje. Energinivåerna är höga. Fira att må bra."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Яскраве здоров'я та життєва сила. Ваше тіло випромінює благополуччя та радість. Рівні енергії високі. Відзначайте, що почуваєтеся добре."
          }
        }
      }
    },
    "interpretation.the_sun_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vorübergehende Wolken trüben dein romantisches Glück. Pessimismus oder unrealistische Erwartungen könnten die Freude blockieren. Denke daran, dass dies vorübergehend ist. Die Sonne kommt immer zurück. Passe deine Perspektive an."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Temporary clouds are dimming your romantic happiness. Pessimism or unrealistic expectations may be blocking joy. Remember that this is temporary. The sun always returns. Adjust your perspective."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nubes temporales están nublando tu felicidad romántica. El pesimismo o las expectativas poco realistas pueden estar bloqueando la alegría. Recuerda que esto es temporal. El sol siempre regresa. Ajusta tu perspectiva."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Des nuages temporaires assombrissent votre bonheur romantique. Le pessimisme ou des attentes irréalistes peuvent bloquer la joie. Rappelez-vous que c'est temporaire. Le soleil revient toujours. Ajustez votre perspective."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nuvole temporanee stanno offuscando la tua felicità romantica. Il pessimismo o le aspettative irrealistiche potrebbero bloccare la gioia. Ricorda che questo è temporaneo. Il sole torna sempre. Modifica la tua prospettiva."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一時的な雲があなたの恋愛の幸せを曇らせています。悲観主義や非現実的な期待が喜びを妨げているかもしれません。これは一時的なものだと覚えておいてください。太陽はいつか戻ってきます。視点を調整してください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Midlertidige skyer demper din romantiske lykke. Pessimisme eller urealistiske forventninger kan blokkere gleden. Husk at dette er midlertidig. Solen kommer alltid tilbake. Juster perspektivet ditt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tymczasowe chmury przyćmiewają twoje romantyczne szczęście. Pesymizm lub nierealistyczne oczekiwania mogą blokować radość. Pamiętaj, że to tymczasowe. Słońce zawsze powraca. Dostosuj swoją perspektywę."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nuvens temporárias estão obscurecendo sua felicidade romântica. O pessimismo ou expectativas irreais podem estar bloqueando a alegria. Lembre-se de que isso é temporário. O sol sempre volta. Ajuste sua perspectiva."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tillfälliga moln dämpar din romantiska lycka. Pessimism eller orealistiska förväntningar kan blockera glädjen. Kom ihåg att detta är tillfälligt. Solen kommer alltid tillbaka. Justera ditt perspektiv."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Тимчасові хмари затьмарюють ваше романтичне щастя. Песимізм або нереалістичні очікування можуть блокувати радість. Пам'ятайте, що це тимчасово. Сонце завжди повертається. Відкоригуйте свою перспективу."
          }
        }
      }
    },
    "interpretation.the_sun_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reine Freude, Wärme und Feierlichkeit erhellen dein Liebesleben. Wenn du Single bist, zieht deine Strahlkraft wunderbare Verbindungen an. Wenn du vergeben bist, erlebst du eine schöne Zeit der Harmonie und des Glücks. Bade in dieser wunderschönen Energie."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pure joy, warmth, and celebration shine on your love life. If you're single, your radiance is attracting wonderful connections. If partnered, you're experiencing a beautiful period of harmony and happiness. Bask in this beautiful energy."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La alegría pura, la calidez y la celebración brillan en tu vida amorosa. Si estás soltero, tu resplandor atrae conexiones maravillosas. Si estás en pareja, estás experimentando un hermoso período de armonía y felicidad. Báñate en esta hermosa energía."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La joie pure, la chaleur et la célébration illuminent votre vie amoureuse. Si vous êtes célibataire, votre rayonnement attire de merveilleuses connexions. Si vous êtes en couple, vous vivez une belle période d'harmonie et de bonheur. Baignez-vous dans cette belle énergie."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gioia pura, calore e celebrazione brillano nella tua vita amorosa. Se sei single, il tuo splendore attira connessioni meravigliose. Se sei in coppia, stai vivendo un bellissimo periodo di armonia e felicità. Bagnati in questa bellissima energia."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "純粋な喜び、温かさ、祝福があなたの恋愛を照らします。独身の場合、あなたの輝きは素晴らしいつながりを引き寄せます。パートナーがいる場合、あなたは調和と幸福の美しい時期を経験しています。この美しいエネルギーに浸ってください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ren glede, varme og feiring skinner på kjærlighetslivet ditt. Hvis du er singel, tiltrekker din utstråling fantastiske forbindelser. Hvis du er i et forhold, opplever du en vakker periode med harmoni og lykke. Bad i denne vakre energien."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Czysta radość, ciepło i celebracja rozświetlają twoje życie miłosne. Jeśli jesteś singlem, twój blask przyciąga wspaniałe połączenia. Jeśli jesteś w związku, przeżywasz piękny okres harmonii i szczęścia. Kąp się w tej pięknej energii."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alegria pura, calor e celebração brilham em sua vida amorosa. Se você é solteiro, seu brilho atrai conexões maravilhosas. Se está em um relacionamento, você está experimentando um belo período de harmonia e felicidade. Banhe-se nessa bela energia."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ren glädje, värme och firande lyser upp ditt kärleksliv. Om du är singel lockar din utstrålning underbara kontakter. Om du är i ett förhållande upplever du en vacker period av harmoni och lycka. Bada i denna vackra energi."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Чиста радість, тепло та святкування сяють у вашому любовному житті. Якщо ви самотні, ваше сяйво приваблює чудові зв'язки. Якщо ви в стосунках, ви переживаєте прекрасний період гармонії та щастя. Купайтеся в цій прекрасній енергії."
          }
        }
      }
    },
    "interpretation.the_tower_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du entgehst knapp einer Karrierekatastrophe oder widerstehst dem unvermeidlichen Umbruch am Arbeitsplatz. Der Turm-Moment wird kommen – bereite dich auf die Wahrheit vor."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Narrowly avoiding career disaster or resisting inevitable workplace upheaval. The tower moment is coming—prepare for truth."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apenas evitas un desastre profesional o te resistes a una agitación inevitable en el lugar de trabajo. El momento de la torre está por llegar: prepárate para la verdad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous évitez de justesse une catastrophe professionnelle ou vous résistez à un bouleversement inévitable sur le lieu de travail. Le moment de la tour arrive – préparez-vous à la vérité."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stai appena evitando un disastro professionale o resisti a un inevitabile sconvolgimento sul lavoro. Il momento della torre sta arrivando – preparati per la verità."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたはかろうじてキャリアの災難を免れているか、避けられない職場の激変に抵抗しています。塔の瞬間がやって来ます – 真実に備えてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du unngår så vidt en karrierekatastrofe, eller motstår en uunngåelig omveltning på jobben. Tårnøyeblikket kommer – forbered deg på sannheten."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ledwo unikasz katastrofy zawodowej lub opierasz się nieuniknionym wstrząsom w pracy. Moment wieży nadchodzi – przygotuj się na prawdę."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você mal está evitando um desastre na carreira ou resistindo a uma agitação inevitável no trabalho. O momento da torre está chegando – prepare-se para a verdade."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du undviker knappt en karriärkatastrof eller motstår en oundviklig omvälvning på jobbet. Tornögonblicket kommer – förbered dig på sanningen."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ви ледве уникаєте кар'єрної катастрофи або чините опір неминучим потрясінням на роботі. Момент вежі настає – підготуйтеся до правди."
          }
        }
      }
    },
    "interpretation.the_tower_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Plötzlicher Karriereumbruch zerbricht falsche Strukturen. Jobverlust, Umstrukturierung oder dramatische Enthüllungen erschüttern dein berufliches Fundament. Diese Zerstörung macht Platz für die Wahrheit."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sudden career upheaval shatters false structures. Job loss, restructuring, or dramatic revelations shake your professional foundation. This destruction makes way for truth."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una agitación profesional repentina rompe estructuras falsas. La pérdida del trabajo, la reestructuración o las revelaciones dramáticas sacuden tu base profesional. Esta destrucción hace espacio para la verdad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un bouleversement professionnel soudain brise les fausses structures. Perte d'emploi, restructuration ou révélations dramatiques ébranlent votre base professionnelle. Cette destruction fait place à la vérité."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un improvviso sconvolgimento professionale rompe le false strutture. Perdita di lavoro, ristrutturazione o rivelazioni drammatiche scuotono la tua base professionale. Questa distruzione fa spazio alla verità."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "突然のキャリアの激変が偽りの構造を打ち砕きます。仕事の喪失、再編、または劇的な暴露があなたの職業的基盤を揺るがします。この破壊は真実のためのスペースを作ります。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Plutselig karriereomveltning knuser falske strukturer. Jobbtap, omorganisering eller dramatiske avsløringer ryster ditt profesjonelle fundament. Denne ødeleggelsen gjør plass for sannheten."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nagłe wstrząsy w karierze niszczą fałszywe struktury. Utrata pracy, restrukturyzacja lub dramatyczne rewelacje wstrząsają twoimi podstawami zawodowymi. To zniszczenie robi miejsce dla prawdy."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uma agitação repentina na carreira quebra estruturas falsas. Perda de emprego, reestruturação ou revelações dramáticas abalam sua base profissional. Essa destruição abre espaço para a verdade."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Plötslig karriäromvälvning krossar falska strukturer. Arbetsförlust, omorganisation eller dramatiska avslöjanden skakar din professionella grund. Denna förstörelse gör plats för sanningen."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Раптове кар'єрне потрясіння руйнує фальшиві структури. Втрата роботи, реструктуризація або драматичні розкриття підривають вашу професійну основу. Це руйнування звільняє місце для правди."
          }
        }
      }
    },
    "interpretation.the_tower_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du entgehst knapp einer finanziellen Katastrophe oder verzögerst eine unvermeidliche Geldkrise. Die Wahrheit über deine Finanzen wird ans Licht kommen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Narrowly avoiding financial catastrophe or delaying inevitable money crisis. The truth about your finances will emerge."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apenas evitas una catástrofe financiera o retrasas una crisis económica inevitable. La verdad sobre tus finanzas saldrá a la luz."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous évitez de justesse une catastrophe financière ou retardez une crise monétaire inévitable. La vérité sur vos finances finira par émerger."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stai appena evitando una catastrofe finanziaria o ritardando una crisi monetaria inevitabile. La verità sulle tue finanze verrà a galla."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたはかろうじて財政的破綻を免れているか、避けられないお金の危機を遅らせています。あなたの財政に関する真実が浮上するでしょう。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du unngår så vidt en økonomisk katastrofe eller utsetter en uunngåelig pengekrise. Sannheten om økonomien din vil komme frem."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ledwo unikasz katastrofy finansowej lub opóźniasz nieunikniony kryzys pieniężny. Prawda o twoich finansach wyjdzie na jaw."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você mal está evitando uma catástrofe financeira ou adiando uma crise de dinheiro inevitável. A verdade sobre suas finanças virá à tona."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du undviker knappt en finansiell katastrof eller försenar en oundviklig penningkris. Sanningen om din ekonomi kommer att komma fram."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ви ледве уникаєте фінансової катастрофи або відкладаєте неминучу грошову кризу. Правда про ваші фінанси спливе."
          }
        }
      }
    },
    "interpretation.the_tower_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Plötzlicher finanzieller Umbruch oder Verlust. Falsche Sicherheit bröckelt. Diese schockierende Veränderung enthüllt die Wahrheit über deine Ressourcen. Baue das nächste Mal auf festem Boden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sudden financial upheaval or loss. False security crumbles. This shocking change reveals the truth about your resources. Build on solid ground next time."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Agitación financiera repentina o pérdida. La falsa seguridad se desmorona. Este cambio impactante revela la verdad sobre tus recursos. Construye sobre suelo sólido la próxima vez."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bouleversement financier soudain ou perte. La fausse sécurité s'effrite. Ce changement choquant révèle la vérité sur vos ressources. Construisez sur un terrain solide la prochaine fois."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Improvviso sconvolgimento finanziario o perdita. La falsa sicurezza si sgretola. Questo cambiamento scioccante rivela la verità sulle tue risorse. Costruisci su un terreno solido la prossima volta."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "突然の財政的激変または損失。偽りの安心が崩れ去ります。この衝撃的な変化は、あなたのリソースに関する真実を明らかにします。次回は堅固な基盤の上に構築してください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Plutselig økonomisk omveltning eller tap. Falsk trygghet smuldrer opp. Denne sjokkerende endringen avslører sannheten om ressursene dine. Bygg på solid grunn neste gang."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nagłe wstrząsy finansowe lub strata. Fałszywe bezpieczeństwo kruszy się. Ta szokująca zmiana ujawnia prawdę o twoich zasobach. Następnym razem buduj na solidnym gruncie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Agitação financeira repentina ou perda. A falsa segurança se desfaz. Essa mudança chocante revela a verdade sobre seus recursos. Construa em terreno sólido na próxima vez."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Plötslig ekonomisk omvälvning eller förlust. Falsk säkerhet smulas sönder. Denna chockerande förändring avslöjar sanningen om dina resurser. Bygg på solid mark nästa gång."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Раптове фінансове потрясіння або втрата. Фальшива безпека розсипається. Ця шокуюча зміна розкриває правду про ваші ресурси. Наступного разу будуйте на твердому ґрунті."
          }
        }
      }
    },
    "interpretation.the_tower_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du wehrst dich gegen den notwendigen Umbruch oder entgehst knapp einer Katastrophe. Du kannst den Turm-Moment nicht für immer verhindern – er kommt, um dich von Illusionen zu befreien. Mach dich bereit und suche das Geschenk in der Zerstörung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You're resisting necessary upheaval, or narrowly avoiding catastrophe. You can't prevent the tower moment forever—it's coming to liberate you from illusions. Brace yourself and look for the gift in the destruction."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Te resistes a la agitación necesaria o apenas evitas una catástrofe. No puedes prevenir el momento de la torre para siempre, viene a liberarte de las ilusiones. Prepárate y busca el regalo en la destrucción."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous résistez au bouleversement nécessaire ou évitez de justesse une catastrophe. Vous ne pouvez pas empêcher le moment de la tour pour toujours – il vient vous libérer des illusions. Préparez-vous et cherchez le cadeau dans la destruction."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resisti allo sconvolgimento necessario o eviti a malapena una catastrofe. Non puoi prevenire il momento della torre per sempre – viene per liberarti dalle illusioni. Preparati e cerca il dono nella distruzione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたは必要な激変に抵抗しているか、かろうじて大惨事を免れています。あなたは塔の瞬間を永遠に防ぐことはできません – それはあなたを幻想から解放するためにやって来ます。覚悟を決め、破壊の中の贈り物を探してください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du motstår den nødvendige omveltningen eller unngår så vidt en katastrofe. Du kan ikke forhindre tårnøyeblikket for alltid – det kommer for å frigjøre deg fra illusjoner. Forbered deg og se etter gaven i ødeleggelsen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opierasz się koniecznym wstrząsom lub ledwo unikasz katastrofy. Nie możesz zapobiec momentowi wieży na zawsze – przychodzi, by uwolnić cię od iluzji. Przygotuj się i szukaj daru w zniszczeniu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você resiste à agitação necessária ou mal evita uma catástrofe. Você não pode prevenir o momento da torre para sempre – ele vem para libertá-lo das ilusões. Prepare-se e procure o presente na destruição."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du motstår den nödvändiga omvälvningen eller undviker knappt en katastrof. Du kan inte förhindra tornögonblicket för alltid – det kommer för att befria dig från illusioner. Förbered dig och leta efter gåvan i förstörelsen."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ви чините опір необхідному потрясінню або ледве уникаєте катастрофи. Ви не можете запобігти моменту вежі назавжди – він приходить, щоб звільнити вас від ілюзій. Приготуйтеся і шукайте дар у руйнуванні."
          }
        }
      }
    },
    "interpretation.the_tower_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ein plötzlicher, disruptiver Wandel zerbricht deine Welt. Alles, von dem du dachtest, es sei stabil, wird erschüttert. Auf diese Weise baut das Universum falsche Strukturen ab. In den Trümmern wirst du die Wahrheit finden. Dem Chaos geht die Klarheit voraus."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sudden, disruptive change is shattering your world. Everything you thought was stable is being shaken. This is the universe's way of breaking down false structures. In the rubble, you'll find truth. Chaos precedes clarity."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un cambio repentino y disruptivo está destrozando tu mundo. Todo lo que creías estable está siendo sacudido. Esta es la forma en que el universo derriba estructuras falsas. Entre los escombros, encontrarás la verdad. El caos precede a la claridad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un changement soudain et perturbateur brise votre monde. Tout ce que vous pensiez stable est ébranlé. C'est la façon dont l'univers détruit les fausses structures. Dans les décombres, vous trouverez la vérité. Le chaos précède la clarté."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un cambiamento improvviso e dirompente sta frantumando il tuo mondo. Tutto ciò che pensavi stabile viene scosso. Questo è il modo in cui l'universo abbatte le false strutture. Tra le macerie, troverai la verità. Il caos precede la chiarezza."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "突然の破壊的な変化があなたの世界を粉々にしています。安定していると思っていたすべてのものが揺るがされています。これは宇宙が偽りの構造を壊す方法です。瓦礫の中に、あなたは真実を見つけるでしょう。混乱の後に明確さが訪れます。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En plutselig, forstyrrende endring knuser verden din. Alt du trodde var stabilt blir rystet. Dette er universets måte å bryte ned falske strukturer på. I ruinene vil du finne sannheten. Kaos går forut for klarhet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nagła, destrukcyjna zmiana rozbija twój świat. Wszystko, co uważałeś za stabilne, zostaje wstrząśnięte. W ten sposób wszechświat burzy fałszywe struktury. W gruzach znajdziesz prawdę. Chaos poprzedza jasność."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uma mudança repentina e disruptiva está destruindo seu mundo. Tudo o que você pensava ser estável está sendo abalado. Essa é a maneira do universo derrubar estruturas falsas. Nos escombros, você encontrará a verdade. O caos precede a clareza."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En plötslig, störande förändring krossar din värld. Allt du trodde var stabilt skakas. Detta är universums sätt att bryta ner falska strukturer. I ruinerna kommer du att finna sanningen. Kaos föregår klarhet."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Раптова руйнівна зміна розбиває ваш світ. Все, що ви вважали стабільним, трясеться. Так Всесвіт руйнує фальшиві структури. У руїнах ви знайдете правду. Хаос передує ясності."
          }
        }
      }
    },
    "interpretation.the_tower_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du entgehst knapp einer gesundheitlichen Krise oder ignorierst Warnsignale. Der Turm-Moment für deine Gesundheit naht – warte nicht zu lange."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Narrowly avoiding health crisis or ignoring warning signs. The tower moment for your health approaches—don't wait."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apenas evitas una crisis de salud o ignoras las señales de advertencia. El momento de la torre para tu salud se acerca, no esperes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous évitez de justesse une crise de santé ou ignorez les signes avant-coureurs. Le moment de la tour pour votre santé approche – n'attendez pas."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stai appena evitando una crisi sanitaria o ignori i segnali di avvertimento. Il momento della torre per la tua salute si avvicina – non aspettare."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたはかろうじて健康危機を免れているか、警告サインを無視しています。あなたの健康のための塔の瞬間が近づいています – 待たないでください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du unngår så vidt en helsekrise eller ignorerer advarselsskilt. Tårnøyeblikket for helsen din nærmer seg – ikke vent."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ledwo unikasz kryzysu zdrowotnego lub ignorujesz sygnały ostrzegawcze. Moment wieży dla twojego zdrowia zbliża się – nie czekaj."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você mal está evitando uma crise de saúde ou ignorando sinais de alerta. O momento da torre para a sua saúde se aproxima – não espere."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du undviker knappt en hälsokris eller ignorerar varningssignaler. Tornögonblicket för din hälsa närmar sig – vänta inte."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ви ледве уникаєте кризи здоров'я або ігноруєте попереджувальні знаки. Момент вежі для вашого здоров'я наближається – не чекайте."
          }
        }
      }
    },
    "interpretation.the_tower_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Plötzliche Gesundheitskrise oder schockierende Diagnose. Die falsche Stabilität deines Körpers zerbricht. Dieser Umbruch erzwingt notwendige Veränderungen und enthüllt die Wahrheit."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sudden health crisis or shocking diagnosis. Your body's false stability shatters. This upheaval forces necessary change and reveals truth."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Crisis de salud repentina o diagnóstico impactante. La falsa estabilidad de tu cuerpo se rompe. Esta agitación obliga a cambios necesarios y revela la verdad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Crise de santé soudaine ou diagnostic choquant. La fausse stabilité de votre corps se brise. Ce bouleversement force des changements nécessaires et révèle la vérité."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Crisi di salute improvvisa o diagnosi scioccante. La falsa stabilità del tuo corpo si frantuma. Questo sconvolgimento forza cambiamenti necessari e rivela la verità."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "突然の健康危機または衝撃的な診断。あなたの体の偽りの安定が打ち砕かれます。この激変は必要な変化を強制し、真実を明らかにします。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Plutselig helsekrise eller sjokkerende diagnose. Kroppens falske stabilitet knuses. Denne omveltningen tvinger frem nødvendige endringer og avslører sannheten."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nagły kryzys zdrowotny lub szokująca diagnoza. Fałszywa stabilność twojego ciała zostaje zmiażdżona. To wstrząs wymusza konieczne zmiany i ujawnia prawdę."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Crise de saúde repentina ou diagnóstico chocante. A falsa estabilidade do seu corpo é desfeita. Essa agitação força mudanças necessárias e revela a verdade."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Plötslig hälsokris eller chockerande diagnos. Din kropps falska stabilitet krossas. Denna omvälvning tvingar fram nödvändiga förändringar och avslöjar sanningen."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Раптова криза здоров'я або шокуючий діагноз. Фальшива стабільність вашого тіла руйнується. Це потрясіння змушує до необхідних змін і розкриває правду."
          }
        }
      }
    },
    "interpretation.the_tower_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du entgehst knapp einer Katastrophe oder verzögerst den unvermeidlichen Umbruch. Der Turm-Moment wird kommen, ob du bereit bist oder nicht. Anstatt ihn zu fürchten, bereite dich auf die Wahrheit vor, die ans Licht kommen wird."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You're barely avoiding disaster, or delaying inevitable upheaval. The tower moment is coming whether you're ready or not. Instead of fearing it, prepare for the truth that's about to surface."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apenas evitas un desastre o retrasas la agitación inevitable. El momento de la torre llegará, estés listo o no. En lugar de temerlo, prepárate para la verdad que está a punto de salir a la superficie."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous évitez de justesse un désastre ou vous retardez un bouleversement inévitable. Le moment de la tour viendra, que vous soyez prêt ou non. Au lieu de le craindre, préparez-vous à la vérité qui est sur le point de faire surface."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stai appena evitando un disastro o ritardando un sconvolgimento inevitabile. Il momento della torre arriverà, che tu sia pronto o no. Invece di temerlo, preparati per la verità che sta per venire a galla."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたはかろうじて災難を免れているか、避けられない激変を遅らせています。あなたが準備できているかどうかに関わらず、塔の瞬間は訪れます。それを恐れる代わりに、表面化しようとしている真実に備えてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du unngår så vidt en katastrofe, eller utsetter den uunngåelige omveltningen. Tårnøyeblikket vil komme, enten du er klar eller ikke. I stedet for å frykte det, forbered deg på sannheten som er i ferd med å komme opp til overflaten."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ledwo unikasz katastrofy lub opóźniasz nieuniknione wstrząsy. Moment wieży nadejdzie, niezależnie od tego, czy jesteś gotowy, czy nie. Zamiast się go bać, przygotuj się na prawdę, która ma wyjść na jaw."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você mal está evitando um desastre ou adiando uma agitação inevitável. O momento da torre chegará, quer você esteja pronto ou não. Em vez de temê-lo, prepare-se para a verdade que está prestes a vir à tona."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du undviker knappt en katastrof eller försenar den oundvikliga omvälvningen. Tornögonblicket kommer, oavsett om du är redo eller inte. Istället för att frukta det, förbered dig på sanningen som är på väg att komma upp till ytan."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ви ледве уникаєте катастрофи або відкладаєте неминуче потрясіння. Момент вежі настане, готові ви чи ні. Замість того, щоб боятися його, підготуйтеся до правди, яка ось-ось випливе на поверхню."
          }
        }
      }
    },
    "interpretation.the_tower_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ein plötzlicher Umbruch erschüttert deine Beziehung oder dein Liebesleben. Grundfesten, von denen du dachtest, sie wären solide, bröckeln. Das ist schmerzhaft, aber notwendig – falsche Strukturen müssen fallen, damit die Wahrheit ans Licht kommen kann. Was wird enthüllt?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sudden upheaval is shaking your relationship or romantic life. Foundations you thought were solid are crumbling. This is painful but necessary—false structures must fall so truth can emerge. What's being revealed?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una agitación repentina está sacudiendo tu relación o vida amorosa. Los cimientos que creías sólidos se están desmoronando. Esto es doloroso pero necesario: las estructuras falsas deben caer para que la verdad emerja. ¿Qué se está revelando?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un bouleversement soudain ébranle votre relation ou votre vie amoureuse. Les fondations que vous pensiez solides s'effritent. C'est douloureux mais nécessaire – les fausses structures doivent tomber pour que la vérité émerge. Qu'est-ce qui se révèle ?"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un improvviso sconvolgimento sta scuotendo la tua relazione o vita amorosa. Le fondamenta che pensavi fossero solide stanno crollando. Questo è doloroso ma necessario – le false strutture devono cadere affinché la verità emerga. Cosa viene rivelato?"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "突然の激変があなたの関係や恋愛を揺るがしています。あなたが堅固だと思っていた基盤が崩れつつあります。これは痛みを伴いますが、必要なことです – 真実が現れるためには偽りの構造は崩れ落ちなければなりません。何が明らかにされていますか？"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En plutselig omveltning ryster forholdet ditt eller kjærlighetslivet. Fundamenter du trodde var solide smuldrer opp. Dette er smertefullt, men nødvendig – falske strukturer må falle slik at sannheten kan komme frem. Hva blir avslørt?"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nagłe wstrząsy wstrząsają twoim związkiem lub życiem miłosnym. Fundamenty, które uważałeś za solidne, kruszą się. To bolesne, ale konieczne – fałszywe struktury muszą upaść, aby prawda mogła wyjść na jaw. Co zostaje ujawnione?"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uma agitação repentina está abalando seu relacionamento ou vida amorosa. Alicerces que você pensava serem sólidos estão desmoronando. Isso é doloroso, mas necessário – estruturas falsas devem cair para que a verdade possa emergir. O que está sendo revelado?"
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En plötslig omvälvning skakar din relation eller ditt kärleksliv. Grunder som du trodde var solida smulas sönder. Detta är smärtsamt men nödvändigt – falska strukturer måste falla så att sanningen kan komma fram. Vad avslöjas?"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Раптове потрясіння вражає ваші стосунки або любовне життя. Основи, які ви вважали міцними, руйнуються. Це боляче, але необхідно – фальшиві структури мають впасти, щоб правда могла вийти назовні. Що розкривається?"
          }
        }
      }
    },
    "interpretation.the_world_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unvollständige Karriereprojekte oder berufliche Verzögerungen. Abkürzungen untergraben den Erfolg. Mangelnder Abschluss in alten Rollen blockiert neue."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Incomplete career projects or professional delays. Taking shortcuts undermines success. Lack of closure in old roles blocks new ones."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Proyectos profesionales incompletos o retrasos profesionales. Los atajos socavan el éxito. La falta de cierre en roles antiguos bloquea los nuevos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Projets professionnels incomplets ou retards professionnels. Les raccourcis compromettent le succès. Le manque de clôture dans les anciens rôles bloque les nouveaux."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Progetti professionali incompleti o ritardi professionali. Le scorciatoie minano il successo. La mancanza di chiusura nei vecchi ruoli blocca quelli nuovi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "不完全なキャリアプロジェクトや職業上の遅延。近道は成功を損ないます。古い役割の決着の欠如が新しい役割を妨げます。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ufullstendige karriereprosjekter eller profesjonelle forsinkelser. Snarveier undergraver suksess. Mangel på avslutning i gamle roller blokkerer nye."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niekompletne projekty zawodowe lub opóźnienia zawodowe. Skróty podważają sukces. Brak zamknięcia w starych rolach blokuje nowe."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Projetos de carreira incompletos ou atrasos profissionais. Atalhos prejudicam o sucesso. A falta de encerramento em funções antigas bloqueia novas."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ofullständiga karriärprojekt eller professionella förseningar. Genvägar undergräver framgång. Brist på avslutning i gamla roller blockerar nya."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Незавершені кар'єрні проекти або професійні затримки. Короткі шляхи підривають успіх. Відсутність завершення в старих ролях блокує нові."
          }
        }
      }
    },
    "interpretation.the_world_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriereabschluss und Erfolg. Ein großer beruflicher Zyklus endet erfolgreich. Anerkennung und Erfüllung. Deine Arbeitsreise erreicht ihren Abschluss."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Career completion and achievement. A major professional cycle concludes successfully. Recognition and fulfillment. Your work journey reaches completion."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finalización de carrera y logro. Un ciclo profesional importante concluye exitosamente. Reconocimiento y satisfacción. Tu viaje laboral alcanza su finalización."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Achèvement de carrière et succès. Un grand cycle professionnel se termine avec succès. Reconnaissance et épanouissement. Votre parcours professionnel atteint son aboutissement."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Completamento della carriera e successo. Un grande ciclo professionale si conclude con successo. Riconoscimento e appagamento. Il tuo percorso lavorativo raggiunge il completamento."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャリアの完了と達成。大きな職業的サイクルが成功裡に終了します。認識と充足。あなたの仕事の旅は完了に達します。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karrierefullføring og prestasjon. En stor profesjonell syklus avsluttes vellykket. Anerkjennelse og oppfyllelse. Arbeidsreisen din når fullføring."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zakończenie kariery i osiągnięcie. Duży cykl zawodowy kończy się pomyślnie. Uznanie i spełnienie. Twoja podróż zawodowa osiąga ukończenie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conclusão de carreira e realização. Um grande ciclo profissional se conclui com sucesso. Reconhecimento e realização. Sua jornada de trabalho chega à conclusão."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriäravslut och prestation. En stor professionell cykel avslutas framgångsrikt. Erkännande och uppfyllelse. Ditt arbetsresa når slutförande."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Завершення кар'єри та досягнення. Великий професійний цикл успішно завершується. Визнання та виконання. Ваша робоча подорож досягає завершення."
          }
        }
      }
    },
    "interpretation.the_world_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unvollständige Finanzzyklen oder verzögerter Wohlstand. Abkürzungen bei Geld schlagen fehl. Mangelnder Abschluss bei alten finanziellen Mustern."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Incomplete financial cycles or delayed prosperity. Shortcuts with money backfire. Lack of closure in old financial patterns."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ciclos financieros incompletos o prosperidad retrasada. Los atajos con el dinero fracasan. Falta de cierre en viejos patrones financieros."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cycles financiers incomplets ou prospérité retardée. Les raccourcis avec l'argent échouent. Manque de clôture dans les anciens schémas financiers."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cicli finanziari incompleti o prosperità ritardata. Le scorciatoie con i soldi falliscono. Mancanza di chiusura nei vecchi schemi finanziari."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "不完全な財務サイクルまたは遅れた繁栄。お金の近道は失敗します。古い財務パターンの決着の欠如。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ufullstendige økonomiske sykluser eller forsinket velstand. Snarveier med penger mislykkes. Mangel på avslutning i gamle økonomiske mønstre."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niekompletne cykle finansowe lub opóźniony dobrobyt. Skróty z pieniędzmi zawodzą. Brak zamknięcia w starych wzorcach finansowych."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ciclos financeiros incompletos ou prosperidade atrasada. Atalhos com dinheiro falham. Falta de encerramento em padrões financeiros antigos."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ofullständiga finansiella cykler eller försenad välstånd. Genvägar med pengar misslyckas. Brist på avslutning i gamla finansiella mönster."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Незавершені фінансові цикли або відкладений достаток. Короткі шляхи з грошима провалюються. Відсутність завершення в старих фінансових моделях."
          }
        }
      }
    },
    "interpretation.the_world_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzieller Abschluss und Wohlstand. Finanzielle Ziele werden erreicht. Ein Zyklus der Vermögensbildung endet erfolgreich. Feiere deine finanzielle Reise."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial completion and prosperity. Money goals are achieved. A cycle of wealth creation concludes successfully. Celebrate your financial journey."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finalización financiera y prosperidad. Se logran las metas financieras. Un ciclo de creación de riqueza concluye exitosamente. Celebra tu viaje financiero."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Achèvement financier et prospérité. Les objectifs financiers sont atteints. Un cycle de création de richesse se termine avec succès. Célébrez votre parcours financier."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Completamento finanziario e prosperità. Gli obiettivi finanziari vengono raggiunti. Un ciclo di creazione di ricchezza si conclude con successo. Celebra il tuo viaggio finanziario."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "財政的完了と繁栄。経済的目標が達成されます。富の創造のサイクルが成功裡に終わります。あなたの財政の旅を祝いましょう。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk fullføring og velstand. Økonomiske mål oppnås. En syklus av formuesbygging avsluttes vellykket. Feir din økonomiske reise."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zakończenie finansowe i dobrobyt. Cele finansowe zostają osiągnięte. Cykl tworzenia bogactwa kończy się pomyślnie. Świętuj swoją finansową podróż."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conclusão financeira e prosperidade. Metas financeiras são alcançadas. Um ciclo de criação de riqueza se conclui com sucesso. Celebre sua jornada financeira."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomiskt slutförande och välstånd. Ekonomiska mål uppnås. En cykel av förmögenhetsskapande avslutas framgångsrikt. Fira din ekonomiska resa."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансове завершення та процвітання. Фінансові цілі досягнуті. Цикл створення багатства успішно завершується. Відзначайте свою фінансову подорож."
          }
        }
      }
    },
    "interpretation.the_world_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unvollständigkeit, Abkürzungen, Verzögerungen und mangelnder Abschluss. Beende, was du begonnen hast. Der einfache Weg verhindert echte Erfüllung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Incompletion, shortcuts, delays, and lack of closure. Finish what you started. Taking the easy way out prevents real fulfillment."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Incompletitud, atajos, retrasos y falta de cierre. Termina lo que empezaste. Tomar el camino fácil impide la verdadera realización."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inachèvement, raccourcis, retards et manque de clôture. Terminez ce que vous avez commencé. Prendre le chemin facile empêche la véritable épanouissement."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Incompletezza, scorciatoie, ritardi e mancanza di chiusura. Finisci ciò che hai iniziato. Prendere la strada facile impedisce la vera realizzazione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "不完全、近道、遅延、決着の欠如。始めたことを終わらせてください。簡単な道を選ぶことは真の充足を妨げます。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ufullstendighet, snarveier, forsinkelser og mangel på avslutning. Fullfør det du startet. Å ta den enkle veien forhindrer ekte oppfyllelse."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niekompletność, skróty, opóźnienia i brak zamknięcia. Skończ to, co zacząłeś. Podążanie łatwą ścieżką uniemożliwia prawdziwe spełnienie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Incompletude, atalhos, atrasos e falta de encerramento. Termine o que você começou. Seguir o caminho fácil impede a verdadeira realização."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ofullständighet, genvägar, förseningar och brist på avslutning. Avsluta det du påbörjat. Att ta den enkla vägen förhindrar verklig uppfyllelse."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Незавершеність, короткі шляхи, затримки та відсутність завершення. Закінчіть те, що почали. Легкий шлях заважає справжньому виконанню."
          }
        }
      }
    },
    "interpretation.the_world_general_upright" : {
