          "stringUnit": {
            "state": "translated",
            "value": "Ta en stund att centrera dig"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Приділіть хвилину, щоб зосередитися"
          }
        }
      }
    },
    "cardOfDay.instruction": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Place your finger on the card and hold for 3 seconds"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lege deinen Finger auf die Karte und halte 3 Sekunden lang"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Coloca tu dedo sobre la carta y mantén durante 3 segundos"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Placez votre doigt sur la carte et maintenez pendant 3 secondes"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Posiziona il dito sulla carta e tieni premuto per 3 secondi"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カードに指を置き、3秒間押し続けてください"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Plasser fingeren din på kortet og hold i 3 sekunder"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Połóż palec na karcie i przytrzymaj przez 3 sekundy"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Coloque seu dedo na carta e segure por 3 segundos"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Placera ditt finger på kortet och håll i 3 sekunder"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Покладіть палець на карту і тримайте 3 секунди"
          }
        }
      }
    },
