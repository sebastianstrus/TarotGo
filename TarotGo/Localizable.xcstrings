    "interpretation.eight_of_wands_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verzögerungen, Frustration, Widerstand gegen Veränderungen und Notwendigkeit innerer Ausrichtung. Nichts bewegt sich so schnell, wie du möchtest. Geduld ist erforderlich."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Delays, frustration, resisting change, and need for internal alignment. Nothing's moving as fast as you want. Patience required."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Retrasos, frustración, resistencia al cambio y necesidad de alineación interna. Nada se mueve tan rápido como quieres. Se requiere paciencia."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Retards, frustration, résistance au changement et besoin d'alignement interne. Rien ne bouge aussi vite que vous le souhaitez. La patience est requise."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ritardi, frustrazione, resistenza al cambiamento e necessità di allineamento interno. Niente si muove velocemente come vuoi. Pazienza richiesta."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "遅延、フラストレーション、変化への抵抗、そして内部調整の必要性。あなたが望むほど速く何も動いていない。忍耐が必要。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Forsinkelser, frustrasjon, motstand mot endring og behov for intern justering. Ingenting beveger seg så raskt som du vil. Tålmodighet kreves."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opóźnienia, frustracja, opór przed zmianą i potrzeba wewnętrznego dostosowania. Nic nie porusza się tak szybko, jak chcesz. Wymagana cierpliwość."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atrasos, frustração, resistência à mudança e necessidade de alinhamento interno. Nada está se movendo tão rápido quanto você quer. Paciência é necessária."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Förseningar, frustration, motstånd mot förändring och behov av intern anpassning. Ingenting rör sig så snabbt som du vill. Tålamod krävs."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Затримки, фрустрація, опір змінам і потреба у внутрішньому узгодженні. Ніщо не рухається так швидко, як ви хочете. Потрібне терпіння."
          }
        }
      }
    },
