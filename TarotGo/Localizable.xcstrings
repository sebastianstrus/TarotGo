    "interpretation.the_moon_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klarheit entsteht aus Verwirrung. Loslassen von Angst und Offenbarung der Wahrheit. Die Angst lässt nach, als sich die Illusionen auflösen."
