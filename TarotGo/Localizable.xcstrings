    "interpretation.three_of_swords_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gesundheitlicher Herzschmerz und körperlicher Schmerz. Schwierige Diagnose oder Körperverrat. Die Wahrheit über die Gesundheit schmerzt, bringt aber Klarheit. Trauer über das Wohlbefinden ist berechtigt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Health heartbreak and physical pain. Difficult diagnosis or body betrayal. Truth about health hurts but brings clarity. Grief about wellness is valid."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desamor por la salud y dolor físico. Diagnóstico difícil o traición del cuerpo. La verdad sobre la salud duele pero aporta claridad. El dolor por el bienestar es válido."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chagrin de santé et douleur physique. Diagnostic difficile ou trahison du corps. La vérité sur la santé fait mal mais apporte de la clarté. Le chagrin lié au bien-être est valide."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Crepacuore per la salute e dolore fisico. Diagnosi difficile o tradimento del corpo. La verità sulla salute fa male ma porta chiarezza. Il dolore per il benessere è valido."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "健康の失意と身体の痛み。困難な診断または体の裏切り。健康についての真実は痛いが明確さをもたらす。ウェルネスについての悲しみは正当なものだ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Helsehjertesorg og fysisk smerte. Vanskelig diagnose eller kroppssvik. Sannheten om helse gjør vondt, men bringer klarhet. Sorg over velvære er gyldig."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Złamane serce zdrowotne i ból fizyczny. Trudna diagnoza lub zdrada ciała. Prawda o zdrowiu boli, ale przynosi jasność. Smutek z powodu dobrego samopoczucia jest uzasadniony."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desgosto de saúde e dor física. Diagnóstico difícil ou traição do corpo. A verdade sobre a saúde dói, mas traz clareza. A tristeza sobre o bem-estar é válida."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hälsokross och fysisk smärta. Svår diagnos eller kroppssvek. Sanningen om hälsa gör ont men ger klarhet. Sorg över välbefinnande är giltig."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Розбите серце через здоров'я та фізичний біль. Важкий діагноз або зрада тіла. Правда про здоров'я болить, але приносить ясність. Горе через благополуччя виправдане."
          }
        }
      }
    },
    "interpretation.three_of_swords_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
