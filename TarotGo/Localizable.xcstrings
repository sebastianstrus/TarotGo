        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ansiedade financeira e preocupação com dinheiro. Pesadelos sobre recursos. Medo esmagador sobre finanças. Sua mente te atormenta. Busque apoio."
