        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Espansione della salute e lungimiranza del benessere. Il corpo cresce oltre i limiti attuali. Prendere in carico la guarigione. Guardare al potenziale di vitalità."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "健康の拡大とウェルネスの先見性。身体は現在の制限を超えて成長する。癒しの主導権を握る。活力の可能性に目を向ける。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Helseutvidelse og velværefremsyn. Kropp vokser utover nåværende begrensninger. Ta ansvar for helbredelse. Se frem til vitalitetspotensialet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekspansja zdrowotna i przewidywanie wellness. Ciało rośnie poza obecne ograniczenia. Przejęcie kontroli nad uzdrawianiem. Patrzenie w przyszłość potencjału witalności."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Expansão da saúde e visão do bem-estar. O corpo cresce além das limitações atuais. Assumindo o controle da cura. Olhando para o potencial de vitalidade."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hälsoexpansion och välmåendeframförhållning. Kroppen växer bortom nuvarande begränsningar. Ta ansvar för läkning. Se fram emot vitalitetspotentialen."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Розширення здоров'я та передбачливість благополуччя. Тіло зростає за межі поточних обмежень. Взяття на себе відповідальності за зцілення. Погляд у майбутнє потенціалу життєвої сили."
          }
        }
      }
    },
