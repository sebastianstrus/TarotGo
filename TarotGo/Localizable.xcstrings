        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abordagem profissional ambiciosa e orientada à ação. Pensamento rápido e motivado no trabalho. Avanço na carreira através de decisões rápidas. Clareza mental serve à ambição."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ambitiös, handlingsorienterad professionell inställning. Snabbt tänkande och driven på jobbet. Karriärframsteg genom snabba beslut. Mental klarhet tjänar ambition."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Амбітний, орієнтований на дію професійний підхід. Швидке мислення та драйв на роботі. Кар'єрний ріст через швидкі рішення. Розумова ясність служить амбіціям."
          }
        }
      }
    },
