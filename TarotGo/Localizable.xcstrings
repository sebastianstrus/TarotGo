        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oportunidades criativas, mensagens e novas experiências emocionais. Sua intuição está aguçada. Aborde a vida com curiosidade e coração aberto. Belos começos aguardam."
          }
