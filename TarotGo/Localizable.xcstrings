        }
      }
    },
    "interpretation.six_of_cups_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beruflich in alten Mustern feststecken. Veraltete Ansätze funktionieren nicht mehr. Naive Erwartungen an die Arbeit. Es ist notwendig, deine berufliche Perspektive zu aktualisieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Career stuck in past patterns. Outdated approaches don't work anymore. Naive expectations about work. Need to update your professional perspective."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carrera estancada en patrones pasados. Los enfoques obsoletos ya no funcionan. Expectativas ingenuas sobre el trabajo. Necesitas actualizar tu perspectiva profesional."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carrière coincée dans des schémas passés. Les approches obsolètes ne fonctionnent plus. Attentes naïves quant au travail. Besoin de mettre à jour votre perspective professionnelle."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carriera bloccata in schemi passati. Gli approcci obsoleti non funzionano più. Aspettative ingenue sul lavoro. Necessità di aggiornare la tua prospettiva professionale."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャリアが過去のパターンに固執しています。時代遅れのアプローチはもう機能しません。仕事に対する甘い期待。専門的な視点を更新する必要があります。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karrieren sitt fast i gamle mønstre. Utdaterte tilnærminger fungerer ikke lenger. Naive forventninger til arbeid. Behov for å oppdatere ditt profesjonelle perspektiv."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kariera utknęła w przeszłych wzorcach. Przestarzałe podejścia już nie działają. Naiwne oczekiwania wobec pracy. Potrzeba zaktualizowania swojej perspektywy zawodowej."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carreira presa em padrões passados. Abordagens ultrapassadas não funcionam mais. Expectativas ingênuas sobre o trabalho. Precisa atualizar sua perspectiva profissional."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriären fast i gamla mönster. Föråldrade tillvägagångssätt fungerar inte längre. Naiva förväntningar på arbetet. Behov av att uppdatera ditt professionella perspektiv."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Кар'єра застрягла в минулих моделях. Застарілі підходи більше не працюють. Наївні очікування щодо роботи. Потрібно оновити ваш професійний погляд."
          }
        }
      }
    },
    "interpretation.six_of_cups_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Berufliche Nostalgie oder Rückkehr zu früheren Arbeiten. Alte Kollegen verbinden sich wieder. Deine bisherige Erfahrung fließt in den aktuellen Erfolg ein. Einfachere Zeiten im Berufsleben sprechen dich an."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Career nostalgia or returning to past work. Old colleagues reconnect. Your past experience informs current success. Simpler times in professional life appeal to you."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nostalgia profesional o regreso a trabajos pasados. Viejos colegas se reconectan. Tu experiencia pasada influye en el éxito actual. Te atraen los tiempos más simples en la vida profesional."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nostalgie professionnelle ou retour à un travail antérieur. D'anciens collègues renouent. Votre expérience passée éclaire votre réussite actuelle. Les temps plus simples de la vie professionnelle vous attirent."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nostalgia professionale o ritorno a lavori passati. Vecchi colleghi si riconnettono. La tua esperienza passata informa il successo attuale. I tempi più semplici della vita professionale ti attraggono."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャリアの郷愁または過去の仕事への回帰。昔の同僚と再びつながります。あなたの過去の経験が現在の成功に役立っています。職業生活におけるよりシンプルな時代があなたに魅力を感じさせます。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karrierenostalgi eller tilbakevending til tidligere arbeid. Gamle kolleger gjenoppretter kontakten. Din tidligere erfaring informerer nåværende suksess. Enklere tider i yrkeslivet appellerer til deg."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nostalgia zawodowa lub powrót do poprzedniej pracy. Starzy współpracownicy odnawiają kontakty. Twoje przeszłe doświadczenie wpływa na obecny sukces. Prostszesze czasy w życiu zawodowym do ciebie przemawiają."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nostalgia de carreira ou retorno ao trabalho passado. Velhos colegas se reconectam. Sua experiência passada informa o sucesso atual. Tempos mais simples na vida profissional atraem você."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriärnostalgi eller återgång till tidigare arbete. Gamla kollegor återansluter. Din tidigare erfarenhet informerar nuvarande framgång. Enklare tider i yrkeslivet tilltalar dig."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Кар'єрна ностальгія або повернення до минулої роботи. Старі колеги відновлюють зв'язок. Ваш минулий досвід впливає на поточний успіх. Простіші часи в професійному житті приваблюють вас."
          }
        }
      }
    },
    "interpretation.six_of_cups_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unrealistische finanzielle Erwartungen, die auf der Vergangenheit basieren. Was früher funktioniert hat, funktioniert jetzt nicht. Über seine Verhältnisse leben, um den alten Lebensstil nachzuahmen. Aktualisiere deinen Ansatz in Geldangelegenheiten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unrealistic financial expectations based on the past. What worked before doesn't work now. Living beyond means trying to recreate old lifestyle. Update money approach."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Expectativas financieras poco realistas basadas en el pasado. Lo que funcionó antes no funciona ahora. Viviendo por encima de las posibilidades tratando de recrear el viejo estilo de vida. Actualiza tu enfoque del dinero."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Attentes financières irréalistes basées sur le passé. Ce qui fonctionnait avant ne fonctionne plus maintenant. Vivre au-dessus de ses moyens en essayant de recréer l'ancien mode de vie. Mettez à jour votre approche de l'argent."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aspettative finanziarie irrealistiche basate sul passato. Ciò che funzionava prima non funziona ora. Vivere al di sopra delle proprie possibilità cercando di ricreare il vecchio stile di vita. Aggiorna il tuo approccio al denaro."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "過去に基づいた非現実的な経済的期待。以前うまくいったことは今はうまくいきません。古いライフスタイルを再現しようとして収入以上の生活をしている。お金へのアプローチを更新してください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Urealistiske økonomiske forventninger basert på fortiden. Det som fungerte før, fungerer ikke nå. Lever over evne for å prøve å gjenskape gammel livsstil. Oppdater din tilnærming til penger."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nierealistyczne oczekiwania finansowe oparte na przeszłości. To, co działało wcześniej, teraz nie działa. Życie ponad stan, próbując odtworzyć stary styl życia. Zaktualizuj swoje podejście do pieniędzy."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Expectativas financeiras irreais baseadas no passado. O que funcionava antes não funciona agora. Vivendo acima das possibilidades tentando recriar o estilo de vida antigo. Atualize sua abordagem financeira."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Orealistiska ekonomiska förväntningar baserade på det förflutna. Det som fungerade förut fungerar inte nu. Lever över tillgångarna för att försöka återskapa gammal livsstil. Uppdatera ditt sätt att hantera pengar."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Нереалістичні фінансові очікування, засновані на минулому. Те, що працювало раніше, зараз не працює. Життя не за коштами, намагаючись відтворити старий спосіб життя. Оновіть свій підхід до грошей."
          }
        }
      }
    },
    "interpretation.six_of_cups_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Nostalgie oder Renditen aus vergangenen Investitionen. Alte Ansätze mit Geld dienen dir gut. Geschenke oder Unterstützung aus der Vergangenheit. Einfache finanzielle Zufriedenheit."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial nostalgia or returns from past investments. Old approaches to money serve you well. Gifts or support from the past. Simple financial satisfaction."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nostalgia financiera o retornos de inversiones pasadas. Los viejos enfoques del dinero te sirven bien. Regalos o apoyo del pasado. Satisfacción financiera simple."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nostalgie financière ou retours sur investissements passés. Les anciennes approches de l'argent vous servent bien. Cadeaux ou soutien du passé. Satisfaction financière simple."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nostalgia finanziaria o rendimenti da investimenti passati. I vecchi approcci al denaro ti servono bene. Regali o supporto dal passato. Semplice soddisfazione finanziaria."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的な郷愁、または過去の投資からのリターン。お金に対する昔ながらのアプローチがうまく機能します。過去からの贈り物やサポート。シンプルな経済的満足。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk nostalgi eller avkastning fra tidligere investeringer. Gamle tilnærminger til penger tjener deg godt. Gaver eller støtte fra fortiden. Enkel økonomisk tilfredshet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finansowa nostalgia lub zwroty z przeszłych inwestycji. Stare podejścia do pieniędzy służą ci dobrze. Prezenty lub wsparcie z przeszłości. Prosta satysfakcja finansowa."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nostalgia financeira ou retornos de investimentos passados. Abordagens antigas em relação ao dinheiro servem bem. Presentes ou apoio do passado. Satisfação financeira simples."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomisk nostalgi eller avkastning från tidigare investeringar. Gamla sätt att hantera pengar tjänar dig väl. Gåvor eller stöd från det förflutna. Enkel ekonomisk tillfredsställelse."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансова ностальгія або прибуток від минулих інвестицій. Старі підходи до грошей вам добре служать. Дарунки або підтримка з минулого. Просте фінансове задоволення."
          }
        }
      }
    },
    "interpretation.six_of_cups_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "In der Vergangenheit stecken bleiben oder unrealistische Nostalgie. Du idealisierst das, was war, und kannst nicht vorankommen. Naive Erwartungen blockieren das Wachstum. Es ist Zeit, in der Gegenwart zu leben."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stuck in the past or unrealistic nostalgia. You're idealizing what was and can't move forward. Naive expectations block growth. It's time to live in the present."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atrapado en el pasado o nostalgia poco realista. Estás idealizando lo que fue y no puedes seguir adelante. Las expectativas ingenuas bloquean el crecimiento. Es hora de vivir en el presente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Coincé dans le passé ou nostalgie irréaliste. Vous idéalisez ce qui était et ne pouvez pas avancer. Des attentes naïves bloquent la croissance. Il est temps de vivre dans le présent."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bloccato nel passato o nostalgia irrealistica. Stai idealizzando ciò che era e non puoi andare avanti. Le aspettative ingenue bloccano la crescita. È ora di vivere nel presente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "過去に固執しているか、非現実的な郷愁。あなたはあったものを理想化し、前に進めません。甘い期待が成長を妨げます。現在を生きる時です。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sittende fast i fortiden eller urealistisk nostalgi. Du idealiserer det som var og kan ikke gå videre. Naive forventninger blokkerer vekst. Det er på tide å leve i nuet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utknięty w przeszłości lub nierealistyczna nostalgia. Idealizujesz to, co było, i nie możesz iść do przodu. Naiwne oczekiwania blokują rozwój. Czas żyć teraźniejszością."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Preso no passado ou nostalgia irrealista. Você está idealizando o que foi e não consegue seguir em frente. Expectativas ingênuas bloqueiam o crescimento. É hora de viver no presente."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fast i det förflutna eller orealistisk nostalgi. Du idealiserar det som var och kan inte gå vidare. Naiva förväntningar blockerar tillväxt. Det är dags att leva i nuet."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Застрягли в минулому або нереалістична ностальгія. Ви ідеалізуєте те, що було, і не можете рухатися далі. Наївні очікування блокують зростання. Настав час жити сьогоденням."
          }
        }
      }
    },
    "interpretation.six_of_cups_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nostalgie, Erinnerungen und Unschuld. Die Vergangenheit ist präsent – sei es durch Wiedervereinigungen, Erinnerungen oder die Rückkehr an vertraute Orte. Es liegt eine Süße darin, aber verliere dich nicht zu sehr in dem, was war."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nostalgia, memories, and innocence. The past is present—whether through reunions, memories, or returning to familiar places. There's sweetness here, but don't get too lost in what was."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nostalgia, recuerdos e inocencia. El pasado está presente, ya sea a través de reuniones, recuerdos o el regreso a lugares familiares. Hay dulzura aquí, pero no te pierdas demasiado en lo que fue."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nostalgie, souvenirs et innocence. Le passé est présent – que ce soit à travers des retrouvailles, des souvenirs ou le retour dans des lieux familiers. Il y a de la douceur ici, mais ne vous perdez pas trop dans ce qui était."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nostalgia, ricordi e innocenza. Il passato è presente – sia attraverso riunioni, ricordi o il ritorno in luoghi familiari. C'è dolcezza qui, ma non perdetevi troppo in ciò che era."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "郷愁、思い出、そして無邪気さ。過去は現在に存在します―再会、思い出、または見慣れた場所への回帰を通じて。ここには甘さがありますが、あったものにあまり夢中になりすぎないでください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nostalgi, minner og uskyld. Fortiden er til stede – enten gjennom gjenforeninger, minner eller tilbakevending til kjente steder. Det er sødme her, men ikke bli for tapt i det som var."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nostalgia, wspomnienia i niewinność. Przeszłość jest obecna – czy to przez spotkania, wspomnienia, czy powrót do znajomych miejsc. Jest w tym słodycz, ale nie zagub się zbytnio w tym, co było."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nostalgia, memórias e inocência. O passado está presente – seja através de reuniões, memórias ou retorno a lugares familiares. Há doçura aqui, mas não se perca muito no que foi."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nostalgi, minnen och oskuld. Det förflutna är närvarande – oavsett om det är genom återföreningar, minnen eller att återvända till bekanta platser. Det finns sötma här, men gå inte för vilse i det som var."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ностальгія, спогади та невинність. Минуле присутнє – будь то через возз'єднання, спогади чи повернення до знайомих місць. Тут є солодкість, але не надто захоплюйтеся тим, що було."
          }
        }
      }
    },
    "interpretation.six_of_cups_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Veraltete Gesundheitsansätze funktionieren nicht mehr. In Ablehnung der aktuellen Bedürfnisse deines Körpers zu leben. Vergangene Gesundheitsprobleme tauchen wieder auf. Es ist notwendig, deine Wellness-Praktiken zu aktualisieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Outdated health approaches don't work anymore. Living in denial about your body's current needs. Past health issues resurface. Need to update wellness practices."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los enfoques de salud obsoletos ya no funcionan. Vivir en negación sobre las necesidades actuales de tu cuerpo. Los problemas de salud pasados resurgen. Necesitas actualizar las prácticas de bienestar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les approches de santé obsolètes ne fonctionnent plus. Vivre dans le déni des besoins actuels de votre corps. Les problèmes de santé passés refont surface. Besoin de mettre à jour les pratiques de bien-être."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gli approcci sanitari obsoleti non funzionano più. Vivere negando i bisogni attuali del tuo corpo. Problemi di salute passati riaffiorano. Necessità di aggiornare le pratiche di benessere."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "時代遅れの健康法はもう機能しません。自分の体の現在のニーズを否定して生きています。過去の健康問題が再発します。ウェルネス習慣を更新する必要があります。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utdaterte helsetilnærminger fungerer ikke lenger. Å leve i fornektelse av kroppens nåværende behov. Tidligere helseproblemer dukker opp igjen. Behov for å oppdatere velværepraksis."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przestarzałe podejścia do zdrowia już nie działają. Życie w zaprzeczeniu dotyczącym obecnych potrzeb twojego ciała. Przeszłe problemy zdrowotne powracają. Potrzeba aktualizacji praktyk wellness."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abordagens de saúde ultrapassadas não funcionam mais. Viver em negação sobre as necessidades atuais do seu corpo. Problemas de saúde passados ressurgem. Precisa atualizar as práticas de bem-estar."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Föråldrade hälsotillvägagångssätt fungerar inte längre. Att leva i förnekelse om din kropps nuvarande behov. Tidigare hälsoproblem dyker upp igen. Behov av att uppdatera friskvårdspraxis."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Застарілі підходи до здоров'я більше не працюють. Життя в запереченні поточних потреб вашого тіла. Минулі проблеми зі здоров'ям знову спливають. Потрібно оновити оздоровчі практики."
          }
        }
      }
    },
    "interpretation.six_of_cups_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gesundheitspraktiken aus der Vergangenheit dienen dir gut. Die Rückkehr zu einfacheren Wellness-Routinen. Kindheitsaktivitäten bringen Freude und Gesundheit. Nostalgie unterstützt die Heilung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Health practices from the past serve you well. Returning to simpler wellness routines. Childhood activities bring joy and health. Nostalgia supports healing."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las prácticas de salud del pasado te sirven bien. Volver a rutinas de bienestar más simples. Las actividades de la infancia traen alegría y salud. La nostalgia apoya la curación."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les pratiques de santé du passé vous servent bien. Retour à des routines de bien-être plus simples. Les activités d'enfance apportent joie et santé. La nostalgie favorise la guérison."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le pratiche sanitarie del passato ti servono bene. Tornare a routine di benessere più semplici. Le attività dell'infanzia portano gioia e salute. La nostalgia supporta la guarigione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "過去の健康法があなたに役立ちます。よりシンプルなウェルネス習慣への回帰。子供時代の活動が喜びと健康をもたらします。郷愁が癒しをサポートします。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Helsepraksis fra fortiden tjener deg godt. Tilbakevending til enklere velværerutiner. Barndomsaktiviteter bringer glede og helse. Nostalgi støtter helbredelse."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Praktyki zdrowotne z przeszłości służą ci dobrze. Powrót do prostszych rutyn dobrego samopoczucia. Zajęcia z dzieciństwa przynoszą radość i zdrowie. Nostalgia wspomaga uzdrawianie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Práticas de saúde do passado servem bem. Retornar a rotinas de bem-estar mais simples. Atividades da infância trazem alegria e saúde. A nostalgia apoia a cura."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hälsopraxis från det förflutna tjänar dig väl. Återgång till enklare friskvårdsrutiner. Barndomsaktiviteter ger glädje och hälsa. Nostalgi stödjer läkning."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Практики здоров'я з минулого вам добре служать. Повернення до простіших оздоровчих ритуалів. Дитячі заняття приносять радість і здоров'я. Ностальгія підтримує зцілення."
          }
        }
      }
    },
    "interpretation.six_of_cups_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "In der Vergangenheit zu leben verhindert die gegenwärtige Liebe. Alte Beziehungen zu idealisieren blockiert neue. Du steckst in dem fest, was war, anstatt das zu umarmen, was ist. Geh weiter."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Living in the past prevents present love. Idealizing old relationships blocks new ones. You're stuck in what was instead of embracing what is. Move forward."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vivir en el pasado impide el amor presente. Idealizar viejas relaciones bloquea las nuevas. Estás atrapado en lo que fue en lugar de abrazar lo que es. Sigue adelante."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vivre dans le passé empêche l'amour présent. Idéaliser les anciennes relations bloque les nouvelles. Vous êtes bloqué dans ce qui était au lieu d'accepter ce qui est. Allez de l'avant."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vivere nel passato impedisce l'amore presente. Idealizzare vecchie relazioni blocca quelle nuove. Sei bloccato in ciò che era invece di abbracciare ciò che è. Vai avanti."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "過去に生きることは現在の愛を妨げます。古い関係を理想化することは新しい関係をブロックします。あなたは今あるものを受け入れる代わりに、あったものに固執しています。前進してください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Å leve i fortiden hindrer nåværende kjærlighet. Å idealisere gamle forhold blokkerer nye. Du sitter fast i det som var i stedet for å omfavne det som er. Gå videre."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Życie przeszłością uniemożliwia teraźniejszą miłość. Idealizowanie starych związków blokuje nowe. Utknąłeś w tym, co było, zamiast akceptować to, co jest. Idź dalej."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Viver no passado impede o amor presente. Idealizar relacionamentos antigos bloqueia os novos. Você está preso no que era em vez de abraçar o que é. Siga em frente."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Att leva i det förflutna förhindrar nuvarande kärlek. Att idealisera gamla relationer blockerar nya. Du är fast i det som var istället för att omfamna det som är. Gå vidare."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Життя в минулому заважає теперішньому коханню. Ідеалізація старих стосунків блокує нові. Ви застрягли в тому, що було, замість того, щоб прийняти те, що є. Рухайтеся далі."
          }
        }
      }
    },
    "interpretation.six_of_cups_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nostalgie und süße Erinnerungen in der Liebe. Vergangene Beziehungen oder Kindheitsliebschaften können wieder auftauchen. Unschuld und Geborgenheit in vertrauten Verbindungen. Die Vergangenheit beeinflusst die gegenwärtige Liebe."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nostalgia and sweet memories in love. Past relationships or childhood sweethearts may resurface. Innocence and comfort in familiar connections. The past informs present love."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nostalgia y dulces recuerdos en el amor. Pueden resurgir relaciones pasadas o amores de la infancia. Inocencia y comodidad en conexiones familiares. El pasado informa el amor presente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nostalgie et doux souvenirs en amour. Les relations passées ou les amours d'enfance peuvent refaire surface. Innocence et réconfort dans les liens familiers. Le passé éclaire l'amour présent."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nostalgia e dolci ricordi in amore. Relazioni passate o amori d'infanzia potrebbero riaffiorare. Innocenza e conforto in connessioni familiari. Il passato informa l'amore presente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "愛における郷愁と甘い思い出。過去の関係や子供時代の恋人たちが再浮上するかもしれません。親しみのあるつながりにおける無邪気さと安らぎ。過去が現在の愛に知らせます。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nostalgi og søte minner i kjærlighet. Tidligere forhold eller barndomskjærester kan dukke opp igjen. Uskyld og komfort i kjente forbindelser. Fortiden informerer nåværende kjærlighet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nostalgia i słodkie wspomnienia w miłości. Przeszłe związki lub miłości z dzieciństwa mogą powrócić. Niewinność i komfort w znanych połączeniach. Przeszłość wpływa na obecną miłość."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nostalgia e doces memórias no amor. Relacionamentos passados ou amores de infância podem ressurgir. Inocência e conforto em conexões familiares. O passado informa o amor presente."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nostalgi och ljuva minnen i kärlek. Tidigare relationer eller barndomsförälskelser kan dyka upp igen. Oskuld och tröst i välbekanta förbindelser. Det förflutna informerar nuvarande kärlek."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ностальгія та солодкі спогади в коханні. Минулі стосунки або дитячі закоханості можуть спливти. Невинність і комфорт у звичних зв'язках. Минуле впливає на сьогоденне кохання."
          }
        }
      }
    },
    "interpretation.six_of_pentacles_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ungerechtigkeit am Arbeitsplatz oder einseitige berufliche Beziehungen. Bedingungen, die an Chancen geknüpft sind. Schulden oder Verpflichtungen bei der Arbeit. Machtungleichgewichte beeinträchtigen die Karriere."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Workplace unfairness or one-sided professional relationships. Strings attached to opportunities. Debt or obligation at work. Power imbalances affect career."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Injusticia en el lugar de trabajo o relaciones profesionales unilaterales. Condiciones asociadas a las oportunidades. Deuda u obligación en el trabajo. Los desequilibrios de poder afectan la carrera."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Injustice sur le lieu de travail ou relations professionnelles unilatérales. Conditions attachées aux opportunités. Dette ou obligation au travail. Les déséquilibres de pouvoir affectent la carrière."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ingiustizia sul posto di lavoro o relazioni professionali unilaterali. Condizioni legate alle opportunità. Debito o obbligo sul lavoro. Gli squilibri di potere influiscono sulla carriera."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "職場での不公平または一方的な職業関係。機会に条件が付いている。職場での借金や義務。パワーバランスの不均衡がキャリアに影響する。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Urettferdighet på arbeidsplassen eller ensidige profesjonelle forhold. Betingelser knyttet til muligheter. Gjeld eller forpliktelse på jobb. Maktubalanser påvirker karrieren."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niesprawiedliwość w miejscu pracy lub jednostronne relacje zawodowe. Warunki przywiązane do możliwości. Dług lub zobowiązanie w pracy. Brak równowagi sił wpływa na karierę."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Injustiça no local de trabalho ou relações profissionais unilaterais. Condições vinculadas a oportunidades. Dívida ou obrigação no trabalho. Desequilíbrios de poder afetam a carreira."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Orättvisa på arbetsplatsen eller ensidiga professionella relationer. Villkor kopplade till möjligheter. Skuld eller skyldighet på jobbet. Maktobalanser påverkar karriären."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Несправедливість на робочому місці або односторонні професійні стосунки. Умови, прив'язані до можливостей. Борг або зобов'язання на роботі. Дисбаланс влади впливає на кар'єру."
          }
        }
      }
    },
    "interpretation.six_of_pentacles_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Berufliche Großzügigkeit und faire Vergütung. Ihre Arbeit wird geschätzt und belohnt. Unterstützung geben und erhalten bei der Arbeit. Mentoring kommt der Karriere zugute."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professional generosity and fair compensation. Your work is valued and rewarded. Giving and receiving support at work. Mentorship benefits career."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Generosidad profesional y compensación justa. Tu trabajo es valorado y recompensado. Dar y recibir apoyo en el trabajo. La mentoría beneficia la carrera."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Générosité professionnelle et rémunération équitable. Votre travail est valorisé et récompensé. Donner et recevoir du soutien au travail. Le mentorat profite à la carrière."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Generosità professionale e giusta remunerazione. Il tuo lavoro è valorizzato e premiato. Dare e ricevere supporto sul lavoro. Il mentoring avvantaggia la carriera."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "職業上の寛大さと公正な報酬。あなたの仕事は評価され、報われている。職場でのサポートの与え合い。メンターシップがキャリアに役立つ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profesjonell sjenerøsitet og rettferdig kompensasjon. Arbeidet ditt blir verdsatt og belønnet. Å gi og motta støtte på jobb. Mentorordning gagner karrieren."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zawodowa hojność i sprawiedliwe wynagrodzenie. Twoja praca jest doceniana i nagradzana. Dawanie i otrzymywanie wsparcia w pracy. Mentoring korzystnie wpływa na karierę."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Generosidade profissional e compensação justa. Seu trabalho é valorizado e recompensado. Dar e receber apoio no trabalho. Mentoria beneficia a carreira."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professionell generositet och rättvis ersättning. Ditt arbete uppskattas och belönas. Att ge och ta emot stöd på jobbet. Mentorskap gynnar karriären."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Професійна щедрість та справедлива компенсація. Ваша робота цінується і винагороджується. Надання та отримання підтримки на роботі. Наставництво сприяє кар'єрі."
          }
        }
      }
    },
    "interpretation.six_of_pentacles_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielles Ungleichgewicht oder an Geld gebundene Bedingungen. Einseitige finanzielle Beziehungen. Schulden schaffen Abhängigkeit. Egoismus oder Ausbeutung von Ressourcen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial imbalance or strings attached to money. One-sided financial relationships. Debt creates dependency. Selfishness or exploitation with resources."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desequilibrio financiero o condiciones asociadas al dinero. Relaciones financieras unilaterales. La deuda crea dependencia. Egoísmo o explotación de recursos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Déséquilibre financier ou conditions attachées à l'argent. Relations financières unilatérales. La dette crée une dépendance. Égoïsme ou exploitation des ressources."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Squilibrio finanziario o condizioni legate al denaro. Relazioni finanziarie unilaterali. Il debito crea dipendenza. Egoismo o sfruttamento delle risorse."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的不均衡またはお金に条件が付いている。一方的な金銭関係。借金が依存を生む。リソースの利己主義または搾取。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk ubalanse eller betingelser knyttet til penger. Ensidige økonomiske forhold. Gjeld skaper avhengighet. Egennytte eller utnyttelse av ressurser."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nierównowaga finansowa lub warunki przywiązane do pieniędzy. Jednostronne relacje finansowe. Dług tworzy zależność. Egoizm lub wyzysk zasobów."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desequilíbrio financeiro ou condições vinculadas ao dinheiro. Relações financeiras unilaterais. Dívida cria dependência. Egoísmo ou exploração de recursos."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomisk obalans eller villkor kopplade till pengar. Ensidiga ekonomiska relationer. Skuld skapar beroende. Själviskhet eller utnyttjande av resurser."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансовий дисбаланс або умови, прив'язані до грошей. Односторонні фінансові відносини. Борг створює залежність. Егоїзм або експлуатація ресурсів."
          }
        }
      }
    },
    "interpretation.six_of_pentacles_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Großzügigkeit und ausgewogener Wohlstand. Sie haben genug, um zu teilen. Geben und Nehmen von Geld funktioniert gut. Wohltätigkeit bringt Freude und erhält das Gleichgewicht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial generosity and balanced prosperity. You have enough to share. Giving and receiving money flows well. Charity brings joy and maintains balance."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Generosidad financiera y prosperidad equilibrada. Tienes suficiente para compartir. Dar y recibir dinero fluye bien. La caridad trae alegría y mantiene el equilibrio."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Générosité financière et prospérité équilibrée. Vous en avez assez pour partager. Donner et recevoir de l'argent circule bien. La charité apporte de la joie et maintient l'équilibre."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Generosità finanziaria e prosperità equilibrata. Hai abbastanza da condividere. Dare e ricevere denaro scorre bene. La carità porta gioia e mantiene l'equilibrio."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的な寛大さとバランスの取れた繁栄。あなたは分かち合うのに十分なものを持っている。お金の与え合いがうまく流れる。慈善は喜びをもたらし、バランスを維持する。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk sjenerøsitet og balansert velstand. Du har nok til å dele. Å gi og motta penger flyter godt. Veldedighet bringer glede og opprettholder balanse."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hojność finansowa i zrównoważony dobrobyt. Masz wystarczająco, aby się dzielić. Dawanie i otrzymywanie pieniędzy przebiega dobrze. Dobroczynność przynosi radość i utrzymuje równowagę."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Generosidade financeira e prosperidade equilibrada. Você tem o suficiente para compartilhar. Dar e receber dinheiro flui bem. Caridade traz alegria e mantém o equilíbrio."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomisk generositet och balanserat välstånd. Du har tillräckligt att dela. Att ge och ta emot pengar flyter bra. Välgörenhet ger glädje och upprätthåller balans."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансова щедрість та збалансоване процвітання. У вас достатньо, щоб ділитися. Давання та отримання грошей добре тече. Благодійність приносить радість та підтримує баланс."
          }
        }
      }
    },
    "interpretation.six_of_pentacles_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Einseitige Beziehungen, Bedingungen, Schulden oder Egoismus. Das Gleichgewicht von Geben und Nehmen ist gestört. Machtdynamiken schaffen Ungleichheit. Stellen Sie die Fairness wieder her."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "One-sided relationships, strings attached, debt, or selfishness. The balance of giving and receiving is off. Power dynamics create inequality. Restore fairness."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Relaciones unilaterales, condiciones, deudas o egoísmo. El equilibrio entre dar y recibir está desajustado. Las dinámicas de poder crean desigualdad. Restablece la justicia."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Relations unilatérales, conditions, dettes ou égoïsme. L'équilibre entre donner et recevoir est rompu. Les dynamiques de pouvoir créent des inégalités. Rétablir l'équité."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Relazioni unilaterali, condizioni, debiti o egoismo. L'equilibrio tra dare e ricevere è alterato. Le dinamiche di potere creano disuguaglianza. Ripristina l'equità."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一方的な関係、条件、借金、または利己主義。与え合いのバランスが崩れている。パワーダイナミクスが不平等を生み出す。公平さを回復する。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ensidige forhold, betingelser, gjeld eller egoisme. Balansen mellom å gi og ta er ute av kurs. Makt dynamikk skaper ulikhet. Gjenopprett rettferdighet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jednostronne relacje, warunki, dług lub egoizm. Równowaga między dawaniem a braniem jest zachwiana. Dynamika władzy tworzy nierówności. Przywróć sprawiedliwość."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Relacionamentos unilaterais, condições, dívidas ou egoísmo. O equilíbrio entre dar e receber está desregulado. Dinâmicas de poder criam desigualdade. Restaure a justiça."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ensidiga relationer, villkor, skuld eller själviskhet. Balansen mellan givande och tagande är ur spel. Makt dynamik skapar ojämlikhet. Återställ rättvisa."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Односторонні стосунки, умови, борг або егоїзм. Баланс давання та отримання порушений. Динаміка влади створює нерівність. Відновіть справедливість."
          }
        }
      }
    },
    "interpretation.six_of_pentacles_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Großzügigkeit, Nächstenliebe, Teilen und ausgewogenes Geben und Nehmen. Sie sind in der Lage, anderen zu helfen und gleichzeitig bei Bedarf Unterstützung zu erhalten. Wohlstand fließt durch Geben."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Generosity, charity, sharing, and balanced give-and-take. You're in a position to help others while also receiving support when needed. Prosperity flows through giving."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Generosidad, caridad, compartir y dar y recibir equilibrados. Estás en condiciones de ayudar a los demás y también de recibir apoyo cuando lo necesitas. La prosperidad fluye a través de dar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Générosité, charité, partage et équilibre entre donner et recevoir. Vous êtes en mesure d'aider les autres tout en recevant du soutien en cas de besoin. La prospérité circule par le don."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Generosità, carità, condivisione e dare e ricevere equilibrati. Sei in grado di aiutare gli altri mentre ricevi supporto quando necessario. La prosperità scorre attraverso il dare."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "寛大さ、慈善、分かち合い、バランスの取れた与え合い。あなたは他の人を助けつつ、必要な時にサポートを受けられる立場にある。繁栄は与えることを通じて流れる。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sjenerøsitet, veldedighet, deling og balansert gi-og-ta. Du er i en posisjon til å hjelpe andre samtidig som du mottar støtte når du trenger det. Velstand flyter gjennom giving."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hojność, dobroczynność, dzielenie się i zrównoważone dawanie i branie. Jesteś w stanie pomagać innym, jednocześnie otrzymując wsparcie, gdy go potrzebujesz. Dobrobyt płynie przez dawanie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Generosidade, caridade, compartilhamento e dar e receber equilibrados. Você está em posição de ajudar os outros enquanto também recebe apoio quando necessário. A prosperidade flui através do dar."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Generositet, välgörenhet, delande och balanserat givande och tagande. Du är i en position att hjälpa andra samtidigt som du får stöd när det behövs. Välstånd flödar genom att ge."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Щедрість, благодійність, ділення та збалансоване давання і отримання. Ви перебуваєте в позиції допомагати іншим, одночасно отримуючи підтримку, коли це необхідно. Процвітання тече через давання."
          }
        }
      }
    },
    "interpretation.six_of_pentacles_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unausgewogene gesundheitliche Unterstützung. Zu viel Fürsorge für andere oder sich weigern, Hilfe anzunehmen. Bedingungen an Wellness-Ressourcen geknüpft. Stellen Sie das Gleichgewicht wieder her."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Imbalanced health support. Giving too much care to others or refusing to receive help. Strings attached to wellness resources. Restore balance."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apoyo sanitario desequilibrado. Dar demasiado cuidado a los demás o negarse a recibir ayuda. Condiciones asociadas a los recursos de bienestar. Restablece el equilibrio."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Soutien sanitaire déséquilibré. Accorder trop de soins aux autres ou refuser de recevoir de l'aide. Conditions attachées aux ressources de bien-être. Rétablir l'équilibre."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Supporto sanitario sbilanciato. Dare troppa cura agli altri o rifiutarsi di ricevere aiuto. Condizioni legate alle risorse di benessere. Ripristina l'equilibrio."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "不均衡な健康サポート。他人に世話をしすぎるか、助けを受け取ることを拒否する。ウェルネスリソースに条件が付いている。バランスを回復する。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ubalansert helsestøtte. Å gi for mye omsorg til andre eller nekte å motta hjelp. Betingelser knyttet til velværeressurser. Gjenopprett balansen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niezrównoważone wsparcie zdrowotne. Zbyt duża opieka nad innymi lub odmowa przyjęcia pomocy. Warunki przywiązane do zasobów wellness. Przywróć równowagę."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apoio à saúde desequilibrado. Dar muito cuidado aos outros ou recusar receber ajuda. Condições vinculadas aos recursos de bem-estar. Restaure o equilíbrio."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Obalanserat hälso stöd. Att ge för mycket omsorg till andra eller vägra att ta emot hjälp. Villkor kopplade till hälsoresurser. Återställ balansen."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Не збалансована підтримка здоров'я. Занадто багато турботи про інших або відмова від отримання допомоги. Умови, прив'язані до оздоровчих ресурсів. Відновіть баланс."
          }
        }
      }
    },
    "interpretation.six_of_pentacles_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ausgewogener Ansatz für Gesundheit geben und nehmen. Großzügiges Teilen von Wellness-Ressourcen. Anmutiges Annehmen von Fürsorge. Gesundheitsunterstützung fließt in beide Richtungen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Balanced approach to health giving and receiving. Sharing wellness resources generously. Receiving care graciously. Health support flows both ways."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enfoque equilibrado para dar y recibir en salud. Compartir generosamente los recursos de bienestar. Recibir cuidados con gracia. El apoyo a la salud fluye en ambos sentidos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Approche équilibrée pour donner et recevoir en matière de santé. Partager généreusement les ressources de bien-être. Recevoir des soins avec grâce. Le soutien à la santé circule dans les deux sens."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Approccio equilibrato al dare e ricevere salute. Condividere generosamente le risorse di benessere. Ricevere cure con grazia. Il supporto alla salute scorre in entrambe le direzioni."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "健康の与え合いにおけるバランスの取れたアプローチ。ウェルネスリソースを寛大に共有する。優雅にケアを受け取る。健康サポートが双方向に流れる。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Balansert tilnærming til helsegiving og mottakelse. Å dele velværeressurser sjenerøst. Å motta omsorg med eleganse. Helsehjelp flyter begge veier."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zrównoważone podejście do dawania i otrzymywania w zdrowiu. Hojne dzielenie się zasobami wellness. Otrzymywanie opieki z wdziękiem. Wsparcie zdrowotne płynie w obie strony."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abordagem equilibrada para dar e receber saúde. Compartilhar recursos de bem-estar generosamente. Receber cuidados com graça. Suporte à saúde flui em ambas as direções."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Balanserad strategi för att ge och ta emot hälsa. Att generöst dela hälsoresurser. Att ta emot vård med nåd. Hälso stöd flödar åt båda hållen."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Збалансований підхід до давання та отримання здоров'я. Щедре ділення оздоровчими ресурсами. Прийняття турботи з вдячністю. Підтримка здоров'я тече в обох напрямках."
          }
        }
      }
    },
    "interpretation.six_of_pentacles_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unausgewogenes Geben in Beziehungen. Bedingungen an Liebe oder Unterstützung geknüpft. Eine Person gibt zu viel oder nimmt zu viel. Schuldenmentalität beeinträchtigt die Partnerschaft. Stellen Sie das Gleichgewicht wieder her."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unbalanced giving in relationships. Strings attached to love or support. One person gives too much or takes too much. Debt mentality affects partnership. Restore balance."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dar desequilibrado en las relaciones. Condiciones asociadas al amor o al apoyo. Una persona da demasiado o toma demasiado. La mentalidad de deuda afecta la sociedad. Restablece el equilibrio."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Don déséquilibré dans les relations. Des conditions attachées à l'amour ou au soutien. Une personne donne trop ou prend trop. La mentalité de dette affecte le partenariat. Rétablir l'équilibre."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dare sbilanciato nelle relazioni. Condizioni legate all'amore o al supporto. Una persona dà troppo o prende troppo. La mentalità del debito influisce sulla partnership. Ripristina l'equilibrio."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "関係における不均衡な与え合い。愛やサポートに条件が付いている。一人が与えすぎるか、取りすぎる。借金マインドセットがパートナーシップに影響する。バランスを回復する。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ubalansert giving i forhold. Betingelser knyttet til kjærlighet eller støtte. En person gir for mye eller tar for mye. Gjeldstenkning påvirker partnerskapet. Gjenopprett balansen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niezrównoważone dawanie w związkach. Warunki przywiązane do miłości lub wsparcia. Jedna osoba daje za dużo lub bierze za dużo. Mentalność długu wpływa na partnerstwo. Przywróć równowagę."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dar desequilibrado nos relacionamentos. Condições vinculadas ao amor ou apoio. Uma pessoa dá demais ou recebe demais. Mentalidade de dívida afeta a parceria. Restaure o equilíbrio."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Obalanserat givande i relationer. Villkor kopplade till kärlek eller stöd. En person ger för mycket eller tar för mycket. Skuldmentalitet påverkar partnerskapet. Återställ balansen."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Не збалансоване давання у стосунках. Умови, прив'язані до любові або підтримки. Одна людина дає занадто багато або бере занадто багато. Менталітет боргу впливає на партнерство. Відновіть баланс."
          }
        }
      }
    },
    "interpretation.six_of_pentacles_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Großzügiges Geben und Nehmen in Beziehungen. Ausgewogener Austausch von Unterstützung und Fürsorge. Wohltätigkeit und Freundlichkeit fließen in der Liebe in beide Richtungen. Gesunde Beziehungsdynamik."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Generous giving and receiving in relationships. Balanced exchange of support and care. Charity and kindness flow both ways in love. Healthy partnership dynamics."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dar y recibir generosamente en las relaciones. Intercambio equilibrado de apoyo y cuidado. La caridad y la amabilidad fluyen en ambas direcciones en el amor. Dinámica de pareja saludable."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Donner et recevoir généreusement dans les relations. Échange équilibré de soutien et de soins. La charité et la gentillesse circulent dans les deux sens en amour. Dynamique de partenariat saine."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dare e ricevere generosamente nelle relazioni. Scambio equilibrato di supporto e cura. La carità e la gentilezza fluiscono in entrambe le direzioni nell'amore. Dinamiche di partnership sane."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "関係における寛大な与え合いと受け取り。サポートと思いやりのバランスの取れた交換。慈善と優しさが愛において双方向に流れる。健全なパートナーシップのダイナミクス。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gavmild giving og mottakelse i forhold. Balansert utveksling av støtte og omsorg. Veldedighet og vennlighet flyter begge veier i kjærlighet. Sunn partnerskapsdynamikk."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hojne dawanie i otrzymywanie w związkach. Zrównoważona wymiana wsparcia i opieki. Dobroczynność i życzliwość płyną w obie strony w miłości. Zdrowa dynamika partnerstwa."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dar e receber generosamente nos relacionamentos. Troca equilibrada de apoio e cuidado. Caridade e gentileza fluem em ambas as direções no amor. Dinâmica de parceria saudável."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Generöst givande och mottagande i relationer. Balanserat utbyte av stöd och omsorg. Välgörenhet och vänlighet flyter åt båda hållen i kärlek. Hälsosam partnerskapsdynamik."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Щедре давання та отримання у стосунках. Збалансований обмін підтримкою та турботою. Благодійність та доброта течуть в обох напрямках у любові. Здорова динаміка партнерства."
          }
        }
      }
    },
    "interpretation.six_of_swords_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "In vergangenen Karriereschmerzen stecken. Widerstand gegen den notwendigen beruflichen Übergang. Unerledigte Arbeitsgeschäfte blockieren den Fortschritt. Anhaltende Karriereturbulenzen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stuck in past career pain. Resisting necessary professional transition. Unfinished work business blocks progress. Continued career turbulence."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atrapado en el dolor profesional pasado. Resistirse a la transición profesional necesaria. Asuntos laborales pendientes bloquean el progreso. Turbulencia profesional continua."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Coincé dans une douleur professionnelle passée. Résister à la transition professionnelle nécessaire. Des affaires professionnelles inachevées bloquent les progrès. Turbulences professionnelles continues."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bloccato nel dolore professionale passato. Resistenza alla necessaria transizione professionale. Affari lavorativi incompiuti bloccano il progresso. Turbolenza professionale continua."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "過去のキャリアの痛みに行き詰まる。必要な仕事上の移行に抵抗する。未完了の仕事の問題が進歩を妨げる。継続的なキャリアの激動。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fast i tidligere karrieresmerte. Motstand mot nødvendig profesjonell overgang. Ufullført arbeidssaker blokkerer fremgang. Fortsatt karriereturbulens."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uwięziony w przeszłym bólu kariery. Opór przed niezbędnym przejściem zawodowym. Niedokończone sprawy zawodowe blokują postęp. Ciągłe turbulencje w karierze."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Preso na dor da carreira passada. Resistindo à transição profissional necessária. Assuntos de trabalho inacabados bloqueiam o progresso. Turbulência contínua na carreira."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fast i tidigare karriärsmärta. Motstånd mot nödvändig professionell övergång. Ofullbordade arbetsaffärer blockerar framsteg. Fortsatt karriärturbulens."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Застряг у минулому кар'єрному болю. Опір необхідному професійному переходу. Незавершені робочі справи блокують прогрес. Продовження кар'єрної турбулентності."
          }
        }
      }
    },
    "interpretation.six_of_swords_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriereübergang und berufliche Heilungsreise. Fortschritt von Arbeitsplatzschwierigkeiten. Turbulenten Job für ruhigere Aussichten verlassen. Fortschritt durch Herausforderungen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Career transition and professional healing journey. Moving forward from workplace difficulty. Leaving turbulent job for calmer prospects. Progress through challenges."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Transición profesional y viaje de sanación laboral. Avanzar desde las dificultades laborales. Dejar un trabajo turbulento por perspectivas más tranquilas. Progreso a través de desafíos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Transition de carrière et parcours de guérison professionnelle. Avancer à partir des difficultés sur le lieu de travail. Quitter un travail turbulent pour des perspectives plus calmes. Progrès à travers les défis."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Transizione di carriera e percorso di guarigione professionale. Avanzare dalle difficoltà sul posto di lavoro. Lasciare un lavoro turbolento per prospettive più calme. Progresso attraverso le sfide."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャリアの移行と仕事上の癒しの旅。職場の困難から前進する。激動の仕事を離れ、穏やかな見通しへ。課題を通しての進歩。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriereovergang og profesjonell helbredelsesreise. Gå videre fra vanskeligheter på arbeidsplassen. Forlate turbulent jobb for roligere utsikter. Fremgang gjennom utfordringer."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przejście w karierze i zawodowa podróż uzdrawiania. Odejście od trudności w miejscu pracy. Opuszczenie turbulentnej pracy dla spokojniejszych perspektyw. Postęp przez wyzwania."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Transição de carreira e jornada de cura profissional. Avançar a partir das dificuldades no local de trabalho. Deixar um trabalho turbulento para perspectivas mais calmas. Progresso através de desafios."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriärövergång och professionell läkningsresa. Gå vidare från svårigheter på arbetsplatsen. Lämna turbulent jobb för lugnare framtidsutsikter. Framsteg genom utmaningar."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Кар'єрний перехід і професійна цілюща подорож. Рух вперед від труднощів на робочому місці. Залишення турбулентної роботи для спокійніших перспектив. Прогрес через виклики."
          }
        }
      }
    },
    "interpretation.six_of_swords_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "In vergangenen finanziellen Schmerzen stecken. Widerstand gegen den notwendigen Geldübergang. Unerledigte finanzielle Angelegenheiten verhindern Fortschritt. Anhaltende Ressourcenturbulenzen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stuck in past financial pain. Resisting necessary money transition. Unfinished financial business prevents progress. Continued resource turbulence."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atrapado en el dolor financiero pasado. Resistirse a la transición económica necesaria. Asuntos financieros pendientes bloquean el progreso. Turbulencia continua de recursos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Coincé dans une douleur financière passée. Résister à la transition monétaire nécessaire. Des affaires financières inachevées bloquent les progrès. Turbulences continues des ressources."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bloccato nel dolore finanziario passato. Resistenza alla necessaria transizione monetaria. Affari finanziari incompiuti bloccano il progresso. Turbolenza continua delle risorse."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "過去の金銭的な痛みに行き詰まる。必要な金銭の移行に抵抗する。未完了の金銭的問題が進歩を妨げる。継続的なリソースの激動。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fast i tidligere økonomisk smerte. Motstand mot nødvendig pengeovergang. Ufullført økonomisk virksomhet blokkerer fremgang. Fortsatt ressursturbulens."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uwięziony w przeszłym bólu finansowym. Opór przed niezbędnym przejściem pieniężnym. Niedokończone sprawy finansowe blokują postęp. Ciągłe turbulencje zasobów."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Preso na dor financeira passada. Resistindo à transição financeira necessária. Assuntos financeiros inacabados bloqueiam o progresso. Turbulência contínua de recursos."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fast i tidigare finansiell smärta. Motstånd mot nödvändig pengeövergång. Ofullbordade finansiella affärer blockerar framsteg. Fortsatt resursturbulens."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Застряг у минулому фінансовому болю. Опір необхідному грошовому переходу. Незавершені фінансові справи блокують прогрес. Продовження турбулентності ресурсів."
          }
        }
      }
    },
    "interpretation.six_of_swords_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzieller Übergang und Fortschritt von Geldproblemen. Heilungsreise mit Ressourcen. Finanzielle Turbulenzen hinter sich lassen für Stabilität. Fortschritt durch Härten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial transition and moving forward from money difficulty. Healing journey with resources. Leaving financial turbulence for stability. Progress through hardship."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Transición financiera y avance desde la dificultad económica. Viaje de sanación con recursos. Dejar atrás la turbulencia financiera hacia la estabilidad. Progreso a través de la adversidad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Transition financière et avancée à partir des difficultés monétaires. Voyage de guérison avec les ressources. Quitter les turbulences financières pour la stabilité. Progrès à travers les épreuves."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Transizione finanziaria e avanzamento dalla difficoltà monetaria. Viaggio di guarigione con le risorse. Lasciare le turbolenze finanziarie per la stabilità. Progresso attraverso le difficoltà."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "金銭的な移行とお金の困難からの前進。リソースとの癒しの旅。金銭的な激動を離れ、安定へ。苦難を通しての進歩。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk overgang og fremgang fra pengevansker. Helbredelsesreise med ressurser. Forlate økonomisk turbulens for stabilitet. Fremgang gjennom motgang."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przejście finansowe i odejście od trudności pieniężnych. Podróż uzdrawiania z zasobami. Opuszczenie finansowej turbulencji dla stabilności. Postęp przez trudności."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Transição financeira e avanço a partir de dificuldades financeiras. Jornada de cura com recursos. Deixando a turbulência financeira para a estabilidade. Progresso através das dificuldades."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finansiell övergång och framsteg från pengasvårigheter. Läkningsresa med resurser. Lämna finansiell turbulens för stabilitet. Framsteg genom svårigheter."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансовий перехід і рух вперед від грошових труднощів. Цілюща подорож з ресурсами. Залишення фінансової турбулентності для стабільності. Прогрес через труднощі."
          }
        }
      }
    },
    "interpretation.six_of_swords_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "In der Vergangenheit stecken, Widerstand gegen den Übergang, unerledigte Geschäfte und stürmische Gewässer voraus. Du bist nicht bereit, weiterzugehen. Lass los, um voranzukommen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stuck in past, resistance to transition, unfinished business, and rough waters ahead. You're not ready to move on. Let go to progress."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atrapado en el pasado, resistencia a la transición, asuntos pendientes y aguas turbulentas por delante. No estás listo para seguir adelante. Suelta para progresar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Coincé dans le passé, résistance à la transition, affaires inachevées et eaux agitées à venir. Vous n'êtes pas prêt à avancer. Lâchez prise pour progresser."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bloccato nel passato, resistenza alla transizione, affari incompiuti e acque agitate davanti. Non sei pronto per andare avanti. Lascia andare per progredire."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "過去に行き詰まり、移行への抵抗、未完了の問題、そして荒れた水域が待っている。あなたは前進する準備ができていない。進歩するために手放せ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fast i fortiden, motstand mot overgang, ufullført virksomhet og røffe farvann foran. Du er ikke klar til å gå videre. Slipp taket for å komme videre."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uwięziony w przeszłości, opór przed przejściem, niedokończone sprawy i wzburzone wody przed nami. Nie jesteś gotowy, aby iść dalej. Puść, aby robić postępy."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Preso no passado, resistência à transição, assuntos inacabados e águas turbulentas pela frente. Você não está pronto para seguir em frente. Solte para progredir."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fast i det förflutna, motstånd mot övergång, ofullbordade affärer och grova vatten framför dig. Du är inte redo att gå vidare. Släpp taget för att gå framåt."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Застряг у минулому, опір переходу, незавершені справи та бурхливі води попереду. Ви не готові рухатися далі. Відпустіть, щоб прогресувати."
          }
        }
      }
    },
    "interpretation.six_of_swords_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Übergang, Fortschritt, Heilungsreise und Loslassen. Du verlässt turbulente Gewässer in Richtung ruhigerer. Fortschritt geschieht, auch wenn langsam. Vertraue der Reise."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Transition, moving forward, healing journey, and release. You're leaving turbulent waters for calmer ones. Progress is happening even if slow. Trust the journey."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Transición, avance, viaje de sanación y liberación. Estás dejando aguas turbulentas por otras más tranquilas. El progreso está ocurriendo, aunque sea lento. Confía en el viaje."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Transition, avancée, voyage de guérison et libération. Vous quittez des eaux turbulentes pour des eaux plus calmes. Les progrès se font, même lents. Faites confiance au voyage."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Transizione, avanzamento, viaggio di guarigione e rilascio. Stai lasciando acque turbolente per acque più calme. Il progresso sta accadendo anche se lentamente. Fidati del viaggio."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "移行、前進、癒しの旅、解放。あなたは激動の水域を離れ、より穏やかな水域へ向かっている。遅くても進歩は起きている。旅を信じよ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Overgang, fremgang, helbredelsesreise og slipp taket. Du forlater turbulente farvann for roligere. Fremgang skjer selv om det er sakte. Stol på reisen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przejście, pójście naprzód, podróż uzdrawiania i uwolnienie. Opuszczasz wzburzone wody dla spokojniejszych. Postęp następuje, nawet jeśli powolny. Zaufaj podróży."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Transição, avanço, jornada de cura e libertação. Você está deixando águas turbulentas por outras mais calmas. O progresso está acontecendo, mesmo que devagar. Confie na jornada."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Övergång, framsteg, läkningsresa och frigörelse. Du lämnar turbulenta vatten för lugnare. Framsteg sker även om det är långsamt. Lita på resan."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Перехід, рух вперед, цілюща подорож і звільнення. Ви залишаєте бурхливі води для спокійніших. Прогрес відбувається, навіть якщо повільно. Довіртеся подорожі."
          }
        }
      }
    },
    "interpretation.six_of_swords_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "In vergangenen Gesundheitsschmerzen stecken. Widerstand gegen den notwendigen Wohlfühlübergang. Unerledigte Heilungsgeschäfte blockieren die Genesung. Anhaltende körperliche Turbulenzen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stuck in past health pain. Resisting necessary wellness transition. Unfinished healing business blocks recovery. Continued physical turbulence."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atrapado en el dolor de salud pasado. Resistirse a la transición necesaria hacia el bienestar. Asuntos de curación pendientes bloquean la recuperación. Turbulencia física continua."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Coincé dans une douleur de santé passée. Résister à la transition nécessaire vers le bien-être. Des affaires de guérison inachevées bloquent la guérison. Turbulences physiques continues."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bloccato nel dolore di salute passato. Resistenza alla necessaria transizione del benessere. Affari di guarigione incompiuti bloccano il recupero. Turbolenza fisica continua."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "過去の健康の痛みに行き詰まる。必要なウェルネスの移行に抵抗する。未完了の癒しの問題が回復を妨げる。継続的な身体の激動。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fast i tidligere helsesmerte. Motstand mot nødvendig velværeovergang. Ufullført helbredelsesarbeid blokkerer bedring. Fortsatt fysisk turbulens."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uwięziony w przeszłym bólu zdrowotnym. Opór przed niezbędnym przejściem do dobrego samopoczucia. Niedokończone sprawy uzdrawiania blokują powrót do zdrowia. Ciągłe fizyczne turbulencje."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Preso na dor de saúde passada. Resistindo à transição necessária para o bem-estar. Assuntos de cura inacabados bloqueiam a recuperação. Turbulência física contínua."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fast i tidigare hälsosmärta. Motstånd mot nödvändig välmåendeövergång. Ofullbordade läkningsaffärer blockerar återhämtning. Fortsatt fysisk turbulens."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Застряг у минулому болю здоров'я. Опір необхідному переходу до благополуччя. Незавершені справи зцілення блокують одужання. Продовження фізичної турбулентності."
          }
        }
      }
    },
    "interpretation.six_of_swords_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gesundheitsübergang und Heilungsreise. Fortschritt von körperlichen Schwierigkeiten. Wohlfühl-Turbulenzen hinter sich lassen für Genesung. Fortschritt durch Krankheit."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Health transition and healing journey. Moving forward from physical difficulty. Leaving wellness turbulence for recovery. Progress through illness."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Transición de salud y viaje de sanación. Avanzar desde la dificultad física. Dejar atrás la turbulencia del bienestar para recuperarse. Progreso a través de la enfermedad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Transition sanitaire et parcours de guérison. Avancer à partir de difficultés physiques. Quitter les turbulences du bien-être pour la guérison. Progrès à travers la maladie."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Transizione di salute e viaggio di guarigione. Avanzare dalle difficoltà fisiche. Lasciare le turbolenze del benessere per il recupero. Progresso attraverso la malattia."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "健康の移行と癒しの旅。身体的な困難から前進する。ウェルネスの激動を離れ、回復へ。病気を通しての進歩。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Helseovergang og helbredelsesreise. Gå videre fra fysiske vanskeligheter. Forlate velværeturbulens for bedring. Fremgang gjennom sykdom."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przejście zdrowotne i podróż uzdrawiania. Odejście od trudności fizycznych. Opuszczenie turbulencji dobrego samopoczucia dla powrotu do zdrowia. Postęp przez chorobę."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Transição de saúde e jornada de cura. Avançar a partir de dificuldades físicas. Deixar a turbulência do bem-estar para a recuperação. Progresso através da doença."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hälsoövergång och läkningsresa. Gå vidare från fysiska svårigheter. Lämna välmåendeturbulens för återhämtning. Framsteg genom sjukdom."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Перехід здоров'я та цілюща подорож. Рух вперед від фізичних труднощів. Залишення турбулентності благополуччя для одужання. Прогрес через хворобу."
          }
        }
      }
    },
    "interpretation.six_of_swords_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "In vergangenen Beziehungsschmerzen stecken. Widerstand gegen den notwendigen Liebesübergang. Unerledigte romantische Angelegenheiten verhindern das Vorankommen. Stürmische emotionale Gewässer bleiben bestehen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stuck in past relationship pain. Resisting necessary love transition. Unfinished romantic business prevents moving forward. Rough emotional waters continue."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atrapado en el dolor de relaciones pasadas. Resistirse a la transición amorosa necesaria. Asuntos románticos pendientes impiden avanzar. Continúan las aguas emocionales turbulentas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Coincé dans la douleur relationnelle passée. Résister à la transition amoureuse nécessaire. Des affaires romantiques inachevées empêchent d'avancer. Des eaux émotionnelles agitées continuent."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bloccato nel dolore relazionale passato. Resistenza alla necessaria transizione amorosa. Questioni romantiche incompiute impediscono di andare avanti. Acque emotive agitate continuano."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "過去の関係の痛みに行き詰まる。必要な恋愛の移行に抵抗する。未解決の恋愛の問題が前進を妨げる。荒れた感情の水域が続く。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fast i tidligere forholdssmerte. Motstand mot nødvendig kjærlighetsovergang. Ufullført romantisk forretning hindrer fremgang. Tøffe emosjonelle farvann fortsetter."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uwięziony w przeszłym bólu związku. Opór przed niezbędnym przejściem miłosnym. Niedokończone romantyczne sprawy uniemożliwiają pójście naprzód. Trudne emocjonalne wody trwają."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Preso na dor do relacionamento passado. Resistindo à transição amorosa necessária. Assuntos românticos inacabados impedem o avanço. Águas emocionais turbulentas continuam."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fast i tidigare relationssmärta. Motstånd mot nödvändig kärleksövergång. Ofullbordade romantiska affärer hindrar framsteg. Grova känslomässiga vatten fortsätter."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Застряг у минулому болю стосунків. Опір необхідному любовному переходу. Незавершені романтичні справи перешкоджають руху вперед. Бурхливі емоційні води тривають."
          }
        }
      }
    },
    "interpretation.six_of_swords_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beziehungsübergang und Fortschritt vom Liebesschmerz. Heilungsreise in der Partnerschaft. Romantische Turbulenzen hinter sich lassen für ruhigere Gewässer. Fortschritt durch Schwierigkeiten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Relationship transition and moving forward from love pain. Healing journey in partnership. Leaving romantic turbulence for calmer waters. Progress through difficulty."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Transición de la relación y avance desde el dolor del amor. Viaje de sanación en la pareja. Dejar atrás la turbulencia romántica hacia aguas más tranquilas. Progreso a través de la dificultad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Transition relationnelle et avancée à partir de la douleur amoureuse. Voyage de guérison en partenariat. Quitter les turbulences romantiques pour des eaux plus calmes. Progrès à travers la difficulté."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Transizione relazionale e avanzamento dal dolore dell'amore. Viaggio di guarigione nella partnership. Lasciare le turbolenze romantiche per acque più calme. Progresso attraverso la difficoltà."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "関係の移行と愛の痛みからの前進。パートナーシップにおける癒しの旅。恋愛の激動を離れ、穏やかな水域へ。困難を通しての進歩。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Forholdsovergang og fremgang fra kjærlighetssmerte. Helbredelsesreise i partnerskap. Forlate romantisk turbulens for roligere farvann. Fremgang gjennom vanskeligheter."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przejście w związku i odejście od bólu miłości. Podróż uzdrawiania w partnerstwie. Opuszczenie romantycznych turbulencji dla spokojniejszych wód. Postęp przez trudności."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Transição de relacionamento e avanço a partir da dor do amor. Jornada de cura na parceria. Deixando a turbulência romântica para águas mais calmas. Progresso através da dificuldade."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Relationsövergång och framsteg från kärlekssmärta. Läkningsresa i partnerskap. Lämna romantisk turbulens för lugnare vatten. Framsteg genom svårigheter."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Перехід у стосунках і рух вперед від болю кохання. Цілюща подорож у партнерстві. Залишення романтичної турбулентності для спокійніших вод. Прогрес через труднощі."
          }
        }
      }
    },
    "interpretation.six_of_wands_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriereversagen oder mangelnde berufliche Anerkennung. Arbeitsarroganz oder Job-Egoismus. Private Probleme trotz öffentlichem Erfolg."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Career failure or lack of professional recognition. Work arrogance or job egotism. Private struggles despite public success."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fracaso profesional o falta de reconocimiento profesional. Arrogancia laboral o egocentrismo profesional. Luchas privadas a pesar del éxito público."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Échec de carrière ou manque de reconnaissance professionnelle. Arrogance au travail ou égocentrisme professionnel. Luttes privées malgré le succès public."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fallimento della carriera o mancanza di riconoscimento professionale. Arroganza lavorativa o egoismo professionale. Lotte private nonostante il successo pubblico."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャリアの失敗や職業上の認識不足。仕事の傲慢さや仕事の自己中心性。公の成功にもかかわらず、私的な苦闘。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karrieresvikt eller mangel på profesjonell anerkjennelse. Arbeidsarroganse eller jobbegoismer. Private kamper til tross for offentlig suksess."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niepowodzenie w karierze lub brak uznania zawodowego. Arogancja w pracy lub egoizm zawodowy. Prywatne zmagania pomimo publicznego sukcesu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fracasso na carreira ou falta de reconhecimento profissional. Arrogância no trabalho ou egoísmo profissional. Lutas privadas apesar do sucesso público."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriärmisslyckande eller brist på professionellt erkännande. Arbetsarrogan eller jobbegocentrism. Privata kamper trots offentlig framgång."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Кар'єрна невдача або відсутність професійного визнання. Зарозумілість у роботі або егоїзм на роботі. Приватні труднощі, незважаючи на публічний успіх."
          }
        }
      }
    },
    "interpretation.six_of_wands_career_upright" : {
