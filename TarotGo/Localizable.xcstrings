      }
    },
    "interpretation.page_of_cups_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schlechte Gesundheitsnachrichten oder emotionale Unreife, die das Wohlbefinden beeinträchtigt. Eskapismus blockiert den Gesundheitsfortschritt. Ignorieren intuitiver Körperbotschaften."
          }
