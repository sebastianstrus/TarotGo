    "interpretation.king_of_swords_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manipulation, Machtmissbrauch, Tyrannei und Grausamkeit. Du nutzt deinen Intellekt und deine Position als Waffen. Logik ohne Mitgefühl wird zur Tyrannei. Werde weicher."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manipulation, abuse of power, tyranny, and cruelty. You're using your intellect and position as weapons. Logic without compassion becomes tyranny. Soften."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manipulación, abuso de poder, tiranía y crueldad. Estás usando tu intelecto y posición como armas. La lógica sin compasión se convierte en tiranía. Suavízate."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manipulation, abus de pouvoir, tyrannie et cruauté. Vous utilisez votre intellect et votre position comme armes. La logique sans compassion devient tyrannie. Adoucissez-vous."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manipolazione, abuso di potere, tirannia e crudeltà. Stai usando il tuo intelletto e la tua posizione come armi. La logica senza compassione diventa tirannia. Ammorbidisciti."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "操作、権力乱用、専制、残酷さ。あなたは知性と立場を武器として使っている。思いやりのない論理は専制になる。優しくなれ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manipulasjon, maktmisbruk, tyranni og grusomhet. Du bruker intellektet og posisjonen din som våpen. Logikk uten medfølelse blir tyranni. Mykne."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manipulacja, nadużycie władzy, tyrania i okrucieństwo. Używasz swojego intelektu i pozycji jako broni. Logika bez współczucia staje się tyranią. Zmięknij."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manipulação, abuso de poder, tirania e crueldade. Você está usando seu intelecto e posição como armas. Lógica sem compaixão se torna tirania. Suavize."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manipulation, maktmissbruk, tyranni och grymhet. Du använder ditt intellekt och din position som vapen. Logik utan medkänsla blir tyranni. Mjukna."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Маніпуляція, зловживання владою, тиранія та жорстокість. Ви використовуєте свій інтелект і позицію як зброю. Логіка без співчуття стає тиранією. Пом'якшайте."
          }
        }
      }
    },
    "interpretation.king_of_swords_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Autorität, Wahrheit, intellektuelle Kraft und klarer Geist. Du führst mit Logik und Ethik. Dein Urteil ist fundiert und deine Kommunikation ist autoritativ. Macht durch Klarheit."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Authority, truth, intellectual power, and clear mind. You lead with logic and ethics. Your judgment is sound and your communication is authoritative. Power through clarity."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Autoridad, verdad, poder intelectual y mente clara. Lideras con lógica y ética. Tu juicio es sólido y tu comunicación es autoritaria. Poder a través de la claridad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Autorité, vérité, puissance intellectuelle et esprit clair. Vous dirigez avec logique et éthique. Votre jugement est solide et votre communication est autoritaire. Le pouvoir par la clarté."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Autorità, verità, potere intellettuale e mente chiara. Guidate con logica ed etica. Il tuo giudizio è solido e la tua comunicazione è autorevole. Potere attraverso la chiarezza."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "権威、真実、知力、明晰な心。あなたは論理と倫理で導く。あなたの判断は確かで、コミュニケーションは権威的。明確さを通しての力。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Autoritet, sannhet, intellektuell kraft og klart sinn. Du leder med logikk og etikk. Din dømmekraft er solid og kommunikasjonen din er autoritær. Makt gjennom klarhet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Władza, prawda, siła intelektu i jasny umysł. Prowadzisz z logiką i etyką. Twój osąd jest solidny, a komunikacja autorytatywna. Siła przez jasność."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Autoridade, verdade, poder intelectual e mente clara. Você lidera com lógica e ética. Seu julgamento é sólido e sua comunicação é autoritária. Poder através da clareza."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Auktoritet, sanning, intellektuell kraft och klart sinne. Du leder med logik och etik. Din bedömning är sund och din kommunikation är auktoritär. Makt genom klarhet."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Авторитет, правда, інтелектуальна сила та ясний розум. Ви ведете з логікою та етикою. Ваше судження є надійним, а ваше спілкування авторитетним. Сила через ясність."
          }
        }
      }
    },
