        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk tilståelse eller å komme ren om penger. Ærlighet erstatter økonomisk bedrag. Revurdere ressursstrategi. Sannheten kommer frem."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finansowe wyznanie lub oczyszczenie w sprawie pieniędzy. Uczciwość zastępuje finansowe oszustwo. Ponowne przemyślenie strategii zasobów. Prawda wychodzi na jaw."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confissão financeira ou confissão sobre dinheiro. A honestidade substitui o engano financeiro. Repensar a estratégia de recursos. A verdade emerge."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finansiell bekännelse eller komma ren om pengar. Ärlighet ersätter finansiellt bedrägeri. Omtänka resursstrategi. Sanningen kommer fram."
