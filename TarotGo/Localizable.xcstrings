    "interpretation.three_of_cups_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klatsch am Arbeitsplatz oder toxische soziale Dynamiken. Übermäßiger Genuss beeinträchtigt den beruflichen Ruf. Gefühl der Isolation vom Team. Büropolitik verursacht Probleme."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Workplace gossip or toxic social dynamics. Overindulgence affecting professional reputation. Feeling isolated from team. Office politics create problems."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chismes en el lugar de trabajo o dinámicas sociales tóxicas. El exceso afecta la reputación profesional. Sensación de aislamiento del equipo. La política de oficina crea problemas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Commérages au travail ou dynamiques sociales toxiques. Les excès nuisent à la réputation professionnelle. Sentiment d'isolement par rapport à l'équipe. La politique de bureau crée des problèmes."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pettegolezzi sul posto di lavoro o dinamiche sociali tossiche. L'eccessiva indulgenza influisce sulla reputazione professionale. Sensazione di isolamento dal team. La politica d'ufficio crea problemi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "職場のゴシップや有害な社会的力学。過度の贅沢が職業上の評判に影響を与えます。チームから孤立している感覚。オフィスの政治が問題を引き起こします。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sladder på arbeidsplassen eller giftig sosial dynamikk. Overdreven nytelse påvirker profesjonelt rykte. Følelse av isolasjon fra teamet. Kontorpolitikk skaper problemer."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Plotki w miejscu pracy lub toksyczna dynamika społeczna. Nadmierne pobłażanie sobie wpływa na reputację zawodową. Poczucie izolacji od zespołu. Polityka biurowa stwarza problemy."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fofocas no local de trabalho ou dinâmicas sociais tóxicas. O excesso afeta a reputação profissional. Sentimento de isolamento da equipe. A política de escritório cria problemas."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Skvaller på arbetsplatsen eller giftig social dynamik. Överdrivet njutande påverkar professionellt rykte. Känsla av isolering från teamet. Kontorspolitik skapar problem."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Плітки на робочому місці або токсична соціальна динаміка. Надмірне потурання впливає на професійну репутацію. Відчуття ізоляції від команди. Офісна політика створює проблеми."
          }
        }
      }
    },
    "interpretation.three_of_cups_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beruflicher Erfolg durch Teamarbeit und Feiern. Gemeinsame Siege und Freundschaften am Arbeitsplatz gedeihen. Deine Beiträge werden von Kollegen anerkannt und gefeiert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professional success through teamwork and celebration. Collaborative victories and workplace friendships thrive. Your contributions are recognized and celebrated by colleagues."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Éxito profesional a través del trabajo en equipo y la celebración. Las victorias colaborativas y las amistades en el lugar de trabajo prosperan. Tus contribuciones son reconocidas y celebradas por tus colegas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Réussite professionnelle grâce au travail d'équipe et à la célébration. Les victoires collaboratives et les amitiés au travail prospèrent. Vos contributions sont reconnues et célébrées par vos collègues."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Successo professionale attraverso il lavoro di squadra e la celebrazione. Le vittorie collaborative e le amicizie sul posto di lavoro prosperano. I tuoi contributi sono riconosciuti e celebrati dai colleghi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "チームワークと祝福によるプロとしての成功。協力的な勝利と職場の友情が繁栄します。あなたの貢献は同僚に認識され、称賛されます。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profesjonell suksess gjennom teamarbeid og feiring. Samarbeidsseire og vennskap på arbeidsplassen trives. Dine bidrag blir anerkjent og feiret av kolleger."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sukces zawodowy dzięki pracy zespołowej i świętowaniu. Wspólne zwycięstwa i przyjaźnie w miejscu pracy rozkwitają. Twoje wkłady są doceniane i celebrowane przez współpracowników."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sucesso profissional através do trabalho em equipe e celebração. Vitórias colaborativas e amizades no local de trabalho prosperam. Suas contribuições são reconhecidas e celebradas pelos colegas."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professionell framgång genom teamarbete och firande. Samarbetssegrar och arbetsplatsvänskap frodas. Dina bidrag erkänns och firas av kollegor."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Професійний успіх через командну роботу та святкування. Спільні перемоги та дружба на робочому місці процвітають. Ваш внесок визнається та відзначається колегами."
          }
        }
      }
    },
    "interpretation.three_of_cups_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Übermäßige Ausgaben für soziale Aktivitäten oder Feiern. Finanzielle Belastung durch den Versuch, mit anderen mitzuhalten. Klatsch über Geldangelegenheiten. Finanzielle Isolation."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Overspending on social activities or celebrations. Financial strain from trying to keep up with others. Gossip about money matters. Financial isolation."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gastos excesivos en actividades sociales o celebraciones. Tensión financiera por tratar de seguir el ritmo de los demás. Chismes sobre asuntos de dinero. Aislamiento financiero."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dépenses excessives pour des activités sociales ou des célébrations. Tensions financières dues aux tentatives de suivre les autres. Commérages sur les questions d'argent. Isolement financier."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spese eccessive per attività sociali o celebrazioni. Tensione finanziaria nel tentativo di stare al passo con gli altri. Pettegolezzi su questioni di denaro. Isolamento finanziario."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "社交活動や祝賀会での過剰支出。他人に合わせようとして経済的負担がかかります。金銭問題に関するゴシップ。経済的孤立。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "For høye utgifter til sosiale aktiviteter eller feiringer. Økonomisk belastning fra å prøve å holde tritt med andre. Sladder om penger. Økonomisk isolasjon."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nadmierne wydatki na aktywności społeczne lub uroczystości. Napięcia finansowe wynikające z próby dotrzymania kroku innym. Plotki o sprawach pieniężnych. Izolacja finansowa."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gastos excessivos em atividades sociais ou celebrações. Tensão financeira por tentar acompanhar os outros. Fofocas sobre questões financeiras. Isolamento financeiro."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Överutgifter på sociala aktiviteter eller firanden. Ekonomisk påfrestning från att försöka hålla jämna steg med andra. Skvaller om pengar. Ekonomisk isolering."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Надмірні витрати на соціальну діяльність або святкування. Фінансове напруження через спроби не відставати від інших. Плітки про грошові справи. Фінансова ізоляція."
          }
        }
      }
    },
    "interpretation.three_of_cups_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Feier und geteilter Überfluss. Gruppeninvestitionen oder Feiern bringen Freude. Wohlstand wird durch Gemeinschaft und Großzügigkeit gesteigert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial celebration and shared abundance. Group investments or celebrations bring joy. Prosperity is enhanced through community and generosity."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Celebración financiera y abundancia compartida. Las inversiones grupales o celebraciones traen alegría. La prosperidad se mejora a través de la comunidad y la generosidad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Célébration financière et abondance partagée. Les investissements de groupe ou les célébrations apportent de la joie. La prospérité est renforcée par la communauté et la générosité."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Celebrazione finanziaria e abbondanza condivisa. Investimenti di gruppo o celebrazioni portano gioia. La prosperità è accresciuta attraverso la comunità e la generosità."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的な祝福と共有された豊かさ。グループ投資や祝賀が喜びをもたらします。コミュニティと寛大さを通じて繁栄が高まります。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk feiring og delt overflod. Gruppeinvesteringer eller feiringer bringer glede. Velstand forbedres gjennom fellesskap og raushet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finansowe świętowanie i wspólna obfitość. Inwestycje grupowe lub uroczystości przynoszą radość. Dobrobyt jest wzmacniany przez społeczność i hojność."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Celebração financeira e abundância compartilhada. Investimentos em grupo ou celebrações trazem alegria. A prosperidade é melhorada através da comunidade e generosidade."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomiskt firande och delad överflöd. Gruppinvesteringar eller firanden ger glädje. Välstånd förbättras genom gemenskap och generositet."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансове святкування та спільний достаток. Групові інвестиції або святкування приносять радість. Процвітання посилюється через спільноту та щедрість."
          }
        }
      }
    },
    "interpretation.three_of_cups_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isolation, übermäßiger Genuss oder toxische soziale Dynamiken. Klatsch und Drama rauben dir Energie. Du feierst entweder zu viel oder ziehst dich zu sehr zurück. Finde eine gesunde Balance."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isolation, overindulgence, or toxic social dynamics. Gossip and drama drain your energy. You're either partying too much or withdrawing too much. Find healthy balance."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aislamiento, exceso o dinámicas sociales tóxicas. Los chismes y el drama drenan tu energía. O estás de fiesta demasiado o te retiras demasiado. Encuentra un equilibrio saludable."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isolement, excès ou dynamiques sociales toxiques. Les commérages et les drames drainent votre énergie. Vous faites soit trop la fête, soit vous vous retirez trop. Trouvez un équilibre sain."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isolamento, eccessiva indulgenza o dinamiche sociali tossiche. Pettegolezzi e drammi prosciugano la tua energia. O festeggi troppo o ti ritiri troppo. Trova un equilibrio sano."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "孤立、過度の贅沢、または有害な社会的力学。噂話やドラマがあなたのエネルギーを消耗させます。あなたはパーティーをしすぎているか、引きこもりすぎています。健全なバランスを見つけてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isolasjon, overdreven nytelse eller giftig sosial dynamikk. Sladder og drama tapper energien din. Du fester enten for mye eller trekker deg for mye tilbake. Finn sunn balanse."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Izolacja, nadmierne pobłażanie sobie lub toksyczna dynamika społeczna. Plotki i dramaty wysysają twoją energię. Albo za dużo imprezujesz, albo za bardzo się wycofujesz. Znajdź zdrową równowagę."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isolamento, excesso ou dinâmicas sociais tóxicas. Fofocas e dramas drenam sua energia. Você está festejando demais ou se retraindo demais. Encontre um equilíbrio saudável."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isolering, överdrivet njutande eller giftig social dynamik. Skvaller och drama dränerar din energi. Du festar antingen för mycket eller drar dig tillbaka för mycket. Hitta en sund balans."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ізоляція, надмірне потурання або токсична соціальна динаміка. Плітки та драми виснажують вашу енергію. Ви або занадто багато веселитеся, або занадто відсторонюєтеся. Знайдіть здоровий баланс."
          }
        }
      }
    },
    "interpretation.three_of_cups_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Feier, Freundschaft und gemeinschaftliche Freude. Das Leben bittet dich, dich zu verbinden, zu teilen und mit anderen zu feiern. Deine Gemeinschaft unterstützt dich. Die Fülle vervielfacht sich, wenn sie geteilt wird."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Celebration, friendship, and community joy. Life is asking you to connect, share, and celebrate with others. Your tribe supports you. Abundance multiplies when shared."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Celebración, amistad y alegría comunitaria. La vida te pide que te conectes, compartas y celebres con los demás. Tu tribu te apoya. La abundancia se multiplica cuando se comparte."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Célébration, amitié et joie communautaire. La vie vous demande de vous connecter, de partager et de célébrer avec les autres. Votre tribu vous soutient. L'abondance se multiplie lorsqu'elle est partagée."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Celebrazione, amicizia e gioia comunitaria. La vita ti chiede di connetterti, condividere e celebrare con gli altri. La tua tribù ti supporta. L'abbondanza si moltiplica quando è condivisa."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "祝福、友情、そしてコミュニティの喜び。人生はあなたに他者とつながり、共有し、祝うことを求めています。あなたの仲間があなたをサポートします。豊かさは共有されると倍増します。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Feiring, vennskap og fellesskapsglede. Livet ber deg om å koble deg til, dele og feire med andre. Din stamme støtter deg. Overflod multipliseres når den deles."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Świętowanie, przyjaźń i wspólnotowa radość. Życie prosi cię o nawiązywanie kontaktów, dzielenie się i świętowanie z innymi. Twoje plemię cię wspiera. Obfitość mnoży się, gdy jest dzielona."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Celebração, amizade e alegria comunitária. A vida está pedindo que você se conecte, compartilhe e celebre com os outros. Sua tribo o apoia. A abundância se multiplica quando compartilhada."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Firande, vänskap och gemenskapsglädje. Livet ber dig att ansluta, dela och fira med andra. Din stam stödjer dig. Överflöd multipliceras när det delas."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Святкування, дружба та радість спільноти. Життя просить вас спілкуватися, ділитися та святкувати з іншими. Ваше плем'я підтримує вас. Достаток збільшується, коли ним діляться."
          }
        }
      }
    },
    "interpretation.three_of_cups_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Übermäßiger Genuss beeinträchtigt die Gesundheit. Sozialer Druck führt zu ungesunden Entscheidungen. Einsamkeit beeinträchtigt das Wohlbefinden. Brauche Balance zwischen sozialen Aktivitäten und Selbstfürsorge."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Overindulgence affecting health. Social pressures lead to unhealthy choices. Loneliness impacts wellness. Need balance in social activities and self-care."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El exceso afecta la salud. Las presiones sociales conducen a elecciones poco saludables. La soledad afecta el bienestar. Necesitas equilibrio entre las actividades sociales y el cuidado personal."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les excès nuisent à la santé. Les pressions sociales conduisent à des choix malsains. La solitude a un impact sur le bien-être. Besoin d'équilibre entre activités sociales et soins personnels."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'eccessiva indulgenza influisce sulla salute. Le pressioni sociali portano a scelte malsane. La solitudine influisce sul benessere. Necessità di equilibrio tra attività sociali e cura di sé."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "過度の贅沢が健康に影響を与えます。社会的プレッシャーが不健康な選択につながります。孤独が健康に影響を与えます。社交活動と自己管理のバランスが必要です。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Overdreven nytelse påvirker helsen. Sosialt press fører til usunne valg. Ensomhet påvirker velvære. Behov for balanse mellom sosiale aktiviteter og egenomsorg."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nadmierne pobłażanie sobie wpływa na zdrowie. Presja społeczna prowadzi do niezdrowych wyborów. Samotność wpływa na samopoczucie. Potrzeba równowagi między aktywnością społeczną a dbaniem o siebie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O excesso afeta a saúde. Pressões sociais levam a escolhas prejudiciais à saúde. A solidão afeta o bem-estar. Precisa de equilíbrio entre atividades sociais e autocuidado."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Överdrivet njutande påverkar hälsan. Sociala påtryckningar leder till ohälsosamma val. Ensamhet påverkar välbefinnandet. Behov av balans mellan sociala aktiviteter och egenvård."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Надмірне потурання впливає на здоров'я. Соціальний тиск призводить до нездорових виборів. Самотність впливає на благополуччя. Потрібен баланс між соціальною активністю та самообслуговуванням."
          }
        }
      }
    },
    "interpretation.three_of_cups_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gesundheitliche Vorteile durch soziale Verbindungen und Feiern. Freunde unterstützen deinen Wellness-Weg. Freudige Gruppenaktivitäten steigern das Wohlbefinden. Emotionale Gesundheit gedeiht durch Gemeinschaft."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Health benefits from social connection and celebration. Friends support your wellness journey. Joyful group activities boost wellbeing. Emotional health thrives through community."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beneficios para la salud de la conexión social y la celebración. Los amigos apoyan tu viaje de bienestar. Las actividades grupales alegres mejoran el bienestar. La salud emocional prospera a través de la comunidad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bienfaits pour la santé de la connexion sociale et de la célébration. Les amis soutiennent votre parcours de bien-être. Les activités de groupe joyeuses améliorent le bien-être. La santé émotionnelle prospère grâce à la communauté."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Benefici per la salute dalla connessione sociale e dalla celebrazione. Gli amici supportano il tuo percorso di benessere. Le attività di gruppo gioiose aumentano il benessere. La salute emotiva prospera attraverso la comunità."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "社会的なつながりと祝福による健康上の利点。友人があなたのウェルネスの旅をサポートします。楽しいグループ活動が幸福感を高めます。コミュニティを通じて感情的な健康が繁栄します。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Helsefordeler fra sosial tilknytning og feiring. Venner støtter reisen din mot velvære. Glade gruppeaktiviteter øker velvære. Emosjonell helse trives gjennom fellesskap."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Korzyści zdrowotne wynikające z kontaktów społecznych i świętowania. Przyjaciele wspierają twoją drogę do dobrego samopoczucia. Radosne zajęcia grupowe poprawiają samopoczucie. Zdrowie emocjonalne rozwija się dzięki społeczności."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Benefícios à saúde da conexão social e celebração. Amigos apoiam sua jornada de bem-estar. Atividades alegres em grupo aumentam o bem-estar. A saúde emocional prospera através da comunidade."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hälsofördelar från social anslutning och firande. Vänner stödjer din friskvårdsresa. Glada gruppaktiviteter ökar välbefinnandet. Känslomässig hälsa frodas genom gemenskap."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Користь для здоров'я від соціальних зв'язків та святкування. Друзі підтримують ваш шлях до оздоровлення. Радісні групові заняття підвищують благополуччя. Емоційне здоров'я процвітає через спільноту."
          }
        }
      }
    },
    "interpretation.three_of_cups_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Soziale Dynamiken belasten Beziehungen. Klatsch oder Einmischung Dritter beeinträchtigen dein Liebesleben. Übermäßiger Genuss schadet der Verbindung. Isolation vom Unterstützungsnetzwerk."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Social dynamics strain relationships. Gossip or third-party interference affects your love life. Overindulgence damages connection. Isolation from support network."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las dinámicas sociales tensan las relaciones. Los chismes o la interferencia de terceros afectan tu vida amorosa. El exceso daña la conexión. Aislamiento de la red de apoyo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les dynamiques sociales pèsent sur les relations. Les commérages ou les interférences extérieures affectent votre vie amoureuse. Les excès nuisent à la connexion. Isolement du réseau de soutien."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le dinamiche sociali mettono a dura prova le relazioni. I pettegolezzi o le interferenze di terzi influenzano la tua vita amorosa. L'eccessiva indulgenza danneggia la connessione. Isolamento dalla rete di supporto."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "社会的な力学が関係に負担をかけます。噂話や第三者の干渉が恋愛に影響を与えます。過度の贅沢がつながりを損ないます。サポートネットワークからの孤立。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sosiale dynamikker belaster forhold. Sladder eller innblanding utenfra påvirker kjærlighetslivet ditt. Overdreven nytelse skader forbindelsen. Isolasjon fra støttenettverket."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dynamika społeczna obciąża relacje. Plotki lub ingerencja osób trzecich wpływają na twoje życie miłosne. Nadmierne pobłażanie sobie niszczy więź. Izolacja od sieci wsparcia."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dinâmicas sociais prejudicam relacionamentos. Fofocas ou interferência de terceiros afetam sua vida amorosa. O excesso prejudica a conexão. Isolamento da rede de apoio."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Social dynamik belastar relationer. Skvaller eller inblandning utifrån påverkar ditt kärleksliv. Överdrivet njutande skadar anslutningen. Isolering från stödnätverket."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Соціальна динаміка обтяжує стосунки. Плітки або втручання третіх осіб впливають на ваше любовне життя. Надмірне потурання шкодить зв'язку. Ізоляція від мережі підтримки."
          }
        }
      }
    },
    "interpretation.three_of_cups_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Feier, Freude und gemeinschaftliche Unterstützung in der Liebe. Deine Beziehung wird von Freunden und Familie gesegnet. Soziale Verbindungen bereichern dein Liebesleben. Fülle der Liebe umgibt dich."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Celebration, joy, and community support in love. Your relationship is blessed by friends and family. Social connections enhance your romantic life. Abundance of love surrounds you."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Celebración, alegría y apoyo comunitario en el amor. Tu relación es bendecida por amigos y familiares. Las conexiones sociales mejoran tu vida amorosa. Una abundancia de amor te rodea."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Célébration, joie et soutien communautaire en amour. Votre relation est bénie par vos amis et votre famille. Les liens sociaux enrichissent votre vie amoureuse. Une abondance d'amour vous entoure."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Celebrazione, gioia e sostegno della comunità in amore. La tua relazione è benedetta da amici e familiari. Le connessioni sociali arricchiscono la tua vita sentimentale. Un'abbondanza d'amore ti circonda."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "愛における祝福、喜び、そしてコミュニティのサポート。あなたの関係は友人や家族に祝福されています。社会的なつながりがあなたの恋愛生活を豊かにします。愛にあふれています。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Feiring, glede og fellesskapsstøtte i kjærlighet. Forholdet ditt blir velsignet av venner og familie. Sosiale forbindelser forbedrer kjærlighetslivet ditt. Overflod av kjærlighet omgir deg."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Świętowanie, radość i wsparcie społeczności w miłości. Twój związek jest błogosławiony przez przyjaciół i rodzinę. Relacje społeczne wzbogacają twoje życie miłosne. Otacza cię obfitość miłości."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Celebração, alegria e apoio comunitário no amor. Seu relacionamento é abençoado por amigos e familiares. Conexões sociais melhoram sua vida amorosa. Uma abundância de amor o cerca."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Firande, glädje och gemenskapsstöd i kärlek. Din relation välsignas av vänner och familj. Sociala kontakter förbättrar ditt kärleksliv. En överflöd av kärlek omger dig."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Святкування, радість і підтримка спільноти в коханні. Ваші стосунки благословенні друзями та родиною. Соціальні зв'язки покращують ваше любовне життя. Вас оточує достаток кохання."
          }
        }
      }
    },
    "interpretation.three_of_pentacles_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Arbeitsplatz-Desorganisation und mangelnde Teamarbeit. Schlechte Zusammenarbeit beeinträchtigt die Ergebnisse. Konflikte mit Kollegen. Die Qualität der Arbeit leidet. Kommunikationszusammenbruch."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Workplace disorganization and lack of teamwork. Poor collaboration affects results. Conflicts with colleagues. Quality of work suffers. Communication breakdown."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desorganización en el lugar de trabajo y falta de trabajo en equipo. La mala colaboración afecta los resultados. Conflictos con los colegas. La calidad del trabajo se resiente. Ruptura de la comunicación."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Désorganisation du lieu de travail et manque de travail d'équipe. Une mauvaise collaboration affecte les résultats. Conflits avec les collègues. La qualité du travail en souffre. Rupture de communication."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Disorganizzazione sul posto di lavoro e mancanza di lavoro di squadra. Una cattiva collaborazione influisce sui risultati. Conflitti con i colleghi. La qualità del lavoro ne risente. Rottura della comunicazione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "職場の無秩序とチームワークの欠如。協力不足が結果に影響。同僚との衝突。仕事の質が損なわれる。コミュニケーションの断絶。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uorganisering på arbeidsplassen og mangel på teamarbeid. Dårlig samarbeid påvirker resultatene. Konflikter med kolleger. Kvaliteten på arbeidet lider. Kommunikasjonssvikt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dezorganizacja w miejscu pracy i brak pracy zespołowej. Słaba współpraca wpływa na wyniki. Konflikty z kolegami. Jakość pracy cierpi. Załamanie komunikacji."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desorganização no local de trabalho e falta de trabalho em equipe. Colaboração ruim afeta os resultados. Conflitos com colegas. A qualidade do trabalho sofre. Falha na comunicação."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oorganisering på arbetsplatsen och brist på lagarbete. Dåligt samarbete påverkar resultaten. Konflikter med kollegor. Kvaliteten på arbetet lider. Kommunikationsbrist."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Дезорганізація на робочому місці та відсутність командної роботи. Погана співпраця впливає на результати. Конфлікти з колегами. Якість роботи страждає. Розрив комунікації."
          }
        }
      }
    },
    "interpretation.three_of_pentacles_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beruflicher Erfolg durch Zusammenarbeit und qualifizierte Teamarbeit. Ihre Expertise wird anerkannt. Qualitätsarbeit und Kooperation bringen Fortschritt. Sie bauen etwas Dauerhaftes auf."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professional success through collaboration and skilled teamwork. Your expertise is recognized. Quality work and cooperation bring advancement. You're building something lasting."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Éxito profesional a través de la colaboración y el trabajo en equipo cualificado. Tu experiencia es reconocida. El trabajo de calidad y la cooperación traen avance. Estás construyendo algo duradero."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Succès professionnel grâce à la collaboration et au travail d'équipe qualifié. Votre expertise est reconnue. Un travail de qualité et une coopération apportent l'avancement. Vous construisez quelque chose de durable."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Successo professionale attraverso la collaborazione e il lavoro di squadra qualificato. La tua esperienza è riconosciuta. Il lavoro di qualità e la cooperazione portano avanzamento. Stai costruendo qualcosa di duraturo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "協力と熟練したチームワークを通じた職業的成功。あなたの専門知識が認められる。質の高い仕事と協力が前進をもたらす。永続的な何かを築いている。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profesjonell suksess gjennom samarbeid og dyktig teamarbeid. Din ekspertise blir anerkjent. Kvalitetsarbeid og samarbeid gir fremgang. Du bygger noe varig."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sukces zawodowy dzięki współpracy i wykwalifikowanej pracy zespołowej. Twoja wiedza specjalistyczna jest doceniana. Wysokiej jakości praca i współpraca przynoszą awans. Budujesz coś trwałego."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sucesso profissional através da colaboração e trabalho em equipe qualificado. Sua experiência é reconhecida. Trabalho de qualidade e cooperação trazem avanço. Você está construindo algo duradouro."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professionell framgång genom samarbete och skickligt lagarbete. Din expertis erkänns. Kvalitetsarbete och samarbete ger framsteg. Du bygger något varaktigt."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Професійний успіх через співпрацю та кваліфіковану командну роботу. Ваш досвід визнається. Якісна робота та співпраця приносять просування. Ви будуєте щось тривале."
          }
        }
      }
    },
    "interpretation.three_of_pentacles_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Desorganisation oder schlechte Teamarbeit beim Geld. Konflikte um gemeinsame Ressourcen. Die Qualität der Finanzplanung leidet. Bessere Zusammenarbeit ist nötig."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial disorganization or poor money teamwork. Conflicts about shared resources. Quality of financial planning suffers. Need better collaboration."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desorganización financiera o mal trabajo en equipo con el dinero. Conflictos por los recursos compartidos. La calidad de la planificación financiera se resiente. Se necesita mejor colaboración."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Désorganisation financière ou mauvais travail d'équipe en matière d'argent. Conflits autour des ressources partagées. La qualité de la planification financière en souffre. Besoin d'une meilleure collaboration."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Disorganizzazione finanziaria o scarso lavoro di squadra sul denaro. Conflitti sulle risorse condivise. La qualità della pianificazione finanziaria ne risente. Necessaria una migliore collaborazione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "財務上の無秩序または資金に関するチームワークの不足。共有リソースに関する衝突。財務計画の質が損なわれる。より良い協力が必要。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk uorganisering eller dårlig penge-teamarbeid. Konflikter om delte ressurser. Kvaliteten på økonomisk planlegging lider. Trenger bedre samarbeid."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dezorganizacja finansowa lub słaba współpraca pieniężna. Konflikty o wspólne zasoby. Jakość planowania finansowego cierpi. Potrzeba lepszej współpracy."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desorganização financeira ou mau trabalho em equipe financeira. Conflitos sobre recursos compartilhados. A qualidade do planejamento financeiro sofre. Melhor colaboração necessária."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finansiell oorganisering eller dåligt lagarbete kring pengar. Konflikter om delade resurser. Kvaliteten på finansiell planering lider. Behöver bättre samarbete."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансова дезорганізація або погана командна робота з грошима. Конфлікти щодо спільних ресурсів. Якість фінансового планування страждає. Потрібна краща співпраця."
          }
        }
      }
    },
    "interpretation.three_of_pentacles_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzieller Erfolg durch Zusammenarbeit und qualifizierte Bemühungen. Teamarbeit bringt Wohlstand. Hochwertige Finanzplanung zahlt sich aus. Vermögensaufbau durch Fachwissen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial success through collaboration and skilled effort. Teamwork brings prosperity. Quality financial planning pays off. Building wealth through expertise."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Éxito financiero a través de la colaboración y el esfuerzo cualificado. El trabajo en equipo trae prosperidad. Una planificación financiera de calidad da sus frutos. Construyendo riqueza a través de la experiencia."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Succès financier grâce à la collaboration et à un effort qualifié. Le travail d'équipe apporte la prospérité. Une planification financière de qualité porte ses fruits. Construire la richesse grâce à l'expertise."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Successo finanziario attraverso la collaborazione e lo sforzo qualificato. Il lavoro di squadra porta prosperità. Una pianificazione finanziaria di qualità paga. Costruire ricchezza attraverso l'esperienza."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "協力と熟練した努力を通じた経済的成功。チームワークが繁栄をもたらす。質の高い財務計画が報われる。専門知識を通じた富の構築。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk suksess gjennom samarbeid og dyktig innsats. Teamarbeid bringer velstand. Kvalitetsmessig økonomisk planlegging lønner seg. Bygge rikdom gjennom ekspertise."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sukces finansowy dzięki współpracy i wykwalifikowanemu wysiłkowi. Praca zespołowa przynosi dobrobyt. Wysokiej jakości planowanie finansowe popłaca. Budowanie bogactwa dzięki wiedzy specjalistycznej."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sucesso financeiro através da colaboração e esforço qualificado. Trabalho em equipe traz prosperidade. Planejamento financeiro de qualidade compensa. Construindo riqueza através da experiência."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomisk framgång genom samarbete och skicklig ansträngning. Lagarbete ger välstånd. Kvalitativ finansiell planering lönar sig. Bygga rikedom genom expertis."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансовий успіх через співпрацю та кваліфіковані зусилля. Командна робота приносить процвітання. Якісне фінансове планування окупається. Побудова багатства через досвід."
          }
        }
      }
    },
    "interpretation.three_of_pentacles_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mangel an Teamarbeit, Desorganisation und schlechte Ergebnisse. Konflikte stören den Fortschritt. Die Zusammenarbeit scheitert. Fähigkeiten werden nicht anerkannt. Bessere Kommunikation und mehr Einsatz sind nötig."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lack of teamwork, disorganization, and poor quality results. Conflicts disrupt progress. Collaboration fails. Skills aren't recognized. Better communication and effort needed."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Falta de trabajo en equipo, desorganización y malos resultados. Los conflictos interrumpen el progreso. La colaboración fracasa. Las habilidades no son reconocidas. Se necesita mejor comunicación y esfuerzo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manque de travail d'équipe, désorganisation et mauvais résultats. Les conflits perturbent les progrès. La collaboration échoue. Les compétences ne sont pas reconnues. Une meilleure communication et un meilleur effort sont nécessaires."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mancanza di lavoro di squadra, disorganizzazione e scarsi risultati. I conflitti interrompono i progressi. La collaborazione fallisce. Le competenze non sono riconosciute. Necessaria una migliore comunicazione e impegno."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "チームワークの欠如、無秩序、そして質の低い結果。紛争が進歩を妨げる。協力が失敗する。スキルが認められない。より良いコミュニケーションと努力が必要。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mangel på teamarbeid, uorganisering og dårlige resultater. Konflikter forstyrrer fremdriften. Samarbeid mislykkes. Ferdigheter blir ikke anerkjent. Trenger bedre kommunikasjon og innsats."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Brak pracy zespołowej, dezorganizacja i słabe wyniki. Konflikty zakłócają postęp. Współpraca zawodzi. Umiejętności nie są doceniane. Potrzeba lepszej komunikacji i wysiłku."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Falta de trabalho em equipe, desorganização e resultados de baixa qualidade. Conflitos interrompem o progresso. Colaboração falha. Habilidades não são reconhecidas. Melhor comunicação e esforço necessários."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Brist på lagarbete, oorganisering och dåliga resultat. Konflikter stör framstegen. Samarbete misslyckas. Färdigheter erkänns inte. Bättre kommunikation och ansträngning behövs."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Відсутність командної роботи, дезорганізація та погані результати. Конфлікти порушують прогрес. Співпраця провалюється. Навички не визнаються. Потрібна краща комунікація та зусилля."
          }
        }
      }
    },
    "interpretation.three_of_pentacles_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Teamarbeit, Zusammenarbeit und qualifizierte, hochwertige Arbeit. Sie bauen durch Kooperation und Fachwissen etwas Dauerhaftes auf. Ihre Bemühungen werden anerkannt. Erfolg durch gemeinsame Ziele."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Teamwork, collaboration, and skilled quality work. You're building something lasting through cooperation and expertise. Your efforts are recognized. Success through shared goals."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trabajo en equipo, colaboración y trabajo cualificado de calidad. Estás construyendo algo duradero a través de la cooperación y la experiencia. Tus esfuerzos son reconocidos. Éxito a través de objetivos compartidos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Travail d'équipe, collaboration et travail qualifié de qualité. Vous construisez quelque chose de durable grâce à la coopération et à l'expertise. Vos efforts sont reconnus. Le succès passe par des objectifs communs."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lavoro di squadra, collaborazione e lavoro qualificato di qualità. Stai costruendo qualcosa di duraturo attraverso la cooperazione e l'esperienza. I tuoi sforzi sono riconosciuti. Successo attraverso obiettivi condivisi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "チームワーク、協力、そして熟練した質の高い仕事。協力と専門知識を通じて永続的な何かを築いている。あなたの努力は認められている。共通の目標を通じた成功。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Teamarbeid, samarbeid og dyktig kvalitetsarbeid. Du bygger noe varig gjennom samarbeid og ekspertise. Innsatsen din blir anerkjent. Suksess gjennom felles mål."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Praca zespołowa, współpraca i wykwalifikowana, wysokiej jakości praca. Budujesz coś trwałego dzięki współpracy i wiedzy specjalistycznej. Twoje wysiłki są doceniane. Sukces poprzez wspólne cele."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trabalho em equipe, colaboração e trabalho qualificado de qualidade. Você está construindo algo duradouro através da cooperação e experiência. Seus esforços são reconhecidos. Sucesso através de objetivos compartilhados."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lagarbete, samarbete och skickligt kvalitetsarbete. Du bygger något varaktigt genom samarbete och expertis. Dina ansträngningar uppmärksammas. Framgång genom gemensamma mål."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Командна робота, співпраця та кваліфікована якісна робота. Ви будуєте щось тривале через кооперацію та досвід. Ваші зусилля визнаються. Успіх через спільні цілі."
          }
        }
      }
    },
    "interpretation.three_of_pentacles_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gesundheitliche Desorganisation oder schlechte Zusammenarbeit mit dem Pflegeteam. Die Qualität der Wellness-Bemühungen leidet. Konflikte um die Behandlung. Bessere Teamarbeit im Gesundheitswesen ist nötig."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Health disorganization or poor collaboration with care team. Quality of wellness efforts suffers. Conflicts about treatment. Need better health teamwork."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desorganización de la salud o mala colaboración con el equipo de atención. La calidad de los esfuerzos de bienestar se resiente. Conflictos sobre el tratamiento. Se necesita mejor trabajo en equipo en la salud."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Désorganisation de la santé ou mauvaise collaboration avec l'équipe soignante. La qualité des efforts de bien-être en souffre. Conflits concernant le traitement. Besoin d'un meilleur travail d'équipe en matière de santé."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Disorganizzazione della salute o scarsa collaborazione con il team di cura. La qualità degli sforzi di benessere ne risente. Conflitti sul trattamento. Necessario un migliore lavoro di squadra in ambito sanitario."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "健康の無秩序またはケアチームとの協力不足。ウェルネスへの取り組みの質が損なわれる。治療に関する衝突。より良い健康上のチームワークが必要。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uorganisering i helsearbeid eller dårlig samarbeid med omsorgsteamet. Kvaliteten på velværeinnsats lider. Konflikter om behandling. Trenger bedre helseteam-arbeid."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dezorganizacja zdrowotna lub słaba współpraca z zespołem opiekuńczym. Jakość wysiłków wellness cierpi. Konflikty dotyczące leczenia. Potrzeba lepszej pracy zespołowej w kwestiach zdrowotnych."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desorganização da saúde ou má colaboração com a equipe de cuidados. A qualidade dos esforços de bem-estar sofre. Conflitos sobre o tratamento. Melhor trabalho em equipe de saúde necessário."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hälso- och sjukvårdsdesorganisation eller dåligt samarbete med vårdteamet. Kvaliteten på hälsoinsatser lider. Konflikter om behandling. Behöver bättre hälso- och sjukvårdsteamarbete."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Дезорганізація здоров'я або погана співпраця з медичною командою. Якість оздоровчих зусиль страждає. Конфлікти щодо лікування. Потрібна краща командна робота в питаннях здоров'я."
          }
        }
      }
    },
    "interpretation.three_of_pentacles_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gesundheitlicher Erfolg durch Teamarbeit mit Praktikern. Hochwertige Wellness-Bemühungen zahlen sich aus. Qualifizierter Ansatz für die Gesundheit. Aufbau einer soliden Grundlage durch Zusammenarbeit."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Health success through teamwork with practitioners. Quality wellness efforts pay off. Skilled approach to health. Building solid foundation through collaboration."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Éxito en la salud a través del trabajo en equipo con profesionales. Los esfuerzos de bienestar de calidad dan sus frutos. Enfoque cualificado de la salud. Construyendo una base sólida a través de la colaboración."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Succès en matière de santé grâce au travail d'équipe avec les praticiens. Des efforts de bien-être de qualité portent leurs fruits. Approche qualifiée de la santé. Construire une base solide grâce à la collaboration."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Successo nella salute attraverso il lavoro di squadra con i professionisti. Gli sforzi di benessere di qualità ripagano. Approccio qualificato alla salute. Costruire solide fondamenta attraverso la collaborazione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "実践者とのチームワークを通じた健康上の成功。質の高いウェルネスへの取り組みが報われる。健康への熟練したアプローチ。協力を通じて確固たる基盤を築く。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Helsesuksess gjennom teamarbeid med utøvere. Kvalitetsmessig velværeinnsats lønner seg. Dyktig tilnærming til helse. Bygge solid grunnmur gjennom samarbeid."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sukces zdrowotny dzięki pracy zespołowej z praktykami. Wysokiej jakości wysiłki wellness popłacają. Wykwalifikowane podejście do zdrowia. Budowanie solidnych podstaw poprzez współpracę."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sucesso na saúde através do trabalho em equipe com profissionais. Esforços de bem-estar de qualidade compensam. Abordagem qualificada para a saúde. Construindo uma base sólida através da colaboração."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hälsoframgång genom lagarbete med utövare. Kvalitativa hälsoinsatser lönar sig. Kunnigt förhållningssätt till hälsa. Bygga solid grund genom samarbete."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Успіх у здоров'ї через командну роботу з практиками. Якісні оздоровчі зусилля окупаються. Кваліфікований підхід до здоров'я. Побудова міцної основи через співпрацю."
          }
        }
      }
    },
    "interpretation.three_of_pentacles_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mangel an Teamarbeit belastet die Beziehung. Schlechte Zusammenarbeit oder ungleicher Einsatz. Konflikte über gemeinsame Ziele. Die Qualität der Partnerschaft leidet. Bessere Zusammenarbeit."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lack of teamwork strains relationship. Poor collaboration or unequal effort. Conflicts about shared goals. Quality of partnership suffers. Work together better."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La falta de trabajo en equipo tensa la relación. Mala colaboración o esfuerzo desigual. Conflictos sobre objetivos comunes. La calidad de la sociedad se resiente. Trabajen mejor juntos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le manque de travail d'équipe pèse sur la relation. Mauvaise collaboration ou effort inégal. Conflits sur les objectifs communs. La qualité du partenariat en souffre. Mieux travailler ensemble."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La mancanza di lavoro di squadra mette a dura prova la relazione. Scarsa collaborazione o impegno diseguale. Conflitti sugli obiettivi comuni. La qualità della partnership ne risente. Lavorare meglio insieme."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "チームワークの欠如が関係に負担をかける。不十分な協力または不平等な努力。共通の目標に関する衝突。パートナーシップの質が損なわれる。よりうまく協力する。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mangel på teamarbeid belaster forholdet. Dårlig samarbeid eller ujevn innsats. Konflikter om felles mål. Kvaliteten på partnerskapet lider. Samarbeid bedre."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Brak pracy zespołowej obciąża związek. Słaba współpraca lub nierówny wysiłek. Konflikty dotyczące wspólnych celów. Jakość partnerstwa cierpi. Lepiej współpracujcie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Falta de trabalho em equipe prejudica o relacionamento. Colaboração ruim ou esforço desigual. Conflitos sobre objetivos comuns. A qualidade da parceria sofre. Trabalhem melhor juntos."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Brist på lagarbete belastar relationen. Dåligt samarbete eller ojämn ansträngning. Konflikter om gemensamma mål. Partnerskapets kvalitet lider. Arbeta bättre tillsammans."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Відсутність командної роботи обтяжує стосунки. Погана співпраця або нерівні зусилля. Конфлікти щодо спільних цілей. Якість партнерства страждає. Краще працюйте разом."
          }
        }
      }
    },
    "interpretation.three_of_pentacles_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aufbau einer Beziehung durch Teamarbeit und Zusammenarbeit. Qualitätszeit und Einsatz stärken die Partnerschaft. Gemeinsam an gemeinsamen Zielen arbeiten. Liebe, die auf einem soliden Fundament aufbaut."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Building relationship through teamwork and collaboration. Quality time and effort strengthen partnership. Working together on shared goals. Love built on solid foundation."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Construyendo la relación a través del trabajo en equipo y la colaboración. El tiempo y el esfuerzo de calidad fortalecen la sociedad. Trabajando juntos en objetivos comunes. Amor construido sobre una base sólida."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Construire une relation grâce au travail d'équipe et à la collaboration. Le temps de qualité et les efforts renforcent le partenariat. Travailler ensemble sur des objectifs communs. L'amour construit sur une base solide."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Costruire una relazione attraverso il lavoro di squadra e la collaborazione. Tempo di qualità e impegno rafforzano la partnership. Lavorare insieme verso obiettivi comuni. Amore costruito su solide fondamenta."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "チームワークと協力を通じて関係を構築する。質の高い時間と努力がパートナーシップを強化する。共通の目標に向かって一緒に取り組む。確固たる基盤の上に築かれた愛。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bygge forhold gjennom teamarbeid og samarbeid. Kvalitetstid og innsats styrker partnerskapet. Jobbe sammen mot felles mål. Kjærlighet bygget på solid grunnmur."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Budowanie związku poprzez pracę zespołową i współpracę. Wartościowy czas i wysiłek wzmacniają partnerstwo. Wspólna praca nad wspólnymi celami. Miłość zbudowana na solidnym fundamencie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Construindo relacionamento através do trabalho em equipe e colaboração. Tempo de qualidade e esforço fortalecem a parceria. Trabalhando juntos em objetivos comuns. Amor construído em uma base sólida."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bygga relation genom lagarbete och samarbete. Kvalitetstid och ansträngning stärker partnerskapet. Arbeta tillsammans mot gemensamma mål. Kärlek byggd på solid grund."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Побудова стосунків через командну роботу та співпрацю. Якісний час та зусилля зміцнюють партнерство. Спільна робота над спільними цілями. Любов, побудована на міцному фундаменті."
          }
        }
      }
    },
    "interpretation.three_of_swords_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erholung von beruflichem Herzschmerz. Vergebung des beruflichen Verrats. Abschied von Arbeitsschmerz. Heilung beginnt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recovery from career heartbreak. Forgiveness of professional betrayal. Moving on from work pain. Healing begins."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recuperación del desamor profesional. Perdón de la traición profesional. Superar el dolor laboral. La curación comienza."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rétablissement après un chagrin professionnel. Pardon de la trahison professionnelle. Surmonter la douleur du travail. La guérison commence."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recupero dal crepacuore professionale. Perdono del tradimento professionale. Andare oltre il dolore del lavoro. La guarigione inizia."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "仕事上の失意からの回復。仕事上の裏切りの許し。仕事の痛みから前進する。癒しが始まる。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bedring fra karrierehjertesorg. Tilgivelse av profesjonelt svik. Gå videre fra arbeidssmerte. Helbredelse begynner."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Powrót do zdrowia po zawodowym złamanym sercu. Przebaczenie zawodowej zdrady. Odejście od bólu pracy. Leczenie się rozpoczyna."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recuperação de desgosto profissional. Perdão da traição profissional. Superando a dor do trabalho. A cura começa."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Återhämtning från karriärhjärtesorg. Förlåtelse av professionellt svek. Gå vidare från arbetssmärta. Läkning börjar."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Одужання від кар'єрного розбитого серця. Прощення професійної зради. Рух далі від робочого болю. Зцілення починається."
          }
        }
      }
    },
    "interpretation.three_of_swords_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beruflicher Herzschmerz und Arbeitsenttäuschung. Verrat oder Ablehnung bei der Arbeit. Karriereschmerz ist real. Die Wahrheit über die Arbeitssituation schmerzt, klärt aber."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professional heartbreak and work disappointment. Betrayal or rejection at work. Career pain is real. Truth about job situation hurts but clarifies."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desamor profesional y decepción laboral. Traición o rechazo en el trabajo. El dolor profesional es real. La verdad sobre la situación laboral duele pero aclara."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chagrin professionnel et déception au travail. Trahison ou rejet au travail. La douleur professionnelle est réelle. La vérité sur la situation professionnelle fait mal mais clarifie."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Crepacuore professionale e delusione lavorativa. Tradimento o rifiuto sul lavoro. Il dolore professionale è reale. La verità sulla situazione lavorativa fa male ma chiarisce."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "仕事上の失意と職場での失望。職場での裏切りや拒絶。キャリアの痛みは現実だ。仕事の状況についての真実は痛いが明確になる。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profesjonell hjertesorg og jobbskuffelse. Svik eller avvisning på jobb. Karrieresmerte er ekte. Sannheten om jobbsituasjonen gjør vondt, men klargjør."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zawodowe złamane serce i rozczarowanie w pracy. Zdrada lub odrzucenie w pracy. Ból zawodowy jest prawdziwy. Prawda o sytuacji zawodowej boli, ale wyjaśnia."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desgosto profissional e decepção no trabalho. Traição ou rejeição no trabalho. A dor na carreira é real. A verdade sobre a situação profissional dói, mas esclarece."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professionell hjärtesorg och arbetsbesvikelse. Svek eller avvisning på jobbet. Karriärsmärta är verklig. Sanningen om arbetssituationen gör ont men klargör."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Професійне розбите серце та розчарування на роботі. Зрада або відмова на роботі. Кар'єрний біль реальний. Правда про робочу ситуацію болить, але прояснює."
          }
        }
      }
    },
    "interpretation.three_of_swords_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
