    "interpretation.king_of_wands_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impulsivität, Tyrannei, Arroganz und Rücksichtslosigkeit. Deine Führung ist zu Dominanz geworden. Leidenschaft ohne Weisheit zerstört. Zügle dein Feuer."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impulsiveness, tyranny, arrogance, and ruthlessness. Your leadership has become domination. Passion without wisdom destroys. Temper your fire."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impulsividad, tiranía, arrogancia y crueldad. Tu liderazgo se ha convertido en dominación. La pasión sin sabiduría destruye. Refrena tu fuego."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impulsivité, tyrannie, arrogance et impitoyabilité. Votre leadership est devenu domination. La passion sans sagesse détruit. Tempérez votre feu."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impulsività, tirannia, arroganza e spietatezza. La tua leadership è diventata dominio. La passione senza saggezza distrugge. Modera il tuo fuoco."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "衝動性、専制、傲慢、無情。あなたのリーダーシップは支配へと変わった。知恵なき情熱は破壊する。あなたの炎を制御しましょう。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impulsivitet, tyranni, arroganse og nådeløshet. Lederskapet ditt har blitt dominans. Lidenskap uten visdom ødelegger. Tem din ild."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impulsywność, tyrania, arogancja i bezwzględność. Twoje przywództwo stało się dominacją. Pasja bez mądrości niszczy. Okiełznaj swój ogień."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impulsividade, tirania, arrogância e crueldade. Sua liderança se tornou dominação. Paixão sem sabedoria destrói. Domine seu fogo."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impulsivitet, tyranni, arrogans och skoningslöshet. Ditt ledarskap har blivit dominans. Passion utan visdom förstör. Temra din eld."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Імпульсивність, тиранія, зарозумілість і безжальність. Ваше лідерство перетворилося на домінування. Пристрасть без мудрості знищує. Приборкайте свій вогонь."
          }
        }
      }
    },
    "interpretation.king_of_wands_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Führung, Vision, Unternehmergeist und Ehre. Du bist ein geborener Anführer mit Leidenschaft und Weitsicht. Deine Begeisterung inspiriert andere. Kanalisiere dein Feuer weise."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Leadership, vision, entrepreneurship, and honor. You're a natural born leader with passion and vision. Your enthusiasm inspires others. Channel your fire wisely."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Liderazgo, visión, espíritu emprendedor y honor. Eres un líder nato con pasión y visión. Tu entusiasmo inspira a los demás. Canaliza tu fuego sabiamente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Leadership, vision, esprit d'entreprise et honneur. Vous êtes un leader né avec passion et vision. Votre enthousiasme inspire les autres. Canalisez votre feu judicieusement."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Leadership, visione, spirito imprenditoriale e onore. Sei un leader nato con passione e visione. Il tuo entusiasmo ispira gli altri. Canalizza il tuo fuoco saggiamente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "リーダーシップ、ビジョン、起業家精神、名誉。あなたは情熱とビジョンを持つ生まれながらのリーダーです。あなたの熱意は他者を刺激します。炎を賢く導きましょう。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lederskap, visjon, entreprenørskap og ære. Du er en naturlig leder med lidenskap og visjon. Din entusiasme inspirerer andre. Kanaliser ilden din klokt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przywództwo, wizja, przedsiębiorczość i honor. Jesteś urodzonym liderem z pasją i wizją. Twój entuzjazm inspiruje innych. Kieruj swoim ogniem mądrze."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Liderança, visão, espírito empreendedor e honra. Você é um líder nato com paixão e visão. Seu entusiasmo inspira os outros. Canalize seu fogo sabiamente."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ledarskap, vision, entreprenörskap och ära. Du är en född ledare med passion och vision. Din entusiasm inspirerar andra. Kanalisera din eld klokt."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Лідерство, бачення, підприємливість і честь. Ви природжений лідер з пристрастю та баченням. Ваш ентузіазм надихає інших. Спрямовуйте свій вогонь wisely."
          }
        }
      }
    },
