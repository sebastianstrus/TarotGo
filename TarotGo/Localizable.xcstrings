        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "健康のどん底と身体の危機。体の裏切りとウェルネスの崩壊。これ以上悪くはならない——癒しはここから始まる。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Helsebunn og fysisk krise. Kroppssvik og velvære-sammenbrudd. Dette er det verste det kan bli – helbredelse begynner her."
