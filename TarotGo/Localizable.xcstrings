    "interpretation.page_of_wands_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mangel an Richtung, Prokrastination, Rückschläge und überstürzte Entscheidungen. Deiner Begeisterung fehlt der Fokus. Mach langsamer und plane."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lack of direction, procrastination, setbacks, and hasty decisions. Your enthusiasm lacks focus. Slow down and plan."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Falta de dirección, procrastinación, retrocesos y decisiones apresuradas. Tu entusiasmo carece de enfoque. Reduce la velocidad y planifica."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manque de direction, procrastination, reculs et décisions hâtives. Votre enthousiasme manque de concentration. Ralentissez et planifiez."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mancanza di direzione, procrastinazione, battute d'arresto e decisioni affrettate. Il tuo entusiasmo manca di concentrazione. Rallenta e pianifica."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "方向性の欠如、先延ばし、挫折、性急な決断。あなたの熱意は焦点を欠いている。立ち止まって計画を立てましょう。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mangel på retning, prokrastinering, tilbakeslag og forhastede beslutninger. Entusiasmen din mangler fokus. Senk farten og planlegg."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Brak kierunku, prokrastynacja, niepowodzenia i pochopne decyzje. Twojemu entuzjazmowi brakuje skupienia. Zwolnij i zaplanuj."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Falta de direção, procrastinação, reveses e decisões precipitadas. Seu entusiasmo carece de foco. Diminua o ritmo e planeje."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Brist på riktning, prokrastinering, motgångar och förhastade beslut. Din entusiasm saknar fokus. Sakta ner och planera."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Відсутність напрямку, зволікання, невдачі та поспішні рішення. Вашому ентузіазму бракує фокусу. Уповільніться та плануйте."
          }
        }
      }
    },
    "interpretation.page_of_wands_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Begeisterung, Erkundung, Entdeckung und Freiheitsgeist. Du bist aufgeregt wegen neuer Möglichkeiten. Neugierige Energie treibt dich an. Abenteuer beginnt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enthusiasm, exploration, discovery, and free spirit. You're excited about new possibilities. Curious energy drives you. Adventure begins."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Entusiasmo, exploración, descubrimiento y espíritu libre. Estás emocionado por nuevas posibilidades. La energía curiosa te impulsa. La aventura comienza."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enthousiasme, exploration, découverte et esprit libre. Vous êtes excité par les nouvelles possibilités. Une énergie curieuse vous anime. L'aventure commence."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Entusiasmo, esplorazione, scoperta e spirito libero. Sei entusiasta delle nuove possibilità. L'energia curiosa ti guida. L'avventura ha inizio."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "熱意、探求、発見、自由な精神。新しい可能性に胸が躍る。好奇心のエネルギーがあなたを動かす。冒険の始まり。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Entusiasme, utforskning, oppdagelse og frisinn. Du er spent på nye muligheter. Nysgjerrig energi driver deg. Eventyret begynner."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Entuzjazm, eksploracja, odkrycie i wolny duch. Jesteś podekscytowany nowymi możliwościami. Ciekawa energia cię napędza. Przygoda zaczyna się."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Entusiasmo, exploração, descoberta e espírito livre. Você está animado com novas possibilidades. Energia curiosa te impulsiona. A aventura começa."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Entusiasm, utforskning, upptäckt och fri själ. Du är upphetsad över nya möjligheter. Nyfiken energi driver dig. Äventyret börjar."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Захоплення, дослідження, відкриття та вільний дух. Ви схвильовані новими можливостями. Допитлива енергія веде вас. Пригода починається."
          }
        }
      }
    },
