    "cardOfDay.centerYourself": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nimm dir einen Moment zum Zentrieren"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Take a moment to center yourself"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tómate un momento para centrarte"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Prenez un moment pour vous centrer"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Prenditi un momento per centrarti"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "集中するために少し時間を取ってください"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Ta et øyeblikk for å sentrere deg selv"
