    "interpretation.the_star_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hoffnungslosigkeit, Verzweiflung und Trennung von der Quelle. Negativität blockiert Segnungen. Verbinde dich wieder mit Glaube und Vertrauen. Das Licht ist immer noch da."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hopelessness, despair, and disconnection from source. Negativity blocks blessings. Reconnect with faith and trust. The light is still there."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desesperanza, desesperación y desconexión de la fuente. La negatividad bloquea las bendiciones. Reconecta con la fe y la confianza. La luz todavía está ahí."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Désespoir, désespoir et déconnexion de la source. La négativité bloque les bénédictions. Renouez avec la foi et la confiance. La lumière est toujours là."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Speranza, disperazione e disconnessione dalla fonte. La negatività blocca le benedizioni. Riconnettiti con fede e fiducia. La luce è ancora lì."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "絶望、絶望、そして源からの断絶。否定性が祝福を妨げます。信仰と信頼と再びつながってください。光はまだそこにあります。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Håpløshet, fortvilelse og frakobling fra kilden. Negativitet blokkerer velsignelser. Gjenopprett forbindelsen med tro og tillit. Lyset er fortsatt der."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beznadziejność, rozpacz i odłączenie od źródła. Negatywność blokuje błogosławieństwa. Połącz się ponownie z wiarą i zaufaniem. Światło wciąż tam jest."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desesperança, desespero e desconexão da fonte. A negatividade bloqueia as bênçãos. Reconecte-se com a fé e a confiança. A luz ainda está lá."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hopplöshet, förtvivlan och frånkoppling från källan. Negativitet blockerar välsignelser. Återknyt kontakten med tro och tillit. Ljuset finns fortfarande där."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Безнадія, відчай і від'єднання від джерела. Негатив блокує благословення. Возз'єднайтеся з вірою та довірою. Світло все ще там."
          }
        }
      }
    },
    "interpretation.the_star_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hoffnung, Inspiration, Erneuerung und Gelassenheit. Nach dem Sturm kehrt die Ruhe zurück. Du wirst von göttlichem Licht geführt. Vertraue auf den Plan des Universums für dich."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hope, inspiration, renewal, and serenity. After the storm, peace returns. You're being guided by divine light. Trust in the universe's plan for you."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esperanza, inspiración, renovación y serenidad. Después de la tormenta, regresa la paz. Estás siendo guiado por la luz divina. Confía en el plan del universo para ti."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Espoir, inspiration, renouveau et sérénité. Après la tempête, la paix revient. Vous êtes guidé par la lumière divine. Faites confiance au plan de l'univers pour vous."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Speranza, ispirazione, rinnovamento e serenità. Dopo la tempesta, la pace ritorna. Sei guidato dalla luce divina. Fidati del piano dell'universo per te."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "希望、インスピレーション、再生、そして静けさ。嵐の後、平和が戻ります。あなたは神の光に導かれています。あなたのための宇宙の計画を信頼してください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Håp, inspirasjon, fornyelse og ro. Etter stormen kommer freden tilbake. Du blir ledet av guddommelig lys. Stol på universets plan for deg."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nadzieja, inspiracja, odnowa i spokój. Po burzy powraca pokój. Jesteś prowadzony przez boskie światło. Ufaj planowi wszechświata wobec ciebie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esperança, inspiração, renovação e serenidade. Após a tempestade, a paz retorna. Você está sendo guiado pela luz divina. Confie no plano do universo para você."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hopp, inspiration, förnyelse och lugn. Efter stormen återvänder freden. Du leds av gudomligt ljus. Lita på universums plan för dig."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Надія, натхнення, оновлення та безтурботність. Після шторму повертається спокій. Вас веде божественне світло. Довіряйте плану Всесвіту для вас."
          }
        }
      }
    },
    "interpretation.the_star_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
