        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Expansión de la salud y previsión del bienestar. El cuerpo crece más allá de las limitaciones actuales. Tomando el control de la curación. Mirando hacia el potencial de vitalidad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Expansion de la santé et prospective du bien-être. Le corps se développe au-delà des limitations actuelles. Prendre en charge la guérison. Regarder vers l'avant pour le potentiel de vitalité."
