    "history.deleteMessage" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bist du sicher, dass du diese Legung löschen möchtest? Diese Aktion kann nicht rückgängig gemacht werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Are you sure you want to delete this reading? This action cannot be undone."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Estás seguro de que quieres eliminar esta lectura? Esta acción no se puede deshacer."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Êtes-vous sûr de vouloir supprimer ce tirage ? Cette action ne peut pas être annulée."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sei sicuro di voler eliminare questa lettura? Questa azione non può essere annullata."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このリーディングを削除してもよろしいですか?この操作は元に戻せません。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Er du sikker på at du vil slette denne leggingen? Denne handlingen kan ikke angres."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
