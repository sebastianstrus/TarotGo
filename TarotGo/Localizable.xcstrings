        }
      }
    },
    "interpretation.eight_of_wands_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Romantische Verzögerungen oder Widerstand gegen Liebesveränderungen. Frustration über das Beziehungstempo. Innere Ausrichtung erforderlich, bevor sich die Partnerschaft bewegt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Romantic delays or resisting love change. Frustration with relationship pace. Internal alignment needed before partnership movement."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Retrasos románticos o resistencia al cambio amoroso. Frustración con el ritmo de la relación. Se necesita alineación interna antes del movimiento de la pareja."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Retards romantiques ou résistance au changement amoureux. Frustration face au rythme de la relation. Alignement interne nécessaire avant le mouvement du partenariat."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ritardi romantici o resistenza al cambiamento amoroso. Frustrazione per il ritmo della relazione. Allineamento interno necessario prima del movimento della partnership."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "恋愛の遅れや愛の変化への抵抗。関係のペースへのフラストレーション。パートナーシップの動きの前に内部の調整が必要。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Romantiske forsinkelser eller motstand mot kjærlighetsendring. Frustrasjon med forholdstempoet. Intern justering nødvendig før partnerskapsbevegelse."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opóźnienia romantyczne lub opór przed zmianą w miłości. Frustracja tempem związku. Wewnętrzne dostosowanie potrzebne przed ruchem w partnerstwie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atrasos românticos ou resistência à mudança no amor. Frustração com o ritmo do relacionamento. Alinhamento interno necessário antes do movimento da parceria."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Romantiska förseningar eller motstånd mot kärleksförändring. Frustration över relationstakten. Intern anpassning krävs innan partnerskapsrörelse."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Романтичні затримки або опір змінам у коханні. Фрустрація через темп стосунків. Внутрішнє узгодження необхідне перед рухом у партнерстві."
          }
        }
      }
    },
