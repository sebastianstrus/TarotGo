    "interpretation.ace_of_swords_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Romantische Verwirrung und Mangel an Klarheit. Missverständnisse schaden der Liebe. Chaotische Gedanken über die Beziehung. Geistiger Durchbruch blockiert. Suche die Wahrheit."
          }
        },
