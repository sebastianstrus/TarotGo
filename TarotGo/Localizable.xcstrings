    "shuffle.instruction": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Place your finger on the deck and hold for 5 seconds while focusing on your question"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lege deinen Finger auf das Deck und halte 5 Sekunden lang, während du dich auf deine Frage konzentrierst"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Coloca tu dedo sobre el mazo y mantén durante 5 segundos mientras te concentras en tu pregunta"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Placez votre doigt sur le jeu et maintenez pendant 5 secondes en vous concentrant sur votre question"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Posiziona il dito sul mazzo e tieni premuto per 5 secondi mentre ti concentri sulla tua domanda"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デッキに指を置き、質問に集中しながら5秒間押し続けてください"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Plasser fingeren din på kortstokken og hold i 5 sekunder mens du fokuserer på spørsmålet ditt"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Połóż palec na talii i przytrzymaj przez 5 sekund koncentrując się na swoim pytaniu"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Coloque seu dedo no baralho e segure por 5 segundos enquanto se concentra em sua pergunta"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Placera ditt finger på kortleken och håll i 5 sekunder medan du fokuserar på din fråga"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
