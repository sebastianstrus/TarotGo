    "interpretation.wheel_of_fortune_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriere-Rückschläge oder Widerstand gegen notwendige Veränderungen. Schlechtes Timing oder Pech. Kämpfe nicht gegen das Rad – arbeite mit den Zyklen, nicht gegen sie."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Career setbacks or resisting necessary changes. Bad timing or luck. Don't fight the wheel—work with the cycles, not against them."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reveses profesionales o resistencia a los cambios necesarios. Mal momento o mala suerte. No luches contra la rueda: trabaja con los ciclos, no contra ellos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Revers de carrière ou résistance aux changements nécessaires. Mauvais timing ou malchance. Ne luttez pas contre la roue – travaillez avec les cycles, pas contre eux."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Battute d'arresto nella carriera o resistenza ai cambiamenti necessari. Tempismo sfortunato o sfortuna. Non combattere la ruota – lavora con i cicli, non contro di essi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャリアの挫折や必要な変化への抵抗。タイミングが悪いか不運。車輪と戦わないでください。サイクルと共に働き、それに逆らわないでください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karrieretilbakeslag eller motstand mot nødvendige endringer. Dårlig timing eller uflaks. Ikke kjemp mot hjulet – arbeid med syklusene, ikke mot dem."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niepowodzenia w karierze lub opór wobec koniecznych zmian. Zły moment lub pech. Nie walcz z kołem – pracuj z cyklami, a nie przeciwko nim."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Contratempos na carreira ou resistência a mudanças necessárias. Momento ruim ou azar. Não lute contra a roda – trabalhe com os ciclos, não contra eles."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriärmotgångar eller motstånd mot nödvändiga förändringar. Dålig tajming eller otur. Kämpa inte mot hjulet – arbeta med cyklerna, inte mot dem."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Кар'єрні невдачі або опір необхідним змінам. Поганий час або невдача. Не боріться з колесом – працюйте з циклами, а не проти них."
          }
        }
      }
    },
    "interpretation.wheel_of_fortune_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das Schicksal der Karriere entfaltet sich günstig. Glückliche Fügungen und gutes Timing bringen Chancen. Vertraue auf die natürlichen Zyklen des beruflichen Wachstums."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Career destiny unfolds favorably. Lucky breaks and good timing bring opportunities. Trust the natural cycles of professional growth."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El destino profesional se desarrolla favorablemente. Los descansos de suerte y el buen momento traen oportunidades. Confía en los ciclos naturales del crecimiento profesional."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le destin professionnel se déroule favorablement. Les coups de chance et le bon timing apportent des opportunités. Faites confiance aux cycles naturels de la croissance professionnelle."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il destino professionale si svolge favorevolmente. Colpi di fortuna e buon tempismo portano opportunità. Fidati dei cicli naturali della crescita professionale."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャリアの運命は好都合に展開します。幸運なブレイクと良いタイミングが機会をもたらします。キャリア成長の自然なサイクルを信頼してください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriereskjebnen utfolder seg gunstig. Lykkelige pauser og god timing gir muligheter. Stol på de naturlige syklusene for profesjonell vekst."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przeznaczenie zawodowe rozwija się pomyślnie. Szczęśliwe przerwy i dobry moment przynoszą możliwości. Ufaj naturalnym cyklom rozwoju zawodowego."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O destino da carreira se desenrola favoravelmente. Pausas de sorte e bom momento trazem oportunidades. Confie nos ciclos naturais do crescimento profissional."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriärödet utvecklas fördelaktigt. Lyckliga pauser och bra tajming ger möjligheter. Lita på de naturliga cyklerna för professionell tillväxt."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Кар'єрна доля розгортається сприятливо. Щасливі перерви та вдалий час приносять можливості. Довіряйте природним циклам професійного зростання."
          }
        }
      }
    },
    "interpretation.wheel_of_fortune_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Rückschläge oder Zyklen der Knappheit. Widerstand gegen das natürliche Kommen und Gehen von Ressourcen. Dieser Zyklus wird sich drehen – bereite dich auf die nächste Phase vor."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial setbacks or cycles of scarcity. Resisting the natural ebb and flow of resources. This cycle will turn—prepare for the next phase."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reveses financieros o ciclos de escasez. Resistencia al flujo y reflujo natural de los recursos. Este ciclo cambiará, prepárate para la próxima fase."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Revers financiers ou cycles de pénurie. Résistance au flux et reflux naturel des ressources. Ce cycle va tourner – préparez-vous pour la phase suivante."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Battute d'arresto finanziarie o cicli di scarsità. Resistenza al flusso e riflusso naturale delle risorse. Questo ciclo girerà – preparati per la fase successiva."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的な挫折や不足のサイクル。リソースの自然な流れと逆流に対する抵抗。このサイクルは回転します – 次の段階に備えてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomiske tilbakeslag eller sykluser av knapphet. Motstand mot naturlig ebb og flyt av ressurser. Denne syklusen vil snu – forbered deg på neste fase."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niepowodzenia finansowe lub cykle niedoboru. Opór wobec naturalnego przypływu i odpływu zasobów. Ten cykl się obróci – przygotuj się na następną fazę."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Contratempos financeiros ou ciclos de escassez. Resistência ao fluxo e refluxo natural dos recursos. Este ciclo vai girar – prepare-se para a próxima fase."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomiska bakslag eller cykler av brist. Motstånd mot naturlig ebb och flod av resurser. Denna cykel kommer att vända – förbered dig för nästa fas."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансові невдачі або цикли дефіциту. Опір природному припливу та відпливу ресурсів. Цей цикл повернеться – підготуйтеся до наступної фази."
          }
        }
      }
    },
    "interpretation.wheel_of_fortune_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielles Glück und glückliche Veränderungen kommen auf dich zu. Vertraue auf die Zyklen des Überflusses. Was du aussäst, wirst du ernten – jetzt zu deinen Gunsten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial luck and fortunate changes come your way. Trust the cycles of abundance. What goes around comes around—in your favor now."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La suerte financiera y los cambios afortunados vienen hacia ti. Confía en los ciclos de abundancia. Lo que das, recibes, a tu favor ahora."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La chance financière et les changements heureux viennent à vous. Faites confiance aux cycles de l'abondance. Ce que vous semez, vous le récoltez – en votre faveur maintenant."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La fortuna finanziaria e i cambiamenti fortunati arrivano da te. Fidati dei cicli di abbondanza. Quello che semini raccogli – a tuo favore ora."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的な幸運と幸運な変化があなたに訪れます。豊かさのサイクルを信頼してください。蒔いたものは刈り取る – 今はあなたの味方です。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk lykke og heldige endringer kommer din vei. Stol på syklusene av overflod. Det du sår, høster du – til din fordel nå."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finansowe szczęście i szczęśliwe zmiany nadchodzą. Ufaj cyklom obfitości. Co zasiejesz, to zbierzesz – teraz na twoją korzyść."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sorte financeira e mudanças afortunadas vêm em sua direção. Confie nos ciclos de abundância. O que você planta, você colhe – a seu favor agora."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomisk lycka och lyckliga förändringar kommer din väg. Lita på överflödets cykler. Det du sår får du skörda – till din fördel nu."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансова удача та щасливі зміни приходять до вас. Довіряйте циклам достатку. Що посієш, те й пожнеш – тепер на вашу користь."
          }
        }
      }
    },
    "interpretation.wheel_of_fortune_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pech, Rückschläge oder Widerstand gegen die natürlichen Zyklen des Lebens. Das Rad dreht sich – du kannst es nicht aufhalten, aber du kannst dich vorbereiten. Auch das wird vorübergehen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bad luck, setbacks, or resistance to life's natural cycles. The wheel is turning—you can't stop it, but you can prepare. This too shall pass."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mala suerte, contratiempos o resistencia a los ciclos naturales de la vida. La rueda está girando, no puedes detenerla, pero puedes prepararte. Esto también pasará."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Malchance, revers ou résistance aux cycles naturels de la vie. La roue tourne – vous ne pouvez pas l'arrêter, mais vous pouvez vous préparer. Cela aussi passera."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sfortuna, battute d'arresto o resistenza ai cicli naturali della vita. La ruota sta girando – non puoi fermarla, ma puoi prepararti. Anche questo passerà."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "不運、挫折、または人生の自然なサイクルへの抵抗。車輪は回っています – 止めることはできませんが、準備はできます。これもいつかは過ぎ去ります。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uflaks, tilbakeslag eller motstand mot livets naturlige sykluser. Hjulet snur – du kan ikke stoppe det, men du kan forberede deg. Dette skal også gå over."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pech, niepowodzenia lub opór wobec naturalnych cykli życia. Koło się obraca – nie możesz go zatrzymać, ale możesz się przygotować. To też minie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Azar, contratempos ou resistência aos ciclos naturais da vida. A roda está girando – você não pode pará-la, mas pode se preparar. Isso também passará."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Otur, bakslag eller motstånd mot livets naturliga cykler. Hjulet snurrar – du kan inte stoppa det, men du kan förbereda dig. Detta kommer också att gå över."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Невдача, невдачі або опір природним циклам життя. Колесо обертається – ви не можете його зупинити, але можете підготуватися. Це теж мине."
          }
        }
      }
    },
    "interpretation.wheel_of_fortune_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schicksal, Wandel und Glück sind angekommen. Das Rad des Lebens dreht sich zu deinen Gunsten. Vertraue auf die Zyklen und gehe mit dem Strom. Was dir bestimmt ist, wird dich nicht verfehlen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Destiny, change, and good fortune arrive. Life's wheel turns in your favor. Trust the cycles and go with the flow. What's meant for you won't miss you."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El destino, el cambio y la buena fortuna llegan. La rueda de la vida gira a tu favor. Confía en los ciclos y fluye. Lo que es para ti no te fallará."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le destin, le changement et la bonne fortune arrivent. La roue de la vie tourne en votre faveur. Faites confiance aux cycles et suivez le courant. Ce qui est destiné pour vous ne vous manquera pas."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Destino, cambiamento e buona fortuna arrivano. La ruota della vita gira a tuo favore. Fidati dei cicli e vai con il flusso. Ciò che è destinato a te non ti mancherà."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "運命、変化、幸運が訪れます。人生の輪があなたに味方して回っています。サイクルを信頼し、流れに身を任せてください。あなたのために運命づけられているものは、あなたを逃しません。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Skjebne, endring og lykke ankommer. Livets hjul snur til din fordel. Stol på syklusene og gå med strømmen. Det som er ment for deg vil ikke gå deg forbi."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przeznaczenie, zmiana i szczęście nadchodzą. Koło życia obraca się na twoją korzyść. Ufaj cyklom i idź z prądem. To, co jest ci przeznaczone, nie minie cię."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Destino, mudança e boa sorte chegam. A roda da vida gira a seu favor. Confie nos ciclos e vá com o fluxo. O que é destinado a você não o perderá."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Öde, förändring och lycka anländer. Livets hjul vänder till din fördel. Lita på cyklerna och gå med strömmen. Det som är menat för dig kommer inte att missa dig."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Доля, зміни та удача приходять. Колесо життя обертається на вашу користь. Довіряйте циклам і пливіть за течією. Те, що призначено вам, не обійде вас стороною."
          }
        }
      }
    },
    "interpretation.wheel_of_fortune_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gesundheitliche Herausforderungen aufgrund natürlicher Zyklen oder schlechtem Timing. Widerstrebe nicht – arbeite mit den Rhythmen deines Körpers. Diese Phase wird vorübergehen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Health challenges due to natural cycles or bad timing. Don't resist—work with your body's rhythms. This phase will pass."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desafíos de salud debido a ciclos naturales o mal momento. No te resistas: trabaja con los ritmos de tu cuerpo. Esta fase pasará."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Problèmes de santé dus aux cycles naturels ou au mauvais timing. Ne résistez pas – travaillez avec les rythmes de votre corps. Cette phase passera."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sfide per la salute dovute a cicli naturali o cattivo tempismo. Non resistere – lavora con i ritmi del tuo corpo. Questa fase passerà."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "自然なサイクルやタイミングの悪さによる健康上の課題。抵抗しないでください。自分の体のリズムと共に働いてください。この段階は過ぎ去ります。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Helseutfordringer på grunn av naturlige sykluser eller dårlig timing. Ikke motstå – arbeid med kroppens rytmer. Denne fasen vil gå over."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Problemy zdrowotne z powodu naturalnych cykli lub złego momentu. Nie opieraj się – pracuj z rytmami swojego ciała. Ta faza minie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desafios de saúde devido a ciclos naturais ou mau momento. Não resista – trabalhe com os ritmos do seu corpo. Esta fase passará."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hälsoutmaningar på grund av naturliga cykler eller dålig tajming. Gör inte motstånd – arbeta med din kropps rytmer. Denna fas kommer att gå över."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Проблеми зі здоров'ям через природні цикли або поганий час. Не противтеся – працюйте з ритмами свого тіла. Ця фаза мине."
          }
        }
      }
    },
    "interpretation.wheel_of_fortune_health_upright" : {
