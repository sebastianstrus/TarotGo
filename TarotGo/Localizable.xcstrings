        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Здоров'я розпач або від'єднання від зцілення. Безнадія блокує одужання. Возз'єднайтеся з вірою в мудрість вашого тіла."
          }
        }
      }
    },
