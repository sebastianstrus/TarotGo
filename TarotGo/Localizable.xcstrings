    "summary.suit.swords.dominant" : {
      "comment" : "Swords dominate - mental energy and thoughts",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schwerter dominieren diese Legung—hier ist viel mentale Energie. Du verarbeitest, analysierst, vielleicht denkst du zu viel nach. Dein Verstand ist sehr aktiv."
