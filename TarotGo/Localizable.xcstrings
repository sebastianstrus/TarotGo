    "interpretation.knight_of_swords_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rücksichtslosigkeit, Ungeduld, unkonzentrierte Energie und Impulsivität. Du bewegst dich zu schnell, ohne nachzudenken. Bremse ab, bevor du abstürzt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recklessness, impatience, unfocused energy, and impulsiveness. You're moving too fast without thinking. Slow down before you crash."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Imprudencia, impaciencia, energía sin enfoque e impulsividad. Te mueves demasiado rápido sin pensar. Reduce la velocidad antes de estrellarte."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Imprudence, impatience, énergie non focalisée et impulsivité. Vous avancez trop vite sans réfléchir. Ralentissez avant de vous écraser."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spericolatezza, impazienza, energia non focalizzata e impulsività. Ti muovi troppo velocemente senza pensare. Rallenta prima di schiantarti."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "無謀さ、焦り、焦点の定まらないエネルギー、衝動性。あなたは考えずに速すぎる動きをしている。墜落する前にスピードを落とせ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uforsiktighet, utålmodighet, ufokusert energi og impulsivitet. Du beveger deg for raskt uten å tenke. Senk farten før du krasjer."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lekkomyślność, niecierpliwość, nieskoncentrowana energia i impulsywność. Poruszasz się zbyt szybko bez myślenia. Zwolnij, zanim się rozbijesz."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Imprudência, impaciência, energia sem foco e impulsividade. Você está se movendo rápido demais sem pensar. Diminua a velocidade antes de bater."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vårdslöshet, otålighet, ofokuserad energi och impulsivitet. Du rör dig för snabbt utan att tänka. Sakta ner innan du kraschar."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Необережність, нетерплячість, несфокусована енергія та імпульсивність. Ви рухаєтеся занадто швидко, не думаючи. Сповільніться, перш ніж розіб'єтеся."
          }
        }
      }
    },
    "interpretation.knight_of_swords_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aktion, Ehrgeiz, schnelles Denken und angetriebene Energie. Du bewegst dich schnell und entschlossen. Geistige Klarheit treibt den Vorwärtsimpuls an. Schmiede das Eisen, solange es heiß ist."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Action, ambition, fast thinking, and driven energy. You're moving quickly and decisively. Mental clarity fuels forward momentum. Strike while the iron is hot."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Acción, ambición, pensamiento rápido y energía impulsada. Te mueves rápida y decididamente. La claridad mental impulsa el impulso hacia adelante. Hierro mientras está caliente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Action, ambition, pensée rapide et énergie motrice. Vous avancez rapidement et avec détermination. La clarté mentale alimente l'élan vers l'avant. Battez le fer pendant qu'il est chaud."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Azione, ambizione, pensiero rapido ed energia trainante. Ti muovi rapidamente e con decisione. La chiarezza mentale alimenta lo slancio in avanti. Battere il ferro finché è caldo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "行動、野心、速い思考、駆り立てられるエネルギー。あなたは素早く決断的に動いている。精神的な明晰さが前進の勢いを生む。鉄は熱いうちに打て。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Handling, ambisjon, rask tenkning og drevet energi. Du beveger deg raskt og besluttsomt. Mental klarhet driver fremoverfart. Smi mens jernet er varmt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Działanie, ambicja, szybkie myślenie i napędzana energia. Poruszasz się szybko i zdecydowanie. Jasność umysłu napędza pęd do przodu. Kuj żelazo póki gorące."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ação, ambição, pensamento rápido e energia impulsionada. Você está se movendo rápida e decisivamente. Clareza mental alimenta o impulso para frente. Bata no ferro enquanto está quente."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Handling, ambition, snabbt tänkande och driven energi. Du rör dig snabbt och beslutsamt. Mental klarhet driver framåtrörelse. Smi medan järnet är varmt."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Дія, амбітність, швидке мислення та енергія. Ви рухаєтеся швидко і рішуче. Розумова ясність живить імпульс вперед. Коваль залізо, поки гаряче."
          }
        }
      }
    },
    "interpretation.knight_of_swords_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rücksichtslose Gesundheitsmaßnahmen oder Wellness-Ungeduld. Unfokussierte Körperenergie. Impulsive Gesundheitsentscheidungen. Verlangsame und höre auf deinen Körper."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reckless health moves or wellness impatience. Unfocused body energy. Impulsive health decisions. Slow down and listen to body."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Movimientos de salud imprudentes o impaciencia con el bienestar. Energía corporal sin enfoque. Decisiones de salud impulsivas. Reduce la velocidad y escucha a tu cuerpo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mouvements de santé imprudents ou impatience de bien-être. Énergie corporelle non focalisée. Décisions de santé impulsives. Ralentissez et écoutez votre corps."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mosse sanitarie spericolate o impazienza del benessere. Energia corporea non focalizzata. Decisioni sanitarie impulsive. Rallenta e ascolta il corpo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "無謀な健康行動またはウェルネスへの焦り。焦点の定まらない体のエネルギー。衝動的な健康の決断。スピードを落として体の声を聞け。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uforsiktige helsetrekk eller velværeutålmodighet. Ufokusert kroppsenergi. Impulsive helsebeslutninger. Senk farten og lytt til kroppen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lekkomyślne ruchy zdrowotne lub niecierpliwość wobec dobrego samopoczucia. Nieskoncentrowana energia ciała. Impulsywne decyzje zdrowotne. Zwolnij i posłuchaj ciała."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Movimentos de saúde imprudentes ou impaciência com o bem-estar. Energia corporal sem foco. Decisões de saúde impulsivas. Diminua a velocidade e ouça o corpo."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vårdslösa hälsoförflyttningar eller välmåendeotålighet. Ofokuserad kroppsenergi. Impulsiva hälsobeslut. Sakta ner och lyssna på kroppen."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Необережні кроки для здоров'я або нетерплячість до благополуччя. Несфокусована енергія тіла. Імпульсивні рішення про здоров'я. Сповільніться і слухайте тіло."
          }
        }
      }
    },
