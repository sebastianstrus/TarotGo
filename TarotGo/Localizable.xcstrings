        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Riconciliazione della salute con il corpo. Riparazione con il sé fisico. Andare oltre il conflitto del benessere. Cooperazione con il corpo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "体との健康の和解。身体的な自己との償い。ウェルネスの葛藤から前進する。体との協力。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Helseforlik med kroppen. Gjøre opp med fysisk selv. Gå videre fra velværekonflikt. Samarbeid med kroppen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zdrowotne pojednanie z ciałem. Naprawienie błędów z fizycznym ja. Odejście od konfliktu o dobre samopoczucie. Współpraca z ciałem."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reconciliação de saúde com o corpo. Reparação com o eu físico. Superando o conflito de bem-estar. Cooperação com o corpo."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hälsoförsoning med kroppen. Gottgörelse med fysiska jaget. Gå vidare från välmåendekonflikt. Samarbete med kroppen."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Примирення здоров'я з тілом. Виправлення з фізичним я. Рух далі від конфлікту благополуччя. Співпраця з тілом."
          }
        }
      }
    },
    "interpretation.five_of_swords_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gesundheitskonflikt und Kampf gegen den Körper. Sieg-um-jeden-Preis-Ansatz für das Wohlbefinden. Zu starkes Drängen schadet der Gesundheit. Überprüfe deine Methoden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Health conflict and fighting body. Win-at-all-costs approach to wellness. Pushing too hard damages health. Examine your methods."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conflicto de salud y lucha contra el cuerpo. Enfoque de ganar a toda costa para el bienestar. Forzar demasiado daña la salud. Examina tus métodos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conflit de santé et lutte contre le corps. Approche gagner à tout prix du bien-être. Forcer trop fort nuit à la santé. Examinez vos méthodes."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conflitto di salute e lotta contro il corpo. Approccio del vincere a tutti i costi per il benessere. Spingere troppo forte danneggia la salute. Esamina i tuoi metodi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "健康の葛藤と体との戦い。ウェルネスに対する勝利のためのアプローチ。頑張りすぎは健康を損なう。自分の方法を検討せよ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Helsekonflikt og kamp mot kroppen. Vinn-for-all-pris-tilnærming til velvære. Å presse for hardt skader helsen. Undersøk metodene dine."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Konflikt zdrowotny i walka z ciałem. Podejście zwycięstwa za wszelką cenę do dobrego samopoczucia. Zbyt mocne naciskanie szkodzi zdrowiu. Sprawdź swoje metody."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conflito de saúde e luta contra o corpo. Abordagem de vencer a qualquer custo para o bem-estar. Forçar demais prejudica a saúde. Examine seus métodos."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hälsokonflikt och kamp mot kroppen. Vinn-till-varje-pris-inställning till välbefinnande. Att pressa för hårt skadar hälsan. Undersök dina metoder."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Конфлікт здоров'я та боротьба з тілом. Підхід до благополуччя \"перемога за будь-яку ціну\". Занадто сильне напруження шкодить здоров'ю. Перевірте свої методи."
          }
        }
      }
    },
    "interpretation.five_of_swords_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Versöhnung nach Konflikten oder Wiedergutmachung in der Liebe. Abschied vom Beziehungsverrat. Kompromiss ersetzt Kampf. Heilung beginnt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reconciliation after conflict or making amends in love. Moving on from relationship betrayal. Compromise replaces combat. Healing begins."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reconciliación después del conflicto o reparación en el amor. Superar la traición en la relación. El compromiso reemplaza la lucha. La curación comienza."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Réconciliation après un conflit ou réparation en amour. Surmonter la trahison relationnelle. Le compromis remplace le combat. La guérison commence."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Riconciliazione dopo il conflitto o riparazione in amore. Andare oltre il tradimento relazionale. Il compromesso sostituisce la lotta. La guarigione inizia."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "衝突後の和解または恋愛における償い。関係の裏切りから前進する。戦いの代わりに妥協。癒しが始まる。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Forlik etter konflikt eller å gjøre opp i kjærlighet. Gå videre fra forholdssvik. Kompromiss erstatter kamp. Helbredelse begynner."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pojednanie po konflikcie lub naprawienie błędów w miłości. Odejście od zdrady w związku. Kompromis zastępuje walkę. Leczenie się rozpoczyna."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reconciliação após conflito ou reparação no amor. Superando a traição no relacionamento. Compromisso substitui o combate. A cura começa."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Försoning efter konflikt eller gottgörelse i kärlek. Gå vidare från relationssvek. Kompromiss ersätter kamp. Läkning börjar."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Примирення після конфлікту або виправлення в коханні. Рух далі від зради у стосунках. Компроміс замінює боротьбу. Зцілення починається."
          }
        }
      }
    },
    "interpretation.five_of_swords_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beziehungskonflikt und Mentalität des Siegens um jeden Preis. Verrat oder unfaires Spiel in der Liebe. Sieg, aber um welchen Preis? Überprüfe, ob der Sieg den Verlust der Beziehung wert ist."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Relationship conflict and win-at-all-costs mentality. Betrayal or fighting dirty in love. Victory but at what price? Examine if winning is worth losing the relationship."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conflicto de relación y mentalidad de ganar a toda costa. Traición o juego sucio en el amor. Victoria, ¿pero a qué precio? Examina si ganar vale la pena perder la relación."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conflit relationnel et mentalité de gagner à tout prix. Trahison ou combat déloyal en amour. Victoire, mais à quel prix ? Examinez si gagner vaut la peine de perdre la relation."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conflitto relazionale e mentalità del vincere a tutti i costi. Tradimento o combattere sporco in amore. Vittoria, ma a quale prezzo? Esamina se vincere vale la pena di perdere la relazione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "関係の葛藤と勝利のための精神。恋愛における裏切りまたは汚い戦い。勝利だが、代償は何か？勝つことが関係を失う価値があるか検討せよ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Relasjonskonflikt og vinn-for-all-pris-mentalitet. Svik eller skitten kamp i kjærlighet. Seier, men til hvilken pris? Undersøk om det er verdt å tape forholdet for å vinne."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Konflikt w związku i mentalność zwycięstwa za wszelką cenę. Zdrada lub nieczysta walka w miłości. Zwycięstwo, ale za jaką cenę? Sprawdź, czy wygrana jest warta utraty związku."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conflito de relacionamento e mentalidade de vencer a qualquer custo. Traição ou jogo sujo no amor. Vitória, mas a que preço? Examine se vencer vale a pena perder o relacionamento."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Relationskonflikt och vinn-till-varje-pris-mentalitet. Svek eller smutsigt spel i kärlek. Seger, men till vilket pris? Undersök om det är värt att förlora relationen för att vinna."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Конфлікт у стосунках і менталітет перемоги за будь-яку ціну. Зрада або брудна гра в коханні. Перемога, але якою ціною? Подивіться, чи варта перемога втрати стосунків."
          }
        }
      }
    },
    "interpretation.five_of_wands_career_reversed" : {
