    "interpretation.seven_of_cups_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Berufliche Klarheit und realistische Bewertung der Optionen. Du siehst die Chancen jetzt deutlich. Bereit, fundierte berufliche Entscheidungen zu treffen. Fantasie weicht praktischem Handeln."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Career clarity and realistic assessment of options. You're seeing opportunities clearly now. Ready to make grounded professional decisions. Fantasy gives way to practical action."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Claridad profesional y evaluación realista de opciones. Estás viendo las oportunidades con claridad ahora. Listo para tomar decisiones profesionales fundamentadas. La fantasía da paso a la acción práctica."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clarté professionnelle et évaluation réaliste des options. Vous voyez les opportunités clairement maintenant. Prêt à prendre des décisions professionnelles fondées. La fantaisie cède la place à l'action pratique."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chiarezza professionale e valutazione realistica delle opzioni. Ora vedi le opportunità chiaramente. Pronto a prendere decisioni professionali fondate. La fantasia lascia il posto all'azione pratica."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャリアの明確さと選択肢の現実的な評価。あなたは今、機会をはっきりと見ています。根拠のあるプロとしての決断をする準備ができています。幻想は実用的な行動に取って代わられます。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriereklarhet og realistisk vurdering av alternativer. Du ser muligheter tydelig nå. Klar til å ta fornuftige profesjonelle beslutninger. Fantasi viker for praktisk handling."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jasność kariery i realistyczna ocena opcji. Teraz wyraźnie widzisz możliwości. Gotowy do podejmowania ugruntowanych decyzji zawodowych. Fantazja ustępuje miejsca praktycznemu działaniu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clareza de carreira e avaliação realista das opções. Você está vendo oportunidades claramente agora. Pronto para tomar decisões profissionais fundamentadas. A fantasia dá lugar à ação prática."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriärtydlighet och realistisk bedömning av alternativ. Du ser möjligheterna tydligt nu. Redo att fatta grundade professionella beslut. Fantasi ger vika för praktisk handling."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Кар'єрна ясність та реалістична оцінка варіантів. Тепер ви чітко бачите можливості. Готові приймати обґрунтовані професійні рішення. Фантазія поступається місцем практичним діям."
          }
        }
      }
    },
    "interpretation.seven_of_cups_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zu viele Karriereoptionen sorgen für Verwirrung. Wunschdenken über berufliche Möglichkeiten. Manche Gelegenheiten sind nicht real. Klarheit ist nötig, bevor du dich auf einen Weg festlegst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Too many career options create confusion. Wishful thinking about professional possibilities. Some opportunities aren't real. Need clarity before committing to a path."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Demasiadas opciones profesionales crean confusión. Ilusiones sobre posibilidades profesionales. Algunas oportunidades no son reales. Necesitas claridad antes de comprometerte con un camino."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trop d'options de carrière créent de la confusion. Rêveries sur les possibilités professionnelles. Certaines opportunités ne sont pas réelles. Besoin de clarté avant de s'engager sur une voie."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Troppe opzioni di carriera creano confusione. Illusioni sulle possibilità professionali. Alcune opportunità non sono reali. Necessità di chiarezza prima di impegnarsi su un percorso."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャリアの選択肢が多すぎると混乱を招きます。仕事の可能性についての希望的観測。実現しない機会もある。道を決める前に明確さが必要です。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "For mange karrieremuligheter skaper forvirring. Ønsketenkning om profesjonelle muligheter. Noen muligheter er ikke reelle. Behov for klarhet før du forplikter deg til en vei."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zbyt wiele opcji kariery powoduje zamieszanie. Myślenie życzeniowe o możliwościach zawodowych. Niektóre możliwości nie są realne. Potrzeba jasności przed podjęciem decyzji o ścieżce."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Muitas opções de carreira criam confusão. Pensamento ilusório sobre possibilidades profissionais. Algumas oportunidades não são reais. Precisa de clareza antes de se comprometer com um caminho."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "För många karriärmöjligheter skapar förvirring. Önsketänkande om professionella möjligheter. Vissa möjligheter är inte verkliga. Behov av klarhet innan du åtar dig en väg."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Забагато варіантів кар'єри створює плутанину. Бажання, що видаються за дійсність, щодо професійних можливостей. Деякі можливості не реальні. Потрібна ясність, перш ніж обрати шлях."
          }
        }
      }
    },
    "interpretation.seven_of_cups_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Klarheit und realistische Geldentscheidungen. Du durchschaust Schneeballsysteme. Pragmatische Entscheidungen über Ressourcen treffen. Nüchternheit ersetzt Fantasie."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial clarity and realistic money decisions. You're seeing through get-rich-quick schemes. Making practical choices about resources. Sobriety replaces fantasy."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Claridad financiera y decisiones monetarias realistas. Estás viendo a través de los esquemas de enriquecimiento rápido. Tomando decisiones prácticas sobre los recursos. La sobriedad reemplaza la fantasía."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clarté financière et décisions monétaires réalistes. Vous voyez clair dans les stratagèmes pour s'enrichir rapidement. Prendre des décisions pratiques concernant les ressources. La sobriété remplace la fantaisie."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chiarezza finanziaria e decisioni realistiche sul denaro. Vedi attraverso gli schemi per arricchirsi velocemente. Fare scelte pratiche sulle risorse. La sobrietà sostituisce la fantasia."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的な明確さと現実的な金銭判断。あなたは一攫千金のスキームを見抜いています。リソースについて実用的な選択をする。冷静さが幻想に取って代わります。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk klarhet og realistiske pengebeslutninger. Du ser gjennom ordninger for å bli raskt rik. Gjør praktiske valg om ressurser. Nøkternhet erstatter fantasi."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jasność finansowa i realistyczne decyzje pieniężne. Przejrzysz schematy szybkiego wzbogacenia się. Podejmowanie praktycznych wyborów dotyczących zasobów. Trzeźwość zastępuje fantazję."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clareza financeira e decisões realistas sobre dinheiro. Você está vendo através de esquemas de enriquecimento rápido. Fazendo escolhas práticas sobre recursos. A sobriedade substitui a fantasia."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomisk tydlighet och realistiska penningbeslut. Du ser igenom snabba rikedomar. Gör praktiska val om resurser. Nykterhet ersätter fantasi."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансова ясність та реалістичні грошові рішення. Ви бачите наскрізь схеми швидкого збагачення. Робите практичний вибір щодо ресурсів. Тверезість замінює фантазію."
          }
        }
      }
    },
    "interpretation.seven_of_cups_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Illusionen oder zu viele Investitionsoptionen. Wenn es zu gut klingt, um wahr zu sein, ist es das wahrscheinlich auch. Fantasien über Reichtum trüben das Urteilsvermögen. Suche Klarheit und Expertenrat."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial illusions or too many investment options. If it sounds too good to be true, it probably is. Fantasies about wealth cloud judgment. Seek clarity and expert advice."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ilusiones financieras o demasiadas opciones de inversión. Si suena demasiado bueno para ser verdad, probablemente lo sea. Las fantasías sobre la riqueza nublan el juicio. Busca claridad y asesoramiento de expertos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Illusions financières ou trop d'options d'investissement. Si cela semble trop beau pour être vrai, c'est probablement le cas. Les fantasmes de richesse obscurcissent le jugement. Recherchez la clarté et les conseils d'experts."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Illusioni finanziarie o troppe opzioni di investimento. Se sembra troppo bello per essere vero, probabilmente lo è. Le fantasie sulla ricchezza offuscano il giudizio. Cerca chiarezza e consigli da esperti."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的な幻想、または投資の選択肢が多すぎる。良すぎる話には注意が必要です。富についての空想が判断を曇らせます。明確さと専門家のアドバイスを求めてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomiske illusjoner eller for mange investeringsalternativer. Hvis det høres for godt ut til å være sant, er det sannsynligvis det. Fantasier om rikdom tilslører dømmekraften. Søk klarhet og ekspertråd."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Iluzje finansowe lub zbyt wiele opcji inwestycyjnych. Jeśli coś brzmi zbyt pięknie, aby było prawdziwe, prawdopodobnie takie jest. Fantazje o bogactwie zaciemniają osąd. Szukaj jasności i porady ekspertów."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ilusões financeiras ou muitas opções de investimento. Se parece bom demais para ser verdade, provavelmente é. Fantasias sobre riqueza obscurecem o julgamento. Busque clareza e conselhos de especialistas."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomiska illusioner eller för många investeringsalternativ. Om det låter för bra för att vara sant, är det förmodligen det. Fantasier om rikedom grumlar omdömet. Sök klarhet och expertråd."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансові ілюзії або занадто багато варіантів інвестування. Якщо це звучить надто добре, щоб бути правдою, то, ймовірно, так воно і є. Фантазії про багатство затьмарюють судження. Шукайте ясності та поради експертів."
          }
        }
      }
    },
    "interpretation.seven_of_cups_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klarheit, Realitätschecks und klare Entscheidungen. Der Nebel lichtet sich. Du siehst Situationen realistisch und bist bereit, fundierte Entscheidungen zu treffen. Wunschdenken weicht der Weisheit."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clarity, reality checks, and clear decisions. The fog is lifting. You're seeing situations realistically and ready to make grounded choices. Wishful thinking gives way to wisdom."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Claridad, comprobaciones de la realidad y decisiones claras. La niebla se está levantando. Estás viendo las situaciones de manera realista y listo para tomar decisiones fundamentadas. El pensamiento ilusorio da paso a la sabiduría."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clarté, vérifications de la réalité et décisions claires. Le brouillard se lève. Vous voyez les situations de manière réaliste et êtes prêt à prendre des décisions fondées. Les rêves éveillés cèdent la place à la sagesse."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chiarezza, verifiche della realtà e decisioni chiare. La nebbia si sta sollevando. Vedi le situazioni realisticamente e sei pronto a fare scelte fondate. Il pensiero illusorio lascia il posto alla saggezza."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "明確さ、現実確認、そして明確な決断。霧が晴れつつあります。あなたは状況を現実的に見ており、根拠のある選択をする準備ができています。希望的観測は知恵に取って代わられます。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klarhet, virkelighetssjekk og klare avgjørelser. Tåken letter. Du ser situasjoner realistisk og er klar til å ta fornuftige valg. Ønsketenkning gir plass til visdom."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jasność, sprawdzanie rzeczywistości i jasne decyzje. Mgła się podnosi. Widzisz sytuacje realistycznie i jesteś gotowy do podejmowania ugruntowanych wyborów. Myślenie życzeniowe ustępuje miejsca mądrości."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clareza, verificações da realidade e decisões claras. O nevoeiro está se levantando. Você está vendo as situações realisticamente e pronto para fazer escolhas fundamentadas. O pensamento ilusório dá lugar à sabedoria."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tydlighet, verklighetskontroller och tydliga beslut. Dimman lyfter. Du ser situationer realistiskt och är redo att fatta grundade val. Önsketänkande ger vika för visdom."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ясність, перевірка реальності та чіткі рішення. Туман розсіюється. Ви бачите ситуації реалістично і готові робити обґрунтований вибір. Бажання, що видаються за дійсність, поступаються місцем мудрості."
          }
        }
      }
    },
    "interpretation.seven_of_cups_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Illusion, Fantasie und überwältigende Auswahl. Dir werden viele Optionen präsentiert, aber nicht alle sind real. Deine Fantasie läuft wild. Verankere dich und sieh klar, bevor du dich entscheidest."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Illusion, fantasy, and overwhelming choices. You're presented with many options but not all are real. Your imagination runs wild. Ground yourself and see clearly before deciding."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ilusión, fantasía y opciones abrumadoras. Se te presentan muchas opciones, pero no todas son reales. Tu imaginación se desboca. Conéctate a tierra y ve con claridad antes de decidir."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Illusion, fantaisie et choix accablants. On vous présente de nombreuses options, mais toutes ne sont pas réelles. Votre imagination s'emballe. Ancrez-vous et voyez clair avant de décider."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Illusione, fantasia e scelte travolgenti. Ti vengono presentate molte opzioni ma non tutte sono reali. La tua immaginazione corre selvaggia. Radicati e vedi chiaramente prima di decidere."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "幻想、空想、そして圧倒的な選択肢。あなたは多くの選択肢を提示されていますが、すべてが現実的とは限りません。あなたの想像力は暴走しています。決断する前に、現実に立ち返り、はっきりと見極めてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Illusjon, fantasi og overveldende valg. Du blir presentert for mange alternativer, men ikke alle er ekte. Fantasien løper løpsk. Forankre deg selv og se klart før du bestemmer deg."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Iluzja, fantazja i przytłaczające wybory. Masz wiele opcji, ale nie wszystkie są prawdziwe. Twoja wyobraźnia szaleje. Uziemij się i zobacz wyraźnie, zanim podejmiesz decyzję."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ilusão, fantasia e escolhas opressoras. Muitas opções são apresentadas a você, mas nem todas são reais. Sua imaginação corre solta. Aterre-se e veja claramente antes de decidir."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Illusion, fantasi och överväldigande val. Du presenteras med många alternativ men inte alla är verkliga. Din fantasi skenar. Förankra dig själv och se klart innan du bestämmer dig."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ілюзія, фантазія та надмірний вибір. Вам пропонують багато варіантів, але не всі з них реальні. Ваша уява розігрується. Приземліться і подивіться чітко, перш ніж прийняти рішення."
          }
        }
      }
    },
    "interpretation.seven_of_cups_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gesundheitliche Klarheit und realistische Wellness-Entscheidungen. Du durchschaust falsche Gesundheitsversprechen. Fundierte Entscheidungen über deinen Körper treffen. Ein klarer Weg nach vorne zeichnet sich ab."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Health clarity and realistic wellness decisions. You're seeing through false health promises. Making grounded choices about your body. Clear path forward emerges."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Claridad de salud y decisiones realistas de bienestar. Estás viendo a través de falsas promesas de salud. Tomando decisiones fundamentadas sobre tu cuerpo. Surge un camino claro hacia adelante."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clarté de la santé et décisions réalistes en matière de bien-être. Vous voyez clair dans les fausses promesses de santé. Prendre des décisions fondées concernant votre corps. Une voie claire vers l'avant émerge."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chiarezza sulla salute e decisioni realistiche sul benessere. Vedi attraverso false promesse sulla salute. Fare scelte fondate sul tuo corpo. Emerge un chiaro percorso in avanti."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "健康の明確さと現実的なウェルネスの決断。あなたは誤った健康に関する約束を見抜いています。自分の体について根拠のある選択をする。明確な前進の道が現れます。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Helseklarhet og realistiske velværevalg. Du ser gjennom falske helseløfter. Gjør fornuftige valg om kroppen din. Klar vei videre dukker opp."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jasność zdrowotna i realistyczne decyzje dotyczące dobrego samopoczucia. Przejrzysz fałszywe obietnice zdrowotne. Podejmowanie ugruntowanych wyborów dotyczących twojego ciała. Wyłania się jasna droga naprzód."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clareza de saúde e decisões realistas de bem-estar. Você está vendo através de falsas promessas de saúde. Fazendo escolhas fundamentadas sobre seu corpo. Um caminho claro para frente emerge."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hälsoklarhet och realistiska friskvårdsbeslut. Du ser igenom falska hälsolöften. Gör grundade val om din kropp. En tydlig väg framåt växer fram."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ясність здоров'я та реалістичні оздоровчі рішення. Ви бачите наскрізь фальшиві обіцянки щодо здоров'я. Робите обґрунтований вибір щодо свого тіла. З'являється чіткий шлях вперед."
          }
        }
      }
    },
    "interpretation.seven_of_cups_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gesundheitliche Illusionen oder Überforderung durch zu viele Wellness-Optionen. Verwirrung über den einzuschlagenden Ansatz. Einige Gesundheitsbehauptungen sind nicht real. Klarheit und professionelle Anleitung sind nötig."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Health illusions or overwhelm by too many wellness options. Confusion about what approach to take. Some health claims aren't real. Need clarity and professional guidance."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ilusiones de salud o agobio por demasiadas opciones de bienestar. Confusión sobre qué enfoque tomar. Algunas afirmaciones de salud no son reales. Necesitas claridad y orientación profesional."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Illusions sur la santé ou submergé par trop d'options de bien-être. Confusion sur l'approche à adopter. Certaines allégations de santé ne sont pas réelles. Besoin de clarté et de conseils professionnels."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Illusioni sulla salute o sopraffazione da troppe opzioni di benessere. Confusione su quale approccio prendere. Alcune affermazioni sulla salute non sono reali. Necessità di chiarezza e guida professionale."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "健康に関する幻想、またはあまりにも多くのウェルネスオプションによる圧倒。どのアプローチを取るべきか混乱しています。健康に関する主張の中には現実的でないものもあります。明確さと専門家の指導が必要です。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Helseillusjoner eller overveldelse av for mange velværealternativer. Forvirring om hvilken tilnærming du skal ta. Noen helsepåstander er ikke ekte. Behov for klarhet og profesjonell veiledning."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Iluzje zdrowotne lub przytłoczenie zbyt wieloma opcjami wellness. Zamieszanie co do podejścia, które należy zastosować. Niektóre twierdzenia dotyczące zdrowia nie są prawdziwe. Potrzeba jasności i profesjonalnego doradztwa."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ilusões de saúde ou sobrecarga por muitas opções de bem-estar. Confusão sobre qual abordagem tomar. Algumas alegações de saúde não são reais. Precisa de clareza e orientação profissional."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hälsoillusioner eller överväldigande av för många friskvårdsalternativ. Förvirring om vilken metod du ska använda. Vissa hälsopåståenden är inte verkliga. Behov av tydlighet och professionell vägledning."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ілюзії щодо здоров'я або надмірна кількість оздоровчих варіантів. Плутанина щодо того, який підхід обрати. Деякі твердження про здоров'я не є реальними. Потрібна ясність і професійна порада."
          }
        }
      }
    },
    "interpretation.seven_of_cups_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Romantische Klarheit entsteht aus der Verwirrung. Du siehst Menschen und Situationen realistischer. Klare Entscheidungen über die Liebe treffen. Illusionen lösen sich auf."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Romantic clarity emerges from confusion. You're seeing people and situations more realistically. Making clear decisions about love. Illusions dissolve."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La claridad romántica emerge de la confusión. Estás viendo a las personas y las situaciones de manera más realista. Tomando decisiones claras sobre el amor. Las ilusiones se disuelven."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La clarté romantique émerge de la confusion. Vous voyez les personnes et les situations de manière plus réaliste. Prendre des décisions claires sur l'amour. Les illusions se dissolvent."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La chiarezza romantica emerge dalla confusione. Vedi le persone e le situazioni in modo più realistico. Prendere decisioni chiare sull'amore. Le illusioni si dissolvono."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "混乱から恋愛の明確さが現れます。あなたは人や状況をより現実的に見ています。愛について明確な決断を下す。幻想が溶けていく。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Romantisk klarhet dukker opp fra forvirring. Du ser mennesker og situasjoner mer realistisk. Tar klare avgjørelser om kjærlighet. Illusjoner oppløses."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Romantyczna jasność wyłania się z zamieszania. Widzisz ludzi i sytuacje bardziej realistycznie. Podejmowanie jasnych decyzji dotyczących miłości. Iluzje znikają."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A clareza romântica emerge da confusão. Você está vendo pessoas e situações de forma mais realista. Tomando decisões claras sobre o amor. Ilusões se dissolvem."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Romantisk klarhet uppstår ur förvirring. Du ser människor och situationer mer realistiskt. Tar tydliga beslut om kärlek. Illusioner upplöses."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Романтична ясність виникає з плутанини. Ви бачите людей і ситуації більш реалістично. Приймаєте чіткі рішення про кохання. Ілюзії розсіюються."
          }
        }
      }
    },
    "interpretation.seven_of_cups_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Romantische Fantasien und Illusionen. Du siehst, was du sehen willst, nicht, was ist. Viele Optionen fühlen sich überwältigend an. Verankere dich in der Realität, bevor du dich entscheidest."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Romantic fantasies and illusions. You're seeing what you want to see, not what is. Many options feel overwhelming. Ground yourself in reality before choosing."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fantasías románticas e ilusiones. Estás viendo lo que quieres ver, no lo que es. Muchas opciones se sienten abrumadoras. Conéctate a la realidad antes de elegir."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fantasmes romantiques et illusions. Vous voyez ce que vous voulez voir, pas ce qui est. De nombreuses options semblent accablantes. Ancrez-vous dans la réalité avant de choisir."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fantasie romantiche e illusioni. Vedi quello che vuoi vedere, non quello che è. Molte opzioni sembrano travolgenti. Radicati nella realtà prima di scegliere."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "恋愛の空想と幻想。あなたは現実ではなく、見たいものを見ています。多くの選択肢に圧倒されます。選択する前に現実に立ち返ってください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Romantiske fantasier og illusjoner. Du ser det du vil se, ikke det som er. Mange alternativer føles overveldende. Forankre deg i virkeligheten før du velger."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Romantyczne fantazje i iluzje. Widzisz to, co chcesz widzieć, a nie to, co jest. Wiele opcji jest przytłaczających. Uziemij się w rzeczywistości przed wyborem."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fantasias românticas e ilusões. Você está vendo o que quer ver, não o que é. Muitas opções parecem opressoras. Aterre-se na realidade antes de escolher."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Romantiska fantasier och illusioner. Du ser vad du vill se, inte vad som är. Många alternativ känns överväldigande. Förankra dig i verkligheten innan du väljer."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Романтичні фантазії та ілюзії. Ви бачите те, що хочете бачити, а не те, що є. Багато варіантів здаються надто великими. Приземліться в реальності, перш ніж обирати."
          }
        }
      }
    },
    "interpretation.seven_of_pentacles_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Berufliche Ungeduld und Enttäuschung über den Fortschritt. Die Arbeit fühlt sich nicht lohnend an. Die Bemühungen bringen nicht die erwarteten Ergebnisse. Überdenken Sie Ihren beruflichen Weg oder passen Sie Ihren Ansatz an."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Career impatience and disappointment in progress. Work feels unrewarding. Efforts don't yield expected results. Reevaluate professional path or adjust approach."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impaciencia profesional y decepción por el progreso. El trabajo no es gratificante. Los esfuerzos no dan los resultados esperados. Reevalúa tu trayectoria profesional o ajusta tu enfoque."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impatience professionnelle et déception face aux progrès. Le travail ne semble pas gratifiant. Les efforts ne donnent pas les résultats escomptés. Réévaluez votre parcours professionnel ou ajustez votre approche."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impazienza professionale e delusione per i progressi. Il lavoro non sembra gratificante. Gli sforzi non producono i risultati attesi. Rivaluta il tuo percorso professionale o adatta il tuo approccio."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャリアへの焦りと進歩への失望。仕事が報われていないと感じる。努力が期待した結果をもたらさない。職業上の道を再評価するか、アプローチを調整する。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriereutålmodighet og skuffelse over fremgang. Arbeidet føles lite givende. Innsats gir ikke forventede resultater. Vurder din profesjonelle vei på nytt eller juster tilnærmingen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niecierpliwość zawodowa i rozczarowanie postępami. Praca nie daje satysfakcji. Wysiłki nie przynoszą oczekiwanych rezultatów. Przeanalizuj swoją ścieżkę zawodową lub dostosuj podejście."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impaciência na carreira e decepção com o progresso. O trabalho parece não recompensador. Os esforços não produzem os resultados esperados. Reavalie seu caminho profissional ou ajuste a abordagem."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriär otålighet och besvikelse över framsteg. Arbetet känns inte givande. Ansträngningar ger inte förväntade resultat. Omvärdera din yrkesväg eller justera ditt tillvägagångssätt."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Кар'єрне нетерпіння та розчарування в прогресі. Робота здається невинагородженою. Зусилля не дають очікуваних результатів. Переоцініть свій професійний шлях або скоригуйте підхід."
          }
        }
      }
    },
    "interpretation.seven_of_pentacles_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Geduldiger Karriereaufbau und Bewertung des beruflichen Fortschritts. Ihre Arbeitsbemühungen wachsen langsam, aber sicher. Die langfristige Perspektive zahlt sich aus. Vertrauen Sie Ihrer Investition."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Patient career building and assessing professional progress. Your work efforts are growing slowly but surely. Long-term view pays off. Trust your investment."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Construcción de carrera paciente y evaluación del progreso profesional. Tus esfuerzos laborales están creciendo lenta pero seguramente. La visión a largo plazo vale la pena. Confía en tu inversión."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Construction de carrière patiente et évaluation des progrès professionnels. Vos efforts de travail augmentent lentement mais sûrement. La vision à long terme porte ses fruits. Faites confiance à votre investissement."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Costruzione paziente della carriera e valutazione dei progressi professionali. I tuoi sforzi lavorativi crescono lentamente ma costantemente. La visione a lungo termine ripaga. Fidati del tuo investimento."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "忍耐強いキャリア構築と職業上の進捗状況の評価。あなたの仕事への努力は、ゆっくりとしかし確実に実を結んでいる。長期的視野が報われる。自分の投資を信頼する。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tålmodig karrierebygging og vurdering av profesjonell fremgang. Arbeidsinnsatsen din vokser sakte, men sikkert. Langsiktig perspektiv lønner seg. Stol på investeringen din."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cierpliwe budowanie kariery i ocena postępów zawodowych. Twoje wysiłki w pracy rosną powoli, ale pewnie. Długoterminowa perspektywa popłaca. Zaufaj swojej inwestycji."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Construção de carreira paciente e avaliação do progresso profissional. Seus esforços de trabalho estão crescendo lenta mas seguramente. A visão de longo prazo compensa. Confie no seu investimento."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tålmodig karriärbyggande och bedömning av professionella framsteg. Dina arbetsinsatser växer långsamt men säkert. Långsiktig syn lönar sig. Lita på din investering."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Терпляча побудова кар'єри та оцінка професійного прогресу. Ваші робочі зусилля зростають повільно, але впевнено. Довгострокова перспектива окупається. Довіртеся своїм інвестиціям."
          }
        }
      }
    },
    "interpretation.seven_of_pentacles_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Ungeduld und Enttäuschung über die Renditen. Investitionen entsprechen nicht den Erwartungen. Fühlt sich wie verschwendete Geldmühe an. Strategie überdenken."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial impatience and disappointment in returns. Investments don't meet expectations. Feels like wasted money effort. Reevaluate strategy."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impaciencia financiera y decepción por los rendimientos. Las inversiones no cumplen con las expectativas. Sensación de esfuerzo monetario desperdiciado. Reevaluar la estrategia."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impatience financière et déception face aux rendements. Les investissements ne répondent pas aux attentes. Sentiment d'effort financier gaspillé. Réévaluer la stratégie."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impazienza finanziaria e delusione per i rendimenti. Gli investimenti non soddisfano le aspettative. Sensazione di sforzo finanziario sprecato. Rivalutare la strategia."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的な焦りとリターンへの失望。投資が期待に応えない。金銭的な努力が無駄に感じられる。戦略を再評価する。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk utålmodighet og skuffelse over avkastning. Investeringer lever ikke opp til forventningene. Føles som bortkastet pengeinnsats. Vurder strategien på nytt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niecierpliwość finansowa i rozczarowanie zwrotami. Inwestycje nie spełniają oczekiwań. Poczucie zmarnowanego wysiłku finansowego. Przeanalizuj strategię."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impaciência financeira e decepção com os retornos. Investimentos não correspondem às expectativas. Sensação de esforço financeiro desperdiçado. Reavaliar a estratégia."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomisk otålighet och besvikelse över avkastning. Investeringar lever inte upp till förväntningarna. Känns som bortkastad penninginsats. Omvärdera strategin."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансове нетерпіння та розчарування у прибутках. Інвестиції не виправдовують очікувань. Відчуття марної трати грошових зусиль. Переглянути стратегію."
          }
        }
      }
    },
    "interpretation.seven_of_pentacles_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Geduldiges finanzielles Wachstum und langfristige Investitionsperspektive. Ihre finanziellen Bemühungen tragen langsam Früchte. Vertrauen Sie dem Prozess des Vermögensaufbaus. Beharrlichkeit zahlt sich aus."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Patient financial growth and long-term investment view. Your money efforts are bearing fruit slowly. Trust the process of wealth building. Perseverance pays."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Crecimiento financiero paciente y visión de inversión a largo plazo. Tus esfuerzos económicos están dando frutos lentamente. Confía en el proceso de construcción de riqueza. La perseverancia vale la pena."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Croissance financière patiente et vision d'investissement à long terme. Vos efforts financiers portent lentement leurs fruits. Faites confiance au processus de création de richesse. La persévérance paie."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Crescita finanziaria paziente e visione di investimento a lungo termine. I tuoi sforzi finanziari stanno dando frutti lentamente. Fidati del processo di costruzione della ricchezza. La perseveranza paga."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "忍耐強い経済的成長と長期的な投資視点。あなたの金銭的努力はゆっくりと実を結んでいる。富の構築プロセスを信頼する。忍耐が報われる。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tålmodig økonomisk vekst og langsiktig investeringssyn. Dine pengeinnsatser bærer frukt sakte. Stol på prosessen med å bygge rikdom. Utholdenhet lønner seg."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cierpliwy wzrost finansowy i długoterminowa perspektywa inwestycyjna. Twoje wysiłki pieniężne przynoszą owoce powoli. Zaufaj procesowi budowania bogactwa. Wytrwałość popłaca."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Crescimento financeiro paciente e visão de investimento de longo prazo. Seus esforços financeiros estão dando frutos lentamente. Confie no processo de construção de riqueza. Perseverança compensa."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tålmodig ekonomisk tillväxt och långsiktig investeringssyn. Dina penninginsatser bär frukt långsamt. Lita på processen för att bygga rikedom. Uthållighet lönar sig."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Терпляче фінансове зростання та довгостроковий інвестиційний погляд. Ваші грошові зусилля повільно приносять плоди. Довіртеся процесу побудови багатства. Наполегливість окупається."
          }
        }
      }
    },
    "interpretation.seven_of_pentacles_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ungeduld, mangelnder Fortschritt und verschwendete Mühe. Ihre Investitionen zahlen sich nicht wie erwartet aus. Enttäuschung bringt Sie dazu, alles zu hinterfragen. Überdenken Sie oder beharren Sie."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impatience, lack of progress, and wasted effort. Your investments aren't paying off as expected. Disappointment makes you question everything. Reevaluate or persevere."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impaciencia, falta de progreso y esfuerzo desperdiciado. Tus inversiones no están dando los frutos esperados. La decepción te hace cuestionarlo todo. Reevalúa o persevera."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impatience, manque de progrès et effort gaspillé. Vos investissements ne rapportent pas comme prévu. La déception vous fait tout remettre en question. Réévaluez ou persévérez."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impazienza, mancanza di progressi e sforzo sprecato. I tuoi investimenti non stanno dando i frutti sperati. La delusione ti fa mettere tutto in discussione. Rivaluta o persevera."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "焦り、進歩の欠如、無駄な努力。あなたの投資は期待通りに報われていない。失望がすべてを疑わせる。再評価するか、忍耐強く続ける。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utålmodighet, mangel på fremgang og bortkastet innsats. Investeringene dine lønner seg ikke som forventet. Skuffelse får deg til å stille spørsmål ved alt. Vurder på nytt eller hold ut."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niecierpliwość, brak postępów i zmarnowany wysiłek. Twoje inwestycje nie przynoszą oczekiwanych rezultatów. Rozczarowanie sprawia, że kwestionujesz wszystko. Oceń ponownie lub wytrwaj."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impaciência, falta de progresso e esforço desperdiçado. Seus investimentos não estão compensando como esperado. A decepção faz você questionar tudo. Reavalie ou persevere."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Otålighet, brist på framsteg och bortkastad ansträngning. Dina investeringar lönar sig inte som förväntat. Besvikelse får dig att ifrågasätta allt. Omvärdera eller håll ut."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Нетерпіння, відсутність прогресу та марні зусилля. Ваші інвестиції не виправдовуються, як очікувалося. Розчарування змушує вас ставити під сумнів все. Переоцініть або наполягайте."
          }
        }
      }
    },
    "interpretation.seven_of_pentacles_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Geduld, langfristige Investition und Bewertung des Fortschritts. Sie haben hart gearbeitet und machen nun eine Pause, um die Ergebnisse zu sehen. Vertrauen Sie dem Prozess – Ihre Bemühungen werden sich auszahlen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Patience, long-term investment, and assessment of progress. You've worked hard and now you're pausing to see results. Trust the process—your efforts will pay off."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Paciencia, inversión a largo plazo y evaluación del progreso. Has trabajado duro y ahora haces una pausa para ver los resultados. Confía en el proceso: tus esfuerzos darán sus frutos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Patience, investissement à long terme et évaluation des progrès. Vous avez travaillé dur et vous faites maintenant une pause pour voir les résultats. Faites confiance au processus – vos efforts porteront leurs fruits."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pazienza, investimento a lungo termine e valutazione dei progressi. Hai lavorato duro e ora ti stai fermando per vedere i risultati. Fidati del processo – i tuoi sforzi daranno i loro frutti."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "忍耐、長期的な投資、進捗状況の評価。あなたは一生懸命働き、今結果を見るために一時停止している。プロセスを信頼せよ - あなたの努力は報われるだろう。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tålmodighet, langsiktig investering og vurdering av fremgang. Du har jobbet hardt og nå tar du en pause for å se resultater. Stol på prosessen – innsatsen din vil lønne seg."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cierpliwość, długoterminowa inwestycja i ocena postępów. Ciężko pracowałeś i teraz zatrzymujesz się, aby zobaczyć wyniki. Zaufaj procesowi – twoje wysiłki się opłacą."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Paciência, investimento de longo prazo e avaliação do progresso. Você trabalhou duro e agora está pausando para ver os resultados. Confie no processo – seus esforços valerão a pena."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tålamod, långsiktig investering och bedömning av framsteg. Du har arbetat hårt och nu pausar du för att se resultat. Lita på processen – dina ansträngningar kommer att löna sig."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Терпіння, довгострокові інвестиції та оцінка прогресу. Ви наполегливо працювали, а тепер робите паузу, щоб побачити результати. Довіртеся процесу – ваші зусилля окупляться."
          }
        }
      }
    },
    "interpretation.seven_of_pentacles_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ungeduld mit den gesundheitlichen Fortschritten. Wellness-Bemühungen bringen nicht die erwarteten Ergebnisse. Enttäuschung über die Reaktion des Körpers. Ansatz überdenken oder Erwartungen anpassen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impatience with health progress. Wellness efforts don't yield expected results. Disappointment in body's response. Reevaluate approach or adjust expectations."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impaciencia con el progreso de la salud. Los esfuerzos de bienestar no dan los resultados esperados. Decepción en la respuesta del cuerpo. Reevaluar el enfoque o ajustar las expectativas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impatience face aux progrès de la santé. Les efforts de bien-être ne donnent pas les résultats escomptés. Déception face à la réponse du corps. Réévaluer l'approche ou ajuster les attentes."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impazienza con i progressi della salute. Gli sforzi di benessere non producono i risultati attesi. Delusione per la risposta del corpo. Rivalutare l'approccio o adattare le aspettative."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "健康の進歩への焦り。ウェルネスへの取り組みが期待した結果をもたらさない。身体の反応への失望。アプローチを再評価するか、期待を調整する。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utålmodighet med helsefremskritt. Velværeinnsats gir ikke forventede resultater. Skuffelse over kroppens respons. Vurder tilnærmingen på nytt eller juster forventningene."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niecierpliwość wobec postępów zdrowotnych. Wysiłki wellness nie przynoszą oczekiwanych rezultatów. Rozczarowanie reakcją ciała. Przeanalizuj podejście lub dostosuj oczekiwania."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impaciência com o progresso da saúde. Esforços de bem-estar não produzem os resultados esperados. Decepção com a resposta do corpo. Reavalie a abordagem ou ajuste as expectativas."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Otålighet med hälsoframsteg. Hälso- och välmåendeinsatser ger inte förväntade resultat. Besvikelse över kroppens svar. Omvärdera tillvägagångssättet eller justera förväntningarna."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Нетерпіння з прогресом здоров'я. Оздоровчі зусилля не дають очікуваних результатів. Розчарування в реакції тіла. Перегляньте підхід або скоригуйте очікування."
          }
        }
      }
    },
    "interpretation.seven_of_pentacles_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Geduldige gesundheitliche Fortschritte und langfristige Wellness-Perspektive. Ihre gesundheitlichen Bemühungen wirken langsam, aber sicher. Vertrauen Sie dem Zeitplan Ihres Körpers. Beharrlichkeit bringt Ergebnisse."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Patient health progress and long-term wellness view. Your health efforts are working slowly but surely. Trust your body's timeline. Perseverance brings results."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Progreso de salud paciente y visión de bienestar a largo plazo. Tus esfuerzos de salud están funcionando lenta pero seguramente. Confía en el ritmo de tu cuerpo. La perseverancia trae resultados."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Progrès de santé patient et vision à long terme du bien-être. Vos efforts de santé fonctionnent lentement mais sûrement. Faites confiance au calendrier de votre corps. La persévérance apporte des résultats."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Progressi sanitari pazienti e visione del benessere a lungo termine. I tuoi sforzi per la salute funzionano lentamente ma costantemente. Fidati dei tempi del tuo corpo. La perseveranza porta risultati."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "忍耐強い健康の進歩と長期的なウェルネスの視点。あなたの健康への努力は、ゆっくりとしかし確実に効果を上げている。自分の身体のタイムラインを信頼する。忍耐が結果をもたらす。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tålmodig helsefremskritt og langsiktig velværesyn. Helsearbeidet ditt fungerer sakte, men sikkert. Stol på kroppens tidslinje. Utholdenhet gir resultater."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cierpliwe postępy zdrowotne i długoterminowa perspektywa wellness. Twoje wysiłki zdrowotne działają powoli, ale skutecznie. Zaufaj harmonogramowi swojego ciała. Wytrwałość przynosi rezultaty."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Progresso de saúde paciente e visão de bem-estar de longo prazo. Seus esforços de saúde estão funcionando lenta mas seguramente. Confie no cronograma do seu corpo. Perseverança traz resultados."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tålmodiga hälsoframsteg och långsiktig hälso- och välmåendesyn. Dina hälsoinsatser fungerar långsamt men säkert. Lita på din kropps tidslinje. Uthållighet ger resultat."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Терплячий прогрес здоров'я та довгостроковий погляд на оздоровлення. Ваші оздоровчі зусилля працюють повільно, але впевнено. Довіртеся часовій лінії вашого тіла. Наполегливість приносить результати."
          }
        }
      }
    },
    "interpretation.seven_of_pentacles_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ungeduld mit dem Fortschritt der Beziehung. Enttäuschung über die Erträge der Liebe. Fühlt sich wie verschwendete Mühe in der Partnerschaft an. Investition neu bewerten oder Erwartungen anpassen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impatience with relationship progress. Disappointment in love's returns. Feels like wasted effort on partnership. Reevaluate investment or adjust expectations."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impaciencia con el progreso de la relación. Decepción en los retornos del amor. Sensación de esfuerzo desperdiciado en la sociedad. Reevaluar la inversión o ajustar las expectativas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impatience face aux progrès de la relation. Déception quant aux retours de l'amour. Sentiment d'effort gaspillé dans le partenariat. Réévaluer l'investissement ou ajuster les attentes."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impazienza con i progressi della relazione. Delusione per i ritorni dell'amore. Sensazione di sforzo sprecato nella partnership. Rivalutare l'investimento o adattare le aspettative."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "関係の進展に対する焦り。愛の見返りに対する失望。パートナーシップへの努力が無駄に感じられる。投資を再評価するか、期待を調整する。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utålmodighet med forholdsfremgang. Skuffelse over kjærlighetens avkastning. Føles som bortkastet innsats i partnerskapet. Vurder investeringen på nytt eller juster forventningene."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niecierpliwość wobec postępów w związku. Rozczarowanie zwrotami z miłości. Poczucie zmarnowanego wysiłku w partnerstwie. Ponowna ocena inwestycji lub dostosowanie oczekiwań."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impaciência com o progresso do relacionamento. Decepção com os retornos do amor. Sensação de esforço desperdiçado na parceria. Reavalie o investimento ou ajuste as expectativas."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Otålighet med relationsframsteg. Besvikelse över kärlekens avkastning. Känns som bortkastad ansträngning i partnerskapet. Omvärdera investeringen eller justera förväntningarna."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Нетерпіння з прогресом стосунків. Розчарування у віддачі від любові. Відчуття марної трати зусиль у партнерстві. Переоцініть інвестиції або скоригуйте очікування."
          }
        }
      }
    },
    "interpretation.seven_of_pentacles_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Geduld mit dem Wachstum der Beziehung und Bewertung des Fortschritts der Liebe. Sie haben Zeit und Mühe investiert – warten nun auf Ergebnisse. Langfristige Sicht auf die Partnerschaft. Vertrauen Sie dem Prozess."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Patience with relationship growth and assessing love's progress. You've invested time and effort—now waiting to see results. Long-term view of partnership. Trust the process."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Paciencia con el crecimiento de la relación y evaluación del progreso del amor. Has invertido tiempo y esfuerzo, ahora esperas ver resultados. Visión a largo plazo de la sociedad. Confía en el proceso."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Patience face à la croissance de la relation et évaluation des progrès de l'amour. Vous avez investi du temps et des efforts – vous attendez maintenant les résultats. Vision à long terme du partenariat. Faites confiance au processus."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pazienza con la crescita della relazione e valutazione dei progressi dell'amore. Hai investito tempo e impegno – ora aspetti di vedere i risultati. Visione a lungo termine della partnership. Fidati del processo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "関係の成長に対する忍耐と愛の進捗状況の評価。あなたは時間と労力を投資した - 今結果を待っている。パートナーシップの長期的視点。プロセスを信頼する。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tålmodighet med forholdsvekst og vurdering av kjærlighetens fremgang. Du har investert tid og innsats – nå venter du på å se resultater. Langsiktig syn på partnerskap. Stol på prosessen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cierpliwość wobec wzrostu związku i ocena postępów miłości. Zainwestowałeś czas i wysiłek – teraz czekasz na rezultaty. Długoterminowa perspektywa partnerstwa. Zaufaj procesowi."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Paciência com o crescimento do relacionamento e avaliação do progresso do amor. Você investiu tempo e esforço – agora esperando para ver os resultados. Visão de longo prazo da parceria. Confie no processo."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tålamod med relationstillväxt och bedömning av kärlekens framsteg. Du har investerat tid och ansträngning – nu väntar du på att se resultat. Långsiktig syn på partnerskap. Lita på processen."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Терпіння з ростом стосунків та оцінка прогресу любові. Ви інвестували час та зусилля – тепер чекаєте на результати. Довгостроковий погляд на партнерство. Довіртеся процесу."
          }
        }
      }
    },
    "interpretation.seven_of_swords_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reinen Tisch machen bei der Arbeit oder berufliches Geständnis. Ehrlichkeit ersetzt Täuschung am Arbeitsplatz. Karrierestrategie überdenken. Wahrheit kommt ans Licht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Coming clean at work or professional confession. Honesty replaces workplace deception. Rethinking career strategy. Truth emerges."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confesar en el trabajo o confesión profesional. La honestidad reemplaza el engaño en el lugar de trabajo. Repensar la estrategia profesional. La verdad emerge."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se confesser au travail ou confession professionnelle. L'honnêteté remplace la tromperie sur le lieu de travail. Repenser la stratégie de carrière. La vérité émerge."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confessare al lavoro o confessione professionale. L'onestà sostituisce l'inganno sul lavoro. Ripensare la strategia di carriera. La verità emerge."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "仕事での白状または仕事上の告白。誠実さが職場の欺瞞に取って代わる。キャリア戦略を再考する。真実が現れる。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Renere bord på jobb eller profesjonell tilståelse. Ærlighet erstatter bedrag på arbeidsplassen. Revurdere karrierestrategi. Sannheten kommer frem."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oczyszczenie w pracy lub zawodowe wyznanie. Uczciwość zastępuje oszustwo w miejscu pracy. Ponowne przemyślenie strategii kariery. Prawda wychodzi na jaw."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confessar no trabalho ou confissão profissional. A honestidade substitui o engano no local de trabalho. Repensar a estratégia de carreira. A verdade emerge."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Komma ren på jobbet eller professionell bekännelse. Ärlighet ersätter bedrägeri på arbetsplatsen. Omtänka karriärstrategi. Sanningen kommer fram."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Зізнання на роботі або професійне визнання. Чесність замінює обман на робочому місці. Переосмислення кар'єрної стратегії. Правда виходить назовні."
          }
        }
      }
    },
    "interpretation.seven_of_swords_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Berufliche Täuschung oder strategischer Arbeitsplatzansatz. Heimliches Verhalten bei der Arbeit. Beruflich etwas durchkommen lassen. Überprüfe, ob die Methoden ethisch sind."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professional deception or strategic workplace approach. Sneaky behavior at work. Getting away with something professionally. Examine if methods are ethical."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Engaño profesional o enfoque estratégico en el trabajo. Comportamiento furtivo en el trabajo. Salirse con la suya profesionalmente. Examina si los métodos son éticos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tromperie professionnelle ou approche stratégique sur le lieu de travail. Comportement furtif au travail. S'en tirer professionnellement. Examinez si les méthodes sont éthiques."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inganno professionale o approccio strategico sul lavoro. Comportamento furtivo al lavoro. Farla franca professionalmente. Esamina se i metodi sono etici."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "仕事上の欺瞞または戦略的な職場アプローチ。職場でのこそこそした行動。仕事上での逃げ切り。方法が倫理的か検討せよ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profesjonelt bedrag eller strategisk arbeidsplasstilnærming. Snikete oppførsel på jobb. Å komme unna med noe profesjonelt. Undersøk om metodene er etiske."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zawodowe oszustwo lub strategiczne podejście w miejscu pracy. Podstępne zachowanie w pracy. Uchodzenie na sucho zawodowo. Sprawdź, czy metody są etyczne."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Engano profissional ou abordagem estratégica no local de trabalho. Comportamento sorrateiro no trabalho. Sair impune profissionalmente. Examine se os métodos são éticos."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professionellt bedrägeri eller strategiskt arbetssätt. Smygande beteende på jobbet. Komma undan med något professionellt. Undersök om metoderna är etiska."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Професійний обман або стратегічний підхід на роботі. Потайна поведінка на роботі. Безкарність у професійній сфері. Перевірте, чи є методи етичними."
          }
        }
      }
    },
    "interpretation.seven_of_swords_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielles Geständnis oder reinen Tisch machen beim Geld. Ehrlichkeit ersetzt finanzielle Täuschung. Ressourcenstrategie überdenken. Wahrheit kommt ans Licht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial confession or coming clean about money. Honesty replaces financial deception. Rethinking resource strategy. Truth emerges."
