        }
      }
    },
    "interpretation.five_of_swords_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzieller Konflikt und Geldverrat. Sieg um jeden Preis mit Ressourcen. Finanzieller Sieg, aber beschädigte Beziehungen. Überprüfe, ob Reichtum die Kosten wert ist."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial conflict and money betrayal. Win-at-all-costs with resources. Financial victory but damaged relationships. Examine if wealth is worth the cost."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conflicto financiero y traición económica. Ganar a toda costa con los recursos. Victoria financiera pero relaciones dañadas. Examina si la riqueza vale la pena."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conflit financier et trahison monétaire. Gagner à tout prix avec les ressources. Victoire financière mais relations endommagées. Examinez si la richesse vaut le coût."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conflitto finanziario e tradimento monetario. Vincere a tutti i costi con le risorse. Vittoria finanziaria ma relazioni danneggiate. Esamina se la ricchezza vale il costo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "金銭的な対立とお金の裏切り。リソースで勝利のためなら何でもする。金銭的勝利だが、人間関係は損なわれる。富が代償に見合うか検討せよ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk konflikt og penge-svik. Vinn-for-all-pris med ressurser. Økonomisk seier men skadde relasjoner. Undersøk om rikdom er verdt prisen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Konflikt finansowy i zdrada pieniężna. Zwycięstwo za wszelką cenę z zasobami. Zwycięstwo finansowe, ale uszkodzone relacje. Sprawdź, czy bogactwo jest warte kosztów."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conflito financeiro e traição financeira. Vencer a qualquer custo com recursos. Vitória financeira, mas relacionamentos prejudicados. Examine se a riqueza vale o custo."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finansiell konflikt och pengasvek. Vinn-till-varje-pris med resurser. Finansiell seger men skadade relationer. Undersök om rikedom är värt kostnaden."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансовий конфлікт і грошова зрада. Перемога за будь-яку ціну з ресурсами. Фінансова перемога, але зіпсовані стосунки. Перевірте, чи варте багатство такої ціни."
          }
        }
      }
    },
    "interpretation.five_of_swords_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Versöhnung, Wiedergutmachung, Loslassen und Kompromiss. Du bist bereit, den Konflikt zu beenden. Frieden statt Sieg wählen. Zusammenarbeit ersetzt Kampf."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reconciliation, making amends, moving on, and compromise. You're ready to end the conflict. Choosing peace over victory. Cooperation replaces combat."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reconciliación, reparación, superación y compromiso. Estás listo para terminar el conflicto. Elegir la paz sobre la victoria. La cooperación reemplaza el combate."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Réconciliation, réparation, dépassement et compromis. Vous êtes prêt à mettre fin au conflit. Choisir la paix plutôt que la victoire. La coopération remplace le combat."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Riconciliazione, riparazione, superamento e compromesso. Sei pronto a porre fine al conflitto. Scegliere la pace sulla vittoria. La cooperazione sostituisce la lotta."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "和解、償い、前進、妥協。あなたは葛藤を終わらせる準備ができている。勝利よりも平和を選ぶ。戦いの代わりに協力。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Forlik, oppreisning, videregang og kompromiss. Du er klar til å avslutte konflikten. Velge fred fremfor seier. Samarbeid erstatter kamp."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pojednanie, naprawienie błędów, pójście dalej i kompromis. Jesteś gotowy zakończyć konflikt. Wybór pokoju nad zwycięstwem. Współpraca zastępuje walkę."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reconciliação, reparação, superação e compromisso. Você está pronto para encerrar o conflito. Escolher a paz em vez da vitória. Cooperação substitui o combate."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Försoning, gottgörelse, vidaregång och kompromiss. Du är redo att avsluta konflikten. Välja fred framför seger. Samarbete ersätter kamp."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Примирення, виправлення, рух далі та компроміс. Ви готові закінчити конфлікт. Обрати мир замість перемоги. Співпраця замінює боротьбу."
          }
        }
      }
    },
    "interpretation.five_of_swords_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Konflikt, Niederlage, Sieg um jeden Preis und Verrat. Du gewinnst vielleicht die Schlacht, verlierst aber den Krieg. Unfaire Kämpfe schaden Beziehungen. Ist dieser Sieg die Kosten wert?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conflict, defeat, win-at-all-costs, and betrayal. You might win the battle but lose the war. Fighting dirty damages relationships. Is this victory worth the cost?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conflicto, derrota, ganar a toda costa y traición. Puedes ganar la batalla pero perder la guerra. Luchar sucio daña las relaciones. ¿Vale la pena esta victoria?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conflit, défaite, gagner à tout prix et trahison. Vous pouvez gagner la bataille mais perdre la guerre. Se battre sale nuit aux relations. Cette victoire en vaut-elle la peine ?"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conflitto, sconfitta, vincere a tutti i costi e tradimento. Potresti vincere la battaglia ma perdere la guerra. Combattere sporco danneggia le relazioni. Questa vittoria vale il costo?"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "葛藤、敗北、勝利のための精神、裏切り。戦いに勝っても戦争に負けるかもしれない。汚い戦いは人間関係を損なう。この勝利は代償に見合うか？"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Konflikt, nederlag, vinn-for-all-pris, og svik. Du kan vinne slaget, men tape krigen. Å kjempe skittent skader relasjoner. Er denne seieren verdt prisen?"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Konflikt, porażka, zwycięstwo za wszelką cenę i zdrada. Możesz wygrać bitwę, ale przegrać wojnę. Nieczysta walka rani relacje. Czy to zwycięstwo jest warte kosztów?"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conflito, derrota, vencer a qualquer custo e traição. Você pode vencer a batalha, mas perder a guerra. Lutar sujo prejudica os relacionamentos. Esta vitória vale o custo?"
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Konflikt, nederlag, vinn-till-varje-pris och svek. Du kan vinna slaget men förlora kriget. Att slåss smutsigt skadar relationer. Är denna seger värd kostnaden?"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Конфлікт, поразка, перемога за будь-яку ціну та зрада. Ви можете виграти битву, але програти війну. Брудна боротьба шкодить стосункам. Чи варта ця перемога такої ціни?"
          }
        }
      }
    },
    "interpretation.five_of_swords_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gesundheitliche Versöhnung mit dem Körper. Wiedergutmachung mit dem physischen Selbst. Abschied vom Wohlfühlkonflikt. Zusammenarbeit mit dem Körper."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Health reconciliation with body. Making amends with physical self. Moving on from wellness conflict. Cooperation with body."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reconciliación de la salud con el cuerpo. Reparación con el yo físico. Superar el conflicto de bienestar. Cooperación con el cuerpo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Réconciliation de la santé avec le corps. Réparation avec le soi physique. Surmonter les conflits de bien-être. Coopération avec le corps."
