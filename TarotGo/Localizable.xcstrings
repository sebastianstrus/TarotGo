    "interpretation.three_of_wands_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verzögerungen, Hindernisse, mangelnde Weitsicht und Frustration. Die Expansion ist blockiert. Deine Vision verwirklicht sich nicht wie geplant. Überdenke und passe an."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Delays, obstacles, lack of foresight, and frustration. Expansion is blocked. Your vision isn't materializing as planned. Reassess and adjust."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Retrasos, obstáculos, falta de previsión y frustración. La expansión está bloqueada. Tu visión no se está materializando como se planeó. Reevalúa y ajusta."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Retards, obstacles, manque de prospective et frustration. L'expansion est bloquée. Votre vision ne se matérialise pas comme prévu. Réévaluez et ajustez."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ritardi, ostacoli, mancanza di lungimiranza e frustrazione. L'espansione è bloccata. La tua visione non si sta materializzando come previsto. Rivaluta e aggiusta."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "遅延、障害、先見性の欠如、そしてフラストレーション。拡大がブロックされている。あなたのビジョンは計画通りに実現していない。再評価し、調整しなさい。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Forsinkelser, hindringer, mangel på fremsyn og frustrasjon. Utvidelse er blokkert. Visjonen din realiseres ikke som planlagt. Revurder og juster."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opóźnienia, przeszkody, brak przewidywania i frustracja. Ekspansja jest zablokowana. Twoja wizja nie realizuje się zgodnie z planem. Przeanalizuj i dostosuj."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atrasos, obstáculos, falta de visão e frustração. A expansão está bloqueada. Sua visão não está se materializando como planejado. Reavalie e ajuste."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Förseningar, hinder, brist på framförhållning och frustration. Expansionen är blockerad. Din vision förverkligas inte som planerat. Omvärdera och justera."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Затримки, перешкоди, відсутність передбачливості та фрустрація. Розширення заблоковано. Ваше бачення не матеріалізується за планом. Переоцініть та скоригуйте."
          }
        }
      }
    },
    "interpretation.three_of_wands_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Expansion, Weitsicht, Auslandschancen und Führung. Du blickst voraus und planst Wachstum. Deine Welt erweitert sich. Chancen warten jenseits des Horizonts."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Expansion, foresight, overseas opportunities, and leadership. You're looking ahead and planning growth. Your world is expanding. Opportunities await beyond the horizon."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Expansión, previsión, oportunidades en el extranjero y liderazgo. Estás mirando hacia adelante y planificando el crecimiento. Tu mundo se está expandiendo. Las oportunidades te esperan más allá del horizonte."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Expansion, prospective, opportunités à l'étranger et leadership. Vous regardez vers l'avant et planifiez la croissance. Votre monde s'agrandit. Des opportunités vous attendent au-delà de l'horizon."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Espansione, lungimiranza, opportunità all'estero e leadership. Stai guardando avanti e pianificando la crescita. Il tuo mondo si sta espandendo. Le opportunità ti aspettano oltre l'orizzonte."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "拡大、先見性、海外での機会、そしてリーダーシップ。あなたは未来を見据え、成長を計画している。あなたの世界は広がっている。機会は地平線の向こうに待っている。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utvidelse, fremsyn, utenlandsmuligheter og ledelse. Du ser fremover og planlegger vekst. Verden din utvides. Muligheter venter utenfor horisonten."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekspansja, przezorność, możliwości zagraniczne i przywództwo. Patrzysz w przyszłość i planujesz rozwój. Twój świat się rozszerza. Możliwości czekają za horyzontem."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Expansão, visão, oportunidades no exterior e liderança. Você está olhando para frente e planejando o crescimento. Seu mundo está se expandindo. Oportunidades esperam além do horizonte."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Expansion, framförhållning, utlandsmöjligheter och ledarskap. Du ser framåt och planerar tillväxt. Din värld expanderar. Möjligheter väntar bortom horisonten."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Розширення, передбачливість, закордонні можливості та лідерство. Ви дивитеся вперед і плануєте зростання. Ваш світ розширюється. Можливості чекають за горизонтом."
          }
        }
      }
    },
    "interpretation.three_of_wands_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gesundheitsverzögerungen oder Wellness-Hindernisse. Mangelnde Heilungsweitsicht. Körperliche Frustration. Vitalitätsexpansion blockiert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Health delays or wellness obstacles. Lack of healing foresight. Physical frustration. Vitality expansion blocked."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Retrasos en la salud u obstáculos para el bienestar. Falta de previsión curativa. Frustración física. Expansión de la vitalidad bloqueada."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Retards de santé ou obstacles au bien-être. Manque de prospective de guérison. Frustration physique. Expansion de la vitalité bloquée."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ritardi nella salute o ostacoli al benessere. Mancanza di lungimiranza nella guarigione. Frustrazione fisica. Espansione della vitalità bloccata."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "健康の遅れやウェルネスの障害。癒しの先見性の欠如。身体的なフラストレーション。活力の拡大がブロックされている。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Helseforsinkelser eller velværehindringer. Mangel på helbredelsesfremsyn. Fysisk frustrasjon. Vitalitetsutvidelse blokkert."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opóźnienia zdrowotne lub przeszkody wellness. Brak przewidywania uzdrawiania. Fizyczna frustracja. Ekspansja witalności zablokowana."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atrasos na saúde ou obstáculos ao bem-estar. Falta de visão de cura. Frustração física. Expansão da vitalidade bloqueada."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hälsoförseningar eller välmåendehinder. Brist på läkningsframförhållning. Fysisk frustration. Vitalitetsexpansion blockerad."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Затримки зі здоров'ям або перешкоди для благополуччя. Відсутність передбачливості в зціленні. Фізична фрустрація. Розширення життєвої сили заблоковано."
          }
        }
      }
    },
    "interpretation.three_of_wands_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gesundheitsexpansion und Wellness-Weitsicht. Körper wächst über die aktuellen Grenzen hinaus. Übernahme der Heilungsverantwortung. Blick in die Zukunft des Vitalitätspotenzials."
          }
        },
        "en" : {
