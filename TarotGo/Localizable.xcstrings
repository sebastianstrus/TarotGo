        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的な防御に疲れ果てた。繁栄をあきらめる。お金の課題に圧倒される。リソースの立場を失う。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utslitt av finansiell forsvar. Gi opp velstand. Overveldet av pengeutfordringer. Miste ressursgrunn."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wyczerpany obroną finansową. Poddawanie się dobrobytowi. Przytłoczony wyzwaniami pieniężnymi. Tracenie gruntu w zasobach."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Exausto de defender as finanças. Desistindo da prosperidade. Sobrecarregado pelos desafios financeiros. Perdendo terreno nos recursos."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utmattad av finansiellt försvar. Ge upp välståndet. Överväldigad av pengautmaningar. Förlora resursmark."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Виснажений фінансовим захистом. Здатися процвітанню. Перевантажений грошовими викликами. Втрата ресурсних позицій."
          }
        }
      }
    },
