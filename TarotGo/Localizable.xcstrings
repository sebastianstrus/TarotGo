        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Malas noticias de salud o inmadurez emocional que afecta el bienestar. El escapismo bloquea el progreso de la salud. Ignorar los mensajes intuitivos del cuerpo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mauvaises nouvelles concernant la santé ou immaturité émotionnelle affectant le bien-être. L'évasion bloque les progrès en matière de santé. Ignorer les messages intuitifs du corps."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cattive notizie sulla salute o immaturità emotiva che influisce sul benessere. L'evasione blocca i progressi della salute. Ignorare i messaggi intuitivi del corpo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "健康に関する悪い知らせや感情的な未熟さが健康に影響。逃避が健康の進歩を妨げる。直感的な身体のメッセージを無視する。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dårlige helsenyheter eller emosjonell umodenhet som påvirker velvære. Eskapisme blokkerer helsefremgang. Ignorerer intuitive kroppsmeldinger."
          }
        },
        "pl" : {
