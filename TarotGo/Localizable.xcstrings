    "interpretation.page_of_swords_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klatsch, Hast, verstreute Gedanken und Zynismus. Dein Geist arbeitet gegen dich. Verlangsame und denke nach, bevor du sprichst. Schlechte Nachrichten treffen ein."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gossiping, hastiness, scattered thoughts, and cynicism. Your mind works against you. Slow down and think before speaking. Bad news arrives."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chismes, prisas, pensamientos dispersos y cinismo. Tu mente trabaja en tu contra. Reduce la velocidad y piensa antes de hablar. Llegan malas noticias."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Potins, précipitation, pensées dispersées et cynisme. Votre esprit travaille contre vous. Ralentissez et réfléchissez avant de parler. De mauvaises nouvelles arrivent."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pettegolezzi, fretta, pensieri sparsi e cinismo. La tua mente lavora contro di te. Rallenta e pensa prima di parlare. Arrivano cattive notizie."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ゴシップ、性急さ、散らかった思考、冷笑。あなたの心はあなたに逆らって働く。スピードを落とし、話す前に考えよ。悪い知らせが届く。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sladder, hastverk, spredte tanker og kynisme. Sinnet ditt jobber mot deg. Senk farten og tenk før du snakker. Dårlige nyheter ankommer."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Plotki, pośpiech, rozproszone myśli i cynizm. Twój umysł działa przeciwko tobie. Zwolnij i pomyśl, zanim zaczniesz mówić. Nadchodzą złe wieści."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fofoca, pressa, pensamentos dispersos e cinismo. Sua mente trabalha contra você. Diminua a velocidade e pense antes de falar. Más notícias chegam."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Skvaller, brådska, spridda tankar och kynism. Ditt sinne arbetar mot dig. Sakta ner och tänk innan du talar. Dåliga nyheter anländer."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Плітки, поспіх, розрізнені думки та цинізм. Ваш розум працює проти вас. Сповільніться і подумайте, перш ніж говорити. Надходять погані новини."
          }
        }
      }
    },
    "interpretation.page_of_swords_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Neugier, geistige Beweglichkeit, Wachsamkeit und Kommunikation. Du lernst, beobachtest und bleibst wachsam. Dein Geist ist scharf und schnell. Nachrichten treffen ein."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Curiosity, mental agility, vigilance, and communication. You're learning, observing, and staying alert. Your mind is sharp and quick. Messages arrive."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Curiosidad, agilidad mental, vigilancia y comunicación. Estás aprendiendo, observando y manteniéndote alerta. Tu mente es aguda y rápida. Llegan mensajes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Curiosité, agilité mentale, vigilance et communication. Vous apprenez, observez et restez alerte. Votre esprit est vif et rapide. Des messages arrivent."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Curiosità, agilità mentale, vigilanza e comunicazione. Stai imparando, osservando e rimanendo attento. La tua mente è acuta e veloce. Arrivano messaggi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "好奇心、精神的な機敏さ、警戒心、コミュニケーション。あなたは学び、観察し、警戒を保っている。あなたの心は鋭く速い。メッセージが届く。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nysgjerrighet, mental smidighet, våkenhet og kommunikasjon. Du lærer, observerer og holder deg årvåken. Sinnet ditt er skarpt og raskt. Meldinger ankommer."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ciekawość, zwinność umysłowa, czujność i komunikacja. Uczysz się, obserwujesz i pozostajesz czujny. Twój umysł jest bystry i szybki. Napływają wiadomości."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Curiosidade, agilidade mental, vigilância e comunicação. Você está aprendendo, observando e se mantendo alerta. Sua mente é afiada e rápida. Mensagens chegam."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nyfikenhet, mental smidighet, vaksamhet och kommunikation. Du lär dig, observerar och håller dig alert. Ditt sinne är skarpt och snabbt. Meddelanden anländer."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Допитливість, розумова спритність, пильність і комунікація. Ви вчитеся, спостерігаєте та залишаєтеся пильним. Ваш розум гострий і швидкий. Повідомлення надходять."
          }
        }
      }
    },
