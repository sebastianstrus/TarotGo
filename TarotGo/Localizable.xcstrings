    "interpretation.knight_of_wands_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rücksichtslosigkeit, Eile, Frustration und passive Energie. Deine Leidenschaft ist fehlgeleitet oder blockiert. Mach langsamer und kanalisiere Energie weise."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recklessness, haste, frustration, and passive energy. Your passion is misdirected or blocked. Slow down and channel energy wisely."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Imprudencia, prisas, frustración y energía pasiva. Tu pasión está mal dirigida o bloqueada. Reduce la velocidad y canaliza la energía sabiamente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Imprudence, hâte, frustration et énergie passive. Votre passion est mal dirigée ou bloquée. Ralentissez et canalisez l'énergie judicieusement."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spericolatezza, fretta, frustrazione ed energia passiva. La tua passione è mal indirizzata o bloccata. Rallenta e canalizza l'energia saggiamente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "無謀さ、性急さ、フラストレーション、受動的なエネルギー。あなたの情熱は誤った方向に向かっているか、妨げられている。立ち止まってエネルギーを賢く導きましょう。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uforsiktighet, hastverk, frustrasjon og passiv energi. Lidenskapen din er feilrettet eller blokkert. Senk farten og kanaliser energi klokt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lekkomyślność, pośpiech, frustracja i bierna energia. Twoja pasja jest źle skierowana lub zablokowana. Zwolnij i mądrze kieruj energią."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Imprudência, pressa, frustração e energia passiva. Sua paixão está mal direcionada ou bloqueada. Diminua o ritmo e canalize a energia sabiamente."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Förhastning, brådska, frustration och passiv energi. Din passion är felriktad eller blockerad. Sakta ner och kanalisera energi klokt."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Необачність, поспіх, фрустрація та пасивна енергія. Ваша пристрасть спрямована неправильно або заблокована. Уповільніться та спрямовуйте енергію wisely."
          }
        }
      }
    },
    "interpretation.knight_of_wands_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Energie, Leidenschaft, Abenteuer und Impulsivität. Du stürmst mit Begeisterung voran. Folgst deiner Leidenschaft, wohin sie auch führt. Aufregung treibt zum Handeln an."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Energy, passion, adventure, and impulsiveness. You're charging forward with enthusiasm. Following your passion wherever it leads. Excitement drives action."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Energía, pasión, aventura e impulsividad. Avanzas con entusiasmo. Siguiendo tu pasión donde sea que te lleve. La emoción impulsa la acción."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Énergie, passion, aventure et impulsivité. Vous avancez avec enthousiasme. Suivant votre passion où qu'elle mène. L'excitation motive l'action."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Energia, passione, avventura e impulsività. Stai avanzando con entusiasmo. Seguendo la tua passione ovunque ti porti. L'eccitazione guida l'azione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "エネルギー、情熱、冒険、衝動性。あなたは熱意を持って前進している。情熱の向かう先へ従う。興奮が行動を駆り立てる。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Energi, lidenskap, eventyr og impulsivitet. Du stormer fremover med entusiasme. Følger lidenskapen din uansett hvor den leder. Spenning driver handling."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Energia, pasja, przygoda i impulsywność. Ruszasz naprzód z entuzjazmem. Podążasz za swoją pasją, gdziekolwiek prowadzi. Ekscytacja napędza działanie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Energia, paixão, aventura e impulsividade. Você avança com entusiasmo. Seguindo sua paixão para onde quer que leve. A emoção impulsiona a ação."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Energi, passion, äventyr och impulsivitet. Du rusar framåt med entusiasm. Följer din passion vart den än leder. Spänning driver handling."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Енергія, пристрасть, пригода та імпульсивність. Ви рветеся вперед з ентузіазмом. Слідуєте своїй пристрасті, куди б вона не вела. Хвилювання спонукає до дії."
          }
        }
      }
    },
