    },
    "interpretation.temperance_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ungleichgewicht zwischen Arbeit und Privatleben oder Extreme im beruflichen Ansatz. Mangel an Geduld mit dem Karrierefortschritt. Stelle die Mäßigung wieder her."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Work-life imbalance or extremes in professional approach. Lack of patience with career progress. Restore moderation."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desequilibrio entre el trabajo y la vida personal o extremos en el enfoque profesional. Falta de paciencia con el progreso profesional. Restablece la moderación."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Déséquilibre entre vie professionnelle et vie privée ou extrêmes dans l'approche professionnelle. Manque de patience dans l'évolution de carrière. Rétablissez la modération."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Squilibrio tra lavoro e vita privata o estremi nell'approccio professionale. Mancanza di pazienza con i progressi di carriera. Ripristina la moderazione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ワークライフバランスの乱れや職業的アプローチの極端さ。キャリアの進歩に対する忍耐の欠如。節度を取り戻してください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ubalanse mellom jobb og privatliv eller ekstremer i profesjonell tilnærming. Mangel på tålmodighet med karrierefremgang. Gjenopprett måtehold."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Brak równowagi między życiem zawodowym a prywatnym lub skrajności w podejściu zawodowym. Brak cierpliwości wobec postępów w karierze. Przywróć umiar."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desequilíbrio entre trabalho e vida pessoal ou extremos na abordagem profissional. Falta de paciência com o progresso na carreira. Restaure a moderação."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Obalans mellan arbete och privatliv eller extremer i professionellt förhållningssätt. Brist på tålamod med karriärframsteg. Återställ måttfullhet."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Дисбаланс між роботою та особистим життям або крайнощі в професійному підході. Відсутність терпіння до кар'єрного прогресу. Відновіть помірність."
          }
        }
      }
    },
    "interpretation.temperance_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Berufliches Gleichgewicht und geduldiger Fortschritt führen zum Erfolg. Verbinde geschickt verschiedene Elemente deiner Arbeit. Mäßigung und Harmonie in deinem Ansatz."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professional balance and patient progress bring success. Blend different elements of your work skillfully. Moderation and harmony in your approach."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El equilibrio profesional y el progreso paciente traen éxito. Combina hábilmente diferentes elementos de tu trabajo. Moderación y armonía en tu enfoque."
