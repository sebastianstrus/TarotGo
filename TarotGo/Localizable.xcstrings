    "interpretation.seven_of_swords_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reinen Tisch machen, gestehen, Ehrlichkeit und Überdenken des Ansatzes. Du bist bereit, die Wahrheit zu sagen. Täuschung dient dir nicht mehr. Wähle Transparenz."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Coming clean, confessing, honesty, and rethinking approach. You're ready to tell the truth. Deception no longer serves you. Choose transparency."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confesar, sincerarse, honestidad y replantear el enfoque. Estás listo para decir la verdad. El engaño ya no te sirve. Elige la transparencia."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se confesser, avouer, honnêteté et repenser son approche. Vous êtes prêt à dire la vérité. La tromperie ne vous sert plus. Choisissez la transparence."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confessare, fare chiarezza, onestà e ripensare l'approccio. Sei pronto a dire la verità. L'inganno non ti serve più. Scegli la trasparenza."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "白状、告白、誠実さ、アプローチの再考。あなたは真実を語る準備ができている。欺瞞はもうあなたのためにならない。透明性を選べ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Renere bord, tilståelse, ærlighet og revurdering av tilnærming. Du er klar til å fortelle sannheten. Bedrag tjener deg ikke lenger. Velg åpenhet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oczyszczenie, wyznanie, uczciwość i ponowne przemyślenie podejścia. Jesteś gotowy powiedzieć prawdę. Oszustwo już ci nie służy. Wybierz przejrzystość."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confessar, abrir o jogo, honestidade e repensar a abordagem. Você está pronto para dizer a verdade. O engano não serve mais para você. Escolha a transparência."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Komma ren, bekänna, ärlighet och ompröva tillvägagångssätt. Du är redo att berätta sanningen. Bedrägeri tjänar dig inte längre. Välj transparens."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Зізнання, визнання, чесність і переосмислення підходу. Ви готові сказати правду. Обман більше не служить вам. Оберіть прозорість."
          }
        }
      }
    },
    "interpretation.seven_of_swords_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Täuschung, Strategie, Heimlichtuerei und etwas durchkommen lassen. Du bist strategisch – vielleicht zu strategisch. Sind deine Methoden ethisch? Die Wahrheit wird irgendwann ans Licht kommen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deception, strategy, sneakiness, and getting away with something. You're being strategic—maybe too strategic. Are your methods ethical? Truth will emerge eventually."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Engaño, estrategia, sigilo y salirse con la suya. Estás siendo estratégico, quizás demasiado estratégico. ¿Son éticos tus métodos? La verdad surgirá eventualmente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tromperie, stratégie, sournoiserie et s'en tirer. Vous êtes stratégique – peut-être trop stratégique. Vos méthodes sont-elles éthiques ? La vérité finira par émerger."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inganno, strategia, furtività e farla franca. Stai essendo strategico, forse troppo strategico. I tuoi metodi sono etici? La verità emergerà alla fine."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "欺瞞、戦略、こそこそ、逃げ切り。あなたは戦略的すぎるかもしれない。あなたの方法は倫理的か？真実は最終的に現れるだろう。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bedrag, strategi, snikete oppførsel og å komme unna med noe. Du er strategisk – kanskje for strategisk. Er metodene dine etiske? Sannheten vil til slutt komme frem."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oszustwo, strategia, podstępność i uchodzenie na sucho. Jesteś strategiczny – może zbyt strategiczny. Czy twoje metody są etyczne? Prawda w końcu wyjdzie na jaw."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Engano, estratégia, sorrateirice e safar-se. Você está sendo estratégico – talvez estratégico demais. Seus métodos são éticos? A verdade surgirá eventualmente."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bedrägeri, strategi, smygande och komma undan med något. Du är strategisk – kanske för strategisk. Är dina metoder etiska? Sanningen kommer så småningom fram."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Обман, стратегія, потайливість і безкарність. Ви дієте стратегічно – можливо, надто стратегічно. Чи є ваші методи етичними? Правда зрештою вийде назовні."
          }
        }
      }
    },
    "interpretation.seven_of_swords_health_reversed" : {
