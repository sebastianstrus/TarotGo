        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Prokrastynacja zdrowotna lub złe planowanie wellness. Utracona okazja zdrowotna. Brak postępów fizycznych. Potrzeba lepszej edukacji zdrowotnej i działania."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Procrastinação na saúde ou mau planejamento de bem-estar. Oportunidade de saúde perdida. Falta de progresso físico. Melhor educação em saúde e ação necessárias."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hälsoprokrastinering eller dålig hälso- och välmåendeplanering. Missad hälsochans. Brist på fysiska framsteg. Behöver bättre hälsoutbildning och handling."
          }
        },
        "uk" : {
