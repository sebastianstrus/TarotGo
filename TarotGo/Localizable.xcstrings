        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confusão de saúde e sintomas pouco claros. Caos mental afeta o bem-estar. Falta de comunicação com profissionais. Falta de clareza bloqueia a cura."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hälsoförvirring och oklara symptom. Mentalt kaos påverkar välbefinnandet. Missförstånd med vårdgivare. Brist på klarhet blockerar läkning."
          }
