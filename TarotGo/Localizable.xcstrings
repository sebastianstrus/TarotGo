        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Squilibrio, eccessi ed estremi creano discordia. Mancanza di pazienza o armonia. Ripristina la moderazione e trova il tuo centro."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "不均衡、過剰、極端さが不和を生み出します。忍耐や調和の欠如。節度を回復し、自分の中心を見つけてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ubalanse, overdrivelse og ekstremer skaper splid. Mangel på tålmodighet eller harmoni. Gjenopprett måtehold og finn sentrum."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nierównowaga, nadmiar i skrajności tworzą niezgodę. Brak cierpliwości lub harmonii. Przywróć umiar i znajdź swój środek."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desequilíbrio, excesso e extremos criam discórdia. Falta de paciência ou harmonia. Restaure a moderação e encontre seu centro."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Obalans, överdrifter och extremer skapar oenighet. Brist på tålamod eller harmoni. Återställ måttfullhet och hitta din mittpunkt."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Дисбаланс, надмірність і крайнощі створюють розбрат. Відсутність терпіння або гармонії. Відновіть помірність і знайдіть свій центр."
          }
        }
      }
    },
    "interpretation.temperance_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ausgeglichenheit, Mäßigung und Geduld weisen dir den Weg. Verbinde geschickt Gegensätze. Harmonie kommt durch den Mittelweg. Vertraue auf das göttliche Timing."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Balance, moderation, and patience guide your path. Blend opposites skillfully. Harmony comes through the middle way. Trust divine timing."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El equilibrio, la moderación y la paciencia guían tu camino. Combina hábilmente los opuestos. La armonía llega a través del camino medio. Confía en el tiempo divino."
