        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ansiedade romântica diminuindo e esperança no relacionamento surgindo. Buscar apoio amoroso. Desespero sobre a parceria diminuindo. A recuperação começa."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Romantisk ångest avtar och relationshopp uppstår. Söka kärleksstöd. Förtvivlan om partnerskap lättar. Återhämtning börjar."
