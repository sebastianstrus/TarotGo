        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Illusion, intuition, anxiété et forces subconscientes. Tout n'est pas comme il semble. Faites confiance à votre savoir intérieur pour naviguer dans l'incertitude et le mystère."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Illusione, intuizione, ansia e forze subconsce. Non tutto è come sembra. Fidati della tua conoscenza interiore per navigare l'incertezza e il mistero."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "幻想、直感、不安、潜在意識の力。すべてが見たままではありません。不確実性と謎をナビゲートするために、あなたの内なる知識を信頼してください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Illusjon, intuisjon, angst og underbevisste krefter. Ikke alt er som det ser ut. Stol på din indre kunnskap for å navigere usikkerhet og mysterium."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Iluzja, intuicja, niepokój i siły podświadome. Nie wszystko jest takie, jak się wydaje. Zaufaj swojej wewnętrznej wiedzy, aby poruszać się w niepewności i tajemnicy."
