    "interpretation.queen_of_cups_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Berufliche Überforderung oder schlechte emotionale Grenzen bei der Arbeit. Koabhängigkeit mit Kollegen. Sich die Probleme anderer aufhalsen. Bedarf an Selbstfürsorge und Grenzen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professional overwhelm or poor emotional boundaries at work. Codependency with colleagues. Taking on others' problems. Need for self-care and limits."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Agobio profesional o malos límites emocionales en el trabajo. Codependencia con los compañeros. Asumir los problemas de los demás. Necesidad de autocuidado y límites."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dépassement professionnel ou mauvaises limites émotionnelles au travail. Codépendance avec les collègues. S'approprier les problèmes des autres. Besoin de soins personnels et de limites."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sovraccarico professionale o scarsi confini emotivi sul lavoro. Codipendenza con i colleghi. Assumersi i problemi degli altri. Necessità di cura di sé e limiti."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "仕事での専門的負担や感情的な境界線の欠如。同僚との共依存。他人の問題を引き受ける。セルフケアと境界線が必要。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profesjonell overveldelse eller dårlige følelsesmessige grenser på jobb. Medavhengighet med kolleger. Ta på seg andres problemer. Behov for egenomsorg og grenser."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przeciążenie zawodowe lub słabe granice emocjonalne w pracy. Współuzależnienie od współpracowników. Branie na siebie problemów innych. Potrzeba samoopieki i granic."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sobrecarga profissional ou limites emocionais ruins no trabalho. Codependência com colegas. Assumir problemas dos outros. Necessidade de autocuidado e limites."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professionell överväldigande eller dåliga känslomässiga gränser på jobbet. Medberoende med kollegor. Ta på sig andras problem. Behov av egenvård och gränser."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Професійне перевантаження або погані емоційні межі на роботі. Співзалежність з колегами. Береться на себе проблеми інших. Потреба в самодогляді та межах."
          }
        }
      }
    },
    "interpretation.queen_of_cups_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mitfühlende professionelle Führung. Ihre emotionale Intelligenz dient der Arbeit gut. Fürsorge und Intuition führen zum Karriereerfolg. Sie schaffen emotional sichere Arbeitsplätze."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Compassionate professional leadership. Your emotional intelligence serves work well. Caring and intuition guide career success. You create emotionally safe workplaces."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Liderazgo profesional compasivo. Tu inteligencia emocional sirve bien al trabajo. El cuidado y la intuición guían el éxito profesional. Creas lugares de trabajo emocionalmente seguros."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Leadership professionnel compatissant. Votre intelligence émotionnelle sert bien votre travail. L'attention et l'intuition guident la réussite professionnelle. Vous créez des environnements de travail émotionnellement sûrs."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Leadership professionale compassionevole. La tua intelligenza emotiva serve bene al lavoro. Cura e intuizione guidano il successo della carriera. Crei luoghi di lavoro emotivamente sicuri."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "思いやりのあるプロフェッショナルなリーダーシップ。あなたの感情的知性は仕事に役立つ。思いやりと直感がキャリアの成功を導く。感情的に安全な職場を作る。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Medfølende profesjonelt lederskap. Din emosjonelle intelligens tjener arbeidet godt. Omsorg og intuisjon styrer karrieresuksess. Du skaper følelsesmessig trygge arbeidsplasser."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Współczujące przywództwo zawodowe. Twoja inteligencja emocjonalna dobrze służy pracy. Troska i intuicja kierują sukcesem zawodowym. Tworzysz bezpieczne emocjonalnie miejsca pracy."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Liderança profissional compassiva. Sua inteligência emocional serve bem ao trabalho. Cuidado e intuição guiam o sucesso na carreira. Você cria locais de trabalho emocionalmente seguros."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Medkännande professionellt ledarskap. Din emotionella intelligens tjänar arbetet väl. Omsorg och intuition styr karriärframgång. Du skapar känslomässigt trygga arbetsplatser."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Співчутливе професійне лідерство. Ваш емоційний інтелект добре служить роботі. Турбота та інтуїція ведуть до кар'єрного успіху. Ви створюєте емоційно безпечні робочі місця."
          }
        }
      }
    },
    "interpretation.queen_of_cups_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Koabhängigkeit oder Märtyrertum mit Geld. Schlechte Grenzen bei Ressourcen. Von den finanziellen Bedürfnissen anderer überwältigt. Schütze dich selbst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial codependency or martyrdom with money. Poor boundaries around resources. Overwhelmed by others' financial needs. Protect yourself."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Codependencia financiera o martirio con el dinero. Malos límites con los recursos. Abrumado por las necesidades financieras de los demás. Protégete a ti mismo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Codépendance financière ou martyre avec l'argent. Mauvaise gestion des limites concernant les ressources. Débordé par les besoins financiers des autres. Protégez-vous."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Codipendenza finanziaria o martirio con il denaro. Scarsi confini riguardo le risorse. Sopraffatto dai bisogni finanziari altrui. Proteggiti."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "金銭的な共依存や金銭における殉教者気質。資源に関する境界線の欠如。他人の経済的ニーズに圧倒される。自分自身を守れ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk medavhengighet eller martyrium med penger. Dårlige grenser rundt ressurser. Overveldet av andres økonomiske behov. Beskytt deg selv."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Współuzależnienie finansowe lub męczeństwo z pieniędzmi. Słabe granice wokół zasobów. Przytłoczony potrzebami finansowymi innych. Chroń siebie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Codependência financeira ou martírio com dinheiro. Limites ruins em relação aos recursos. Sobrecarregado pelas necessidades financeiras dos outros. Proteja-se."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomiskt medberoende eller martyrium med pengar. Dåliga gränser kring resurser. Överväldigad av andras ekonomiska behov. Skydda dig själv."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансова співзалежність або мучеництво з грошима. Погані межі навколо ресурсів. Перевантаження фінансовими потребами інших. Захистіть себе."
          }
        }
      }
    },
