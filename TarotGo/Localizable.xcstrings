          }
        }
      }
    },
    "interpretation.three_of_swords_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzieller Herzschmerz und Geldleid. Verrat oder Verlust im Zusammenhang mit Ressourcen. Die Wahrheit über Finanzen schmerzt. Trauer über Geld ist berechtigt."
          }
        },
        "en" : {
