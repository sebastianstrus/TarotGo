        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Кар'єрна нестабільність або відсутність професійної підтримки. Проблеми з переходом на роботі. Конфлікт в офісі. Святкування відкладено."
          }
        }
      }
    },
    "interpretation.four_of_wands_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Berufliche Feier und Arbeitsharmonie. Karriere-Meilenstein erreicht. Arbeitsplatzstabilität und -unterstützung. Arbeitsumfeld fühlt sich wie zu Hause an."
          }
        },
