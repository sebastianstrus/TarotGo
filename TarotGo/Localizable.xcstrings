          }
        }
      }
    },
    "interpretation.wheel_of_fortune_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Widerstand gegen Veränderungen in Beziehungen oder das Erleben schwieriger Zyklen. Schlechtes Timing oder Pech. Denke daran, dass sich alle Zyklen drehen – auch das wird vorübergehen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resistant to changes in relationships or experiencing difficult cycles. Bad timing or luck. Remember that all cycles turn—this too shall pass."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resistencia a los cambios en las relaciones o experimentar ciclos difíciles. Mal momento o mala suerte. Recuerda que todos los ciclos giran, esto también pasará."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Résistance aux changements dans les relations ou expérience de cycles difficiles. Mauvais timing ou malchance. Rappelez-vous que tous les cycles tournent – cela aussi passera."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resistenza ai cambiamenti nelle relazioni o esperienza di cicli difficili. Tempismo sfortunato o sfortuna. Ricorda che tutti i cicli girano – anche questo passerà."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "人間関係の変化への抵抗や困難な周期の経験。タイミングが悪いか不運。すべての周期は回転することを忘れないでください。これもいつかは過ぎ去ります。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Motstand mot endringer i relasjoner eller oppleve vanskelige sykluser. Dårlig timing eller uflaks. Husk at alle sykluser snur – også dette vil gå over."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opór wobec zmian w związkach lub doświadczanie trudnych cykli. Zły moment lub pech. Pamiętaj, że wszystkie cykle się obracają – to też minie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resistência a mudanças nos relacionamentos ou experiência de ciclos difíceis. Momento ruim ou azar. Lembre-se de que todos os ciclos giram – isso também passará."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Motstånd mot förändringar i relationer eller uppleva svåra cykler. Dålig tajming eller otur. Kom ihåg att alla cykler vänder – detta kommer också att gå över."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Опір змінам у стосунках або переживання важких циклів. Поганий час або невдача. Пам'ятайте, що всі цикли обертаються – це теж мине."
          }
        }
      }
    },
    "interpretation.wheel_of_fortune_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das Schicksal bringt Veränderungen in dein Liebesleben. Glück und glückliche Begegnungen stehen bevor. Vertraue auf die Zyklen – was dir bestimmt ist, wird kommen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Destiny brings changes to your love life. Good fortune and lucky meetings arrive. Trust the cycles—what's meant for you will come."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El destino trae cambios a tu vida amorosa. La buena fortuna y los encuentros afortunados llegan. Confía en los ciclos: lo que está destinado para ti vendrá."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le destin apporte des changements dans votre vie amoureuse. La bonne fortune et les rencontres chanceuses arrivent. Faites confiance aux cycles – ce qui est destiné pour vous viendra."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il destino porta cambiamenti nella tua vita amorosa. Buona fortuna e incontri fortunati arrivano. Fidati dei cicli – ciò che è destinato a te arriverà."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "運命があなたの恋愛に変化をもたらします。幸運と幸運な出会いが訪れます。周期を信頼してください。あなたのために運命づけられているものはやって来ます。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Skjebnen bringer endringer i kjærlighetslivet ditt. Hell og lykke til møter kommer. Stol på syklusene – det som er ment for deg vil komme."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przeznaczenie przynosi zmiany w twoim życiu miłosnym. Szczęście i szczęśliwe spotkania nadchodzą. Ufaj cyklom – to, co jest ci przeznaczone, nadejdzie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O destino traz mudanças para sua vida amorosa. Boa sorte e encontros de sorte chegam. Confie nos ciclos – o que é destinado a você virá."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ödet förändrar ditt kärleksliv. Lycka och lyckliga möten kommer. Lita på cyklerna – det som är menat för dig kommer att komma."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Доля приносить зміни у ваше любовне життя. Удача та щасливі зустрічі приходять. Довіряйте циклам – те, що призначено вам, прийде."
          }
        }
      }
    },
