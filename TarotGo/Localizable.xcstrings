        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inestabilidad en la relación o falta de apoyo amoroso. Desafíos en la transición de la pareja. El conflicto en el hogar afecta el romance. Celebración retrasada."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Instabilité relationnelle ou manque de soutien amoureux. Défis de transition du partenariat. Conflit domestique affecte la romance. Célébration retardée."
