        }
      }
    },
    "interpretation.ten_of_swords_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erholung, Regeneration, Widerstand gegen das Ende oder verzögerte Katastrophe. Du erhebst dich entweder vom Tiefpunkt oder weigerst dich, etwas sterben zu lassen. Hör auf, dich zu wehren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recovery, regeneration, resisting end, or delayed disaster. You're either rising from rock bottom or refusing to let something die. Stop resisting."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recuperación, regeneración, resistencia al final o desastre retrasado. O estás saliendo del fondo o te niegas a dejar que algo muera. Deja de resistirte."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rétablissement, régénération, résistance à la fin ou catastrophe retardée. Soit vous vous relevez d'un creux, soit vous refusez de laisser quelque chose mourir. Arrêtez de résister."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recupero, rigenerazione, resistenza alla fine o disastro ritardato. O ti stai sollevando dal punto più basso o ti rifiuti di lasciar morire qualcosa. Smettila di resistere."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "回復、再生、終焉への抵抗、または遅れた災害。あなたはどん底から立ち上がっているか、何かを死なせることを拒否している。抵抗をやめろ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bedring, regenerasjon, motstand mot slutt eller forsinket katastrofe. Du reiser deg enten fra bunnen eller nekter å la noe dø. Slutt å motstå."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Powrót do zdrowia, regeneracja, opór przed końcem lub opóźniona katastrofa. Albo podnosisz się z dna, albo odmawiasz pozwolenia czemuś umrzeć. Przestań się opierać."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recuperação, regeneração, resistindo ao fim ou desastre adiado. Ou você está se levantando do fundo do poço ou se recusando a deixar algo morrer. Pare de resistir."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Återhämtning, regenerering, motstånd mot slut eller fördröjd katastrof. Du antingen reser dig från botten eller vägrar låta något dö. Sluta motstå."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Одужання, регенерація, опір завершенню або відкладена катастрофа. Ви або піднімаєтеся з дна, або відмовляєтеся дозволити чомусь померти. Перестаньте опиратися."
          }
        }
      }
    },
    "interpretation.ten_of_swords_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tiefpunkt, schmerzhaftes Ende, Verrat und Krise. Schlimmer geht es nicht. Du bist am Ende. Aber hier ist die Wahrheit: Der einzige Weg von hier ist nach oben. Der Morgen kommt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rock bottom, painful ending, betrayal, and crisis. This is as bad as it gets. You're done. But here's the truth: the only way from here is up. Dawn comes."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fondo, final doloroso, traición y crisis. Esto es lo peor que puede pasar. Has terminado. Pero aquí está la verdad: el único camino desde aquí es hacia arriba. Llega el amanecer."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Creux, fin douloureuse, trahison et crise. C'est le pire qui puisse arriver. Vous êtes à bout. Mais voici la vérité : la seule voie à partir d'ici est vers le haut. L'aube arrive."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Punto più basso, fine dolorosa, tradimento e crisi. Questo è il peggio che possa succedere. Sei alla fine. Ma ecco la verità: l'unica via da qui è verso l'alto. L'alba arriva."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "どん底、痛みを伴う終焉、裏切り、危機。これ以上悪くはない。あなたは終わった。しかし真実はここにある：ここからの唯一の道は上昇だ。夜明けが来る。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bunnpunkt, smertefull slutt, svik og krise. Dette er så ille det kan bli. Du er ferdig. Men her er sannheten: den eneste veien herfra er opp. Daggryet kommer."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dno, bolesne zakończenie, zdrada i kryzys. To najgorsze, co może być. Jesteś skończony. Ale oto prawda: jedyna droga stąd prowadzi w górę. Nadchodzi świt."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fundo, término doloroso, traição e crise. Isso é o pior que pode ser. Você está acabado. Mas aqui está a verdade: o único caminho daqui é para cima. O amanhecer chega."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Botten, smärtsamt slut, svek och kris. Detta är så illa det kan bli. Du är färdig. Men här är sanningen: den enda vägen härifrån är upp. Gryningen kommer."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Дно, болісне завершення, зрада та криза. Це найгірше, що може бути. Ви закінчені. Але ось правда: єдиний шлях звідси — вгору. Настає світанок."
          }
        }
      }
    },
