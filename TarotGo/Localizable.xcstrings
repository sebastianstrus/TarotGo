        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mosse di carriera spericolate o impazienza professionale. Energia lavorativa non focalizzata. Decisioni lavorative impulsive. Rallenta e strategizza."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "無謀なキャリアの動きまたは仕事上の焦り。焦点の定まらない仕事のエネルギー。衝動的な仕事の決断。スピードを落として戦略を立てよ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uforsiktige karrierevalg eller profesjonell utålmodighet. Ufokusert arbeidsenergi. Impulsive jobbbeslutninger. Senk farten og strategiser."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lekkomyślne ruchy w karierze lub zawodowa niecierpliwość. Nieskoncentrowana energia w pracy. Impulsywne decyzje zawodowe. Zwolnij i opracuj strategię."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Movimentos de carreira imprudentes ou impaciência profissional. Energia de trabalho sem foco. Decisões de trabalho impulsivas. Diminua a velocidade e elabore estratégias."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vårdslösa karriärrörelser eller professionell otålighet. Ofokuserad arbetsenergi. Impulsiva arbetsbeslut. Sakta ner och strategisera."
