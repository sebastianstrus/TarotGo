        }
      }
    },
    "interpretation.nine_of_swords_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hoffnung keimt auf, Hilfe suchen und Angst lässt nach. Das Schlimmste der Verzweiflung geht vorüber. Du bist nicht allein. Die Erholung beginnt, wenn du um Unterstützung bittest."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hope emerging, reaching out for help, and anxiety subsiding. The worst of the despair is passing. You're not alone. Recovery begins when you ask for support."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esperanza emergente, búsqueda de ayuda y disminución de la ansiedad. Lo peor de la desesperación está pasando. No estás solo. La recuperación comienza cuando pides apoyo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Espoir émergeant, recherche d'aide et anxiété qui s'atténue. Le pire du désespoir s'en va. Vous n'êtes pas seul. La guérison commence quand vous demandez du soutien."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Speranza emergente, ricerca di aiuto e ansia che si attenua. Il peggio della disperazione sta passando. Non sei solo. La guarigione inizia quando chiedi supporto."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "希望の芽生え、助けを求めること、不安の軽減。絶望の最悪の部分は過ぎ去っている。あなたは一人ではない。サポートを求めたときに回復が始まる。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Håp dukker opp, søker hjelp og angst avtar. Det verste av fortvilelsen går over. Du er ikke alene. Bedring begynner når du ber om støtte."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nadzieja pojawia się, szukanie pomocy i ustępowanie lęku. Najgorsza rozpacz mija. Nie jesteś sam. Powrót do zdrowia zaczyna się, gdy prosisz o wsparcie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esperança surgindo, buscando ajuda e ansiedade diminuindo. O pior do desespero está passando. Você não está sozinho. A recuperação começa quando você pede apoio."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hopp uppstår, söker hjälp och ångest avtar. Det värsta av förtvivlan går över. Du är inte ensam. Återhämtning börjar när du ber om stöd."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Надія з'являється, звернення по допомогу та тривога вщухає. Найгірша частина розпачу минає. Ви не самотні. Одужання починається, коли ви просите підтримки."
          }
        }
      }
    },
    "interpretation.nine_of_swords_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Angst, Sorge, Albträume und Furcht. Dein Geist ist gerade dein schlimmster Feind. Gedanken drehen sich im Kreis und halten dich nachts wach. Dies ist hauptsächlich mental – suche dir Unterstützung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anxiety, worry, nightmares, and fear. Your mind is your worst enemy right now. Thoughts spiral and keep you up at night. This is primarily mental—reach out for support."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ansiedad, preocupación, pesadillas y miedo. Tu mente es tu peor enemigo en este momento. Los pensamientos se vuelven espirales y te mantienen despierto por la noche. Esto es principalmente mental: busca apoyo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anxiété, inquiétude, cauchemars et peur. Votre esprit est votre pire ennemi en ce moment. Les pensées s'enchaînent et vous tiennent éveillé la nuit. C'est principalement mental – cherchez du soutien."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ansia, preoccupazione, incubi e paura. La tua mente è il tuo peggior nemico in questo momento. I pensieri si avvitano e ti tengono sveglio la notte. Questo è principalmente mentale: cerca supporto."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "不安、心配、悪夢、恐怖。あなたの心は今、あなたの最大の敵だ。思考が渦巻き、夜も眠れなくなる。これは主に精神的なものだ。サポートを求めて。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Angst, bekymring, mareritt og frykt. Sinnet ditt er din verste fiende akkurat nå. Tanker spinner og holder deg våken om natten. Dette er primært mentalt – søk støtte."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lęk, zmartwienie, koszmary i strach. Twój umysł jest teraz twoim najgorszym wrogiem. Myśli krążą i nie dają ci spać w nocy. To przede wszystkim mentalne – szukaj wsparcia."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ansiedade, preocupação, pesadelos e medo. Sua mente é sua pior inimiga agora. Pensamentos em espiral te mantêm acordado à noite. Isso é principalmente mental – busque apoio."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ångest, oro, mardrömmar och rädsla. Ditt sinne är din värsta fiende just nu. Tankar snurrar och håller dig vaken på natten. Detta är primärt mentalt – sök stöd."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Тривога, занепокоєння, кошмари та страх. Ваш розум зараз ваш найгірший ворог. Думки крутяться і не дають спати вночі. Це переважно психологічне – зверніться по підтримку."
          }
        }
      }
    },
    "interpretation.nine_of_swords_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gesundheitsangst lässt nach und Wohlfühl-Hoffnung keimt auf. Medizinische Unterstützung suchen. Verzweiflung über den Körper lässt nach. Erholung beginnt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Health anxiety subsiding and wellness hope emerging. Reaching out for medical support. Despair about body lifting. Recovery begins."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La ansiedad por la salud disminuye y la esperanza de bienestar surge. Buscar apoyo médico. La desesperación por el cuerpo se disipa. La recuperación comienza."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'anxiété de santé s'atténue et l'espoir de bien-être émerge. Chercher un soutien médical. Le désespoir lié au corps s'atténue. La guérison commence."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'ansia per la salute si attenua e la speranza di benessere emerge. Cercare supporto medico. La disperazione per il corpo si attenua. La guarigione inizia."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "健康不安が和らぎ、ウェルネスへの希望が芽生える。医療サポートを求める。体への絶望が軽くなる。回復が始まる。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Helseangst avtar og velværehåp dukker opp. Søke medisinsk støtte. Fortvilelse om kroppen letter. Bedring begynner."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lęk o zdrowie ustępuje, a nadzieja na dobre samopoczucie pojawia się. Szukanie wsparcia medycznego. Rozpacz związana z ciałem ustępuje. Powrót do zdrowia zaczyna się."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ansiedade de saúde diminuindo e esperança de bem-estar surgindo. Buscar apoio médico. Desespero sobre o corpo diminuindo. A recuperação começa."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hälsoångest avtar och välmåendehopp uppstår. Söka medicinskt stöd. Förtvivlan om kroppen lättar. Återhämtning börjar."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Тривога за здоров'я вщухає, з'являється надія на благополуччя. Звернення по медичну підтримку. Розпач щодо тіла зникає. Одужання починається."
          }
        }
      }
    },
    "interpretation.nine_of_swords_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gesundheitsangst und Wohlfühl-Sorgen. Albträume über den Körper. Überwältigende Angst über den körperlichen Zustand. Dein Geist quält dich. Suche dir Unterstützung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Health anxiety and wellness worry. Nightmares about body. Overwhelming fear about physical state. Your mind torments you. Reach out for support."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ansiedad por la salud y preocupación por el bienestar. Pesadillas sobre el cuerpo. Miedo abrumador por el estado físico. Tu mente te atormenta. Busca apoyo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anxiété de santé et inquiétude pour le bien-être. Cauchemars sur le corps. Peur accablante de l'état physique. Votre esprit vous tourmente. Cherchez du soutien."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ansia per la salute e preoccupazione per il benessere. Incubi sul corpo. Paura travolgente dello stato fisico. La tua mente ti tormenta. Cerca supporto."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "健康不安とウェルネスの心配。体についての悪夢。身体状態への圧倒的な恐怖。あなたの心があなたを苦しめる。サポートを求めて。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Helseangst og velværebekymring. Mareritt om kroppen. Overveldende frykt for fysisk tilstand. Sinnet ditt plager deg. Søk støtte."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lęk o zdrowie i zmartwienie o dobre samopoczucie. Koszmary o ciele. Przytłaczający strach o stan fizyczny. Twój umysł cię dręczy. Szukaj wsparcia."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ansiedade de saúde e preocupação com bem-estar. Pesadelos sobre o corpo. Medo esmagador sobre o estado físico. Sua mente te atormenta. Busque apoio."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hälsoångest och välmåendeoro. Mardrömmar om kroppen. Överväldigande rädsla för fysiskt tillstånd. Ditt sinne plågar dig. Sök stöd."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Тривога за здоров'я та занепокоєння благополуччям. Кошмари про тіло. Переважний страх перед фізичним станом. Ваш розум мучить вас. Зверніться по підтримку."
          }
        }
      }
    },
    "interpretation.nine_of_swords_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Romantische Angst lässt nach und Beziehungshoffnung keimt auf. Unterstützung in der Liebe suchen. Verzweiflung über die Partnerschaft lässt nach. Erholung beginnt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Romantic anxiety subsiding and relationship hope emerging. Reaching out for love support. Despair about partnership lifting. Recovery begins."
