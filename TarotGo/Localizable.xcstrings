        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "職業的な祝賀と仕事の調和。キャリアのマイルストーンに到達。仕事の安定とサポート。職場が家のように感じられる。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profesjonell feiring og arbeidsharmoni. Karrieremilepæl nådd. Jobbstabilitet og støtte. Arbeidsplassen føles som hjemme."
