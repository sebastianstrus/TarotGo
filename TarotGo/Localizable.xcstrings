    "interpretation.death_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Widerstand gegen notwendige Karriereenden hält dich fest. Du weißt, dass sich etwas ändern muss, aber du klammerst dich daran. Lass die alte berufliche Identität sterben."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resisting necessary career endings keeps you stuck. You know something must change but you're holding on. Let the old professional identity die."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La resistencia a los finales profesionales necesarios te mantiene atascado. Sabes que algo debe cambiar, pero te aferras. Deja que muera la vieja identidad profesional."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La résistance aux fins de carrière nécessaires vous maintient bloqué. Vous savez que quelque chose doit changer, mais vous vous y accrochez. Laissez mourir l'ancienne identité professionnelle."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La resistenza ai necessari finali di carriera ti tiene bloccato. Sai che qualcosa deve cambiare, ma ti aggrappi. Lascia morire la vecchia identità professionale."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "必要なキャリアの終焉への抵抗があなたを閉じ込めています。何かを変えなければならないと分かっているのに、あなたはしがみついています。古い職業的アイデンティティを死なせてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Motstand mot nødvendige karriereslutter holder deg fast. Du vet at noe må endres, men du holder fast. La den gamle profesjonelle identiteten dø."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opór wobec koniecznych zakończeń kariery trzyma cię w miejscu. Wiesz, że coś musi się zmienić, ale się trzymasz. Pozwól umrzeć starej tożsamości zawodowej."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A resistência aos fins de carreira necessários mantém você preso. Você sabe que algo deve mudar, mas está se agarrando. Deixe a velha identidade profissional morrer."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Motståndet mot nödvändiga karriärslut håller dig fast. Du vet att något måste förändras, men du håller fast. Låt den gamla professionella identiteten dö."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Опір необхідним кар'єрним закінченням тримає вас у пастці. Ви знаєте, що щось має змінитися, але ви тримаєтеся. Дозвольте старій професійній ідентичності померти."
          }
        }
      }
    },
    "interpretation.death_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine große berufliche Veränderung findet statt. Ein Job, eine Rolle oder ein ganzer Karriereweg endet, um Platz für etwas Neues zu schaffen. Nimm diesen tiefgreifenden Wandel an."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Major career transformation is occurring. A job, role, or entire career path is ending to make way for something new. Embrace this profound change."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una gran transformación profesional está ocurriendo. Un trabajo, rol o trayectoria profesional completa está terminando para dar paso a algo nuevo. Acepta este cambio profundo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une transformation majeure de carrière se produit. Un emploi, un rôle ou une trajectoire de carrière entière se termine pour laisser place à quelque chose de nouveau. Accueillez ce changement profond."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una grande trasformazione professionale sta avvenendo. Un lavoro, un ruolo o un intero percorso di carriera sta finendo per fare spazio a qualcosa di nuovo. Accogli questo cambiamento profondo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "大きなキャリアの変革が起こっています。仕事、役割、またはキャリアパス全体が終わり、新しいものに道を譲っています。この深遠な変化を受け入れてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En stor karriereendring skjer. En jobb, rolle eller hel karrierevei avsluttes for å gi plass til noe nytt. Omfavn denne dype endringen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wielka transformacja zawodowa ma miejsce. Praca, rola lub cała ścieżka kariery kończy się, aby zrobić miejsce na coś nowego. Przyjmij tę głęboką zmianę."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uma grande transformação na carreira está ocorrendo. Um emprego, função ou caminho de carreira inteiro está terminando para dar lugar a algo novo. Abrace essa mudança profunda."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En stor karriärförvandling sker. Ett jobb, roll eller hel karriärväg tar slut för att ge plats åt något nytt. Omfamna denna djupgående förändring."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Відбувається велика кар'єрна трансформація. Робота, роль або цілий кар'єрний шлях закінчується, щоб звільнити місце для чогось нового. Прийміть цю глибоку зміну."
          }
        }
      }
    },
    "interpretation.death_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du klammerst dich an gescheiterte Finanzstrategien oder -situationen. Der Widerstand gegen die notwendige finanzielle Transformation verlängert nur das Leiden. Lass los."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clinging to failing financial strategies or situations. Resisting necessary financial transformation only prolongs suffering. Let go."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aferrarse a estrategias o situaciones financieras fallidas. Resistir la transformación financiera necesaria solo prolonga el sufrimiento. Déjalo ir."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "S'accrocher à des stratégies ou situations financières défaillantes. Résister à la transformation financière nécessaire ne fait que prolonger la souffrance. Lâchez prise."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aggrapparsi a strategie o situazioni finanziarie fallimentari. Resistere alla necessaria trasformazione finanziaria non fa che prolungare la sofferenza. Lascia andare."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "失敗した財務戦略や状況にしがみつく。必要な財務変革に抵抗することは、苦しみを長引かせるだけです。手放してください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Å klamre seg til mislykkede økonomiske strategier eller situasjoner. Å motstå nødvendig økonomisk transformasjon forlenger bare lidelsen. Gi slipp."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trzymanie się nieudanych strategii lub sytuacji finansowych. Opieranie się koniecznej transformacji finansowej tylko przedłuża cierpienie. Puść."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apegar-se a estratégias ou situações financeiras fracassadas. Resistir à transformação financeira necessária só prolonga o sofrimento. Deixe ir."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Att hålla fast vid misslyckade ekonomiska strategier eller situationer. Att motstå nödvändig ekonomisk förvandling förlänger bara lidandet. Släpp taget."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Чіплятися за невдалі фінансові стратегії чи ситуації. Опір необхідній фінансовій трансформації лише продовжує страждання. Відпустіть."
          }
        }
      }
    },
    "interpretation.death_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Transformation durch Enden. Alte Einkommensquellen oder Geldmuster müssen sterben, damit neuer Wohlstand entstehen kann. Eine tiefgreifende Veränderung in deiner Beziehung zu Ressourcen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial transformation through endings. Old income sources or money patterns must die for new abundance to emerge. Profound change in your relationship with resources."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Transformación financiera a través de finales. Las viejas fuentes de ingresos o patrones de dinero deben morir para que surja nueva abundancia. Un cambio profundo en tu relación con los recursos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Transformation financière par les fins. Les anciennes sources de revenus ou modèles monétaires doivent mourir pour qu'une nouvelle abondance émerge. Un changement profond dans votre relation avec les ressources."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trasformazione finanziaria attraverso le fini. Le vecchie fonti di reddito o modelli di denaro devono morire affinché emergano nuova abbondanza. Un cambiamento profondo nella tua relazione con le risorse."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "終焉を通じた財政的変容。新しい豊かさが現れるためには、古い収入源やお金のパターンは死ななければなりません。リソースとの関係における深い変化。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk transformasjon gjennom avslutninger. Gamle inntektskilder eller pengemønstre må dø for at ny overflod skal dukke opp. En dyp endring i forholdet ditt til ressurser."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Transformacja finansowa poprzez zakończenia. Stare źródła dochodu lub wzorce pieniężne muszą umrzeć, aby pojawiła się nowa obfitość. Głęboka zmiana w twojej relacji z zasobami."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Transformação financeira através de fins. Velhas fontes de renda ou padrões de dinheiro devem morrer para que uma nova abundância surja. Uma mudança profunda em seu relacionamento com os recursos."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomisk förvandling genom slut. Gamla inkomstkällor eller pengamönster måste dö för att nytt överflöd ska kunna uppstå. En djupgående förändring i din relation till resurser."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансова трансформація через завершення. Старі джерела доходу або грошові моделі мають померти, щоб з'явилося нове достаток. Глибока зміна ваших стосунків з ресурсами."
          }
        }
      }
    },
    "interpretation.death_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du klammerst dich an das, was enden muss. Die Angst vor Veränderung hält dich in einer stagnierenden Situation gefangen. Die umgekehrte Todeskarte handelt vom Widerstand gegen die natürlichen Zyklen des Lebens. Lass los und vertraue dem Prozess."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You're clinging to what needs to end. Fear of change is keeping you stuck in a stagnant situation. The death card reversed is about resisting the natural cycles of life. Let go and trust the process."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Te aferras a lo que necesita terminar. El miedo al cambio te mantiene atrapado en una situación estancada. La carta de la Muerte invertida trata sobre resistirse a los ciclos naturales de la vida. Déjalo ir y confía en el proceso."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous vous accrochez à ce qui doit se terminer. La peur du changement vous maintient bloqué dans une situation stagnante. La carte de la Mort inversée parle de la résistance aux cycles naturels de la vie. Lâchez prise et faites confiance au processus."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ti aggrappi a ciò che deve finire. La paura del cambiamento ti tiene bloccato in una situazione stagnante. La carta della Morte al contrario parla di resistere ai cicli naturali della vita. Lascia andare e fidati del processo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたは終わらなければならないものにしがみついています。変化への恐怖があなたを停滞した状況に閉じ込めています。逆位置の死神は、人生の自然なサイクルに抵抗することについてです。手放し、プロセスを信頼してください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du klamrer deg til det som må ta slutt. Frykt for endring holder deg fast i en stillestående situasjon. Døden reversert handler om å motstå livets naturlige sykluser. Gi slipp og stol på prosessen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trzymasz się tego, co musi się skończyć. Strach przed zmianą trzyma cię w stagnacji. Odwrócona karta Śmierci mówi o opieraniu się naturalnym cyklom życia. Puść i zaufaj procesowi."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você está se agarrando ao que precisa terminar. O medo da mudança mantém você preso em uma situação estagnada. A carta da Morte invertida é sobre resistir aos ciclos naturais da vida. Deixe ir e confie no processo."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du håller fast vid det som måste ta slut. Rädsla för förändring håller dig fast i en stillastående situation. Döden omvänd handlar om att motstå livets naturliga cykler. Släpp taget och lita på processen."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ви чіпляєтеся за те, що має закінчитися. Страх змін тримає вас у пастці в стагнації. Перевернута карта Смерті – про опір природним циклам життя. Відпустіть і довіртеся процесу."
          }
        }
      }
    },
    "interpretation.death_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ein Ende ist da, und mit ihm eine mächtige Transformation. Widerstehe diesem Wandel nicht – er macht Platz für deine Wiedergeburt. Was muss sterben, damit du wirklich leben kannst? Begrüße den Übergang."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "An ending is here, and with it, a powerful transformation. Don't resist this change—it's making room for your rebirth. What must die so that you can truly live? Embrace the transition."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un final está aquí, y con él, una poderosa transformación. No te resistas a este cambio: está haciendo espacio para tu renacimiento. ¿Qué debe morir para que puedas vivir verdaderamente? Abraza la transición."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une fin est là, et avec elle, une puissante transformation. Ne résistez pas à ce changement – il fait de la place pour votre renaissance. Qu'est-ce qui doit mourir pour que vous puissiez vraiment vivre ? Accueillez la transition."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una fine è qui, e con essa, una potente trasformazione. Non resistere a questo cambiamento – sta facendo spazio per la tua rinascita. Cosa deve morire affinché tu possa veramente vivere? Abbraccia la transizione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "終わりがここにあり、それとともに強力な変容が。この変化に抵抗しないでください – それはあなたの再生のためのスペースを作っています。あなたが本当に生きるために何が死ななければなりませんか？移行を受け入れてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En slutt er her, og med den en kraftig transformasjon. Ikke motstå denne endringen – den gjør plass for din gjenfødsel. Hva må dø slik at du virkelig kan leve? Omfavn overgangen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Koniec jest tutaj, a wraz z nim potężna transformacja. Nie opieraj się tej zmianie – robi miejsce na twoje odrodzenie. Co musi umrzeć, abyś mógł naprawdę żyć? Przyjmij przejście."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um fim está aqui, e com ele, uma poderosa transformação. Não resista a essa mudança – ela está abrindo espaço para o seu renascimento. O que deve morrer para que você possa verdadeiramente viver? Abrace a transição."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ett slut är här, och med det en kraftfull förvandling. Gör inte motstånd mot denna förändring – den gör plats för din återfödelse. Vad måste dö för att du verkligen ska kunna leva? Omfamna övergången."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Кінець тут, і з ним потужна трансформація. Не опирайтеся цій зміні – вона звільняє місце для вашого відродження. Що має померти, щоб ви могли справді жити? Прийміть перехід."
          }
        }
      }
    },
    "interpretation.death_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Widerstand gegen notwendige gesundheitliche Veränderungen hält dich im Verfall. Dein Körper verlangt nach Veränderung. Hör auf, gegen den unvermeidlichen Wandel anzukämpfen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resisting necessary health changes keeps you in decay. Your body demands transformation. Stop fighting the inevitable change."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La resistencia a los cambios de salud necesarios te mantiene en decadencia. Tu cuerpo exige transformación. Deja de luchar contra el cambio inevitable."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La résistance aux changements de santé nécessaires vous maintient en déclin. Votre corps exige une transformation. Cessez de lutter contre le changement inévitable."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La resistenza ai necessari cambiamenti di salute ti tiene in declino. Il tuo corpo chiede trasformazione. Smetti di lottare contro il cambiamento inevitabile."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "必要な健康変化への抵抗があなたを衰退させます。あなたの体は変容を要求しています。避けられない変化と戦うのをやめてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Motstand mot nødvendige helseendringer holder deg i forfall. Kroppen din krever transformasjon. Slutt å kjempe mot den uunngåelige endringen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opór wobec koniecznych zmian zdrowotnych trzyma cię w upadku. Twoje ciało domaga się transformacji. Przestań walczyć z nieuniknioną zmianą."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A resistência às mudanças necessárias na saúde mantém você em declínio. Seu corpo exige transformação. Pare de lutar contra a mudança inevitável."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Motstånd mot nödvändiga hälsoförändringar håller dig i förfall. Din kropp kräver förvandling. Sluta kämpa mot den oundvikliga förändringen."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Опір необхідним змінам у здоров'ї тримає вас у занепаді. Ваше тіло вимагає трансформації. Перестаньте боротися з неминучими змінами."
          }
        }
      }
    },
    "interpretation.death_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Große gesundheitliche Veränderung. Alte Muster sterben, um Platz für ein lebendiges neues Wohlbefinden zu schaffen. Nimm diesen tiefgreifenden Wandel in deinem körperlichen Sein an."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Major health transformation. Old patterns die to make way for vibrant new wellness. Embrace this profound shift in your physical being."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gran transformación de la salud. Los viejos patrones mueren para dar paso a un nuevo bienestar vibrante. Acepta este cambio profundo en tu ser físico."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Grande transformation de la santé. Les vieux schémas meurent pour laisser place à un nouveau bien-être dynamique. Accueillez ce changement profond dans votre être physique."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Grande trasformazione della salute. I vecchi schemi muoiono per fare spazio a un nuovo vibrante benessere. Accogli questo profondo cambiamento nel tuo essere fisico."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "大きな健康変革。古いパターンは死に、活気に満ちた新しい健康に道を譲ります。あなたの身体的存在におけるこの深遠な変化を受け入れてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stor helsetransformasjon. Gamle mønstre dør for å gi plass til ny, levende velvære. Omfavn denne dype endringen i ditt fysiske vesen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wielka transformacja zdrowotna. Stare wzorce umierają, aby zrobić miejsce dla nowego, żywego dobrego samopoczucia. Przyjmij tę głęboką zmianę w swoim fizycznym bycie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Grande transformação na saúde. Padrões antigos morrem para dar lugar a um novo bem-estar vibrante. Abrace essa mudança profunda em seu ser físico."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stor hälsoförvandling. Gamla mönster dör för att ge plats åt ny, levande välbefinnande. Omfamna denna djupgående förändring i din fysiska varelse."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Велика трансформація здоров'я. Старі патерни вмирають, щоб звільнити місце для нового яскравого благополуччя. Прийміть цю глибоку зміну у вашому фізичному єстві."
          }
        }
      }
    },
    "interpretation.death_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du wehrst dich gegen notwendige Veränderungen in deinen Beziehungen. An etwas festzuhalten, das bereits tot ist, verlängert nur den Schmerz. Lass los. Die Transformation versucht stattzufinden, aber du kämpfst dagegen an."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You're resisting necessary change in your relationships. Holding on to what's already dead will only prolong the pain. Let go. Transformation is trying to happen, but you're fighting it."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Te resistes al cambio necesario en tus relaciones. Aferrarse a lo que ya está muerto solo prolongará el dolor. Déjalo ir. La transformación está tratando de suceder, pero la estás combatiendo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous résistez aux changements nécessaires dans vos relations. S'accrocher à ce qui est déjà mort ne fera que prolonger la douleur. Lâchez prise. La transformation essaie de se produire, mais vous lui résistez."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resisti ai cambiamenti necessari nelle tue relazioni. Aderire a ciò che è già morto non farà che prolungare il dolore. Lascia andare. La trasformazione sta cercando di accadere, ma la stai combattendo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたは人間関係における必要な変化に抵抗しています。すでに死んでいるものにしがみつくことは、痛みを長引かせるだけです。手放してください。変容が起ころうとしていますが、あなたはそれと戦っています。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du motstår nødvendige endringer i relasjonene dine. Å holde fast i det som allerede er dødt vil bare forlenge smerten. Gi slipp. Transformasjon prøver å skje, men du kjemper imot."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opierasz się koniecznym zmianom w swoich związkach. Trzymanie się tego, co już martwe, tylko przedłuży ból. Puść. Transformacja próbuje nastąpić, ale ty z nią walczysz."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você resiste à mudança necessária em seus relacionamentos. Agarrar-se ao que já está morto só prolongará a dor. Deixe ir. A transformação está tentando acontecer, mas você está lutando contra ela."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du motstår nödvändiga förändringar i dina relationer. Att hålla fast vid det som redan är dött kommer bara att förlänga smärtan. Släpp taget. Förvandlingen försöker ske, men du kämpar emot."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ви чините опір необхідним змінам у ваших стосунках. Триматися за те, що вже мертве, лише продовжить біль. Відпустіть. Трансформація намагається відбутися, але ви боретеся з нею."
          }
        }
      }
    },
    "interpretation.death_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine tiefgreifende Transformation findet in deinem Liebesleben statt. Dies könnte das Ende einer Beziehung oder den Tod alter Muster innerhalb einer Beziehung bedeuten. Trauere um das, was endet, aber wisse, dass etwas Authentischeres geboren wird."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A profound transformation is occurring in your love life. This could mean the end of a relationship, or the death of old patterns within one. Grieve what's ending, but know that something more authentic is being born."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una transformación profunda está ocurriendo en tu vida amorosa. Esto podría significar el fin de una relación, o la muerte de viejos patrones dentro de una. Lamenta lo que termina, pero sabe que algo más auténtico está naciendo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une transformation profonde se produit dans votre vie amoureuse. Cela pourrait signifier la fin d'une relation, ou la mort de vieux schémas au sein d'une relation. Pleurez ce qui se termine, mais sachez que quelque chose de plus authentique est en train de naître."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una profonda trasformazione sta avvenendo nella tua vita amorosa. Questo potrebbe significare la fine di una relazione, o la morte di vecchi schemi all'interno di una relazione. Piangi ciò che finisce, ma sappi che qualcosa di più autentico sta nascendo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたの恋愛において深い変容が起こっています。これは関係の終わり、または関係内の古いパターンの死を意味するかもしれません。終わるものを悲しんでください。しかし、より本物の何かが生まれていることを知ってください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En dyp transformasjon skjer i kjærlighetslivet ditt. Dette kan bety slutten på et forhold, eller døden til gamle mønstre i et forhold. Sørg over det som slutter, men vit at noe mer autentisk blir født."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Głęboka transformacja zachodzi w twoim życiu miłosnym. Może to oznaczać koniec związku lub śmierć starych wzorców w związku. Opłakuj to, co się kończy, ale wiedz, że rodzi się coś bardziej autentycznego."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uma transformação profunda está ocorrendo em sua vida amorosa. Isso pode significar o fim de um relacionamento, ou a morte de velhos padrões dentro de um relacionamento. Lamente o que está terminando, mas saiba que algo mais autêntico está nascendo."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En djupgående förvandling sker i ditt kärleksliv. Detta kan innebära slutet på en relation, eller döden av gamla mönster inom en relation. Sörj det som slutar, men vet att något mer autentiskt föds."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Глибока трансформація відбувається у вашому любовному житті. Це може означати кінець стосунків або смерть старих патернів у стосунках. Оплакуйте те, що закінчується, але знайте, що народжується щось більш автентичне."
          }
        }
      }
    },
    "interpretation.eight_of_cups_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vermeidung des notwendigen Karrierewechsels aus Angst. In unerfüllter Arbeit bleiben, weil das Verlassen beängstigend erscheint. Vor Möglichkeiten für eine tiefere berufliche Bedeutung davonlaufen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avoiding necessary career change due to fear. Staying in unfulfilling work because leaving feels scary. Running from opportunities for deeper professional meaning."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Evitar el cambio de carrera necesario debido al miedo. Permanecer en un trabajo insatisfactorio porque irse da miedo. Huir de oportunidades para un significado profesional más profundo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Éviter un changement de carrière nécessaire par peur. Rester dans un travail insatisfaisant parce que partir fait peur. Fuir les opportunités pour un sens professionnel plus profond."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Evitare il necessario cambiamento di carriera per paura. Rimanere in un lavoro insoddisfacente perché lasciare fa paura. Fuggire dalle opportunità per un significato professionale più profondo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "恐れのために必要なキャリアチェンジを避ける。去るのが怖いからといって、やりがいのない仕事に留まる。より深い仕事上の意味を得る機会から逃げる。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unngår nødvendig karriereendring på grunn av frykt. Bli i et utilfredsstillende arbeid fordi det er skummelt å forlate. Rømmer fra muligheter for dypere profesjonell mening."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unikanie koniecznej zmiany kariery z powodu strachu. Pozostawanie w niespełniającej pracy, ponieważ odejście jest przerażające. Ucieczka od możliwości głębszego sensu zawodowego."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Evitar a mudança de carreira necessária devido ao medo. Permanecer em um trabalho insatisfatório porque sair parece assustador. Fugindo de oportunidades para um significado profissional mais profundo."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Undviker nödvändig karriärförändring på grund av rädsla. Stanna kvar i ett otillfredsställande arbete eftersom det känns läskigt att lämna. Flyr från möjligheter till djupare professionell mening."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Уникнення необхідної зміни кар'єри через страх. Залишатися на невтішній роботі, тому що йти страшно. Втеча від можливостей для глибшого професійного сенсу."
          }
        }
      }
    },
    "interpretation.eight_of_cups_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die berufliche Sicherheit verlassen, um eine sinnvolle Arbeit zu finden. Dein Job erfüllt dich nicht mehr. Zeit, einen tieferen Sinn zu suchen, auch wenn das bedeutet, den Komfort aufzugeben."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Leaving professional security to find meaningful work. Your job doesn't fulfill you anymore. Time to seek deeper purpose even if it means walking away from comfort."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dejar la seguridad profesional para encontrar un trabajo significativo. Tu trabajo ya no te llena. Es hora de buscar un propósito más profundo, incluso si eso significa alejarse de la comodidad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quitter la sécurité professionnelle pour trouver un travail significatif. Votre travail ne vous épanouit plus. Il est temps de chercher un but plus profond, même si cela signifie s'éloigner du confort."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lasciare la sicurezza professionale per trovare un lavoro significativo. Il tuo lavoro non ti soddisfa più. È ora di cercare uno scopo più profondo anche se significa allontanarsi dal comfort."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "プロとしての安定を離れ、有意義な仕事を見つける。あなたの仕事はもうあなたを満たしていません。たとえそれが快適さから離れることを意味しても、より深い目的を追求する時です。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Å forlate profesjonell sikkerhet for å finne meningsfullt arbeid. Jobben din tilfredsstiller deg ikke lenger. Tid for å søke dypere mening selv om det betyr å gå bort fra komfort."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odejście od bezpieczeństwa zawodowego, aby znaleźć satysfakcjonującą pracę. Twoja praca już cię nie spełnia. Czas szukać głębszego celu, nawet jeśli oznacza to odejście od komfortu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deixar a segurança profissional para encontrar um trabalho significativo. Seu trabalho não o satisfaz mais. Hora de buscar um propósito mais profundo, mesmo que isso signifique se afastar do conforto."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Att lämna professionell trygghet för att hitta meningsfullt arbete. Ditt jobb uppfyller dig inte längre. Dags att söka djupare syfte även om det innebär att gå ifrån komfort."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Залишення професійної безпеки для пошуку значущої роботи. Ваша робота більше не приносить вам задоволення. Час шукати глибшу мету, навіть якщо це означає відмову від комфорту."
          }
        }
      }
    },
    "interpretation.eight_of_cups_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Angst davor, die finanzielle Sicherheit zu verlassen, auch wenn sie kein Glück bringt. Vermeidung notwendiger finanzieller Veränderungen. In goldenen Handschellen gefangen sein."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fear of leaving financial security even when it doesn't bring happiness. Avoiding necessary financial changes. Staying in golden handcuffs."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Miedo a dejar la seguridad financiera incluso cuando no trae felicidad. Evitar los cambios financieros necesarios. Permanecer en esposas de oro."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Peur de quitter la sécurité financière même lorsqu'elle n'apporte pas le bonheur. Éviter les changements financiers nécessaires. Rester dans des menottes dorées."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Paura di lasciare la sicurezza finanziaria anche quando non porta felicità. Evitare i necessari cambiamenti finanziari. Rimanere in manette d'oro."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "たとえ幸福をもたらさなくても、経済的安全を離れることへの恐れ。必要な経済的変化を避ける。黄金の手錠に留まる。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Frykt for å forlate økonomisk sikkerhet selv når det ikke bringer lykke. Unngå nødvendige økonomiske endringer. Å bli i gyldne håndjern."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Strach przed opuszczeniem bezpieczeństwa finansowego, nawet gdy nie przynosi ono szczęścia. Unikanie koniecznych zmian finansowych. Pozostawanie w złotych kajdankach."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Medo de deixar a segurança financeira, mesmo quando ela não traz felicidade. Evitar mudanças financeiras necessárias. Permanecer em algemas douradas."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rädsla för att lämna ekonomisk trygghet även när det inte ger lycka. Undvika nödvändiga ekonomiska förändringar. Att stanna i gyllene handbojor."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Страх залишити фінансову безпеку, навіть коли вона не приносить щастя. Уникнення необхідних фінансових змін. Залишатися в золотих кайданах."
          }
        }
      }
    },
    "interpretation.eight_of_cups_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sich von der finanziellen Sicherheit abwenden, um dem nachzugehen, was wirklich zählt. Geld ist nicht alles. Ein tieferes Glück zu suchen, kann einen vorübergehenden materiellen Verzicht bedeuten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Walking away from financial security to pursue what truly matters. Money isn't everything. Seeking deeper fulfillment may mean temporary material sacrifice."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alejarse de la seguridad financiera para perseguir lo que realmente importa. El dinero no lo es todo. Buscar una realización más profunda puede significar un sacrificio material temporal."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "S'éloigner de la sécurité financière pour poursuivre ce qui compte vraiment. L'argent n'est pas tout. Rechercher un épanouissement plus profond peut signifier un sacrifice matériel temporaire."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Allontanarsi dalla sicurezza finanziaria per perseguire ciò che conta veramente. Il denaro non è tutto. Cercare una realizzazione più profonda può significare un temporaneo sacrificio materiale."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的安全から離れ、本当に重要なことを追求する。お金がすべてではありません。より深い充実感を求めることは、一時的な物質的な犠牲を意味するかもしれません。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Å gå bort fra økonomisk sikkerhet for å forfølge det som virkelig betyr noe. Penger er ikke alt. Å søke dypere oppfyllelse kan bety midlertidig materiell oppofrelse."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odejście od bezpieczeństwa finansowego, aby realizować to, co naprawdę ważne. Pieniądze to nie wszystko. Poszukiwanie głębszego spełnienia może oznaczać tymczasową ofiarę materialną."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Afastar-se da segurança financeira para buscar o que realmente importa. Dinheiro não é tudo. Buscar realização mais profunda pode significar sacrifício material temporário."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Att gå bort från ekonomisk trygghet för att fullfölja det som verkligen betyder något. Pengar är inte allt. Att söka djupare tillfredsställelse kan innebära tillfälligt materiellt uppoffring."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Відхід від фінансової безпеки, щоб займатися тим, що дійсно важливо. Гроші – це не все. Пошук глибшого задоволення може означати тимчасову матеріальну жертву."
          }
        }
      }
    },
    "interpretation.eight_of_cups_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vermeidung des notwendigen Abschieds oder Verharren in schlechten Situationen. Die Angst vor Veränderung hält dich fest. Vielleicht rennst du auch vor allem davon, anstatt zu erkennen, was sich wirklich ändern muss."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avoiding necessary departure or staying in bad situations. Fear of change keeps you stuck. You might also be running away from everything instead of discerning what truly needs to change."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Evitar la salida necesaria o permanecer en malas situaciones. El miedo al cambio te mantiene atrapado. También puedes estar huyendo de todo en lugar de discernir lo que realmente necesita cambiar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Éviter le départ nécessaire ou rester dans de mauvaises situations. La peur du changement vous maintient bloqué. Vous pourriez aussi fuir tout au lieu de discerner ce qui doit vraiment changer."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Evitare la partenza necessaria o rimanere in cattive situazioni. La paura del cambiamento ti tiene bloccato. Potresti anche scappare da tutto invece di discernere ciò che deve veramente cambiare."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "必要な離脱を避けたり、悪い状況に留まったりする。変化への恐怖があなたを立ち往生させます。また、本当に何を変える必要があるかを見極める代わりに、すべてから逃げている可能性もあります。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unngår nødvendig avreise eller blir i dårlige situasjoner. Frykt for forandring holder deg fast. Du kan også rømme fra alt i stedet for å skjelne hva som virkelig trenger å endres."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unikanie koniecznego odejścia lub pozostawanie w złych sytuacjach. Strach przed zmianą trzyma cię w miejscu. Możesz też uciekać od wszystkiego zamiast rozeznawać, co naprawdę wymaga zmiany."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Evitar a saída necessária ou permanecer em más situações. O medo da mudança mantém você preso. Você também pode estar fugindo de tudo em vez de discernir o que realmente precisa mudar."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Undviker nödvändig avgång eller stannar i dåliga situationer. Rädsla för förändring håller dig fast. Du kanske också flyr från allt istället för att urskilja vad som verkligen behöver förändras."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Уникнення необхідного відходу або перебування в поганих ситуаціях. Страх змін утримує вас на місці. Ви також можете тікати від усього, замість того, щоб розрізняти, що дійсно потребує змін."
          }
        }
      }
    },
    "interpretation.eight_of_cups_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Weggehen, um einen tieferen Sinn zu finden. Was dich einst zufriedenstellte, tut es nicht mehr. Es geht darum, den Mut zu haben, hinter sich zu lassen, was deiner Seele nicht mehr dient, auch wenn es schwer ist."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Walking away to find deeper meaning. What once satisfied you doesn't anymore. This is about having the courage to leave behind what no longer serves your soul, even when it's hard."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alejarse para encontrar un significado más profundo. Lo que antes te satisfacía ya no lo hace. Esto se trata de tener el valor de dejar atrás lo que ya no sirve a tu alma, incluso cuando es difícil."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "S'éloigner pour trouver un sens plus profond. Ce qui vous satisfaisait autrefois ne le fait plus. Il s'agit d'avoir le courage de laisser derrière soi ce qui ne sert plus votre âme, même quand c'est difficile."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Allontanarsi per trovare un significato più profondo. Ciò che una volta ti soddisfaceva non lo fa più. Si tratta di avere il coraggio di lasciare alle spalle ciò che non serve più alla tua anima, anche quando è difficile."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "より深い意味を見つけるために立ち去る。かつてあなたを満たしていたものは、もうそうではありません。たとえ困難であっても、もはやあなたの魂に役立たないものを置き去りにする勇気を持つことです。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Å gå bort for å finne dypere mening. Det som en gang tilfredsstilte deg, gjør det ikke lenger. Dette handler om å ha mot til å legge bak seg det som ikke lenger tjener sjelen din, selv når det er vanskelig."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odejście, aby znaleźć głębszy sens. To, co kiedyś cię satysfakcjonowało, już nie działa. Chodzi o to, by mieć odwagę zostawić za sobą to, co już nie służy twojej duszy, nawet gdy jest to trudne."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Afastar-se para encontrar um significado mais profundo. O que antes o satisfazia não o satisfaz mais. Trata-se de ter coragem de deixar para trás o que não serve mais à sua alma, mesmo quando é difícil."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Att gå bort för att hitta djupare mening. Det som en gång tillfredsställde dig gör det inte längre. Det här handlar om att ha modet att lämna bakom sig det som inte längre tjänar din själ, även när det är svårt."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Відхід, щоб знайти глибший сенс. Те, що колись задовольняло вас, більше не задовольняє. Йдеться про мужність залишити позаду те, що більше не служить вашій душі, навіть коли це важко."
          }
        }
      }
    },
    "interpretation.eight_of_cups_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vermeidung notwendiger gesundheitlicher Veränderungen. Angst hält dich in ungesunden Mustern. Vor der Wellness-Reise davonlaufen oder sich weigern, der gesundheitlichen Wahrheit ins Auge zu sehen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avoiding necessary health changes. Fear keeps you in unhealthy patterns. Running from wellness journey or refusing to face health truth."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Evitar los cambios de salud necesarios. El miedo te mantiene en patrones poco saludables. Huir del viaje de bienestar o negarse a enfrentar la verdad de la salud."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Éviter les changements de santé nécessaires. La peur vous maintient dans des schémas malsains. Fuir le parcours de bien-être ou refuser de faire face à la vérité sur la santé."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Evitare i necessari cambiamenti per la salute. La paura ti mantiene in schemi malsani. Fuggire dal percorso di benessere o rifiutarsi di affrontare la verità sulla salute."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "必要な健康上の変化を避ける。恐怖があなたを不健康なパターンに留めます。ウェルネスの旅から逃げるか、健康の真実に直面することを拒否します。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unngå nødvendige helseendringer. Frykt holder deg i usunne mønstre. Rømmer fra velværereisen eller nekter å møte helsesannheten."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unikanie koniecznych zmian zdrowotnych. Strach utrzymuje cię w niezdrowych wzorcach. Ucieczka od podróży wellness lub odmowa spojrzenia prawdzie w oczy w kwestii zdrowia."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Evitar mudanças necessárias na saúde. O medo mantém você em padrões não saudáveis. Fugindo da jornada de bem-estar ou recusando-se a enfrentar a verdade sobre a saúde."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Undviker nödvändiga hälsoförändringar. Rädsla håller dig i ohälsosamma mönster. Flyr från friskvårdsresan eller vägrar att möta hälso sanningen."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Уникнення необхідних змін у здоров'ї. Страх утримує вас у нездорових моделях поведінки. Втеча від оздоровчої подорожі або відмова дивитися правді в очі щодо здоров'я."
          }
        }
      }
    },
    "interpretation.eight_of_cups_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sich von ungesunden Mustern abwenden, um wahres Wohlbefinden zu finden. Hinter sich lassen, was deinem Körper nicht mehr dient. Reise zu tieferer Gesundheit und Ganzheitlichkeit."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Walking away from unhealthy patterns to find true wellness. Leaving behind what no longer serves your body. Journey toward deeper health and wholeness."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alejarse de patrones poco saludables para encontrar el verdadero bienestar. Dejar atrás lo que ya no sirve a tu cuerpo. Viaje hacia una salud más profunda y plenitud."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "S'éloigner des schémas malsains pour trouver le véritable bien-être. Laisser derrière soi ce qui ne sert plus votre corps. Voyage vers une santé plus profonde et la plénitude."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Allontanarsi da schemi malsani per trovare il vero benessere. Lasciarsi alle spalle ciò che non serve più al tuo corpo. Viaggio verso una salute più profonda e la completezza."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "不健康なパターンから離れ、真の健康を見つける。もはやあなたの体に役立たないものを置き去りにする。より深い健康と全体性への旅。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Å gå bort fra usunne mønstre for å finne ekte velvære. Legge bak seg det som ikke lenger tjener kroppen din. Reise mot dypere helse og helhet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odejście od niezdrowych wzorców, aby znaleźć prawdziwe dobre samopoczucie. Zostawienie za sobą tego, co już nie służy twojemu ciału. Podróż w kierunku głębszego zdrowia i całości."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Afastar-se de padrões não saudáveis para encontrar o verdadeiro bem-estar. Deixar para trás o que não serve mais ao seu corpo. Jornada em direção a uma saúde mais profunda e plenitude."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Att gå bort från ohälsosamma mönster för att hitta sann välbefinnande. Lämna bakom sig det som inte längre tjänar din kropp. Resa mot djupare hälsa och helhet."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Відхід від нездорових моделей поведінки, щоб знайти справжнє благополуччя. Залишити позаду те, що більше не служить вашому тілу. Подорож до глибшого здоров'я та цілісності."
          }
        }
      }
    },
    "interpretation.eight_of_cups_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vermeidung des notwendigen Abschieds von einer unerfüllenden Beziehung. Angst vor Veränderung hält dich in dem, was dir nicht dient. Vor der Bindung davonlaufen oder sich weigern, der Wahrheit in der Beziehung ins Auge zu sehen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avoiding necessary departure from unfulfilling relationship. Fear of change keeps you in what doesn't serve you. Running from commitment or refusing to face relationship truth."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Evitar la salida necesaria de una relación insatisfactoria. El miedo al cambio te mantiene en lo que no te sirve. Huir del compromiso o negarse a enfrentar la verdad de la relación."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Éviter le départ nécessaire d'une relation insatisfaisante. La peur du changement vous maintient dans ce qui ne vous sert pas. Fuir l'engagement ou refuser de faire face à la vérité de la relation."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Evitare la necessaria partenza da una relazione insoddisfacente. La paura del cambiamento ti tiene in ciò che non ti serve. Fuggire dall'impegno o rifiutarsi di affrontare la verità della relazione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "満たされない関係からの必要な離脱を避ける。変化への恐怖が、あなたのために良くないことにあなたを留まらせます。コミットメントから逃げるか、関係の真実に直面することを拒否します。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unngår nødvendig avreise fra et utilfredsstillende forhold. Frykt for forandring holder deg i det som ikke tjener deg. Rømmer fra forpliktelser eller nekter å møte forholdets sannhet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unikanie koniecznego odejścia z niespełniającego związku. Strach przed zmianą trzyma cię w tym, co ci nie służy. Ucieczka od zaangażowania lub odmowa spojrzenia prawdzie w oczy w związku."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Evitar a saída necessária de um relacionamento insatisfatório. O medo da mudança mantém você no que não serve. Fugindo do compromisso ou recusando-se a enfrentar a verdade do relacionamento."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Undviker nödvändig avgång från ett otillfredsställande förhållande. Rädsla för förändring håller dig kvar i det som inte tjänar dig. Flyr från engagemang eller vägrar att möta relationssanningen."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Уникнення необхідного відходу з невтішних стосунків. Страх змін утримує вас у тому, що вам не служить. Втеча від зобов'язань або відмова дивитися правді в очі у стосунках."
          }
        }
      }
    },
    "interpretation.eight_of_cups_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sich von unerfüllter Liebe abwenden, um etwas Tieferes zu finden. Diese Beziehung nährt deine Seele nicht mehr. Es ist schwer zu gehen, aber zu bleiben ist schwerer. Vertraue auf dein Bedürfnis nach mehr."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Walking away from unfulfilling love to find something deeper. This relationship doesn't feed your soul anymore. It's hard to leave, but staying is harder. Trust your need for more."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alejarse de un amor insatisfactorio para encontrar algo más profundo. Esta relación ya no alimenta tu alma. Es difícil irse, pero quedarse es más difícil. Confía en tu necesidad de más."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "S'éloigner d'un amour insatisfaisant pour trouver quelque chose de plus profond. Cette relation ne nourrit plus votre âme. Il est difficile de partir, mais rester est plus difficile. Faites confiance à votre besoin de plus."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Allontanarsi da un amore insoddisfacente per trovare qualcosa di più profondo. Questa relazione non nutre più la tua anima. È difficile andarsene, ma restare è più difficile. Fidati del tuo bisogno di più."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "満たされない愛から離れ、より深い何かを見つけるために。この関係はもうあなたの魂を養っていません。去るのは難しいですが、留まるのはもっと難しいです。もっと必要としている自分を信じてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Å gå bort fra en utilfredsstillende kjærlighet for å finne noe dypere. Dette forholdet metter ikke sjelen din lenger. Det er vanskelig å forlate, men å bli er vanskeligere. Stol på behovet ditt for mer."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odejście od niespełniającej miłości, aby znaleźć coś głębszego. Ten związek już nie odżywia twojej duszy. Trudno jest odejść, ale pozostanie jest trudniejsze. Zaufaj swojej potrzebie czegoś więcej."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Afastar-se de um amor insatisfatório para encontrar algo mais profundo. Este relacionamento não alimenta mais sua alma. É difícil sair, mas ficar é mais difícil. Confie na sua necessidade de mais."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Att gå bort från en otillfredsställande kärlek för att hitta något djupare. Det här förhållandet matar inte din själ längre. Det är svårt att lämna, men att stanna är svårare. Lita på ditt behov av mer."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Відхід від невтішного кохання, щоб знайти щось глибше. Ці стосунки більше не живлять вашу душу. Важко піти, але залишатися важче. Довіртеся своїй потребі в більшому."
          }
        }
      }
    },
    "interpretation.eight_of_pentacles_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mangel an beruflichem Fokus oder Abkürzungen bei der Arbeit. Mittelmäßigkeit durch unzureichenden Einsatz. Perfektionismus führt zu Lähmung. Balancieren Sie Qualität mit Vollendung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lack of professional focus or shortcuts at work. Mediocrity from insufficient effort. Perfectionism creates paralysis. Balance quality with completion."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Falta de enfoque profesional o atajos en el trabajo. Mediocridad por esfuerzo insuficiente. El perfeccionismo crea parálisis. Equilibra la calidad con la finalización."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manque de concentration professionnelle ou raccourcis au travail. Médiocrité due à un effort insuffisant. Le perfectionnisme crée une paralysie. Équilibrez la qualité avec l'achèvement."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mancanza di concentrazione professionale o scorciatoie sul lavoro. Mediocrità dovuta a uno sforzo insufficiente. Il perfezionismo crea paralisi. Bilancia la qualità con il completamento."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "専門的な集中力の欠如または仕事での近道。不十分な努力による平凡さ。完璧主義が麻痺を生む。品質と完成のバランスを取る。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mangel på profesjonelt fokus eller snarveier på jobb. Middelmådighet på grunn av utilstrekkelig innsats. Perfeksjonisme skaper lammelse. Balanser kvalitet med fullføring."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Brak zawodowego skupienia lub skróty w pracy. Przeciętność z powodu niewystarczającego wysiłku. Perfekcjonizm powoduje paraliż. Zrównoważ jakość z ukończeniem."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Falta de foco profissional ou atalhos no trabalho. Mediocridade devido a esforço insuficiente. Perfeccionismo cria paralisia. Equilibre qualidade com conclusão."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Brist på professionellt fokus eller genvägar på jobbet. Medelmåttighet på grund av otillräcklig ansträngning. Perfektionism skapar förlamning. Balansera kvalitet med slutförande."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Відсутність професійного фокусу або короткі шляхи на роботі. Посередність через недостатні зусилля. Перфекціонізм створює параліч. Балансуйте якість із завершенням."
          }
        }
      }
    },
    "interpretation.eight_of_pentacles_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kompetenzentwicklung und Hingabe an das berufliche Handwerk. Sorgfältige Arbeit und Liebe zum Detail bringen Karriereerfolg. Sie meistern Ihr Fachgebiet durch konzentrierten Einsatz."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Skill development and dedication to professional craft. Diligent work and attention to detail bring career success. You're mastering your field through focused effort."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desarrollo de habilidades y dedicación al oficio profesional. El trabajo diligente y la atención al detalle traen éxito profesional. Estás dominando tu campo a través del esfuerzo concentrado."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Développement des compétences et dévouement au métier professionnel. Un travail assidu et une attention aux détails apportent la réussite professionnelle. Vous maîtrisez votre domaine grâce à un effort concentré."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sviluppo delle competenze e dedizione al mestiere professionale. Lavoro diligente e attenzione ai dettagli portano successo nella carriera. Stai padroneggiando il tuo campo attraverso uno sforzo concentrato."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "スキル開発と職業的な技への献身。勤勉な仕事と細部への注意がキャリアの成功をもたらす。集中した努力を通じて自分の分野を習得している。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ferdighetsutvikling og dedikasjon til profesjonelt håndverk. Flittig arbeid og oppmerksomhet på detaljer gir karrieresuksess. Du mestrer ditt felt gjennom fokusert innsats."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rozwój umiejętności i poświęcenie dla zawodowego rzemiosła. Pilna praca i dbałość o szczegóły przynoszą sukces w karierze. Opanowujesz swoją dziedzinę dzięki skoncentrowanemu wysiłkowi."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desenvolvimento de habilidades e dedicação ao ofício profissional. Trabalho diligente e atenção aos detalhes trazem sucesso na carreira. Você está dominando seu campo através de esforço focado."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Färdighetsutveckling och hängivenhet till professionellt hantverk. Flitigt arbete och uppmärksamhet på detaljer ger karriärframgång. Du bemästrar ditt område genom fokuserad ansträngning."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Розвиток навичок та відданість професійному ремеслу. Старанна робота та увага до деталей приносять кар'єрний успіх. Ви опановуєте свою сферу через зосереджені зусилля."
          }
        }
      }
    },
    "interpretation.eight_of_pentacles_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzieller Mangel an Fokus oder Abkürzungen im Geldmanagement. Durchschnittliche finanzielle Ergebnisse. Perfektionismus verhindert finanziellen Fortschritt. Bessere Anstrengung und Aufmerksamkeit sind nötig."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial lack of focus or money management shortcuts. Mediocre financial results. Perfectionism prevents financial progress. Need better effort and attention."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Falta de enfoque financiero o atajos en la gestión del dinero. Resultados financieros mediocres. El perfeccionismo impide el progreso financiero. Se necesita más esfuerzo y atención."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manque de concentration financière ou raccourcis dans la gestion de l'argent. Résultats financiers médiocres. Le perfectionnisme empêche les progrès financiers. Besoin de meilleurs efforts et d'attention."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mancanza di concentrazione finanziaria o scorciatoie nella gestione del denaro. Risultati finanziari mediocri. Il perfezionismo impedisce il progresso finanziario. Necessario un migliore impegno e attenzione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的な焦点の欠如または資金管理の近道。平凡な財務結果。完璧主義が経済的進歩を妨げる。より良い努力と注意が必要。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk mangel på fokus eller snarveier i pengeforvaltning. Middelmådige økonomiske resultater. Perfeksjonisme hindrer økonomisk fremgang. Trenger bedre innsats og oppmerksomhet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finansowy brak skupienia lub skróty w zarządzaniu pieniędzmi. Przeciętne wyniki finansowe. Perfekcjonizm uniemożliwia postęp finansowy. Potrzeba lepszego wysiłku i uwagi."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Falta de foco financeiro ou atalhos na gestão do dinheiro. Resultados financeiros medíocres. Perfeccionismo impede o progresso financeiro. Melhor esforço e atenção necessários."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Brist på ekonomiskt fokus eller genvägar i pengehantering. Medelmåttiga ekonomiska resultat. Perfektionism hindrar ekonomiska framsteg. Behöver bättre ansträngning och uppmärksamhet."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансова відсутність фокусу або короткі шляхи в управлінні грошима. Посередні фінансові результати. Перфекціонізм перешкоджає фінансовому прогресу. Потрібні кращі зусилля та увага."
          }
        }
      }
    },
    "interpretation.eight_of_pentacles_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Entwicklung finanzieller Fähigkeiten und sorgfältiges Geldmanagement. Detaillierte Aufmerksamkeit für Ressourcen. Vermögensaufbau durch engagierten Einsatz und Meisterschaft."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial skill development and diligent money management. Detailed attention to resources. Building wealth through dedicated effort and mastery."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desarrollo de habilidades financieras y gestión diligente del dinero. Atención detallada a los recursos. Construyendo riqueza a través del esfuerzo dedicado y el dominio."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Développement des compétences financières et gestion diligente de l'argent. Attention particulière aux ressources. Construire la richesse grâce à un effort dédié et à la maîtrise."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sviluppo delle competenze finanziarie e gestione diligente del denaro. Attenzione dettagliata alle risorse. Costruire ricchezza attraverso uno sforzo dedicato e la padronanza."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "財務スキルの開発と勤勉な資金管理。リソースへの詳細な注意。献身的な努力と習得を通じた富の構築。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utvikling av økonomiske ferdigheter og flittig pengeforvaltning. Detaljert oppmerksomhet til ressurser. Bygge rikdom gjennom dedikert innsats og mestring."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rozwój umiejętności finansowych i sumienne zarządzanie pieniędzmi. Szczegółowa uwaga na zasoby. Budowanie bogactwa poprzez oddany wysiłek i mistrzostwo."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desenvolvimento de habilidades financeiras e gestão diligente do dinheiro. Atenção detalhada aos recursos. Construindo riqueza através de esforço dedicado e maestria."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utveckling av ekonomiska färdigheter och flitig pengehantering. Detaljerad uppmärksamhet på resurser. Bygga rikedom genom dedikerad ansträngning och behärskning."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Розвиток фінансових навичок та старанне управління грошима. Детальна увага до ресурсів. Побудова багатства через присвячені зусилля та майстерність."
          }
        }
      }
    },
    "interpretation.eight_of_pentacles_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mangel an Fokus, Mittelmäßigkeit, Abkürzungen oder Perfektionismus. Sie investieren entweder keine Mühe oder besessen von Details. Finden Sie ein Gleichgewicht zwischen Qualität und Vollendung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lack of focus, mediocrity, shortcuts, or perfectionism. You're either not putting in effort or obsessing over details. Find balance between quality and completion."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Falta de enfoque, mediocridad, atajos o perfeccionismo. O no estás esforzándote o estás obsesionado con los detalles. Encuentra el equilibrio entre calidad y finalización."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manque de concentration, médiocrité, raccourcis ou perfectionnisme. Vous ne faites aucun effort ou vous êtes obsédé par les détails. Trouvez l'équilibre entre qualité et achèvement."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mancanza di concentrazione, mediocrità, scorciatoie o perfezionismo. O non stai facendo alcuno sforzo o sei ossessionato dai dettagli. Trova un equilibrio tra qualità e completamento."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "集中力の欠如、平凡さ、近道、または完璧主義。あなたは努力をしていないか、細部にこだわりすぎている。品質と完成のバランスを見つける。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mangel på fokus, middelmådighet, snarveier eller perfeksjonisme. Du gjør enten ingen innsats eller er besatt av detaljer. Finn balansen mellom kvalitet og fullføring."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Brak skupienia, przeciętność, skróty lub perfekcjonizm. Albo nie wkładasz wysiłku, albo jesteś obsesyjny na punkcie szczegółów. Znajdź równowagę między jakością a ukończeniem."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Falta de foco, mediocridade, atalhos ou perfeccionismo. Você ou não está se esforçando ou está obcecado por detalhes. Encontre o equilíbrio entre qualidade e conclusão."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Brist på fokus, medelmåttighet, genvägar eller perfektionism. Du lägger antingen inte ner någon ansträngning eller är besatt av detaljer. Hitta balans mellan kvalitet och slutförande."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Відсутність фокусу, посередність, короткі шляхи або перфекціонізм. Ви або не докладаєте зусиль, або одержимі деталями. Знайдіть баланс між якістю та завершенням."
          }
        }
      }
    },
    "interpretation.eight_of_pentacles_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kompetenzentwicklung, Fleiß, Handwerkskunst und Liebe zum Detail. Sie widmen sich der Meisterschaft. Qualitätsarbeit durch konzentrierten Einsatz. Sie werden zum Experten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Skill development, diligence, craftsmanship, and attention to detail. You're dedicating yourself to mastery. Quality work through focused effort. You're becoming an expert."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desarrollo de habilidades, diligencia, artesanía y atención al detalle. Te estás dedicando al dominio. Trabajo de calidad a través del esfuerzo concentrado. Te estás convirtiendo en un experto."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Développement des compétences, diligence, savoir-faire et souci du détail. Vous vous consacrez à la maîtrise. Un travail de qualité grâce à un effort concentré. Vous devenez un expert."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sviluppo delle competenze, diligenza, artigianalità e attenzione ai dettagli. Ti stai dedicando alla maestria. Lavoro di qualità attraverso uno sforzo concentrato. Stai diventando un esperto."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "スキル開発、勤勉さ、職人技、細部への注意。あなたは習得に専念している。集中した努力による質の高い仕事。あなたは専門家になりつつある。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ferdighetsutvikling, flid, håndverk og oppmerksomhet på detaljer. Du vier deg til mestring. Kvalitetsarbeid gjennom fokusert innsats. Du blir en ekspert."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rozwój umiejętności, pracowitość, rzemiosło i dbałość o szczegóły. Poświęcasz się mistrzostwu. Wysokiej jakości praca dzięki skoncentrowanemu wysiłkowi. Stajesz się ekspertem."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desenvolvimento de habilidades, diligência, artesanato e atenção aos detalhes. Você está se dedicando ao domínio. Trabalho de qualidade através de esforço focado. Você está se tornando um especialista."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Färdighetsutveckling, flit, hantverk och uppmärksamhet på detaljer. Du ägnar dig åt behärskning. Kvalitetsarbete genom fokuserad ansträngning. Du blir en expert."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Розвиток навичок, старанність, майстерність та увага до деталей. Ви присвячуєте себе майстерності. Якісна робота через зосереджені зусилля. Ви стаєте експертом."
          }
        }
      }
    },
    "interpretation.eight_of_pentacles_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mangel an Gesundheitsfokus oder Wellness-Abkürzungen. Durchschnittliche Ergebnisse bei der Selbstfürsorge. Perfektionismus in Bezug auf die Gesundheit erzeugt Stress. Balancieren Sie Einsatz mit Selbstmitgefühl."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lack of health focus or wellness shortcuts. Mediocre self-care results. Perfectionism about health creates stress. Balance effort with self-compassion."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Falta de enfoque en la salud o atajos de bienestar. Resultados mediocres de autocuidado. El perfeccionismo sobre la salud genera estrés. Equilibra el esfuerzo con la autocompasión."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manque de concentration sur la santé ou raccourcis de bien-être. Résultats médiocres en matière d'autosoins. Le perfectionnisme en matière de santé crée du stress. Équilibrez l'effort avec l'auto-compassion."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mancanza di concentrazione sulla salute o scorciatoie di benessere. Risultati mediocri nella cura di sé. Il perfezionismo sulla salute crea stress. Bilancia lo sforzo con l'autocompassione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "健康への焦点の欠如またはウェルネスの近道。平凡なセルフケアの結果。健康に関する完璧主義がストレスを生む。努力と自己同情のバランスを取る。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mangel på helsefokus eller velværesnarveier. Middelmådige egenomsorgsresultater. Perfeksjonisme rundt helse skaper stress. Balanser innsats med selvmedfølelse."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Brak skupienia na zdrowiu lub skróty wellness. Przeciętne wyniki samoopieki. Perfekcjonizm dotyczący zdrowia powoduje stres. Zrównoważ wysiłek ze współczuciem dla siebie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Falta de foco na saúde ou atalhos de bem-estar. Resultados medíocres de autocuidado. Perfeccionismo sobre a saúde cria estresse. Equilibre o esforço com a autocompaixão."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Brist på hälsofokus eller hälso- och välmåendegenvägar. Medelmåttiga egenvårdsresultat. Perfektionism kring hälsa skapar stress. Balansera ansträngning med självmedkänsla."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Відсутність фокусу на здоров'ї або оздоровчі короткі шляхи. Посередні результати самообслуговування. Перфекціонізм щодо здоров'я створює стрес. Балансуйте зусилля із співчуттям до себе."
          }
        }
      }
    },
    "interpretation.eight_of_pentacles_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Engagierter Gesundheitseinsatz und Kompetenzentwicklung im Wellness-Bereich. Detaillierte Aufmerksamkeit für die Bedürfnisse des Körpers. Gesundheitspraktiken durch sorgfältigen Fokus meistern."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dedicated health effort and skill development in wellness. Detailed attention to body's needs. Mastering health practices through diligent focus."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esfuerzo de salud dedicado y desarrollo de habilidades en bienestar. Atención detallada a las necesidades del cuerpo. Dominando las prácticas de salud a través del enfoque diligente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Effort de santé dédié et développement des compétences en bien-être. Attention particulière aux besoins du corps. Maîtriser les pratiques de santé grâce à une concentration diligente."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impegno dedicato alla salute e sviluppo di competenze nel benessere. Attenzione dettagliata ai bisogni del corpo. Padroneggiare le pratiche di salute attraverso un focus diligente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "献身的な健康への努力とウェルネスにおけるスキル開発。身体のニーズへの詳細な注意。勤勉な集中を通じて健康習慣を習得する。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dedikert helseinnsats og ferdighetsutvikling innen velvære. Detaljert oppmerksomhet til kroppens behov. Mestre helsepraksis gjennom flittig fokus."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oddany wysiłek zdrowotny i rozwój umiejętności w zakresie wellness. Szczegółowa uwaga na potrzeby ciała. Opanowywanie praktyk zdrowotnych poprzez sumienne skupienie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esforço de saúde dedicado e desenvolvimento de habilidades em bem-estar. Atenção detalhada às necessidades do corpo. Dominando práticas de saúde através do foco diligente."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dedikerad hälsoinsats och färdighetsutveckling inom hälsa och välmående. Detaljerad uppmärksamhet på kroppens behov. Bemästra hälsopraxis genom flitigt fokus."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Присвячені зусилля для здоров'я та розвиток навичок в оздоровленні. Детальна увага до потреб тіла. Оволодіння оздоровчими практиками через старанний фокус."
          }
        }
      }
    },
    "interpretation.eight_of_pentacles_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mangel an Einsatz in der Beziehung oder Perfektionismus belastet die Liebe. Nicht an Partnerschaftsfähigkeiten arbeiten. Abkürzungen schaden der Verbindungsqualität. Engagementniveau überdenken."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lack of effort in relationship or perfectionism strains love. Not working on partnership skills. Shortcuts damage connection quality. Reevaluate commitment level."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Falta de esfuerzo en la relación o perfeccionismo tensa el amor. No trabajar en las habilidades de la sociedad. Los atajos dañan la calidad de la conexión. Reevaluar el nivel de compromiso."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manque d'effort dans la relation ou perfectionnisme pèse sur l'amour. Ne pas travailler sur les compétences de partenariat. Les raccourcis nuisent à la qualité de la connexion. Réévaluer le niveau d'engagement."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mancanza di impegno nella relazione o perfezionismo mette a dura prova l'amore. Non lavorare sulle capacità di partnership. Le scorciatoie danneggiano la qualità della connessione. Rivalutare il livello di impegno."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "関係への努力不足または完璧主義が愛に負担をかける。パートナーシップのスキルに取り組んでいない。近道がつながりの質を損なう。コミットメントレベルを再評価する。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mangel på innsats i forholdet eller perfeksjonisme belaster kjærligheten. Ikke jobbe med partnerskapsferdigheter. Snarveier skader tilkoblingskvaliteten. Vurder forpliktelsesnivået på nytt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Brak wysiłku w związku lub perfekcjonizm obciąża miłość. Niepraca nad umiejętnościami partnerskimi. Skróty szkodzą jakości połączenia. Ponowna ocena poziomu zaangażowania."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Falta de esforço no relacionamento ou perfeccionismo sobrecarrega o amor. Não trabalhar nas habilidades de parceria. Atalhos prejudicam a qualidade da conexão. Reavaliar o nível de compromisso."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Brist på ansträngning i relationen eller perfektionism belastar kärleken. Inte arbeta med partnerskapsförmåga. Genvägar skadar anslutningskvaliteten. Omvärdera engagemangsnivån."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Відсутність зусиль у стосунках або перфекціонізм обтяжує любов. Непрацювання над навичками партнерства. Короткі шляхи шкодять якості зв'язку. Переоцініть рівень відданості."
          }
        }
      }
    },
    "interpretation.eight_of_pentacles_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Engagierter Einsatz zur Verbesserung der Beziehung. Arbeit an Kommunikations- und Verbindungsfähigkeiten. Aufbau einer qualitativ hochwertigen Partnerschaft durch Liebe zum Detail. Liebe als Praxis."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dedicated effort to improve relationship. Working on communication and connection skills. Crafting quality partnership through attention to detail. Love as practice."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esfuerzo dedicado para mejorar la relación. Trabajando en habilidades de comunicación y conexión. Creando una sociedad de calidad a través de la atención al detalle. El amor como práctica."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Effort dédié pour améliorer la relation. Travailler sur les compétences en communication et en connexion. Créer un partenariat de qualité grâce à une attention aux détails. L'amour comme pratique."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impegno dedicato per migliorare la relazione. Lavorare sulle capacità di comunicazione e connessione. Creare una partnership di qualità attraverso l'attenzione ai dettagli. L'amore come pratica."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "関係改善への献身的な努力。コミュニケーションとつながりのスキルに取り組む。細部への注意を通じて質の高いパートナーシップを築く。実践としての愛。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dedikert innsats for å forbedre forholdet. Arbeide med kommunikasjons- og tilknytningsferdigheter. Skape kvalitetspartnerskap gjennom oppmerksomhet på detaljer. Kjærlighet som praksis."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oddany wysiłek na rzecz poprawy związku. Praca nad umiejętnościami komunikacji i tworzenia więzi. Tworzenie wysokiej jakości partnerstwa poprzez dbałość o szczegóły. Miłość jako praktyka."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esforço dedicado para melhorar o relacionamento. Trabalhando em habilidades de comunicação e conexão. Criando parceria de qualidade através da atenção aos detalhes. Amor como prática."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dedikerad ansträngning för att förbättra relationen. Arbeta med kommunikations- och anslutningsförmåga. Skapa kvalitetspartnerskap genom uppmärksamhet på detaljer. Kärlek som praktik."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Присвячені зусилля для покращення стосунків. Робота над навичками спілкування та зв'язку. Створення якісного партнерства через увагу до деталей. Любов як практика."
          }
        }
      }
    },
    "interpretation.eight_of_swords_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Befreiung von Karrierebeschränkungen. Berufliche Freiheit und neue Perspektive. Selbstakzeptanz ermöglicht Arbeitsfortschritt. Deine Macht erkennen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Release from career restrictions. Professional freedom and new perspective. Self-acceptance allows work progress. Recognizing your power."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Liberación de las restricciones profesionales. Libertad profesional y nueva perspectiva. La autoaceptación permite el progreso laboral. Reconocer tu poder."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Libération des restrictions de carrière. Liberté professionnelle et nouvelle perspective. L'acceptation de soi permet le progrès au travail. Reconnaître votre pouvoir."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rilascio dalle restrizioni professionali. Libertà professionale e nuova prospettiva. L'accettazione di sé permette il progresso lavorativo. Riconoscere il proprio potere."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャリアの制限からの解放。仕事上の自由と新しい視点。自己受容が仕事の進歩を可能にする。自分の力を認識すること。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Frigjøring fra karrierebegrensninger. Profesjonell frihet og nytt perspektiv. Selvaksept muliggjør arbeidsfremgang. Gjenkjenne din egen makt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uwolnienie od ograniczeń w karierze. Wolność zawodowa i nowa perspektywa. Samoakceptacja umożliwia postęp w pracy. Rozpoznanie swojej siły."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Libertação das restrições de carreira. Liberdade profissional e nova perspectiva. A autoaceitação permite o progresso no trabalho. Reconhecendo seu poder."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Frigörelse från karriärbegränsningar. Professionell frihet och nytt perspektiv. Självacceptans möjliggör arbetsframsteg. Att känna igen din makt."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Звільнення від кар'єрних обмежень. Професійна свобода та новий погляд. Самоприйняття дозволяє прогресувати в роботі. Усвідомлення своєї сили."
          }
        }
      }
    },
    "interpretation.eight_of_swords_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beruflich gefangen fühlen, aber das Gefängnis ist selbst gemacht. Karriere-Opfermentalität. Selbstauferlegte Arbeitsbeschränkungen. Du hast mehr Optionen, als du siehst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Feeling trapped professionally but prison is self-made. Career victim mentality. Self-imposed work restrictions. You have more options than you see."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sentirse atrapado profesionalmente, pero la prisión es autoimpuesta. Mentalidad de víctima profesional. Restricciones laborales autoimpuestas. Tienes más opciones de las que ves."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sentiment d'être piégé professionnellement mais la prison est auto-construite. Mentalité de victime professionnelle. Restrictions de travail auto-imposées. Vous avez plus d'options que vous ne le voyez."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sentirsi intrappolati professionalmente ma la prigione è auto-costruita. Mentalità da vittima della carriera. Restrizioni lavorative autoimposte. Hai più opzioni di quante ne vedi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "仕事上で閉じ込められていると感じるが、刑務所は自己構築されたもの。キャリアの被害者意識。自己課した仕事の制限。あなたは見ている以上に多くの選択肢を持っている。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Føler seg fanget profesjonelt, men fengselet er selvlaget. Karriere-offermentalitet. Selvpålagte arbeidsbegrensninger. Du har flere alternativer enn du ser."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Poczucie uwięzienia zawodowego, ale więzienie jest samodzielnie zbudowane. Mentalność ofiary w karierze. Samonarzucone ograniczenia w pracy. Masz więcej opcji, niż widzisz."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sentindo-se preso profissionalmente, mas a prisão é autoimposta. Mentalidade de vítima na carreira. Restrições de trabalho autoimpostas. Você tem mais opções do que vê."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Känner sig fången professionellt men fängelset är självbyggt. Karriäoffermentalitet. Självpåtagna arbetsbegränsningar. Du har fler alternativ än du ser."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Відчуття професійної пастки, але в'язниця створена самостійно. Кар'єрна ментальність жертви. Самостійно накладені робочі обмеження. У вас більше варіантів, ніж ви бачите."
          }
        }
      }
    },
    "interpretation.eight_of_swords_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Befreiung von finanziellen Einschränkungen. Geld-Freiheit und neue Perspektive. Selbstakzeptanz ermöglicht Wohlstand. Deine Macht erkennen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Release from financial restrictions. Money freedom and new perspective. Self-acceptance allows prosperity. Recognizing your power."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Liberación de las restricciones financieras. Libertad financiera y nueva perspectiva. La autoaceptación permite la prosperidad. Reconocer tu poder."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Libération des restrictions financières. Liberté financière et nouvelle perspective. L'acceptation de soi permet la prospérité. Reconnaître votre pouvoir."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rilascio dalle restrizioni finanziarie. Libertà finanziaria e nuova prospettiva. L'accettazione di sé permette la prosperità. Riconoscere il proprio potere."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "金銭的制限からの解放。お金の自由と新しい視点。自己受容が繁栄を可能にする。自分の力を認識すること。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Frigjøring fra økonomiske begrensninger. Pengefrihet og nytt perspektiv. Selvaksept muliggjør velstand. Gjenkjenne din egen makt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uwolnienie od ograniczeń finansowych. Wolność pieniężna i nowa perspektywa. Samoakceptacja umożliwia dobrobyt. Rozpoznanie swojej siły."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Libertação das restrições financeiras. Liberdade financeira e nova perspectiva. A autoaceitação permite a prosperidade. Reconhecendo seu poder."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Frigörelse från finansiella begränsningar. Pengafrihet och nytt perspektiv. Självacceptans möjliggör välstånd. Att känna igen din makt."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Звільнення від фінансових обмежень. Грошова свобода та новий погляд. Самоприйняття дозволяє процвітання. Усвідомлення своєї сили."
          }
        }
      }
    },
    "interpretation.eight_of_swords_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanziell gefangen fühlen, aber Einschränkungen sind selbst auferlegt. Geld-Opfermentalität. Du hast mehr finanzielle Optionen, als du siehst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Feeling financially trapped but restrictions are self-imposed. Money victim mentality. You have more financial options than you see."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sentirse atrapado financieramente, pero las restricciones son autoimpuestas. Mentalidad de víctima del dinero. Tienes más opciones financieras de las que ves."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sentiment d'être piégé financièrement mais les restrictions sont auto-imposées. Mentalité de victime de l'argent. Vous avez plus d'options financières que vous ne le voyez."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sentirsi intrappolati finanziariamente ma le restrizioni sono autoimposte. Mentalità da vittima del denaro. Hai più opzioni finanziarie di quante ne vedi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "金銭的に閉じ込められていると感じるが、制限は自己課したもの。お金の被害者意識。あなたは見ている以上に多くの金銭的選択肢を持っている。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Føler seg økonomisk fanget, men begrensningene er selvpålagte. Penger-offermentalitet. Du har flere økonomiske alternativer enn du ser."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Poczucie uwięzienia finansowego, ale ograniczenia są samonarzucone. Mentalność ofiary pieniędzy. Masz więcej opcji finansowych, niż widzisz."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sentindo-se preso financeiramente, mas as restrições são autoimpostas. Mentalidade de vítima do dinheiro. Você tem mais opções financeiras do que vê."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Känner sig finansiellt fången men begränsningarna är självpåtagna. Pengeoffermentalitet. Du har fler finansiella alternativ än du ser."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Відчуття фінансової пастки, але обмеження є самостійно накладеними. Грошова ментальність жертви. У вас більше фінансових варіантів, ніж ви бачите."
          }
        }
      }
    },
    "interpretation.eight_of_swords_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Befreiung, Freiheit, neue Perspektive und Selbstakzeptanz. Die Einschränkungen lassen nach. Du erkennst deine Macht und Optionen. Die Befreiung beginnt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Release, freedom, new perspective, and self-acceptance. The restrictions are lifting. You're recognizing your power and options. Liberation begins."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Liberación, libertad, nueva perspectiva y autoaceptación. Las restricciones se están levantando. Estás reconociendo tu poder y opciones. La liberación comienza."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Libération, liberté, nouvelle perspective et acceptation de soi. Les restrictions se lèvent. Vous reconnaissez votre pouvoir et vos options. La libération commence."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rilascio, libertà, nuova prospettiva e accettazione di sé. Le restrizioni si stanno sollevando. Stai riconoscendo il tuo potere e le tue opzioni. La liberazione inizia."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "解放、自由、新しい視点、自己受容。制限が解けつつある。あなたは自分の力と選択肢を認識し始めている。解放が始まる。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Frigjøring, frihet, nytt perspektiv og selvaksept. Begrensningene letter. Du gjenkjenner din makt og dine alternativer. Frigjøring begynner."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uwolnienie, wolność, nowa perspektywa i samoakceptacja. Ograniczenia ustępują. Rozpoznajesz swoją siłę i opcje. Wyzwolenie się zaczyna."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Libertação, liberdade, nova perspectiva e autoaceitação. As restrições estão diminuindo. Você está reconhecendo seu poder e opções. A libertação começa."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Frigörelse, frihet, nytt perspektiv och självacceptans. Begränsningarna lättar. Du känner igen din makt och dina alternativ. Befrielsen börjar."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Звільнення, свобода, новий погляд і самоприйняття. Обмеження зникають. Ви усвідомлюєте свою силу та варіанти. Звільнення починається."
          }
        }
      }
    },
    "interpretation.eight_of_swords_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Einschränkung, Gefangenschaft, Opfermentalität und Hilflosigkeit. Du fühlst dich gefangen, aber die Ketten sind nicht real. Du hast mehr Macht, als du denkst. Nimm die Augenbinde ab."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Restriction, imprisonment, victim mentality, and helplessness. You feel trapped but the chains aren't real. You have more power than you think. Remove the blindfold."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Restricción, encarcelamiento, mentalidad de víctima e impotencia. Te sientes atrapado, pero las cadenas no son reales. Tienes más poder del que crees. Quítate la venda."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Restriction, emprisonnement, mentalité de victime et impuissance. Vous vous sentez piégé mais les chaînes ne sont pas réelles. Vous avez plus de pouvoir que vous ne le pensez. Retirez le bandeau."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Restrizione, prigionia, mentalità da vittima e impotenza. Ti senti intrappolato ma le catene non sono reali. Hai più potere di quanto pensi. Togli la benda."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "制限、監禁、被害者意識、無力感。あなたは閉じ込められていると感じるが、鎖は本物ではない。あなたは思っているよりも多くの力を持っている。目隠しを外せ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Begrensning, fangenskap, offermentalitet og hjelpeløshet. Du føler deg fanget, men kjedene er ikke ekte. Du har mer makt enn du tror. Fjern bindet for øynene."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ograniczenie, uwięzienie, mentalność ofiary i bezradność. Czujesz się uwięziony, ale łańcuchy nie są prawdziwe. Masz więcej władzy, niż myślisz. Zdejmij przepaskę."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Restrição, aprisionamento, mentalidade de vítima e impotência. Você se sente preso, mas as correntes não são reais. Você tem mais poder do que pensa. Tire a venda."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Begränsning, fängelse, offermentalitet och hjälplöshet. Du känner dig fången men kedjorna är inte verkliga. Du har mer makt än du tror. Ta av ögonbindeln."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Обмеження, ув'язнення, ментальність жертви та безпорадність. Ви відчуваєте себе в пастці, але ланцюги не справжні. У вас більше влади, ніж ви думаєте. Зніміть пов'язку з очей."
          }
        }
      }
    },
    "interpretation.eight_of_swords_health_reversed" : {
