    "interpretation.ace_of_wands_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verzögerungen, mangelnde Richtung, verpasste Chancen und Rückschläge. Dein kreatives Feuer ist blockiert oder fehlgeleitet. Entfache deine Leidenschaft neu."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Delays, lack of direction, missed opportunities, and setbacks. Your creative fire is blocked or misdirected. Reignite your passion."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Retrasos, falta de dirección, oportunidades perdidas y reveses. Tu fuego creativo está bloqueado o mal dirigido. Reaviva tu pasión."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Retards, manque de direction, opportunités manquées et revers. Votre feu créatif est bloqué ou mal dirigé. Ravivez votre passion."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ritardi, mancanza di direzione, opportunità mancate e battute d'arresto. Il tuo fuoco creativo è bloccato o male indirizzato. Rianima la tua passione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "遅延、方向性の欠如、逃した機会、そして挫折。あなたの創造的な火はブロックされているか、誤った方向に向かっています。情熱を再燃させなさい。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Forsinkelser, mangel på retning, tapte muligheter og tilbakeslag. Din kreative ild er blokkert eller feilstyrt. Tenn lidenskapen på nytt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opóźnienia, brak kierunku, stracone okazje i niepowodzenia. Twoja kreatywna energia jest zablokowana lub źle skierowana. Rozpal na nowo swoją pasję."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atrasos, falta de direção, oportunidades perdidas e reveses. Seu fogo criativo está bloqueado ou mal direcionado. Reacenda sua paixão."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Förseningar, brist på riktning, missade möjligheter och motgångar. Din kreativa eld är blockerad eller felriktad. Tänd din passion igen."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Затримки, відсутність напрямку, втрачені можливості та невдачі. Ваше творче полум'я заблоковане або спрямоване неправильно. Розпаліть свою пристрасть знову."
          }
        }
      }
    },
    "interpretation.ace_of_wands_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inspiration, neue Chancen, Wachstum und Potenzial. Kreatives Feuer entzündet sich in dir. Dies ist der Funke von etwas Aufregendem und Neuem. Nutze den Moment."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inspiration, new opportunities, growth, and potential. Creative fire ignites within you. This is the spark of something exciting and new. Seize the moment."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inspiración, nuevas oportunidades, crecimiento y potencial. El fuego creativo se enciende dentro de ti. Esta es la chispa de algo emocionante y nuevo. Aprovecha el momento."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inspiration, nouvelles opportunités, croissance et potentiel. Le feu créatif s'enflamme en vous. C'est l'étincelle de quelque chose d'excitant et de nouveau. Saisissez le moment."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ispirazione, nuove opportunità, crescita e potenziale. Il fuoco creativo si accende dentro di te. Questa è la scintilla di qualcosa di entusiasmante e nuovo. Cogli l'attimo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "インスピレーション、新しい機会、成長、可能性。創造の火があなたの中で燃え上がる。これはエキサイティングで新しい何かの火花です。瞬間をつかみなさい。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inspirasjon, nye muligheter, vekst og potensial. Kreativ ild tennes i deg. Dette er gnisten til noe spennende og nytt. Grip øyeblikket."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inspiracja, nowe możliwości, rozwój i potencjał. Kreatywny ogień zapala się w tobie. To iskra czegoś ekscytującego i nowego. Wykorzystaj chwilę."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inspiração, novas oportunidades, crescimento e potencial. O fogo criativo se acende dentro de você. Esta é a centelha de algo empolgante e novo. Aproveite o momento."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inspiration, nya möjligheter, tillväxt och potential. Kreativ eld tänds inom dig. Detta är gnistan till något spännande och nytt. Ta tillvara på ögonblicket."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Натхнення, нові можливості, зростання та потенціал. Творчий вогонь запалюється всередині вас. Це іскра чогось хвилюючого та нового. Ловіть момент."
          }
        }
      }
    },
