        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bonnes nouvelles concernant la santé ou informations intuitives sur le bien-être. Des approches créatives de la santé vous sont bénéfiques. Votre corps envoie des messages clairs : écoutez."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Buone notizie sulla salute o intuizioni di benessere intuitive. Approcci creativi alla salute ti avvantaggiano. Il tuo corpo invia messaggi chiari: ascolta."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "健康に関する良い知らせや直感的なウェルネスの洞察。創造的な健康法が役立つ。あなたの体は明確なメッセージを送っている—耳を傾けよ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gode helsenyheter eller intuitive velværeinnsikter. Kreative tilnærminger til helse gagner deg. Kroppen din sender klare meldinger – lytt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dobre wieści o zdrowiu lub intuicyjne spostrzeżenia dotyczące dobrego samopoczucia. Kreatywne podejścia do zdrowia przynoszą korzyści. Twoje ciało wysyła jasne komunikaty – słuchaj."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Boas notícias de saúde ou insights intuitivos de bem-estar. Abordagens criativas para a saúde beneficiam você. Seu corpo envia mensagens claras – ouça."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Goda hälsonyheter eller intuitiva välmåendeinsikter. Kreativa tillvägagångssätt för hälsa gynnar dig. Din kropp skickar tydliga meddelanden – lyssna."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Хороші новини про здоров'я або інтуїтивні оздоровчі інсайти. Творчі підходи до здоров'я приносять вам користь. Ваше тіло надсилає чіткі повідомлення — слухайте."
          }
        }
      }
    },
    "interpretation.page_of_cups_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Emotionale Unreife in der Liebe oder gemischte romantische Signale. Kreative Blockaden beim Ausdruck von Gefühlen. Schlechte Nachrichten in Beziehungen. Unsicherheit verhindert authentische Verbindung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Emotional immaturity in love or mixed romantic signals. Creative blocks in expressing feelings. Bad news in relationships. Insecurity prevents authentic connection."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inmadurez emocional en el amor o señales románticas contradictorias. Bloqueos creativos para expresar sentimientos. Malas noticias en las relaciones. La inseguridad impide la conexión auténtica."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Immaturité émotionnelle en amour ou signaux romantiques mitigés. Blocages créatifs dans l'expression des sentiments. Mauvaises nouvelles dans les relations. L'insécurité empêche une connexion authentique."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Immaturità emotiva in amore o segnali romantici contrastanti. Blocchi creativi nell'esprimere i sentimenti. Cattive notizie nelle relazioni. L'insicurezza impedisce una connessione autentica."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "恋愛における感情的未熟さや曖昧な恋愛シグナル。感情表現の創造的ブロック。関係における悪い知らせ。不安が真のつながりを妨げる。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Emosjonell umodenhet i kjærlighet eller blandede romantiske signaler. Kreative blokkeringer i å uttrykke følelser. Dårlige nyheter i relasjoner. Usikkerhet hindrer autentisk tilknytning."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niedojrzałość emocjonalna w miłości lub mieszane sygnały romantyczne. Blokady twórcze w wyrażaniu uczuć. Złe wieści w związkach. Niepewność uniemożliwia autentyczne połączenie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Imaturidade emocional no amor ou sinais românticos mistos. Bloqueios criativos para expressar sentimentos. Más notícias nos relacionamentos. Insegurança impede conexão autêntica."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Känslomässig omognad i kärlek eller blandade romantiska signaler. Kreativa blockeringar i att uttrycka känslor. Dåliga nyheter i relationer. Osäkerhet förhindrar autentisk anslutning."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Емоційна незрілість у коханні або змішані романтичні сигнали. Творчі блокування у вираженні почуттів. Погані новини у стосунках. Невпевненість заважає автентичному зв'язку."
          }
        }
      }
    },
    "interpretation.page_of_cups_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Neue romantische Botschaft oder kreativer Gefühlsausdruck. Unschuldige, aufrichtige Liebe entsteht. Dein Herz öffnet sich für neue emotionale Erfahrungen. Süße Anfänge in der Liebe."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "New romantic message or creative expression of feelings. Innocent, sincere love emerges. Your heart opens to new emotional experiences. Sweet beginnings in love."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nuevo mensaje romántico o expresión creativa de sentimientos. Surge un amor inocente y sincero. Tu corazón se abre a nuevas experiencias emocionales. Dulces comienzos en el amor."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nouveau message romantique ou expression créative des sentiments. Un amour innocent et sincère émerge. Votre cœur s'ouvre à de nouvelles expériences émotionnelles. Doux débuts en amour."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nuovo messaggio romantico o espressione creativa dei sentimenti. Emerge un amore innocente e sincero. Il tuo cuore si apre a nuove esperienze emotive. Dolci inizi nell'amore."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "新しい恋のメッセージや感情の創造的表現。無邪気で誠実な愛が芽生える。あなたの心は新しい感情体験に開かれる。恋における甘い始まり。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ny romantisk melding eller kreativt uttrykk for følelser. Usunn, oppriktig kjærlighet oppstår. Hjertet ditt åpner seg for nye emosjonelle opplevelser. Søte begynnelser i kjærlighet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nowa romantyczna wiadomość lub kreatywne wyrażanie uczuć. Niewinna, szczera miłość wyłania się. Twoje serce otwiera się na nowe doświadczenia emocjonalne. Słodkie początki w miłości."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nova mensagem romântica ou expressão criativa de sentimentos. Amor inocente e sincero surge. Seu coração se abre para novas experiências emocionais. Doces começos no amor."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ny romantisk hälsning eller kreativt uttryck för känslor. Oskyldig, uppriktig kärlek uppstår. Ditt hjärta öppnas för nya känslomässiga upplevelser. Söta nybörjare i kärlek."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Нове романтичне повідомлення або творче вираження почуттів. Виникає невинне, щире кохання. Ваше серце відкривається для нових емоційних переживань. Солодкі початки в коханні."
          }
        }
      }
    },
    "interpretation.page_of_pentacles_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Berufliche Prokrastination oder mangelnder beruflicher Fortschritt. Schlechte Arbeitsplanung. Verpasste Berufschance. Mehr Ehrgeiz und Fokus sind nötig."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Career procrastination or lack of professional progress. Poor work planning. Missed job opportunity. Need more ambition and focus."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Procrastinación profesional o falta de progreso profesional. Mala planificación del trabajo. Oportunidad laboral perdida. Se necesita más ambición y enfoque."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Procrastination professionnelle ou manque de progrès professionnels. Mauvaise planification du travail. Opportunité d'emploi manquée. Besoin de plus d'ambition et de concentration."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Procrastinazione professionale o mancanza di progressi professionali. Scarsa pianificazione del lavoro. Opportunità di lavoro persa. Necessità di più ambizione e concentrazione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャリアの先延ばしまたは職業的進歩の欠如。仕事の計画不足。逃した仕事の機会。より多くの野心と集中力が必要。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriereprokrastinering eller mangel på profesjonell fremgang. Dårlig arbeidsplanlegging. Gått glipp av en jobbmulighet. Trenger mer ambisjon og fokus."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Prokrastynacja zawodowa lub brak postępów zawodowych. Złe planowanie pracy. Utracona szansa na pracę. Potrzeba więcej ambicji i skupienia."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Procrastinação na carreira ou falta de progresso profissional. Mau planejamento de trabalho. Oportunidade de emprego perdida. Mais ambição e foco necessários."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriärprokrastinering eller brist på professionella framsteg. Dålig arbetsplanering. Missad jobbmöjlighet. Behöver mer ambition och fokus."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Прокрастинація в кар'єрі або відсутність професійного прогресу. Погане планування роботи. Втрачена робоча можливість. Потрібно більше амбіцій та фокусу."
          }
        }
      }
    },
