    },
    "interpretation.queen_of_swords_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kälte, Grausamkeit, Bitterkeit und Isolation. Dein scharfer Verstand ist zur Waffe geworden. Abwehrhaltung isoliert dich. Mildere deine Schärfe."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Coldness, cruelty, bitterness, and isolation. Your sharp mind has become a weapon. Defensiveness isolates you. Soften your edges."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Frialdad, crueldad, amargura y aislamiento. Tu mente aguda se ha convertido en un arma. La actitud defensiva te aísla. Suaviza tus bordes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Froideur, cruauté, amertume et isolement. Votre esprit vif est devenu une arme. La défensive vous isole. Adoucissez vos angles."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Freddezza, crudeltà, amarezza e isolamento. La tua mente acuta è diventata un'arma. La difensiva ti isola. Ammorbidisci i tuoi spigoli."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "冷たさ、残酷さ、 bitterness、孤立。あなたの鋭い心は武器になってしまった。防御的な態度があなたを孤立させる。角を丸くしろ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kulde, grusomhet, bitterhet og isolasjon. Dine skarpe sinn har blitt et våpen. Defensivitet isolerer deg. Mykne kantene dine."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chłód, okrucieństwo, gorycz i izolacja. Twój bystry umysł stał się bronią. Defensywność cię izoluje. Zmiękcz swoje krawędzie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Frieza, crueldade, amargura e isolamento. Sua mente afiada se tornou uma arma. A defensividade isola você. Suavize suas arestas."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kyla, grymhet, bitterhet och isolering. Ditt skarpa sinne har blivit ett vapen. Defensivitet isolerar dig. Mjuka upp dina kanter."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Холодність, жорстокість, гіркота та ізоляція. Ваш гострий розум став зброєю. Захисна реакція ізолює вас. Пом'якшіть свої кути."
          }
        }
      }
    },
    "interpretation.queen_of_swords_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unabhängigkeit, klares Denken, Ehrlichkeit und Direktheit. Du siehst die Wahrheit klar und sprichst sie aus. Grenzen schützen dich. Dein Geist ist scharf und dein Herz ist weise geschützt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Independence, clear thinking, honesty, and directness. You see truth clearly and speak it. Boundaries protect you. Your mind is sharp and your heart is guarded wisely."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Independencia, pensamiento claro, honestidad y franqueza. Ves la verdad con claridad y la dices. Los límites te protegen. Tu mente es aguda y tu corazón está sabiamente guardado."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Indépendance, clarté d'esprit, honnêteté et franchise. Vous voyez la vérité clairement et la dites. Les limites vous protègent. Votre esprit est vif et votre cœur est sagement gardé."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Indipendenza, pensiero chiaro, onestà e direttezza. Vedi la verità chiaramente e la dici. I confini ti proteggono. La tua mente è acuta e il tuo cuore è saggiamente custodito."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "独立、明確な思考、正直さ、率直さ。あなたは真実をはっきりと見て、それを語る。境界があなたを守る。あなたの心は鋭く、あなたの心は賢く守られている。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uavhengighet, klar tenkning, ærlighet og direkthet. Du ser sannheten klart og sier den. Grenser beskytter deg. Sinnet ditt er skarpt og hjertet ditt er klokt bevoktet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niezależność, jasne myślenie, uczciwość i bezpośredniość. Widzisz prawdę wyraźnie i mówisz ją. Granice cię chronią. Twój umysł jest bystry, a serce mądrze strzeżone."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Independência, pensamento claro, honestidade e franqueza. Você vê a verdade claramente e a fala. Limites protegem você. Sua mente é afiada e seu coração é sabiamente guardado."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Självständighet, klart tänkande, ärlighet och direktör. Du ser sanningen tydligt och säger den. Gränser skyddar dig. Ditt sinne är skarpt och ditt hjärta är klokt bevakat."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Незалежність, чітке мислення, чесність і прямота. Ви бачите правду ясно і говорите її. Межі захищають вас. Ваш розум гострий, а серце мудро захищене."
          }
        }
      }
    },
    "interpretation.queen_of_swords_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gesundheitliche Kälte oder grausame Selbstgespräche über den Körper. Verbittert über das Wohlbefinden. Durch körperliche Abwehrhaltung isoliert. Harter Gesundheitsansatz schadet dem Selbst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Health coldness or cruel self-talk about body. Bitter about wellness. Isolated through physical defensiveness. Harsh health approach damages self."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Frialdad de salud o diálogo interno cruel sobre el cuerpo. Amargado por el bienestar. Aislado por la actitud defensiva física. El enfoque duro de la salud se daña a sí mismo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Froideur de santé ou discours intérieur cruel sur le corps. Amer à propos du bien-être. Isolé par la défensive physique. Une approche sévère de la santé nuit à soi-même."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Freddezza sanitaria o dialogo interiore crudele sul corpo. Amareggiato per il benessere. Isolato dalla difensiva fisica. L'approccio sanitario duro danneggia il sé."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "健康の冷たさまたは体についての残酷な自己対話。ウェルネスへの bitterness。身体的な防御による孤立。厳しい健康アプローチが自分自身を傷つける。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Helsekulde eller grusom selvsnakk om kroppen. Bitter om velvære. Isolert gjennom fysisk defensivitet. Hard helsetilnærming skader selvet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zdrowotny chłód lub okrutny wewnętrzny dialog o ciele. Gorzki w stosunku do dobrego samopoczucia. Odizolowany przez fizyczną defensywność. Surowe podejście do zdrowia szkodzi sobie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Frieza de saúde ou autodiálogo cruel sobre o corpo. Amargurado sobre bem-estar. Isolado pela defensividade física. Abordagem dura da saúde prejudica a si mesmo."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hälsokyla eller grym självprat om kroppen. Bitter om välbefinnande. Isolerad genom fysisk defensivitet. Hård hälsosyn skadar jaget."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Холодність здоров'я або жорстокий внутрішній діалог про тіло. Гіркота щодо благополуччя. Ізоляція через фізичну захисну реакцію. Суворий підхід до здоров'я шкодить собі."
          }
        }
      }
    },
