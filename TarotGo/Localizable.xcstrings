    "cardOfDay.instruction" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lege deinen Finger auf die Karte und halte 3 Sekunden lang"
