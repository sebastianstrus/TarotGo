        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nuova opportunità, apprendimento, ambizione e manifestazione pratica. Sei all'inizio di qualcosa di solido. Rimani concentrato e diligente. Studia e cresci."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "新しい機会、学習、野心、そして実用的な顕現。あなたは確かな何かの始まりにいる。集中して勤勉に。学び、成長せよ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ny mulighet, læring, ambisjon og praktisk manifestasjon. Du er i begynnelsen av noe solid. Hold fokus og vær flittig. Studer og voks."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nowa szansa, nauka, ambicja i praktyczna manifestacja. Jesteś na początku czegoś solidnego. Pozostań skupiony i sumienny. Ucz się i rozwijaj."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nova oportunidade, aprendizado, ambição e manifestação prática. Você está no começo de algo sólido. Mantenha o foco e a diligência. Estude e cresça."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
