        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Необережні кар'єрні кроки або професійна нетерплячість. Несфокусована робоча енергія. Імпульсивні робочі рішення. Сповільніться і стратегуйте."
          }
        }
      }
    },
    "interpretation.knight_of_swords_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ehrgeiziger, handlungsorientierter Berufsansatz. Schnelles Denken und Zielstrebigkeit bei der Arbeit. Karrierefortschritt durch schnelle Entscheidungen. Geistige Klarheit dient dem Ehrgeiz."
