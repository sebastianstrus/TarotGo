          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fardeau financier et responsabilité monétaire. Les ressources semblent lourdes. La prospérité exige un travail acharné. Prendre trop de stress financier."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fardello finanziario e responsabilità monetaria. Le risorse sembrano pesanti. La prosperità richiede duro lavoro. Assumere troppo stress finanziario."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的な負担とお金の責任。リソースが重く感じられる。繁栄にはハードワークが必要。経済的なストレスを負いすぎる。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk byrde og pengeansvar. Ressurser føles tunge. Velstand krever hardt arbeid. Tar på seg for mye økonomisk stress."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ciężar finansowy i odpowiedzialność pieniężna. Zasoby wydają się ciężkie. Dobrobyt wymaga ciężkiej pracy. Branie na siebie zbyt dużego stresu finansowego."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fardo financeiro e responsabilidade monetária. Os recursos parecem pesados. A prosperidade exige trabalho árduo. Assumindo muito estresse financeiro."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomisk börda och pengaansvar. Resurser känns tunga. Välstånd kräver hårt arbete. Ta på sig för mycket ekonomisk stress."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансовий тягар і грошова відповідальність. Ресурси здаються важкими. Процвітання вимагає важкої праці. Брати на себе забагато фінансового стресу."
          }
        }
      }
    },
    "interpretation.ten_of_wands_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loslassen, Delegieren, Loslassen und Last erleichtern. Du legst endlich einige Lasten ab. Erleichterung kommt durch das Loslassen von Verantwortung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Release, delegation, letting go, and lightening load. You're finally putting down some burdens. Relief comes through releasing responsibility."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Liberación, delegación, dejar ir y aligerar la carga. Finalmente estás dejando algunas cargas. El alivio llega al liberar responsabilidades."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Libération, délégation, lâcher prise et allègement du fardeau. Vous déposez enfin certains fardeaux. Le soulagement vient en libérant les responsabilités."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rilascio, delega, lasciare andare e alleggerimento del carico. Finalmente stai deponendo alcuni fardelli. Il sollievo arriva rilasciando la responsabilità."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "解放、委任、手放し、そして負荷の軽減。あなたはついにいくつかの負担を下ろしている。責任を手放すことで安堵がもたらされる。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Frigjøring, delegering, slippe tak og lette belastningen. Du legger endelig ned noen byrder. Lettelse kommer ved å slippe ansvar."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uwolnienie, delegowanie, puszczanie i zmniejszanie obciążenia. Wreszcie odkładasz niektóre ciężary. Ulga przychodzi poprzez uwolnienie odpowiedzialności."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Liberação, delegação, deixar ir e aliviar a carga. Você finalmente está deixando alguns fardos. O alívio vem ao liberar a responsabilidade."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Frigörelse, delegering, släppa taget och lätta bördan. Du lägger äntligen ner några bördor. Lättnad kommer genom att släppa ansvar."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Звільнення, делегування, відпускання та полегшення навантаження. Ви нарешті складаєте деякі тягарі. Полегшення приходить через звільнення від відповідальності."
          }
        }
      }
    },
    "interpretation.ten_of_wands_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Last, Verantwortung, harte Arbeit und Stress. Du trägst zu viel. Fast am Ziel, aber überfordert. Delegiere oder lasse etwas los."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Burden, responsibility, hard work, and stress. You're carrying too much. Almost at the destination but overwhelmed. Delegate or let go of something."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carga, responsabilidad, trabajo duro y estrés. Estás cargando demasiado. Casi en el destino pero abrumado. Delega o deja ir algo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fardeau, responsabilité, travail acharné et stress. Vous portez trop. Presque à destination mais dépassé. Déléguez ou lâchez quelque chose."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fardello, responsabilità, duro lavoro e stress. Stai portando troppo. Quasi a destinazione ma sopraffatto. Delega o lascia andare qualcosa."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "負担、責任、ハードワーク、そしてストレス。あなたは負いすぎている。目的地にほぼ到達しているが、圧倒されている。委任するか、何かを手放しなさい。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Byrde, ansvar, hardt arbeid og stress. Du bærer for mye. Nesten ved målet, men overveldet. Deleger eller slipp noe."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ciężar, odpowiedzialność, ciężka praca i stres. Niesiesz zbyt wiele. Prawie u celu, ale przytłoczony. Deleguj lub odpuść coś."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fardo, responsabilidade, trabalho árduo e estresse. Você está carregando muito. Quase no destino, mas sobrecarregado. Delegue ou deixe algo ir."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Börda, ansvar, hårt arbete och stress. Du bär för mycket. Nästan vid målet men överväldigad. Delegera eller släpp något."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Тягар, відповідальність, важка праця та стрес. Ви несете занадто багато. Майже біля мети, але перевантажені. Делегуйте або відпустіть щось."
          }
        }
      }
    },
    "interpretation.ten_of_wands_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loslassen von Gesundheitsbelastungen oder Delegieren von Wellness-Verantwortungen. Körperlichen Stress loslassen. Körperliche Last erleichtern."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Releasing health burden or delegating wellness responsibilities. Letting go of physical stress. Lightening body load."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Soltando la carga de salud o delegando responsabilidades de bienestar. Dejando ir el estrés físico. Aligerando la carga corporal."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Relâcher le fardeau de santé ou déléguer les responsabilités de bien-être. Lâcher prise sur le stress physique. Alléger la charge corporelle."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rilasciare il fardello della salute o delegare le responsabilità del benessere. Lasciare andare lo stress fisico. Alleggerire il carico del corpo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "健康の負担を手放すか、ウェルネスの責任を委譲する。身体的なストレスを手放す。身体の負荷を軽くする。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Slippe helsebyrde eller delegere velværeansvar. Slippe tak i fysisk stress. Lette kroppsbelastning."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uwalnianie ciężaru zdrowotnego lub delegowanie odpowiedzialności wellness. Puszczanie fizycznego stresu. Zmniejszanie obciążenia ciała."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Liberando o fardo da saúde ou delegando responsabilidades de bem-estar. Deixando o estresse físico ir embora. Aliviando a carga corporal."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Släppa hälsobörda eller delegera välmåendeansvar. Släppa taget om fysisk stress. Lätta kroppsbelastning."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Звільнення від тягаря здоров'я або делегування обов'язків благополуччя. Відпускання фізичного стресу. Полегшення навантаження на тіло."
          }
        }
      }
    },
