    "interpretation.five_of_cups_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erholung von beruflichen Rückschlägen. Du schließt Frieden mit vergangenen Fehlern und siehst neue Möglichkeiten. Mit den gewonnenen Erkenntnissen gehst du voran."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recovery from career setbacks. You're making peace with past failures and seeing new possibilities. Moving forward with lessons learned."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recuperación de reveses profesionales. Te estás reconciliando con fracasos pasados y viendo nuevas posibilidades. Avanzando con las lecciones aprendidas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Récupération après des revers professionnels. Vous faites la paix avec les échecs passés et voyez de nouvelles possibilités. Avancer avec les leçons apprises."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ripresa da battute d'arresto professionali. Stai facendo pace con i fallimenti passati e vedendo nuove possibilità. Andare avanti con le lezioni apprese."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャリアの挫折からの回復。あなたは過去の失敗を受け入れ、新たな可能性を見ています。学んだ教訓を活かして前進します。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Restitusjon fra karrieretilbakeslag. Du gjør fred med tidligere feil og ser nye muligheter. Går videre med lærdom."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Powrót do zdrowia po niepowodzeniach zawodowych. Godzisz się z przeszłymi porażkami i widzisz nowe możliwości. Idziesz do przodu z wyciągniętymi wnioskami."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recuperação de contratempos na carreira. Você está fazendo as pazes com falhas passadas e vendo novas possibilidades. Avançando com as lições aprendidas."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Återhämtning från karriärmotgångar. Du gör upp med tidigare misslyckanden och ser nya möjligheter. Går vidare med lärdomar."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Відновлення після кар'єрних невдач. Ви миритеся з минулими помилками та бачите нові можливості. Рухаєтеся вперед із засвоєними уроками."
          }
        }
      }
    },
    "interpretation.five_of_cups_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Berufliche Enttäuschung und Verlust. Ein Job, ein Projekt oder eine Gelegenheit hat nicht geklappt. Du trauerst um das, was gescheitert ist. Gültige Gefühle, aber verliere nicht den Blick für das, was bleibt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professional disappointment and loss. A job, project, or opportunity didn't work out. You're mourning what failed. Valid feelings, but don't lose sight of what remains."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Decepción y pérdida profesional. Un trabajo, proyecto u oportunidad no funcionó. Estás lamentando lo que fracasó. Sentimientos válidos, pero no pierdas de vista lo que queda."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Déception et perte professionnelles. Un emploi, un projet ou une opportunité n'a pas fonctionné. Vous pleurez ce qui a échoué. Sentiments valables, mais ne perdez pas de vue ce qui reste."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Delusione e perdita professionale. Un lavoro, progetto o opportunità non ha funzionato. Stai piangendo ciò che è fallito. Sentimenti validi, ma non perdere di vista ciò che rimane."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "職業上の失望と損失。仕事、プロジェクト、または機会がうまくいきませんでした。あなたは失敗したことを悼んでいます。感情は理解できますが、何が残っているかを見失わないでください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profesjonell skuffelse og tap. En jobb, et prosjekt eller en mulighet fungerte ikke. Du sørger over det som mislyktes. Gyldige følelser, men ikke mist synet av hva som gjenstår."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zawodowe rozczarowanie i strata. Praca, projekt lub okazja nie wypaliły. Opłakujesz to, co się nie udało. Uczucia są uzasadnione, ale nie trać z oczu tego, co pozostaje."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Decepção e perda profissional. Um trabalho, projeto ou oportunidade não deu certo. Você está lamentando o que falhou. Sentimentos válidos, mas não perca de vista o que resta."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professionell besvikelse och förlust. Ett jobb, projekt eller möjlighet fungerade inte. Du sörjer det som misslyckades. Giltiga känslor, men tappa inte sikte på vad som återstår."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Професійне розчарування та втрата. Робота, проект або можливість не спрацювали. Ви сумуєте за тим, що не вдалося. Почуття виправдані, але не втрачайте з виду те, що залишилося."
          }
        }
      }
    },
    "interpretation.five_of_cups_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Erholung und Akzeptanz. Du schließt Frieden mit den Verlusten und siehst die verbleibenden Ressourcen klar. Vergebung finden und vorwärts gehen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial recovery and acceptance. You're making peace with losses and seeing remaining resources clearly. Finding forgiveness and moving forward."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recuperación financiera y aceptación. Te estás reconciliando con las pérdidas y ves claramente los recursos restantes. Encontrando el perdón y siguiendo adelante."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rétablissement financier et acceptation. Vous faites la paix avec les pertes et voyez clairement les ressources restantes. Trouver le pardon et aller de l'avant."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ripresa finanziaria e accettazione. Stai facendo pace con le perdite e vedendo chiaramente le risorse rimanenti. Trovare il perdono e andare avanti."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的回復と受容。あなたは損失を受け入れ、残りのリソースをはっきりと見ています。許しを見つけて前進します。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk bedring og aksept. Du gjør fred med tap og ser gjenværende ressurser tydelig. Finner tilgivelse og går videre."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Powrót do zdrowia finansowego i akceptacja. Godzisz się ze stratami i wyraźnie widzisz pozostałe zasoby. Znajdujesz przebaczenie i idziesz dalej."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recuperação financeira e aceitação. Você está fazendo as pazes com as perdas e vendo os recursos restantes claramente. Encontrando o perdão e seguindo em frente."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomisk återhämtning och acceptans. Du gör upp med förluster och ser återstående resurser tydligt. Hitta förlåtelse och gå vidare."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансове відновлення та прийняття. Ви миритеся з втратами та чітко бачите ресурси, що залишилися. Знаходите прощення та рухаєтесь далі."
          }
        }
      }
    },
    "interpretation.five_of_cups_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzieller Verlust oder Enttäuschung. Geld fließt dir durch die Finger und du konzentrierst dich auf das, was weg ist. Trauer ist natürlich, aber beurteile, welche Ressourcen noch vorhanden sind."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial loss or disappointment. Money slip through your fingers and you're focused on what's gone. Grief is natural, but assess what resources remain."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pérdida financiera o decepción. El dinero se te escapa de las manos y te concentras en lo que se ha ido. El dolor es natural, pero evalúa qué recursos quedan."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Perte financière ou déception. L'argent vous glisse entre les doigts et vous vous concentrez sur ce qui est parti. Le chagrin est naturel, mais évaluez les ressources qui restent."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Perdita finanziaria o delusione. Il denaro ti scivola tra le dita e ti concentri su ciò che è andato. Il dolore è naturale, ma valuta quali risorse rimangono."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的損失や失望。お金があなたの指をすり抜け、あなたは何がなくなったかに集中しています。悲しみは自然なことですが、どのようなリソースが残っているかを評価してください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk tap eller skuffelse. Penger glir gjennom fingrene dine, og du fokuserer på hva som er borte. Sorg er naturlig, men vurder hvilke ressurser som gjenstår."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Strata finansowa lub rozczarowanie. Pieniądze wymykają ci się z rąk, a ty skupiasz się na tym, co odeszło. Żal jest naturalny, ale oceń, jakie zasoby pozostały."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Perda financeira ou decepção. O dinheiro escorrega pelos seus dedos e você está focado no que se foi. O luto é natural, mas avalie quais recursos permanecem."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomisk förlust eller besvikelse. Pengar glider mellan fingrarna på dig och du fokuserar på vad som är borta. Sorg är naturligt, men bedöm vilka resurser som finns kvar."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансова втрата або розчарування. Гроші вислизають крізь пальці, і ви зосереджені на тому, що пішло. Горе природне, але оцініть, які ресурси залишилися."
          }
        }
      }
    },
    "interpretation.five_of_cups_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Heilung, Vergebung und Weitergehen. Du beginnst, über den Verlust hinauszusehen. Akzeptanz bringt Frieden. Die Trauer lässt nach und du findest deinen Weg nach vorne."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Healing, forgiveness, and moving on. You're beginning to see past the loss. Acceptance brings peace. The grief is subsiding and you're finding your way forward."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sanación, perdón y seguir adelante. Estás empezando a ver más allá de la pérdida. La aceptación trae paz. El dolor está disminuyendo y estás encontrando tu camino hacia adelante."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Guérison, pardon et passage à autre chose. Vous commencez à voir au-delà de la perte. L'acceptation apporte la paix. Le chagrin s'atténue et vous trouvez votre chemin vers l'avant."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Guarigione, perdono e andare avanti. Stai iniziando a vedere oltre la perdita. L'accettazione porta pace. Il dolore si sta attenuando e stai trovando la tua strada."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "癒し、許し、そして前進。あなたは喪失を乗り越え始めています。受け入れが平和をもたらします。悲しみは静まり、あなたは前進する道を見つけています。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Helbredelse, tilgivelse og å gå videre. Du begynner å se forbi tapet. Aksept gir fred. Sorgen avtar, og du finner veien videre."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uzdrowienie, przebaczenie i pójście dalej. Zaczynasz widzieć poza stratą. Akceptacja przynosi spokój. Żal ustępuje i znajdujesz drogę naprzód."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cura, perdão e seguir em frente. Você está começando a ver além da perda. A aceitação traz paz. O luto está diminuindo e você está encontrando seu caminho para frente."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Läkning, förlåtelse och att gå vidare. Du börjar se bortom förlusten. Acceptans ger frid. Sorgen avtar och du hittar din väg framåt."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Зцілення, прощення та рух далі. Ви починаєте бачити за межами втрати. Прийняття приносить спокій. Горе вщухає, і ви знаходите свій шлях вперед."
          }
        }
      }
    },
    "interpretation.five_of_cups_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verlust, Trauer und Enttäuschung dominieren deinen Fokus. Etwas ist zu Ende gegangen und du trauerst. Deine Gefühle sind berechtigt. Aber diese Karte erinnert dich: Nicht alles ist verloren. Zwei Becher stehen noch."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loss, grief, and disappointment dominate your focus. Something has ended and you're mourning. Your feelings are valid. But this card reminds you: not everything is lost. Two cups still stand."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pérdida, dolor y decepción dominan tu enfoque. Algo ha terminado y estás de duelo. Tus sentimientos son válidos. Pero esta carta te recuerda: no todo está perdido. Dos copas aún están en pie."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La perte, le chagrin et la déception dominent votre attention. Quelque chose est terminé et vous êtes en deuil. Vos sentiments sont valables. Mais cette carte vous le rappelle : tout n'est pas perdu. Deux coupes tiennent encore."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Perdita, dolore e delusione dominano la tua attenzione. Qualcosa è finito e sei in lutto. I tuoi sentimenti sono validi. Ma questa carta ti ricorda: non tutto è perduto. Due coppe sono ancora in piedi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "喪失、悲しみ、失望があなたの焦点を支配しています。何かが終わり、あなたは悼んでいます。あなたの気持ちは理解できます。しかし、このカードはあなたに思い出させます：すべてが失われたわけではありません。まだ2つのカップが立っています。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tap, sorg og skuffelse dominerer fokuset ditt. Noe er over, og du sørger. Følelsene dine er gyldige. Men dette kortet minner deg: ikke alt er tapt. To kopper står fortsatt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Strata, żal i rozczarowanie dominują w twoim skupieniu. Coś się skończyło i żałujesz. Twoje uczucia są uzasadnione. Ale ta karta przypomina ci: nie wszystko stracone. Dwa kielichy wciąż stoją."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Perda, luto e decepção dominam seu foco. Algo terminou e você está de luto. Seus sentimentos são válidos. Mas esta carta lembra: nem tudo está perdido. Dois cálices ainda estão de pé."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Förlust, sorg och besvikelse dominerar ditt fokus. Något har tagit slut och du sörjer. Dina känslor är giltiga. Men detta kort påminner dig: allt är inte förlorat. Två bägare står fortfarande."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Втрата, горе та розчарування домінують у вашому фокусі. Щось закінчилося, і ви сумуєте. Ваші почуття зрозумілі. Але ця карта нагадує вам: не все втрачено. Два келихи все ще стоять."
          }
        }
      }
    },
    "interpretation.five_of_cups_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gesundheitliche Akzeptanz und emotionale Heilung. Du schließt Frieden mit den Einschränkungen und siehst, was noch möglich ist. Hoffnung finden und im Wohlbefinden vorangehen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Health acceptance and emotional healing. You're making peace with limitations and seeing what's still possible. Finding hope and moving forward in wellness."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aceptación de la salud y sanación emocional. Te estás reconciliando con las limitaciones y viendo lo que aún es posible. Encontrando esperanza y avanzando en el bienestar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Acceptation de la santé et guérison émotionnelle. Vous faites la paix avec les limitations et voyez ce qui est encore possible. Trouver de l'espoir et aller de l'avant dans le bien-être."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Accettazione della salute e guarigione emotiva. Stai facendo pace con i limiti e vedendo cosa è ancora possibile. Trovare speranza e andare avanti nel benessere."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "健康の受容と感情的な癒し。あなたは限界を受け入れ、まだ何が可能かを見ています。希望を見つけ、健康へと前進します。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Helseaksept og emosjonell helbredelse. Du gjør fred med begrensninger og ser hva som fortsatt er mulig. Finner håp og går videre i velvære."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Akceptacja zdrowia i emocjonalne uzdrowienie. Godzisz się z ograniczeniami i widzisz, co jest jeszcze możliwe. Znajdujesz nadzieję i idziesz do przodu w dobrym samopoczuciu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aceitação da saúde e cura emocional. Você está fazendo as pazes com as limitações e vendo o que ainda é possível. Encontrando esperança e seguindo em frente no bem-estar."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hälsoacceptans och känslomässig läkning. Du gör upp med begränsningar och ser vad som fortfarande är möjligt. Hitta hopp och gå vidare i välbefinnande."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Прийняття здоров'я та емоційне зцілення. Ви миритеся з обмеженнями та бачите, що ще можливо. Знаходите надію та рухаєтесь далі до благополуччя."
          }
        }
      }
    },
    "interpretation.five_of_cups_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gesundheitliche Enttäuschung oder Trauer über körperliche Veränderungen. Du trauerst um verlorene Vitalität oder Wohlbefinden. Deine Gefühle sind berechtigt, aber übersehe nicht die verbleibenden Stärken deines Körpers."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Health disappointment or grief about physical changes. Mourning lost vitality or wellness. Your feelings are valid, but don't overlook your body's remaining strengths."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Decepción en la salud o dolor por cambios físicos. Lamentando la vitalidad o el bienestar perdidos. Tus sentimientos son válidos, pero no pases por alto las fortalezas restantes de tu cuerpo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Déception en matière de santé ou chagrin face aux changements physiques. Pleurer la vitalité ou le bien-être perdus. Vos sentiments sont valables, mais ne négligez pas les forces restantes de votre corps."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Delusione per la salute o dolore per i cambiamenti fisici. Piangere la vitalità o il benessere perduti. I tuoi sentimenti sono validi, ma non trascurare i punti di forza rimanenti del tuo corpo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "健康上の失望や身体の変化に対する悲しみ。失われた活力や健康を悼んでいます。あなたの気持ちは理解できますが、体に残っている強みを見落とさないでください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Helseskuffelse eller sorg over fysiske endringer. Sørger over tapt vitalitet eller velvære. Følelsene dine er gyldige, men ikke overse kroppens gjenværende styrker."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rozczarowanie zdrowotne lub żal z powodu zmian fizycznych. Opłakiwanie utraconej witalności lub dobrego samopoczucia. Twoje uczucia są uzasadnione, ale nie przeocz pozostałych mocnych stron swojego ciała."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Decepção com a saúde ou luto por mudanças físicas. Lamentando a vitalidade ou o bem-estar perdidos. Seus sentimentos são válidos, mas não ignore os pontos fortes restantes do seu corpo."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hälsosvikelse eller sorg över fysiska förändringar. Sörjer förlorad vitalitet eller välbefinnande. Dina känslor är giltiga, men förbise inte din kropps kvarvarande styrkor."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Розчарування у здоров'ї або горе через фізичні зміни. Оплакування втраченої життєвої сили або благополуччя. Ваші почуття зрозумілі, але не оминайте сильні сторони вашого тіла, що залишилися."
          }
        }
      }
    },
    "interpretation.five_of_cups_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Heilung von einem Liebesverlust. Du beginnst, weiterzugehen und wieder Hoffnung zu sehen. Vergebung – dir selbst und anderen – bringt Frieden. Das Schlimmste der Trauer geht vorbei."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Healing from romantic loss. You're beginning to move on and see hope again. Forgiveness—of self and others—brings peace. The worst of the grief is passing."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sanando de una pérdida romántica. Estás empezando a seguir adelante y a ver la esperanza nuevamente. El perdón, de uno mismo y de los demás, trae paz. Lo peor del dolor está pasando."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Guérison d'une perte amoureuse. Vous commencez à passer à autre chose et à revoir l'espoir. Le pardon – envers soi-même et les autres – apporte la paix. Le pire du chagrin est en train de passer."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Guarigione da una perdita romantica. Stai iniziando ad andare avanti e a rivedere la speranza. Il perdono, di te stesso e degli altri, porta pace. Il peggio del dolore sta passando."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "恋愛の喪失からの癒し。あなたは前に進み始め、再び希望を見ています。自分自身と他者への許しが平和をもたらします。悲しみの最悪の部分は過ぎ去っています。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Helbredelse fra romantisk tap. Du begynner å gå videre og se håp igjen. Tilgivelse – av deg selv og andre – bringer fred. Det verste av sorgen er i ferd med å gå over."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Leczenie się po stracie romantycznej. Zaczynasz iść dalej i znowu widzieć nadzieję. Przebaczenie – sobie i innym – przynosi spokój. Najgorszy żal mija."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cura de uma perda romântica. Você está começando a seguir em frente e ver esperança novamente. O perdão – de si mesmo e dos outros – traz paz. O pior do luto está passando."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Läkning från romantisk förlust. Du börjar gå vidare och se hopp igen. Förlåtelse – av dig själv och andra – ger frid. Det värsta av sorgen är på väg att gå över."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Зцілення від романтичної втрати. Ви починаєте рухатися далі й знову бачити надію. Прощення – себе та інших – приносить спокій. Найгірша частина горя минає."
          }
        }
      }
    },
    "interpretation.five_of_cups_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trauer und Enttäuschung in der Liebe. Du trauerst um das Verlorene und kannst noch nicht sehen, was bleibt. Ja, das tut weh. Aber dreh dich um – nicht alles ist weg."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Grief and disappointment in love. You're mourning what's lost and can't yet see what remains. Yes, this hurts. But turn around—not everything is gone."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dolor y decepción en el amor. Estás lamentando lo perdido y aún no puedes ver lo que queda. Sí, esto duele. Pero date la vuelta, no todo se ha ido."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chagrin et déception en amour. Vous pleurez ce qui est perdu et ne voyez pas encore ce qui reste. Oui, ça fait mal. Mais retournez-vous – tout n'est pas perdu."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dolore e delusione in amore. Stai piangendo ciò che è perduto e non riesci ancora a vedere ciò che rimane. Sì, fa male. Ma girati: non è tutto perduto."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "愛における悲しみと失望。あなたは失われたものを悼み、何が残っているのかまだ見えていません。はい、これは苦しいです。しかし振り返ってください―すべてが失われたわけではありません。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sorg og skuffelse i kjærlighet. Du sørger over det som er tapt og kan ennå ikke se hva som gjenstår. Ja, dette gjør vondt. Men snu deg – ikke alt er borte."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Żal i rozczarowanie w miłości. Opłakujesz to, co utracone, i nie możesz jeszcze zobaczyć, co pozostało. Tak, to boli. Ale odwróć się – nie wszystko stracone."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Luto e decepção no amor. Você está lamentando o que foi perdido e ainda não consegue ver o que resta. Sim, isso dói. Mas olhe ao redor – nem tudo se foi."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sorg och besvikelse i kärlek. Du sörjer det som förlorats och kan ännu inte se vad som återstår. Ja, det här gör ont. Men vänd dig om – allt är inte borta."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Горе та розчарування в коханні. Ви сумуєте за втраченим і ще не бачите, що залишилося. Так, це боляче. Але озирніться – не все втрачено."
          }
        }
      }
    },
    "interpretation.five_of_pentacles_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Berufliche Erholung und neue Hoffnung. Berufliche Unterstützung finden. Aus der Arbeitsplatznot herauskommen. Hilfe anzunehmen verbessert die Situation."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Career recovery and renewed hope. Finding professional support. Coming out of workplace hardship. Accepting help improves situation."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recuperación profesional y esperanza renovada. Encontrar apoyo profesional. Saliendo de las dificultades en el lugar de trabajo. Aceptar ayuda mejora la situación."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rétablissement professionnel et espoir renouvelé. Trouver un soutien professionnel. Sortir des difficultés au travail. Accepter de l'aide améliore la situation."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ripresa professionale e rinnovata speranza. Trovare supporto professionale. Uscire dalle difficoltà sul posto di lavoro. Accettare aiuto migliora la situazione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャリアの回復と新たな希望。専門的なサポートを見つける。職場の苦難から抜け出す。助けを受け入れることで状況が改善される。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karrierebedring og fornyet håp. Finne profesjonell støtte. Komme ut av vanskeligheter på jobb. Å akseptere hjelp forbedrer situasjonen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Powrót do zdrowia zawodowego i odnowiona nadzieja. Znalezienie wsparcia zawodowego. Wychodzenie z trudności w miejscu pracy. Akceptacja pomocy poprawia sytuację."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recuperação de carreira e esperança renovada. Encontrar apoio profissional. Saindo das dificuldades no local de trabalho. Aceitar ajuda melhora a situação."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriäråterhämtning och förnyat hopp. Hitta professionellt stöd. Komma ur arbetsplatsens svårigheter. Att acceptera hjälp förbättrar situationen."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Кар'єрне відновлення та оновлена надія. Знаходження професійної підтримки. Вихід з труднощів на робочому місці. Прийняття допомоги покращує ситуацію."
          }
        }
      }
    },
    "interpretation.five_of_pentacles_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Berufliche Schwierigkeiten und Isolation am Arbeitsplatz. Arbeitsplatzverlust oder finanzielle Not durch die Arbeit. Sie fühlen sich ausgeschlossen oder nicht unterstützt. Hilfe ist vorhanden, aber Sie müssen sie suchen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professional struggle and workplace isolation. Job loss or financial hardship from work. You feel excluded or unsupported. Help exists but you must seek it."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lucha profesional y aislamiento en el lugar de trabajo. Pérdida de empleo o dificultades financieras por el trabajo. Te sientes excluido o sin apoyo. La ayuda existe, pero debes buscarla."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lutte professionnelle et isolement sur le lieu de travail. Perte d'emploi ou difficultés financières liées au travail. Vous vous sentez exclu ou non soutenu. L'aide existe mais vous devez la chercher."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lotta professionale e isolamento sul posto di lavoro. Perdita del lavoro o difficoltà finanziarie dovute al lavoro. Ti senti escluso o non supportato. L'aiuto esiste ma devi cercarlo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "職業上の苦闘と職場での孤立。仕事による失業または経済的困難。あなたは排除されているか、サポートされていないと感じる。助けは存在するが、あなたはそれを求めなければならない。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profesjonell kamp og isolasjon på arbeidsplassen. Jobbtap eller økonomiske vanskeligheter fra jobb. Du føler deg ekskludert eller uønsket. Hjelp finnes, men du må søke den."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Walka zawodowa i izolacja w miejscu pracy. Utrata pracy lub trudności finansowe z pracy. Czujesz się wykluczony lub niewspierany. Pomoc istnieje, ale musisz jej szukać."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Luta profissional e isolamento no local de trabalho. Perda de emprego ou dificuldades financeiras no trabalho. Você se sente excluído ou sem apoio. A ajuda existe, mas você deve procurá-la."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professionell kamp och isolering på arbetsplatsen. Arbetsförlust eller ekonomiska svårigheter från arbetet. Du känner dig exkluderad eller utan stöd. Hjälp finns men du måste söka den."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Професійна боротьба та ізоляція на робочому місці. Втрата роботи або фінансові труднощі через роботу. Ви відчуваєте себе виключеним або непідтримуваним. Допомога існує, але ви повинні її шукати."
          }
        }
      }
    },
    "interpretation.five_of_pentacles_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Erholung und verbesserte Umstände. Unterstützung und Wohltätigkeit finden. Erneuerte Hoffnung in Bezug auf Geld. Hilfe anzunehmen stellt die Stabilität wieder her."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial recovery and improved circumstances. Finding support and charity. Renewed hope about money. Accepting help restores stability."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recuperación financiera y circunstancias mejoradas. Encontrar apoyo y caridad. Esperanza renovada en el dinero. Aceptar ayuda restablece la estabilidad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rétablissement financier et amélioration des circonstances. Trouver du soutien et de la charité. Espoir renouvelé concernant l'argent. Accepter de l'aide rétablit la stabilité."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ripresa finanziaria e circostanze migliorate. Trovare sostegno e beneficenza. Rinnovata speranza sul denaro. Accettare aiuto ripristina la stabilità."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的回復と状況の改善。サポートと慈善活動を見つける。お金に対する新たな希望。助けを受け入れることで安定が回復する。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk bedring og forbedrede omstendigheter. Finne støtte og veldedighet. Fornyet håp om penger. Å akseptere hjelp gjenoppretter stabilitet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Powrót do zdrowia finansowego i poprawa okoliczności. Znalezienie wsparcia i dobroczynności. Odnowiona nadzieja w kwestii pieniędzy. Akceptacja pomocy przywraca stabilność."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recuperação financeira e circunstâncias melhoradas. Encontrar apoio e caridade. Esperança renovada sobre dinheiro. Aceitar ajuda restaura a estabilidade."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomisk återhämtning och förbättrade omständigheter. Hitta stöd och välgörenhet. Förnyat hopp om pengar. Att acceptera hjälp återställer stabiliteten."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансове відновлення та покращення обставин. Знаходження підтримки та благодійності. Оновлена надія щодо грошей. Прийняття допомоги відновлює стабільність."
          }
        }
      }
    },
    "interpretation.five_of_pentacles_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Not und Verlust. Geldprobleme verursachen Stress. Sie fühlen sich verarmt, auch wenn Hilfe in der Nähe ist. Strecken Sie sich aus – Ressourcen und Unterstützung sind verfügbar."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial hardship and loss. Money struggles create stress. You feel impoverished even if help is nearby. Reach out—resources and support are available."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dificultades financieras y pérdidas. Las luchas económicas generan estrés. Te sientes empobrecido aunque la ayuda esté cerca. Acércate: los recursos y el apoyo están disponibles."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Difficultés financières et pertes. Les difficultés financières créent du stress. Vous vous sentez appauvri même si l'aide est proche. Tendez la main : les ressources et le soutien sont disponibles."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Difficoltà finanziarie e perdite. Le lotte con il denaro creano stress. Ti senti impoverito anche se l'aiuto è vicino. Contatta: risorse e supporto sono disponibili."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的困難と損失。金銭的な苦労がストレスを生む。助けが近くにあっても、あなたは貧しく感じる。手を差し伸べよ - リソースとサポートが利用可能です。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomiske vanskeligheter og tap. Pengeproblemer skaper stress. Du føler deg fattig selv om hjelp er i nærheten. Rekk ut – ressurser og støtte er tilgjengelig."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trudności finansowe i straty. Walka z pieniędzmi powoduje stres. Czujesz się zubożały, nawet jeśli pomoc jest w pobliżu. Wyciągnij rękę – zasoby i wsparcie są dostępne."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dificuldades financeiras e perdas. Lutas com dinheiro criam estresse. Você se sente empobrecido, mesmo que a ajuda esteja próxima. Estenda a mão – recursos e apoio estão disponíveis."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomiska svårigheter och förlust. Pengaproblem skapar stress. Du känner dig fattig även om hjälp finns i närheten. Räck ut – resurser och stöd finns tillgängliga."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансові труднощі та втрати. Боротьба з грошима створює стрес. Ви почуваєтеся збіднілим, навіть якщо допомога поруч. Зверніться – ресурси та підтримка доступні."
          }
        }
      }
    },
    "interpretation.five_of_pentacles_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erholung, neue Hoffnung und Unterstützung finden. Sie überwinden die Not. Hilfe und Wohltätigkeit anzunehmen stellt Sie wieder her. Das Schlimmste liegt hinter Ihnen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recovery, renewed hope, and finding support. You're coming through hardship. Accepting help and charity restores you. The worst is behind you."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recuperación, esperanza renovada y encontrar apoyo. Estás superando las dificultades. Aceptar ayuda y caridad te restaura. Lo peor ha quedado atrás."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rétablissement, espoir renouvelé et recherche de soutien. Vous sortez des difficultés. Accepter l'aide et la charité vous restaure. Le pire est derrière vous."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ripresa, rinnovata speranza e ricerca di supporto. Stai uscendo dalle difficoltà. Accettare aiuto e beneficenza ti ripristina. Il peggio è alle tue spalle."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "回復、新たな希望、サポートの発見。あなたは困難を乗り越えつつある。助けと慈善を受け入れることであなたは回復する。最悪の事態は過ぎ去った。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bedring, fornyet håp og finne støtte. Du kommer gjennom vanskelighetene. Å akseptere hjelp og veldedighet gjenoppretter deg. Det verste er bak deg."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Powrót do zdrowia, odnowiona nadzieja i znalezienie wsparcia. Przechodzisz przez trudności. Akceptacja pomocy i dobroczynności przywraca cię. Najgorsze jest za tobą."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recuperação, esperança renovada e encontrar apoio. Você está superando as dificuldades. Aceitar ajuda e caridade restaura você. O pior ficou para trás."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Återhämtning, förnyat hopp och att hitta stöd. Du kommer igenom svårigheterna. Att acceptera hjälp och välgörenhet återställer dig. Det värsta är bakom dig."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Відновлення, оновлена надія та знаходження підтримки. Ви долаєте труднощі. Прийняття допомоги та благодійності відновлює вас. Найгірше позаду."
          }
        }
      }
    },
    "interpretation.five_of_pentacles_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzieller Verlust, Not, Isolation und Kampf. Sie befinden sich in einer schwierigen Zeit und fühlen sich allein. Aber hier ist die Wahrheit: Hilfe existiert. Suchen Sie das erleuchtete Fenster in der Nähe."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial loss, hardship, isolation, and struggle. You're in a difficult time and feel alone in it. But here's the truth: help exists. Look for the lighted window nearby."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pérdida financiera, dificultades, aislamiento y lucha. Estás en un momento difícil y te sientes solo. Pero aquí está la verdad: la ayuda existe. Busca la ventana iluminada cercana."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Perte financière, difficultés, isolement et lutte. Vous traversez une période difficile et vous vous sentez seul. Mais voici la vérité : l'aide existe. Cherchez la fenêtre éclairée à proximité."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Perdita finanziaria, difficoltà, isolamento e lotta. Stai attraversando un momento difficile e ti senti solo. Ma ecco la verità: l'aiuto esiste. Cerca la finestra illuminata nelle vicinanze."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的損失、困難、孤立、苦闘。あなたは困難な時期にあり、孤独を感じている。しかし真実はこうだ：助けは存在する。近くの明るい窓を探しなさい。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk tap, vanskeligheter, isolasjon og kamp. Du er i en vanskelig tid og føler deg alene. Men her er sannheten: hjelp finnes. Se etter det opplyste vinduet i nærheten."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Strata finansowa, trudności, izolacja i walka. Przechodzisz trudny okres i czujesz się samotny. Ale oto prawda: pomoc istnieje. Poszukaj oświetlonego okna w pobliżu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Perda financeira, dificuldade, isolamento e luta. Você está em um momento difícil e se sente sozinho. Mas aqui está a verdade: a ajuda existe. Procure a janela iluminada nas proximidades."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomisk förlust, svårigheter, isolering och kamp. Du befinner dig i en svår tid och känner dig ensam. Men här är sanningen: hjälp finns. Leta efter det upplysta fönstret i närheten."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансові втрати, труднощі, ізоляція та боротьба. Ви перебуваєте у важкий час і почуваєтеся самотніми. Але ось правда: допомога існує. Шукайте освітлене вікно поруч."
          }
        }
      }
    },
    "interpretation.five_of_pentacles_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gesundheitliche Erholung und neue Hoffnung. Medizinische Unterstützung und Heilungsressourcen finden. Die Krankheit überwinden. Hilfe anzunehmen verbessert das Wohlbefinden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Health recovery and renewed hope. Finding medical support and healing resources. Coming through illness. Accepting help improves wellness."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recuperación de la salud y esperanza renovada. Encontrar apoyo médico y recursos curativos. Superando la enfermedad. Aceptar ayuda mejora el bienestar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rétablissement de la santé et espoir renouvelé. Trouver un soutien médical et des ressources de guérison. Sortir de la maladie. Accepter de l'aide améliore le bien-être."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ripresa della salute e rinnovata speranza. Trovare supporto medico e risorse curative. Superare la malattia. Accettare aiuto migliora il benessere."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "健康の回復と新たな希望。医療サポートと癒しのリソースを見つける。病気を乗り越える。助けを受け入れることで健康が改善される。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Helsebedring og fornyet håp. Finne medisinsk støtte og helbredelsesressurser. Komme gjennom sykdom. Å akseptere hjelp forbedrer velvære."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Powrót do zdrowia i odnowiona nadzieja. Znalezienie wsparcia medycznego i zasobów leczniczych. Przechodzenie przez chorobę. Akceptacja pomocy poprawia samopoczucie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recuperação de saúde e esperança renovada. Encontrar apoio médico e recursos de cura. Superando a doença. Aceitar ajuda melhora o bem-estar."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hälsoåterhämtning och förnyat hopp. Hitta medicinskt stöd och läkningsresurser. Komma igenom sjukdom. Att acceptera hjälp förbättrar välbefinnandet."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Відновлення здоров'я та оновлена надія. Знаходження медичної підтримки та ресурсів для зцілення. Подолання хвороби. Прийняття допомоги покращує благополуччя."
          }
        }
      }
    },
    "interpretation.five_of_pentacles_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gesundheitliche Probleme und körperliche Not. Sich in der Krankheit isoliert fühlen. Ressourcen für die Heilung sind vorhanden, aber Sie greifen nicht auf sie zu. Suchen Sie Unterstützung und Fürsorge."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Health struggles and physical hardship. Feeling isolated in illness. Resources for healing exist but you're not accessing them. Seek support and care."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Problemas de salud y dificultades físicas. Sintiéndose aislado en la enfermedad. Existen recursos para la curación pero no los estás utilizando. Busca apoyo y atención."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Problèmes de santé et difficultés physiques. Se sentir isolé dans la maladie. Des ressources pour la guérison existent mais vous n'y accédez pas. Cherchez du soutien et des soins."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lotte per la salute e difficoltà fisiche. Sentirsi isolati nella malattia. Esistono risorse per la guarigione ma non vi accedi. Cerca supporto e cura."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "健康上の苦闘と身体的な困難。病気の中で孤立していると感じる。癒しのためのリソースは存在するが、あなたはそれにアクセスしていない。サポートとケアを求めてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Helseproblemer og fysiske vanskeligheter. Føle seg isolert i sykdom. Ressurser for helbredelse finnes, men du bruker dem ikke. Søk støtte og omsorg."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Problemy zdrowotne i trudności fizyczne. Poczucie izolacji w chorobie. Zasoby uzdrawiania istnieją, ale nie korzystasz z nich. Szukaj wsparcia i opieki."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lutas de saúde e dificuldades físicas. Sentindo-se isolado na doença. Recursos para cura existem, mas você não está acessando-os. Busque apoio e cuidado."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hälsoproblem och fysiska svårigheter. Känna sig isolerad i sjukdom. Resurser för läkning finns men du använder dem inte. Sök stöd och vård."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Проблеми зі здоров'ям та фізичні труднощі. Відчуття ізоляції в хворобі. Ресурси для зцілення існують, але ви не звертаєтесь до них. Шукайте підтримку та турботу."
          }
        }
      }
    },
    "interpretation.five_of_pentacles_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erholung von Beziehungsnöten. Unterstützung und neue Hoffnung in der Liebe finden. Aus der Kälte kommen. Hilfe anzunehmen stärkt die Partnerschaft."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recovery from relationship hardship. Finding support and renewed hope in love. Coming in from the cold. Accepting help strengthens partnership."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recuperación de las dificultades de la relación. Encontrar apoyo y renovada esperanza en el amor. Saliendo del frío. Aceptar ayuda fortalece la sociedad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rétablissement après des difficultés relationnelles. Trouver du soutien et un espoir renouvelé en amour. Sortir du froid. Accepter de l'aide renforce le partenariat."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ripresa dalle difficoltà relazionali. Trovare sostegno e rinnovata speranza nell'amore. Uscire dal freddo. Accettare aiuto rafforza la partnership."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "関係の困難からの回復。愛におけるサポートと新たな希望を見つける。寒さの中から入ってくる。助けを受け入れることでパートナーシップが強化される。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bedring fra forholdsproblemer. Finne støtte og fornyet håp i kjærligheten. Komme inn fra kulden. Å akseptere hjelp styrker partnerskapet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Powrót do zdrowia po trudnościach w związku. Znalezienie wsparcia i odnowionej nadziei w miłości. Wychodzenie z zimna. Akceptacja pomocy wzmacnia partnerstwo."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recuperação das dificuldades do relacionamento. Encontrar apoio e esperança renovada no amor. Saindo do frio. Aceitar ajuda fortalece a parceria."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Återhämtning från relationssvårigheter. Hitta stöd och förnyat hopp i kärleken. Komma in från kylan. Att acceptera hjälp stärker partnerskapet."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Відновлення після труднощів у стосунках. Знаходження підтримки та оновленої надії в любові. Повернення з холоду. Прийняття допомоги зміцнює партнерство."
          }
        }
      }
    },
    "interpretation.five_of_pentacles_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beziehungskämpfe und das Gefühl, im Regen stehen gelassen zu werden. Finanzieller Stress beeinträchtigt die Liebe. Isolation in der Partnerschaft. Hilfe ist verfügbar, aber Sie sehen sie nicht. Suchen Sie das Licht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Relationship struggles and feeling left out in the cold. Financial stress affects love. Isolation in partnership. Help is available but you're not seeing it. Look for the light."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Problemas en la relación y sensación de quedarse fuera. El estrés financiero afecta al amor. Aislamiento en la sociedad. La ayuda está disponible pero no la estás viendo. Busca la luz."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Difficultés relationnelles et sentiment d'être laissé de côté. Le stress financier affecte l'amour. Isolement dans le partenariat. De l'aide est disponible mais vous ne la voyez pas. Cherchez la lumière."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lotte relazionali e sensazione di essere lasciato fuori al freddo. Lo stress finanziario influisce sull'amore. Isolamento nella partnership. L'aiuto è disponibile ma non lo vedi. Cerca la luce."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "関係の苦闘と、見捨てられたと感じること。経済的ストレスが愛に影響。パートナーシップにおける孤独。助けは利用できるが、あなたはそれを見ていない。光を探しなさい。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Forholdsproblemer og følelse av å bli stående i kulden. Økonomisk stress påvirker kjærligheten. Isolasjon i partnerskapet. Hjelp er tilgjengelig, men du ser det ikke. Se etter lyset."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Problemy w związku i poczucie bycia pozostawionym na lodzie. Stres finansowy wpływa na miłość. Izolacja w partnerstwie. Pomoc jest dostępna, ale jej nie widzisz. Szukaj światła."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lutas no relacionamento e sensação de ser deixado de fora. O estresse financeiro afeta o amor. Isolamento na parceria. A ajuda está disponível, mas você não está vendo. Procure a luz."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Relationsproblem och känsla av att lämnas ute i kylan. Ekonomisk stress påverkar kärleken. Isolering i partnerskapet. Hjälp finns tillgänglig men du ser det inte. Leta efter ljuset."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Проблеми у стосунках і відчуття, що вас залишили на холоді. Фінансовий стрес впливає на любов. Ізоляція в партнерстві. Допомога доступна, але ви її не бачите. Шукайте світло."
          }
        }
      }
    },
    "interpretation.five_of_swords_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Arbeitsplatzversöhnung oder berufliche Wiedergutmachung. Abschied vom Karrierekonflikt. Kompromiss und Zusammenarbeit kehren zurück."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Workplace reconciliation or making professional amends. Moving on from career conflict. Compromise and cooperation return."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reconciliación en el lugar de trabajo o reparación profesional. Superar el conflicto profesional. El compromiso y la cooperación regresan."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Réconciliation sur le lieu de travail ou réparation professionnelle. Surmonter les conflits de carrière. Le compromis et la coopération reviennent."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Riconciliazione sul posto di lavoro o riparazione professionale. Andare oltre il conflitto professionale. Compromesso e cooperazione tornano."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "職場での和解または仕事上の償い。キャリアの葛藤から前進する。妥協と協力が戻る。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Forlik på arbeidsplassen eller profesjonell oppreisning. Gå videre fra karrierekonflikt. Kompromiss og samarbeid kommer tilbake."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pojednanie w miejscu pracy lub zawodowe naprawienie błędów. Odejście od konfliktu zawodowego. Kompromis i współpraca wracają."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reconciliação no local de trabalho ou reparação profissional. Superando o conflito de carreira. Compromisso e cooperação retornam."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Försoning på arbetsplatsen eller professionell gottgörelse. Gå vidare från karriärkonflikt. Kompromiss och samarbete återvänder."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Примирення на робочому місці або професійне виправлення. Рух далі від кар'єрного конфлікту. Компроміс і співпраця повертаються."
          }
        }
      }
    },
    "interpretation.five_of_swords_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beruflicher Konflikt und Arbeitsplatzverrat. Sieg-um-jeden-Preis-Ansatz bei der Arbeit. Karriereerfolg, aber beschädigte Beziehungen. Überprüfe deine Methoden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professional conflict and workplace betrayal. Win-at-all-costs approach at work. Career victory but damaged relationships. Examine your methods."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conflicto profesional y traición en el trabajo. Enfoque de ganar a toda costa en el trabajo. Victoria profesional pero relaciones dañadas. Examina tus métodos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conflit professionnel et trahison au travail. Approche gagner à tout prix au travail. Victoire professionnelle mais relations endommagées. Examinez vos méthodes."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conflitto professionale e tradimento sul posto di lavoro. Approccio del vincere a tutti i costi al lavoro. Vittoria professionale ma relazioni danneggiate. Esamina i tuoi metodi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "仕事上の対立と職場での裏切り。仕事における勝利のためのアプローチ。キャリアの勝利だが、人間関係は損なわれる。自分の方法を検討せよ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profesjonell konflikt og svik på arbeidsplassen. Vinn-for-all-pris-tilnærming på jobb. Karriereseier men skadde relasjoner. Undersøk metodene dine."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Konflikt zawodowy i zdrada w miejscu pracy. Podejście zwycięstwa za wszelką cenę w pracy. Zwycięstwo w karierze, ale uszkodzone relacje. Sprawdź swoje metody."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conflito profissional e traição no local de trabalho. Abordagem de vencer a qualquer custo no trabalho. Vitória na carreira, mas relacionamentos prejudicados. Examine seus métodos."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professionell konflikt och svek på arbetsplatsen. Vinn-till-varje-pris-inställning på jobbet. Karriärseger men skadade relationer. Undersök dina metoder."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Професійний конфлікт і зрада на робочому місці. Підхід до перемоги за будь-яку ціну на роботі. Кар'єрна перемога, але зіпсовані стосунки. Перевірте свої методи."
          }
        }
      }
    },
    "interpretation.five_of_swords_finance_reversed" : {
