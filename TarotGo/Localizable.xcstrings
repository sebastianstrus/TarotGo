        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk bunn og smertefull penge-slutt. Ressurssvik og finansiell krise. Dette er det verste det kan bli – gjenoppbygging begynner her."
          }
