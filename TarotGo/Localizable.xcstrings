          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансове виснаження або грошова параноя. Боротьба з ресурсами без підтримки. Відмова від допомоги в процвітанні. Ледве тримаючись."
          }
        }
      }
    },
    "interpretation.nine_of_wands_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Resilienz und Geldbeharrlichkeit. Ressourcengrenzen nach Herausforderungen. Letzter Stand beim Wohlstand. Wachsam, aber nicht aufgeben."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial resilience and money persistence. Resource boundaries after challenges. Last stand with prosperity. Guarded but not giving up."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resiliencia financiera y persistencia monetaria. Límites de recursos después de los desafíos. Última resistencia con la prosperidad. Cauteloso pero sin rendirse."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Résilience financière et persistance monétaire. Limites de ressources après les défis. Dernier rempart avec la prospérité. Méfiant mais n'abandonnant pas."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resilienza finanziaria e persistenza monetaria. Limiti di risorse dopo le sfide. Ultima resistenza con la prosperità. Guardingo ma non arrendevole."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的な回復力とお金の粘り強さ。挑戦後のリソースの境界。繁栄での最後の抵抗。警戒しているがあきらめない。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk resiliens og pengeutholdenhet. Ressursgrenser etter utfordringer. Siste stand med velstand. Voktsom, men ikke gi opp."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odporność finansowa i wytrwałość pieniężna. Granice zasobów po wyzwaniach. Ostatnia walka z dobrobytem. Czujny, ale niepoddający się."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resiliência financeira e persistência monetária. Limites de recursos após desafios. Última resistência com a prosperidade. Cauteloso, mas não desistindo."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finansiell resiliens och penga uthållighet. Resursgränser efter utmaningar. Sista ståndet med välstånd. Försiktig men inte ge upp."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансова стійкість і грошова наполегливість. Межі ресурсів після викликів. Остання битва з процвітанням. Обережний, але не здається."
          }
        }
      }
    },
    "interpretation.nine_of_wands_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erschöpfung, Paranoia, Durchkämpfen und Hilfe verweigern. Du kannst kaum durchhalten. Nimm Unterstützung an. Du musst das nicht alleine schaffen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Exhaustion, paranoia, struggling on, and refusing help. You can barely hold on. Accept support. You don't have to do this alone."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Agotamiento, paranoia, luchando y negando ayuda. Apenas puedes aguantar. Acepta apoyo. No tienes que hacerlo solo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Épuisement, paranoïa, lutte et refus d'aide. Vous tenez à peine le coup. Acceptez le soutien. Vous n'avez pas à faire cela seul."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esaurimento, paranoia, lotta e rifiuto dell'aiuto. Riesci a malapena a resistere. Accetta il supporto. Non devi farlo da solo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "疲労、パラノイア、苦闘、そして助けの拒否。あなたはかろうじて持ちこたえている。サポートを受け入れなさい。これを一人でやる必要はない。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utmattelse, paranoia, slitende og nekte hjelp. Du så vidt holder ut. Godta støtte. Du trenger ikke gjøre dette alene."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wyczerpanie, paranoja, walka i odmowa pomocy. Ledwo się trzymasz. Zaakceptuj wsparcie. Nie musisz tego robić sam."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Exaustão, paranoia, lutando e recusando ajuda. Você mal consegue se segurar. Aceite apoio. Você não precisa fazer isso sozinho."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utmattning, paranoia, kämpa och vägra hjälp. Du håller knappt ut. Acceptera stöd. Du behöver inte göra detta ensam."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Виснаження, параноя, боротьба та відмова від допомоги. Ви ледве тримаєтеся. Прийміть підтримку. Вам не потрібно робити це наодинці."
          }
        }
      }
    },
    "interpretation.nine_of_wands_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resilienz, Beharrlichkeit, letzter Stand und Grenzen. Du bist kampfmüde, aber nicht besiegt. Noch ein letzter Stoß. Schütze dich, aber isoliere dich nicht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resilience, persistence, last stand, and boundaries. You're battle-weary but not beaten. One more push. Protect yourself but don't isolate."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resiliencia, persistencia, última resistencia y límites. Estás cansado de la batalla pero no vencido. Un último empujón. Protégete pero no te aísles."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Résilience, persistance, dernier rempart et limites. Vous êtes fatigué par la bataille mais pas vaincu. Un dernier effort. Protégez-vous mais ne vous isolez pas."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resilienza, persistenza, ultima resistenza e limiti. Sei stanco della battaglia ma non sconfitto. Un ultimo sforzo. Proteggiti ma non isolarti."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "回復力、粘り強さ、最後の抵抗、そして境界。あなたは戦いに疲れているが、打ち負かされてはいない。あと一押し。自分を守れ、しかし孤立するな。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resiliens, utholdenhet, siste stand og grenser. Du er krigstrøtt, men ikke slått. En siste push. Beskytt deg selv, men ikke isoler deg."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odporność, wytrwałość, ostatnia walka i granice. Jesteś zmęczony walką, ale nie pokonany. Jeszcze jeden pchnięcie. Chroń się, ale nie izoluj."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resiliência, persistência, última resistência e limites. Você está cansado da batalha, mas não derrotado. Mais um empurrão. Proteja-se, mas não se isole."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resiliens, uthållighet, sista stånd och gränser. Du är stridstrött men inte besegrad. En sista knuff. Skydda dig själv men isolera dig inte."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Стійкість, наполегливість, остання битва та межі. Ви втомлені від битви, але не переможені. Ще один поштовх. Захистіть себе, але не ізолюйтеся."
          }
        }
      }
    },
    "interpretation.nine_of_wands_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gesundheitserschöpfung oder Wellness-Paranoia. Mit dem Körper ohne Unterstützung kämpfen. Hilfe bei der Heilung verweigern. Kaum durchhalten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Health exhaustion or wellness paranoia. Struggling on with body without support. Refusing healing help. Barely holding on."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Agotamiento de salud o paranoia de bienestar. Luchando con el cuerpo sin apoyo. Negando ayuda en la curación. Apenas aguantando."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Épuisement de santé ou paranoïa du bien-être. Lutter avec le corps sans soutien. Refuser l'aide à la guérison. Tenant à peine le coup."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esaurimento della salute o paranoia del benessere. Lottare con il corpo senza supporto. Rifiutare l'aiuto alla guarigione. A malapena resistere."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "健康の疲労やウェルネスのパラノイア。サポートなしで身体に苦闘する。癒しの助けを拒否する。かろうじて持ちこたえている。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Helseutmattelse eller velværeparanoia. Slite med kroppen uten støtte. Nekte helbredelseshjelp. Så vidt holde ut."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wyczerpanie zdrowotne lub paranoja wellness. Walczenie z ciałem bez wsparcia. Odmawianie pomocy w uzdrawianiu. Ledwo się trzymając."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Exaustão na saúde ou paranoia de bem-estar. Lutando com o corpo sem apoio. Recusando ajuda na cura. Mal se segurando."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hälso utmattning eller välmående paranoia. Kämpa med kroppen utan stöd. Vägra läkningshjälp. Hålla knappt ut."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Виснаження здоров'я або параноя благополуччя. Боротьба з тілом без підтримки. Відмова від допомоги в зціленні. Ледве тримаючись."
          }
        }
      }
    },
