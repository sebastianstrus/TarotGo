            "value" : "Unikanie rzeczywistości zdrowotnej lub surowa samoocena ciała. Odmowa uczenia się z przeszłych wzorców zdrowotnych. Samokrytyka blokuje leczenie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Evitar a realidade da saúde ou julgamento severo do corpo. Recusar-se a aprender com padrões de saúde passados. A autocrítica bloqueia a cura."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Undvika hälsa verklighet eller hård kroppsbedömning. Vägra att lära av tidigare hälsomönster. Självkritik blockerar läkning."
