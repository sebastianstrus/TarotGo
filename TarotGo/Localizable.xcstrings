    "cardOfDay.centerYourself": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Take a moment to center yourself"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nimm dir einen Moment zum Zentrieren"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tómate un momento para centrarte"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Prenez un moment pour vous centrer"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Prenditi un momento per centrarti"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "少し時間をとって心を落ち着けて"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Ta et øyeblikk for å sentrere deg"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Poświęć chwilę na skoncentrowanie się"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Reserve um momento para se centrar"
          }
        },
