    "interpretation.knight_of_cups_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Berufliche Launenhaftigkeit oder unrealistische Karriereerwartungen. Emotionen überlagern das professionelle Urteilsvermögen. Drama bei der Arbeit. Mehr Bodenhaftung ist nötig."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professional moodiness or unrealistic career expectations. Letting emotions override professional judgment. Drama at work. Need for more grounding."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mal humor profesional o expectativas profesionales poco realistas. Dejar que las emociones anulen el juicio profesional. Drama en el trabajo. Necesidad de más estabilidad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mauvaise humeur professionnelle ou attentes de carrière irréalistes. Laisser les émotions outrepasser le jugement professionnel. Drame au travail. Besoin de plus d'ancrage."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sbalzi d'umore professionali o aspettative di carriera irrealistiche. Lasciare che le emozioni prevalgano sul giudizio professionale. Dramma sul lavoro. Necessità di maggior radicamento."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "仕事上の気分のむらや非現実的なキャリア期待。感情が専門的な判断を上回らせる。職場でのドラマ。より地に足をつける必要がある。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profesjonelle humørsvingninger eller urealistiske karriereforventninger. La følelser overstyre faglig dømmekraft. Drama på jobb. Behov for mer jording."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profesjonalne wahania nastroju lub nierealistyczne oczekiwania zawodowe. Pozwalanie, by emocje przeważały nad osądem zawodowym. Dramat w pracy. Potrzeba większego ugruntowania."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mau humor profissional ou expectativas de carreira irreais. Deixar emoções sobreporem o julgamento profissional. Drama no trabalho. Necessidade de mais firmeza."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professionella humörsvängningar eller orealistiska karriärförväntningar. Låta känslor åsidosätta professionellt omdöme. Drama på jobbet. Behov av mer jordning."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Професійна примхливість або нереалістичні кар'єрні очікування. Дозвіл емоціям переважати професійне судження. Драма на роботі. Потреба в більшому заземленні."
          }
        }
      }
    },
    "interpretation.knight_of_cups_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Folge deinem Herzen bei Karriereentscheidungen. Kreative berufliche Verfolgung, angetrieben von Leidenschaft. Charmante berufliche Möglichkeiten kommen. Deiner Fantasie dient deiner Arbeit."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Following your heart in career decisions. Creative professional pursuit driven by passion. Charming professional opportunities arrive. Imagination serves your work."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seguir tu corazón en las decisiones profesionales. Búsqueda profesional creativa impulsada por la pasión. Llegan oportunidades profesionales encantadoras. La imaginación sirve a tu trabajo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Suivre votre cœur dans les décisions de carrière. Poursuite professionnelle créative motivée par la passion. Des opportunités professionnelles charmantes arrivent. L'imagination sert votre travail."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seguire il cuore nelle decisioni di carriera. Inseguimento professionale creativo guidato dalla passione. Arrivano affascinanti opportunità professionali. L'immaginazione serve il tuo lavoro."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャリアの決断で心に従う。情熱に駆られた創造的な職業追求。魅力的な仕事の機会が訪れる。想像力が仕事に役立つ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Følg hjertet ditt i karrierebeslutninger. Kreativ profesjonell forfølgelse drevet av lidenskap. Sjarmerende profesjonelle muligheter kommer. Fantasien tjener arbeidet ditt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Podążanie za sercem w decyzjach zawodowych. Kreatywne dążenie zawodowe napędzane pasją. Pojawiają się urocze możliwości zawodowe. Wyobraźnia służy twojej pracy."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seguir seu coração nas decisões de carreira. Busca profissional criativa impulsionada pela paixão. Oportunidades profissionais encantadoras chegam. Imaginação serve ao seu trabalho."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Följ ditt hjärta i karriärbeslut. Kreativ professionell strävan driven av passion. Charmiga professionella möjligheter anländer. Fantasi tjänar ditt arbete."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Слідуйте своєму серцю в кар'єрних рішеннях. Творче професійне прагнення, кероване пристрастю. З'являються чарівні професійні можливості. Уява служить вашій роботі."
          }
        }
      }
    },
    "interpretation.knight_of_cups_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Emotionale finanzielle Entscheidungen haben keine Bodenhaftung. Unrealistische Gelderwartungen. Eifersucht auf den Wohlstand anderer. Ein praktischer finanzieller Ansatz ist nötig."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Emotional financial decisions lack grounding. Unrealistic money expectations. Jealousy about others' prosperity. Need practical financial approach."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las decisiones financieras emocionales carecen de fundamento. Expectativas de dinero poco realistas. Celos por la prosperidad de los demás. Necesitas un enfoque financiero práctico."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les décisions financières émotionnelles manquent d'ancrage. Attentes monétaires irréalistes. Jalousie envers la prospérité des autres. Besoin d'une approche financière pratique."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le decisioni finanziarie emotive mancano di radicamento. Aspettative di denaro irrealistiche. Gelosia per la prosperità altrui. Necessità di un approccio finanziario pratico."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "感情的な財政的判断には根拠がない。非現実的な金銭期待。他人の繁栄への嫉妬。実践的な財務アプローチが必要。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Følelsesmessige økonomiske beslutninger mangler jording. Urealistiske pengeforventninger. Sjalusi over andres velstand. Trenger praktisk økonomisk tilnærming."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Emocjonalne decyzje finansowe są nieugruntowane. Nierealistyczne oczekiwania pieniężne. Zazdrość o dobrobyt innych. Potrzebujesz praktycznego podejścia finansowego."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Decisões financeiras emocionais carecem de firmeza. Expectativas de dinheiro irreais. Ciúmes da prosperidade alheia. Necessidade de uma abordagem financeira prática."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Känslomässiga ekonomiska beslut saknar jordning. Orealistiska penningförväntningar. Avundsjuka över andras välstånd. Behov av praktisk ekonomisk inställning."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Емоційні фінансові рішення не мають підґрунтя. Нереалістичні грошові очікування. Заздрість до процвітання інших. Потрібен практичний фінансовий підхід."
          }
        }
      }
    },
    "interpretation.knight_of_cups_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Intuition bei finanziellen Entscheidungen folgen. Kreative Einkommensmöglichkeiten, angetrieben von Leidenschaft. Geld fließt durch herzliche Arbeit. Großzügigkeit und Wohlstand richten sich aus."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Following intuition in financial decisions. Creative income opportunities driven by passion. Money flows through heartfelt work. Generosity and prosperity align."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seguir la intuición en las decisiones financieras. Oportunidades de ingresos creativos impulsadas por la pasión. El dinero fluye a través del trabajo sincero. La generosidad y la prosperidad se alinean."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Suivre l'intuition dans les décisions financières. Opportunités de revenus créatives motivées par la passion. L'argent circule grâce à un travail sincère. La générosité et la prospérité s'alignent."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seguire l'intuito nelle decisioni finanziarie. Opportunità di reddito creative guidate dalla passione. Il denaro scorre attraverso il lavoro del cuore. Generosità e prosperità si allineano."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "財政的判断で直感に従う。情熱に駆られた創造的な収入機会。心からの仕事を通じてお金が流れる。寛大さと繁栄が調和する。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Følg intuisjonen i økonomiske beslutninger. Kreative inntektsmuligheter drevet av lidenskap. Penger flyter gjennom hjertelig arbeid. Generøsitet og velstand er i harmoni."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kierowanie się intuicją w decyzjach finansowych. Kreatywne możliwości zarobku napędzane pasją. Pieniądze płyną dzięki szczerej pracy. Hojność i dobrobyt idą w parze."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seguir a intuição nas decisões financeiras. Oportunidades de renda criativas impulsionadas pela paixão. Dinheiro flui através do trabalho de coração. Generosidade e prosperidade se alinham."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Följa intuition i ekonomiska beslut. Kreativa inkomstmöjligheter drivna av passion. Pengar flödar genom hjärtligt arbete. Generositet och välstånd är i linje."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Слідування інтуїції у фінансових рішеннях. Творчі можливості доходу, керовані пристрастю. Гроші течуть через щиру роботу. Щедрість та процвітання узгоджуються."
          }
        }
      }
    },
    "interpretation.knight_of_cups_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Launenhaftigkeit, unrealistische Erwartungen und emotionales Drama. Eifersucht und übermäßig emotionale Reaktionen. Du bist so sehr in Gefühlen gefangen, dass du den Bezug zur Realität verloren hast."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Moodiness, unrealistic expectations, and emotional drama. Jealousy and overemotional reactions. You're so swept up in feelings that you've lost touch with what's real."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mal humor, expectativas poco realistas y drama emocional. Celos y reacciones demasiado emocionales. Estás tan atrapado en los sentimientos que has perdido el contacto con lo real."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mauvaise humeur, attentes irréalistes et drame émotionnel. Jalousie et réactions trop émotionnelles. Vous êtes tellement emporté par vos sentiments que vous avez perdu le contact avec la réalité."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sbalzi d'umore, aspettative irrealistiche e dramma emotivo. Gelosia e reazioni eccessivamente emotive. Sei così preso dai sentimenti da aver perso il contatto con ciò che è reale."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "気分のむら、非現実的な期待、感情的なドラマ。嫉妬と過剰な感情的反応。あなたは感情に夢中になりすぎて、現実との接触を失っている。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Humørsvingninger, urealistiske forventninger og følelsesmessig drama. Sjalusi og overfølelsesmessige reaksjoner. Du er så oppslukt av følelser at du har mistet kontakten med det som er ekte."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zmienność nastrojów, nierealistyczne oczekiwania i emocjonalny dramat. Zazdrość i nadmiernie emocjonalne reakcje. Jesteś tak pochłonięty uczuciami, że straciłeś kontakt z rzeczywistością."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mau humor, expectativas irreais e drama emocional. Ciúmes e reações exageradas. Você está tão envolvido em sentimentos que perdeu o contato com o que é real."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Humörsvängningar, orealistiska förväntningar och känslomässigt drama. Svartsjuka och överdrivna känslomässiga reaktioner. Du är så uppslukad av känslor att du har tappat kontakten med det som är verkligt."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Перепади настрою, нереалістичні очікування та емоційна драма. Ревнощі та надмірно емоційні реакції. Ви настільки захоплені почуттями, що втратили зв'язок з реальністю."
          }
        }
      }
    },
    "interpretation.knight_of_cups_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Folge deinem Herzen, romantisches Werben und kreatives Handeln. Du lässt dich von Emotionen und Fantasie leiten. Das ist schön, aber stelle sicher, dass du auch in der Realität verankert bist."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Following your heart, romantic pursuit, and creative action. You're led by emotions and imagination. This is beautiful but ensure you're also grounded in reality."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seguir tu corazón, búsqueda romántica y acción creativa. Te guían las emociones y la imaginación. Esto es hermoso, pero asegúrate de estar también conectado con la realidad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Suivre votre cœur, poursuite romantique et action créative. Vous êtes guidé par les émotions et l'imagination. C'est beau, mais assurez-vous d'être également ancré dans la réalité."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seguire il cuore, inseguimento romantico e azione creativa. Sei guidato da emozioni e immaginazione. Questo è bello, ma assicurati di essere anche radicato nella realtà."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "心に従い、ロマンティックな追求と創造的行動。感情と想像力に導かれている。これは美しいことだが、現実にも足をつけていることを確認せよ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Følg hjertet ditt, romantisk forfølgelse og kreativ handling. Du ledes av følelser og fantasi. Dette er vakkert, men sørg for at du også er forankret i virkeligheten."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Podążanie za sercem, romantyczne zaloty i kreatywne działanie. Kierujesz się emocjami i wyobraźnią. To piękne, ale upewnij się, że jesteś też zakorzeniony w rzeczywistości."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seguir seu coração, busca romântica e ação criativa. Você é guiado por emoções e imaginação. Isso é lindo, mas certifique-se de estar também firme na realidade."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Följ ditt hjärta, romantisk jakt och kreativ handling. Du leds av känslor och fantasi. Det här är vackert, men se till att du också är förankrad i verkligheten."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Слідуйте своєму серцю, романтичні залицяння та творчі дії. Ви керуєтеся емоціями та уявою. Це прекрасно, але переконайтеся, що ви також заземлені в реальності."
          }
        }
      }
    },
    "interpretation.knight_of_cups_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stimmungsschwankungen beeinträchtigen die Gesundheit. Unrealistische Wellness-Erwartungen. Emotionales Essen oder Gesundheits-Eskapismus. Mehr bodenständige Selbstfürsorge ist nötig."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mood swings affect health. Unrealistic wellness expectations. Emotional eating or health escapism. Need more grounded self-care."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los cambios de humor afectan la salud. Expectativas de bienestar poco realistas. Comer emocional o escapismo de salud. Necesitas un cuidado personal más práctico."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les sautes d'humeur affectent la santé. Attentes de bien-être irréalistes. Alimentation émotionnelle ou évasion de la santé. Besoin de soins personnels plus ancrés."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gli sbalzi d'umore influiscono sulla salute. Aspettative di benessere irrealistiche. Alimentazione emotiva o evasione dalla salute. Necessità di una cura di sé più radicata."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "気分のむらが健康に影響。非現実的なウェルネス期待。感情的な食事や健康への逃避。より地に足のついたセルフケアが必要。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Humørsvingninger påvirker helsen. Urealistiske velværeforventninger. Emosjonell spising eller helse-eskapisme. Trenger mer jordet egenomsorg."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wahania nastroju wpływają na zdrowie. Nierealistyczne oczekiwania dotyczące dobrego samopoczucia. Jedzenie emocjonalne lub eskapizm zdrowotny. Potrzeba bardziej ugruntowanej samoopieki."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mudanças de humor afetam a saúde. Expectativas de bem-estar irreais. Comer emocional ou escapismo de saúde. Necessidade de autocuidado mais firme."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Humörsvängningar påverkar hälsan. Orealistiska välmående förväntningar. Känslomässigt ätande eller hälsoeskapism. Behov av mer jordad egenvård."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Перепади настрою впливають на здоров'я. Нереалістичні оздоровчі очікування. Емоційне харчування або ескапізм здоров'я. Потрібен більш заземлений самодогляд."
          }
        }
      }
    },
    "interpretation.knight_of_cups_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Folge deinem Herzen bei Wellness-Entscheidungen. Kreative, emotional gesteuerte Gesundheitsansätze. Dein Körper reagiert auf liebevolle Aufmerksamkeit. Intuitive Heilung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Following your heart in wellness choices. Creative, emotionally-driven health approaches. Your body responds to loving attention. Intuitive healing."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seguir tu corazón en las decisiones de bienestar. Enfoques de salud creativos y emocionales. Tu cuerpo responde a la atención amorosa. Sanación intuitiva."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Suivre votre cœur dans les choix de bien-être. Approches de santé créatives et émotionnelles. Votre corps répond à une attention aimante. Guérison intuitive."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seguire il cuore nelle scelte di benessere. Approcci sanitari creativi ed emotivi. Il tuo corpo risponde all'attenzione amorevole. Guarigione intuitiva."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ウェルネスの選択で心に従う。創造的で感情主導の健康法。あなたの体は愛情ある注意に反応する。直感的な癒し。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Følg hjertet ditt i velværevalg. Kreative, følelsesdrevne helsetilnærminger. Kroppen din reagerer på kjærlig oppmerksomhet. Intuitiv helbredelse."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Podążanie za sercem w wyborach dotyczących dobrego samopoczucia. Kreatywne, emocjonalne podejście do zdrowia. Twoje ciało reaguje na troskliwą uwagę. Intuicyjne uzdrawianie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seguir seu coração nas escolhas de bem-estar. Abordagens de saúde criativas e emocionais. Seu corpo responde à atenção amorosa. Cura intuitiva."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Följ ditt hjärta i välmåendeval. Kreativa, känslodrivna hälsotillvägagångssätt. Din kropp svarar på kärleksfull uppmärksamhet. Intuitiv läkning."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Слідуйте своєму серцю у виборі оздоровлення. Творчі, емоційно керовані підходи до здоров'я. Ваше тіло реагує на люблячу увагу. Інтуїтивне зцілення."
          }
        }
      }
    },
    "interpretation.knight_of_cups_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Launenhaftigkeit oder unrealistische romantische Erwartungen. Eifersucht und emotionale Manipulation in der Liebe. Jemand ist zu sehr in Fantasien vertieft, um die Realität zu sehen. Drama statt Substanz."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Moodiness or unrealistic romantic expectations. Jealousy and emotional manipulation in love. Someone's too swept up in fantasy to see reality. Drama over substance."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mal humor o expectativas románticas poco realistas. Celos y manipulación emocional en el amor. Alguien está demasiado absorto en la fantasía para ver la realidad. Drama sin sustancia."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mauvaise humeur ou attentes romantiques irréalistes. Jalousie et manipulation émotionnelle en amour. Quelqu'un est trop emporté par le fantasme pour voir la réalité. Le drame plutôt que le fond."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sbalzi d'umore o aspettative romantiche irrealistiche. Gelosia e manipolazione emotiva in amore. Qualcuno è troppo preso dalla fantasia per vedere la realtà. Dramma invece di sostanza."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "気分のむらや非現実的な恋愛期待。嫉妬と恋愛における感情的操作。誰かが現実を見るには空想に夢中になりすぎている。実質よりドラマ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Humørsvingninger eller urealistiske romantiske forventninger. Sjalusi og emosjonell manipulasjon i kjærlighet. Noen er for oppslukt av fantasi til å se virkeligheten. Drama over substans."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zmienność nastrojów lub nierealistyczne oczekiwania romantyczne. Zazdrość i manipulacja emocjonalna w miłości. Ktoś jest zbyt pochłonięty fantazją, by widzieć rzeczywistość. Dramat zamiast treści."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mau humor ou expectativas românticas irreais. Ciúmes e manipulação emocional no amor. Alguém está muito envolvido em fantasia para ver a realidade. Drama em vez de substância."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Humörsvängningar eller orealistiska romantiska förväntningar. Svartsjuka och känslomässig manipulation i kärlek. Någon är för uppslukad av fantasi för att se verkligheten. Drama över substans."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Перепади настрою або нереалістичні романтичні очікування. Ревнощі та емоційна маніпуляція в коханні. Хтось надто захоплений фантазією, щоб бачити реальність. Драма замість суті."
          }
        }
      }
    },
    "interpretation.knight_of_cups_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Romantisches Werben und dem Herzen in der Liebe folgen. Jemand macht emotionale Annäherungsversuche oder du bist in Romantik vertieft. Charme und Fantasie leiten die Liebe. Schöne Gefühle fließen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Romantic pursuit and following your heart in love. Someone is making emotional overtures or you're swept up in romance. Charm and imagination guide love. Beautiful feelings flow."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Persecución romántica y seguir tu corazón en el amor. Alguien está haciendo avances emocionales o te dejas llevar por el romance. El encanto y la imaginación guían el amor. Hermosos sentimientos fluyen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Poursuite romantique et suivre votre cœur en amour. Quelqu'un fait des avances émotionnelles ou vous êtes emporté par la romance. Le charme et l'imagination guident l'amour. De beaux sentiments coulent."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inseguimento romantico e seguire il cuore in amore. Qualcuno sta facendo avances emotive o sei travolto dal romanticismo. Fascino e immaginazione guidano l'amore. Bellissimi sentimenti fluiscono."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "恋愛におけるロマンティックな追跡と心の赴くままに。誰かが感情的な誘いをしているか、あなたは恋愛に夢中になっている。魅力と想像力が愛を導く。美しい感情が流れる。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Romantisk forfølgelse og følg hjertet ditt i kjærlighet. Noen gjør følelsesmessige tilnærmelser, eller du blir revet med av romantikk. Sjarm og fantasi styrer kjærligheten. Vakre følelser flyter."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Romantyczne zaloty i podążanie za sercem w miłości. Ktoś składa emocjonalne propozycje lub dajesz się ponieść romansowi. Urok i wyobraźnia kierują miłością. Piękne uczucia płyną."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Busca romântica e seguir seu coração no amor. Alguém está fazendo investidas emocionais ou você está envolvido em romance. Charme e imaginação guiam o amor. Belos sentimentos fluem."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Romantisk jakt och följa ditt hjärta i kärlek. Någon gör känslomässiga närmanden eller du sveps med i romantik. Charm och fantasi styr kärleken. Vackra känslor flödar."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Романтичні залицяння та слідування серцю в коханні. Хтось робить емоційні кроки, або ви захоплені романтикою. Чарівність і уява ведуть любов. Прекрасні почуття течуть."
          }
        }
      }
    },
    "interpretation.knight_of_pentacles_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Berufliche Faulheit oder Arbeitsbesessenheit. Perfektionismus verhindert beruflichen Fortschritt. Routine wird zur Sackgasse. Ungleichgewicht zwischen Arbeit und Leben durch berufliche Starrheit."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Career laziness or work obsessiveness. Perfectionism prevents professional progress. Routine becomes rut. Work-life imbalance from career rigidity."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pereza profesional u obsesión por el trabajo. El perfeccionismo impide el progreso profesional. La rutina se convierte en un callejón sin salida. Desequilibrio entre la vida laboral y personal debido a la rigidez profesional."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Paresse professionnelle ou obsession du travail. Le perfectionnisme empêche les progrès professionnels. La routine devient une ornière. Déséquilibre entre vie professionnelle et vie privée dû à la rigidité de carrière."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pigrizia professionale o ossessione per il lavoro. Il perfezionismo impedisce il progresso professionale. La routine diventa una routine noiosa. Squilibrio tra lavoro e vita privata dovuto alla rigidità della carriera."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャリアの怠惰または仕事への執着。完璧主義が職業的進歩を妨げる。ルーティンがルーチンワークになる。キャリアの硬直性によるワークライフバランスの不均衡。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karrierelathet eller arbeidsobsessivitet. Perfeksjonisme hindrer profesjonell fremgang. Rutine blir en fastlåst situasjon. Ubalanse mellom arbeid og liv på grunn av karriererigiditet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lenistwo zawodowe lub obsesja na punkcie pracy. Perfekcjonizm uniemożliwia postęp zawodowy. Rutyna staje się koleiną. Brak równowagi między pracą a życiem z powodu sztywności kariery."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Preguiça na carreira ou obsessão pelo trabalho. Perfeccionismo impede o progresso profissional. Rotina se torna um vício. Desequilíbrio entre trabalho e vida devido à rigidez da carreira."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriärslata eller arbetsbesatthet. Perfektionism hindrar professionella framsteg. Rutin blir en hjulspår. Obalans mellan arbete och liv på grund av karriärstelhet."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Кар'єрна лінь або одержимість роботою. Перфекціонізм перешкоджає професійному прогресу. Рутина стає колією. Дисбаланс між роботою та життям через кар'єрну ригідність."
          }
        }
      }
    },
    "interpretation.knight_of_pentacles_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zuverlässiger, fleißiger professioneller Ansatz. Stetiger Karrierefortschritt durch Routine und Hingabe. Konservativer, aber erfolgreicher Arbeitsstil. Verlässlichkeit dient Ihnen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reliable, hardworking professional approach. Steady career progress through routine and dedication. Conservative but successful work style. Dependability serves you."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enfoque profesional fiable y trabajador. Progreso profesional constante a través de la rutina y la dedicación. Estilo de trabajo conservador pero exitoso. La confiabilidad te sirve."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Approche professionnelle fiable et travailleuse. Progrès de carrière régulier grâce à la routine et au dévouement. Style de travail conservateur mais réussi. La fiabilité vous sert."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Approccio professionale affidabile e laborioso. Progresso costante della carriera attraverso la routine e la dedizione. Stile di lavoro conservatore ma di successo. L'affidabilità ti serve."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "信頼性が高く勤勉な専門的アプローチ。ルーティンと献身を通じた着実なキャリアの進歩。保守的だが成功する仕事スタイル。信頼性が役立つ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pålitelig, hardtarbeidende profesjonell tilnærming. Jevn karrierefremgang gjennom rutine og dedikasjon. Konservativ, men vellykket arbeidsstil. Pålitelighet tjener deg."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niezawodne, pracowite podejście zawodowe. Stały postęp w karierze dzięki rutynie i poświęceniu. Konserwatywny, ale skuteczny styl pracy. Niezawodność służy ci."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abordagem profissional confiável e trabalhadora. Progresso constante na carreira através da rotina e dedicação. Estilo de trabalho conservador, mas bem-sucedido. Confiabilidade serve a você."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pålitligt, hårt arbetande professionellt förhållningssätt. Stadig karriärframsteg genom rutin och hängivenhet. Konservativ men framgångsrik arbetsstil. Pålitlighet tjänar dig."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Надійний, працьовитий професійний підхід. Стабільний кар'єрний прогрес через рутину та відданість. Консервативний, але успішний стиль роботи. Надійність служить вам."
          }
        }
      }
    },
    "interpretation.knight_of_pentacles_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Faulheit oder Geldbesessenheit. Perfektionismus verhindert Wohlstand. Zu konservativ oder zu starr mit Ressourcen. Mehr Flexibilität ist nötig."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial laziness or money obsessiveness. Perfectionism prevents prosperity. Too conservative or too rigid with resources. Need more flexibility."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pereza financiera u obsesión por el dinero. El perfeccionismo impide la prosperidad. Demasiado conservador o demasiado rígido con los recursos. Se necesita más flexibilidad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Paresse financière ou obsession de l'argent. Le perfectionnisme empêche la prospérité. Trop conservateur ou trop rigide avec les ressources. Besoin de plus de flexibilité."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pigrizia finanziaria o ossessione del denaro. Il perfezionismo impedisce la prosperità. Troppo conservativo o troppo rigido con le risorse. Necessaria maggiore flessibilità."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的な怠惰またはお金への執着。完璧主義が繁栄を妨げる。リソースに対して保守的すぎるか硬直しすぎる。より多くの柔軟性が必要。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk latskap eller pengeobsessivitet. Perfeksjonisme hindrer velstand. For konservativ eller for rigid med ressurser. Trenger mer fleksibilitet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lenistwo finansowe lub obsesja na punkcie pieniędzy. Perfekcjonizm uniemożliwia dobrobyt. Zbyt konserwatywny lub zbyt sztywny w kwestii zasobów. Potrzeba więcej elastyczności."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Preguiça financeira ou obsessão por dinheiro. Perfeccionismo impede a prosperidade. Muito conservador ou muito rígido com recursos. Mais flexibilidade necessária."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomisk lathet eller penga besatthet. Perfektionism hindrar välstånd. För konservativ eller för stel med resurser. Behöver mer flexibilitet."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансова лінь або одержимість грошима. Перфекціонізм перешкоджає процвітанню. Занадто консервативний або занадто ригідний з ресурсами. Потрібна більша гнучкість."
          }
        }
      }
    },
    "interpretation.knight_of_pentacles_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zuverlässiger, konservativer finanzieller Ansatz. Stetiger Vermögensaufbau durch harte Arbeit und Routine. Geduldige Anlagestrategie. Zuverlässiges Geldmanagement."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reliable, conservative financial approach. Steady wealth building through hard work and routine. Patient investment strategy. Dependable money management."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enfoque financiero fiable y conservador. Construcción constante de riqueza a través del trabajo duro y la rutina. Estrategia de inversión paciente. Gestión del dinero fiable."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Approche financière fiable et conservatrice. Construction régulière de richesse grâce au travail acharné et à la routine. Stratégie d'investissement patiente. Gestion financière fiable."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Approccio finanziario affidabile e conservativo. Costruzione costante di ricchezza attraverso duro lavoro e routine. Strategia di investimento paziente. Gestione del denaro affidabile."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "信頼性が高く保守的な財務アプローチ。勤勉さとルーティンによる着実な富の構築。忍耐強い投資戦略。信頼できる資金管理。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pålitelig, konservativ finansiell tilnærming. Jevn rikdomsbygging gjennom hardt arbeid og rutine. Tålmodig investeringsstrategi. Pålitelig pengeforvaltning."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niezawodne, konserwatywne podejście finansowe. Stałe budowanie bogactwa poprzez ciężką pracę i rutynę. Cierpliwa strategia inwestycyjna. Niezawodne zarządzanie pieniędzmi."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abordagem financeira confiável e conservadora. Construção constante de riqueza através de trabalho duro e rotina. Estratégia de investimento paciente. Gestão de dinheiro confiável."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pålitlig, konservativ ekonomisk strategi. Stadig rikedomsbyggande genom hårt arbete och rutin. Tålmodig investeringsstrategi. Pålitlig pengehantering."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Надійний, консервативний фінансовий підхід. Стабільне накопичення багатства через важку працю та рутину. Терпляча інвестиційна стратегія. Надійне управління грошима."
          }
        }
      }
    },
    "interpretation.knight_of_pentacles_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Faulheit, Besessenheit, Ungleichgewicht zwischen Arbeit und Leben oder Perfektionismus. Sie bewegen sich entweder überhaupt nicht oder sind so starr, dass Sie sich nicht anpassen können. Finden Sie ein Gleichgewicht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Laziness, obsessiveness, work-life imbalance, or perfectionism. You're either not moving at all or so rigid you can't adapt. Find balance."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pereza, obsesión, desequilibrio entre la vida laboral y personal, o perfeccionismo. O no te mueves en absoluto o eres tan rígido que no puedes adaptarte. Encuentra el equilibrio."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Paresse, obsession, déséquilibre entre vie professionnelle et vie privée ou perfectionnisme. Vous ne bougez pas du tout ou vous êtes si rigide que vous ne pouvez pas vous adapter. Trouvez l'équilibre."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pigrizia, ossessività, squilibrio tra lavoro e vita privata o perfezionismo. O non ti muovi affatto o sei così rigido da non poterti adattare. Trova un equilibrio."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "怠惰、執着、ワークライフバランスの不均衡、または完璧主義。あなたは全く動いていないか、適応できないほど硬直している。バランスを見つけよ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Latskap, besettelse, ubalanse mellom arbeid og liv, eller perfeksjonisme. Du beveger deg enten ikke i det hele tatt eller er så rigid at du ikke kan tilpasse deg. Finn balanse."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lenistwo, obsesyjność, brak równowagi między pracą a życiem lub perfekcjonizm. Albo w ogóle się nie ruszasz, albo jesteś tak sztywny, że nie możesz się dostosować. Znajdź równowagę."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Preguiça, obsessividade, desequilíbrio entre trabalho e vida, ou perfeccionismo. Ou você não está se movendo ou é tão rígido que não consegue se adaptar. Encontre o equilíbrio."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lathet, besatthet, obalans mellan arbete och liv, eller perfektionism. Du rör dig antingen inte alls eller är så stel att du inte kan anpassa dig. Hitta balans."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Лінь, одержимість, дисбаланс між роботою та життям або перфекціонізм. Ви або взагалі не рухаєтесь, або настільки ригідні, що не можете адаптуватися. Знайдіть баланс."
          }
        }
      }
    },
    "interpretation.knight_of_pentacles_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zuverlässigkeit, harte Arbeit, Routine und konservativer Ansatz. Sie machen stetige, geduldige Fortschritte. Verlässlich und engagiert. Langsam, aber sicher gewinnt das Rennen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reliability, hard work, routine, and conservative approach. You're making steady, patient progress. Dependable and dedicated. Slow but sure wins the race."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fiabilidad, trabajo duro, rutina y enfoque conservador. Estás haciendo progresos constantes y pacientes. Fiable y dedicado. La carrera la gana el lento pero seguro."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fiabilité, travail acharné, routine et approche conservatrice. Vous faites des progrès constants et patients. Fiable et dévoué. Lent mais sûr, c'est ce qui gagne la course."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Affidabilità, duro lavoro, routine e approccio conservativo. Stai facendo progressi costanti e pazienti. Affidabile e dedicato. Lento ma sicuro vince la gara."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "信頼性、勤勉さ、ルーティン、そして保守的なアプローチ。あなたは着実に、忍耐強く進歩している。信頼でき、献身的である。遅くても確実に勝つ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pålitelighet, hardt arbeid, rutine og konservativ tilnærming. Du gjør jevne, tålmodige fremskritt. Pålitelig og dedikert. Sakte, men sikkert vinner kappløpet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niezawodność, ciężka praca, rutyna i konserwatywne podejście. Robisz stałe, cierpliwe postępy. Niezawodny i oddany. Powolny, ale pewny wygrywa wyścig."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confiabilidade, trabalho duro, rotina e abordagem conservadora. Você está fazendo progressos constantes e pacientes. Confiável e dedicado. Devagar e sempre vence a corrida."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pålitlighet, hårt arbete, rutin och konservativ strategi. Du gör stadiga, tålmodiga framsteg. Pålitlig och hängiven. Långsamt men säkert vinner loppet."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Надійність, важка праця, рутина та консервативний підхід. Ви робите стабільний, терплячий прогрес. Надійний та відданий. Повільно, але впевнено виграє гонку."
          }
        }
      }
    },
    "interpretation.knight_of_pentacles_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gesundheitliche Faulheit oder Wellness-Besessenheit. Perfektionismus in Bezug auf den Körper verhindert Fortschritte. Die Routine wird zur ungesunden Sackgasse. Ungleichgewicht zwischen Arbeit und Gesundheit."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Health laziness or wellness obsessiveness. Perfectionism about body prevents progress. Routine becomes unhealthy rut. Work-health imbalance."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pereza en la salud u obsesión por el bienestar. El perfeccionismo sobre el cuerpo impide el progreso. La rutina se convierte en un callejón sin salida poco saludable. Desequilibrio entre trabajo y salud."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Paresse de santé ou obsession du bien-être. Le perfectionnisme à propos du corps empêche les progrès. La routine devient une ornière malsaine. Déséquilibre entre travail et santé."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pigrizia della salute o ossessione del benessere. Il perfezionismo sul corpo impedisce il progresso. La routine diventa una routine malsana. Squilibrio tra lavoro e salute."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "健康の怠惰またはウェルネスへの執着。身体に対する完璧主義が進歩を妨げる。ルーティンが不健康な習慣になる。仕事と健康の不均衡。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Helselathet eller velværebesettelse. Perfeksjonisme om kroppen hindrer fremgang. Rutine blir en usunn fastlåst situasjon. Ubalanse mellom arbeid og helse."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lenistwo zdrowotne lub obsesja na punkcie wellness. Perfekcjonizm dotyczący ciała uniemożliwia postęp. Rutyna staje się niezdrową koleiną. Brak równowagi między pracą a zdrowiem."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Preguiça na saúde ou obsessão por bem-estar. Perfeccionismo sobre o corpo impede o progresso. Rotina se torna um vício prejudicial à saúde. Desequilíbrio entre trabalho e saúde."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hälsolata eller hälso- och välmåendebesatthet. Perfektionism kring kroppen hindrar framsteg. Rutin blir en ohälsosam hjulspår. Obalans mellan arbete och hälsa."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Лінь у здоров'ї або одержимість оздоровленням. Перфекціонізм щодо тіла перешкоджає прогресу. Рутина стає нездоровою колією. Дисбаланс між роботою та здоров'ям."
          }
        }
      }
    },
    "interpretation.knight_of_pentacles_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zuverlässiger, stetiger Wellness-Ansatz. Geduldige gesundheitliche Fortschritte durch Routine und harte Arbeit. Konservative, aber effektive Gesundheitspraktiken. Zuverlässigkeit dient dem Körper."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reliable, steady wellness approach. Patient health progress through routine and hard work. Conservative but effective health practices. Dependability serves body."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enfoque de bienestar fiable y constante. Progreso de salud paciente a través de la rutina y el trabajo duro. Prácticas de salud conservadoras pero efectivas. La confiabilidad sirve al cuerpo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Approche de bien-être fiable et régulière. Progrès de santé patient grâce à la routine et au travail acharné. Pratiques de santé conservatrices mais efficaces. La fiabilité sert le corps."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Approccio al benessere affidabile e costante. Progressi sanitari pazienti attraverso la routine e il duro lavoro. Pratiche sanitarie conservative ma efficaci. L'affidabilità serve il corpo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "信頼性が高く着実なウェルネスアプローチ。ルーティンと勤勉さによる忍耐強い健康の進歩。保守的だが効果的な健康習慣。信頼性が身体に役立つ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pålitelig, jevn velværetilnærming. Tålmodig helsefremskritt gjennom rutine og hardt arbeid. Konservative, men effektive helsepraksiser. Pålitelighet tjener kroppen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niezawodne, stałe podejście do wellness. Cierpliwe postępy zdrowotne poprzez rutynę i ciężką pracę. Konserwatywne, ale skuteczne praktyki zdrowotne. Niezawodność służy ciału."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abordagem de bem-estar confiável e constante. Progresso de saúde paciente através da rotina e trabalho duro. Práticas de saúde conservadoras, mas eficazes. Confiabilidade serve ao corpo."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pålitligt, stadigt hälso- och välmåendeförhållningssätt. Tålmodiga hälsoframsteg genom rutin och hårt arbete. Konservativa men effektiva hälsopraxis. Pålitlighet tjänar kroppen."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Надійний, стабільний оздоровчий підхід. Терплячий прогрес здоров'я через рутину та важку працю. Консервативні, але ефективні оздоровчі практики. Надійність служить тілу."
          }
        }
      }
    },
    "interpretation.knight_of_pentacles_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beziehungsträgheit oder zwanghafte Routine. Ungleichgewicht zwischen Arbeit und Leben beeinträchtigt die Liebe. Perfektionismus verhindert Fortschritte in der Partnerschaft. Zu langsam oder zu starr in der Liebe."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Relationship laziness or obsessive routine. Work-life imbalance affects love. Perfectionism prevents partnership progress. Too slow or too rigid in love."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pereza en la relación o rutina obsesiva. El desequilibrio entre el trabajo y la vida afecta al amor. El perfeccionismo impide el progreso de la sociedad. Demasiado lento o demasiado rígido en el amor."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Paresse relationnelle ou routine obsessionnelle. Le déséquilibre entre vie professionnelle et vie privée affecte l'amour. Le perfectionnisme empêche les progrès du partenariat. Trop lent ou trop rigide en amour."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pigrizia relazionale o routine ossessiva. Lo squilibrio tra lavoro e vita privata influisce sull'amore. Il perfezionismo impedisce i progressi della partnership. Troppo lento o troppo rigido in amore."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "関係における怠惰または強迫的なルーティン。ワークライフバランスの不均衡が愛に影響。完璧主義がパートナーシップの進歩を妨げる。愛において遅すぎるか硬直しすぎる。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Forholdslathet eller tvangspreget rutine. Ubalanse mellom arbeid og liv påvirker kjærligheten. Perfeksjonisme hindrer partnerskapsfremgang. For sakte eller for rigid i kjærlighet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lenistwo w związku lub obsesyjna rutyna. Brak równowagi między pracą a życiem wpływa na miłość. Perfekcjonizm uniemożliwia postęp w partnerstwie. Zbyt wolny lub zbyt sztywny w miłości."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Preguiça no relacionamento ou rotina obsessiva. Desequilíbrio entre trabalho e vida afeta o amor. Perfeccionismo impede o progresso da parceria. Muito lento ou muito rígido no amor."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Relationslata eller tvångsmässig rutin. Obalans mellan arbete och liv påverkar kärleken. Perfektionism hindrar partnerskapsframsteg. För långsam eller för stel i kärlek."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Лінощі у стосунках або нав'язлива рутина. Дисбаланс між роботою та життям впливає на любов. Перфекціонізм перешкоджає прогресу партнерства. Занадто повільний або занадто ригідний у любові."
          }
        }
      }
    },
    "interpretation.knight_of_pentacles_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zuverlässiger, stetiger und fleißiger Ansatz in der Beziehung. Geduldige Werbung und verlässliche Partnerschaft. Routine schafft Sicherheit in der Liebe. Langsamer, aber sicherer Fortschritt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reliable, steady, and hardworking approach to relationship. Patient courtship and dependable partnership. Routine creates security in love. Slow but sure progress."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enfoque confiable, constante y trabajador en la relación. Cortejo paciente y sociedad fiable. La rutina crea seguridad en el amor. Progreso lento pero seguro."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Approche fiable, régulière et travailleuse de la relation. Cour patient et partenariat fiable. La routine crée la sécurité en amour. Progrès lent mais sûr."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Approccio affidabile, costante e laborioso alla relazione. Corteggiamento paziente e partnership affidabile. La routine crea sicurezza nell'amore. Progressi lenti ma sicuri."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "関係に対する信頼性が高く、着実で勤勉なアプローチ。忍耐強い求愛と信頼できるパートナーシップ。ルーティンが愛に安心感をもたらす。遅いが確実な進歩。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pålitelig, jevn og hardtarbeidende tilnærming til forhold. Tålmodig frieri og pålitelig partnerskap. Rutine skaper trygghet i kjærligheten. Sakte, men sikker fremgang."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niezawodne, stałe i pracowite podejście do związku. Cierpliwe zaloty i niezawodne partnerstwo. Rutyna tworzy bezpieczeństwo w miłości. Wolny, ale pewny postęp."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abordagem confiável, constante e trabalhadora para o relacionamento. Namoro paciente e parceria confiável. Rotina cria segurança no amor. Progresso lento, mas seguro."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pålitligt, stadigt och hårt arbetande förhållningssätt till relationen. Tålmodig uppvaktning och pålitligt partnerskap. Rutin skapar trygghet i kärleken. Långsam men säker framsteg."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Надійний, стабільний та працьовитий підхід до стосунків. Терплячі залицяння та надійне партнерство. Рутина створює безпеку в любові. Повільний, але впевнений прогрес."
          }
        }
      }
    },
    "interpretation.knight_of_swords_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rücksichtslose Karriereschritte oder berufliche Ungeduld. Unfokussierte Arbeitsenergie. Impulsive Arbeitsentscheidungen. Verlangsame und strategiere."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reckless career moves or professional impatience. Unfocused work energy. Impulsive job decisions. Slow down and strategize."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Movimientos profesionales imprudentes o impaciencia profesional. Energía laboral sin enfoque. Decisiones laborales impulsivas. Reduce la velocidad y estratega."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mouvements de carrière imprudents ou impatience professionnelle. Énergie de travail non focalisée. Décisions professionnelles impulsives. Ralentissez et stratégisez."
