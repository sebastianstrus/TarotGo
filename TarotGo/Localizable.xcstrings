          }
        }
      }
    },
    "interpretation.ten_of_wands_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beziehungsbelastung und romantische Verantwortung. Liebe fühlt sich schwer an. Partnerschaft erfordert harte Arbeit. Zu viel in der Verbindung übernehmen. Stress beeinträchtigt die Intimität."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Relationship burden and romantic responsibility. Love feels heavy. Partnership requires hard work. Taking on too much in connection. Stress affects intimacy."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carga en la relación y responsabilidad romántica. El amor se siente pesado. La pareja requiere trabajo duro. Asumiendo demasiado en la conexión. El estrés afecta la intimidad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fardeau relationnel et responsabilité romantique. L'amour semble lourd. Le partenariat exige un travail acharné. En prendre trop dans la connexion. Le stress affecte l'intimité."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fardello della relazione e responsabilità romantica. L'amore sembra pesante. La partnership richiede duro lavoro. Assumere troppo nella connessione. Lo stress influisce sull'intimità."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "関係の負担と恋愛の責任。愛が重く感じられる。パートナーシップにはハードワークが必要。つながりにおいて負いすぎる。ストレスが親密さに影響する。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Forholdsbyrde og romantisk ansvar. Kjærlighet føles tung. Partnerskap krever hardt arbeid. Tar på seg for mye i forbindelsen. Stress påvirker intimitet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ciężar związku i romantyczna odpowiedzialność. Miłość wydaje się ciężka. Partnerstwo wymaga ciężkiej pracy. Branie na siebie zbyt wiele w połączeniu. Stres wpływa na intymność."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fardo no relacionamento e responsabilidade romântica. O amor parece pesado. A parceria exige trabalho árduo. Assumindo muito na conexão. O estresse afeta a intimidade."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Relationsbörda och romantiskt ansvar. Kärlek känns tung. Partnerskap kräver hårt arbete. Ta på sig för mycket i anslutningen. Stress påverkar intimiteten."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Тягар стосунків і романтична відповідальність. Кохання здається важким. Партнерство вимагає важкої праці. Брати на себе забагато у зв'язку. Стрес впливає на близькість."
          }
        }
      }
    },
    "interpretation.the_chariot_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karrierehindernisse fühlen sich überwältigend an oder du bewegst dich in widersprüchliche Richtungen. Mangel an Fokus oder Kontrolle. Gewinne deinen Orientierungssinn zurück."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Career obstacles feel overwhelming or you're heading in conflicting directions. Lack of focus or control. Regain your sense of direction."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los obstáculos profesionales se sienten abrumadores o te diriges en direcciones contradictorias. Falta de enfoque o control. Recupera tu sentido de dirección."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les obstacles professionnels semblent insurmontables ou vous allez dans des directions contradictoires. Manque de concentration ou de contrôle. Retrouvez votre sens de l'orientation."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gli ostacoli professionali sembrano travolgenti o ti stai muovendo in direzioni contrastanti. Mancanza di concentrazione o controllo. Recupera il tuo senso di direzione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャリアの障害が圧倒的に感じられるか、相反する方向に向かっています。集中力やコントロールの欠如。方向感覚を取り戻してください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karrierehindringer føles overveldende, eller du beveger deg i motstridende retninger. Mangel på fokus eller kontroll. Gjenvinn retningssansen din."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przeszkody zawodowe wydają się przytłaczające lub poruszasz się w sprzecznych kierunkach. Brak skupienia lub kontroli. Odzyskaj poczucie kierunku."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Os obstáculos da carreira parecem esmagadores ou você está se movendo em direções conflitantes. Falta de foco ou controle. Recupere seu senso de direção."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriärhinder känns överväldigande eller så rör du dig i motstridiga riktningar. Brist på fokus eller kontroll. Återfå din känsla för riktning."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Кар'єрні перешкоди здаються непереборними, або ви рухаєтеся в суперечливих напрямках. Відсутність фокусу або контролю. Поверніть своє відчуття напрямку."
          }
        }
      }
    },
    "interpretation.the_chariot_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beruflicher Sieg durch Entschlossenheit und Willenskraft. Du sitzt am Steuer – bleib konzentriert und du wirst Erfolg haben. Überwinde Hindernisse durch pure Entschlossenheit."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Career victory through determination and willpower. You're in the driver's seat—stay focused and you'll succeed. Overcome obstacles through sheer determination."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Victoria profesional a través de la determinación y la fuerza de voluntad. Estás al volante: mantente enfocado y tendrás éxito. Supera obstáculos a través de la pura determinación."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Victoire professionnelle grâce à la détermination et à la volonté. Vous êtes aux commandes – restez concentré et vous réussirez. Surmontez les obstacles par la seule détermination."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vittoria professionale attraverso determinazione e forza di volontà. Sei al posto di guida – rimani concentrato e avrai successo. Supera gli ostacoli con la pura determinazione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "決意と意志の力によるキャリアの勝利。あなたは運転席にいます。集中力を保てば成功します。純粋な決意で障害を乗り越えてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriereseier gjennom besluttsomhet og viljestyrke. Du er i førersetet – hold fokus, så vil du lykkes. Overvinn hindringer gjennom ren besluttsomhet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zwycięstwo zawodowe dzięki determinacji i sile woli. Siedzisz za kierownicą – zachowaj skupienie, a odniesiesz sukces. Pokonuj przeszkody poprzez czystą determinację."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vitória na carreira através da determinação e força de vontade. Você está no comando – mantenha o foco e terá sucesso. Supere obstáculos através da pura determinação."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriärseger genom beslutsamhet och viljestyrka. Du sitter vid ratten – håll fokus så kommer du att lyckas. Övervinna hinder genom ren beslutsamhet."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Кар'єрна перемога завдяки рішучості та силі волі. Ви за кермом – залишайтеся зосередженими, і ви досягнете успіху. Подолайте перешкоди завдяки чистій рішучості."
          }
        }
      }
    },
    "interpretation.the_chariot_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Hindernisse oder mangelnde Kontrolle über die Ausgaben. Gegenläufige Kräfte zehren Ressourcen auf. Gewinne die Kontrolle durch fokussierte Absicht zurück."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial obstacles or lack of control over spending. Opposing forces drain resources. Regain control through focused intention."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Obstáculos financieros o falta de control sobre el gasto. Las fuerzas opuestas agotan los recursos. Recupera el control a través de la intención enfocada."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Obstacles financiers ou manque de contrôle sur les dépenses. Des forces opposées épuisent les ressources. Reprenez le contrôle grâce à une intention ciblée."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ostacoli finanziari o mancanza di controllo sulla spesa. Forze opposte drenano le risorse. Riacquista il controllo attraverso l'intenzione focalizzata."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的な障害や支出のコントロール不足。相反する力がリソースを消耗させます。集中した意図を通じてコントロールを取り戻してください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomiske hindringer eller mangel på kontroll over utgifter. Motstridende krefter tapper ressurser. Gjenopprett kontroll gjennom fokusert intensjon."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przeszkody finansowe lub brak kontroli nad wydatkami. Przeciwstawne siły wyczerpują zasoby. Odzyskaj kontrolę poprzez skupioną intencję."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Obstáculos financeiros ou falta de controle sobre os gastos. Forças opostas drenam recursos. Retome o controle através da intenção focada."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomiska hinder eller brist på kontroll över utgifterna. Motstridande krafter tömmer resurser. Återfå kontrollen genom fokuserad avsikt."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансові перешкоди або відсутність контролю над витратами. Протилежні сили виснажують ресурси. Поверніть контроль через цілеспрямований намір."
          }
        }
      }
    },
    "interpretation.the_chariot_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzieller Erfolg durch entschlossenes Handeln und Selbstkontrolle. Du hast die Willenskraft, deine finanziellen Ziele zu erreichen. Bleib fokussiert und diszipliniert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial success through determined action and self-control. You have the willpower to achieve your monetary goals. Stay focused and disciplined."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Éxito financiero a través de la acción decidida y el autocontrol. Tienes la fuerza de voluntad para lograr tus metas monetarias. Mantente enfocado y disciplinado."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Succès financier grâce à une action déterminée et à la maîtrise de soi. Vous avez la volonté d'atteindre vos objectifs monétaires. Restez concentré et discipliné."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Successo finanziario attraverso un'azione determinata e autocontrollo. Hai la forza di volontà per raggiungere i tuoi obiettivi monetari. Rimani concentrato e disciplinato."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "断固とした行動と自己コントロールによる経済的成功。あなたには経済的な目標を達成する意志の力があります。集中力と規律を保ってください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk suksess gjennom målrettet handling og selvkontroll. Du har viljestyrken til å nå dine økonomiske mål. Hold fokus og disiplin."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sukces finansowy dzięki zdecydowanemu działaniu i samokontroli. Masz siłę woli, aby osiągnąć swoje cele finansowe. Zachowaj skupienie i dyscyplinę."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sucesso financeiro através de ação determinada e autocontrole. Você tem força de vontade para alcançar seus objetivos financeiros. Mantenha o foco e a disciplina."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomisk framgång genom beslutsam handling och självkontroll. Du har viljestyrkan att nå dina monetära mål. Håll fokus och disciplin."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансовий успіх завдяки рішучим діям і самоконтролю. У вас є сила волі, щоб досягти своїх фінансових цілей. Залишайтеся зосередженими та дисциплінованими."
          }
        }
      }
    },
    "interpretation.the_chariot_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verlust der Richtung oder Kontrolle. Gegenläufige Kräfte zerren an dir. Aggression und Hindernisse blockieren den Fortschritt. Gewinne deinen Fokus und deinen Sinn fürs Ziel zurück."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loss of direction or control. Opposing forces pull you apart. Aggression and obstacles block progress. Regain your focus and sense of purpose."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pérdida de dirección o control. Fuerzas opuestas te separan. La agresión y los obstáculos bloquean el progreso. Recupera tu enfoque y sentido de propósito."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Perte de direction ou de contrôle. Des forces opposées vous écartèlent. L'agression et les obstacles bloquent le progrès. Retrouvez votre concentration et votre sens du but."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Perdita di direzione o controllo. Forze opposte ti tirano da parti opposte. Aggressione e ostacoli bloccano il progresso. Ritrova la tua concentrazione e il senso dello scopo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "方向性やコントロールの喪失。相反する力があなたを引き裂きます。攻撃性と障害が進歩を妨げます。集中力と目的意識を取り戻してください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tap av retning eller kontroll. Motstridende krefter trekker deg fra hverandre. Aggresjon og hindringer blokkerer fremgang. Gjenvinn fokus og meningsfølelse."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utrata kierunku lub kontroli. Przeciwstawne siły rozdzierają cię. Agresja i przeszkody blokują postęp. Odzyskaj skupienie i poczucie celu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Perda de direção ou controle. Forças opostas o separam. Agressão e obstáculos bloqueiam o progresso. Recupere seu foco e senso de propósito."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Förlust av riktning eller kontroll. Motstridande krafter drar isär dig. Aggression och hinder blockerar framsteg. Återfå ditt fokus och syfte."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Втрата напрямку або контролю. Протилежні сили розривають вас. Агресія та перешкоди блокують прогрес. Поверніть свою концентрацію та відчуття мети."
          }
        }
      }
    },
    "interpretation.the_chariot_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sieg durch Entschlossenheit und Willenskraft. Du hast die Kontrolle und bewegst dich selbstbewusst vorwärts. Überwinde Hindernisse durch fokussierte Absicht und Disziplin."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Victory through determination and willpower. You're in control and moving forward with confidence. Overcome obstacles through focused intention and discipline."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Victoria a través de la determinación y la fuerza de voluntad. Estás en control y avanzando con confianza. Supera los obstáculos a través de la intención enfocada y la disciplina."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Victoire grâce à la détermination et à la volonté. Vous contrôlez la situation et avancez avec confiance. Surmontez les obstacles grâce à une intention ciblée et à la discipline."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vittoria attraverso determinazione e forza di volontà. Hai il controllo e ti muovi avanti con fiducia. Supera gli ostacoli attraverso l'intenzione focalizzata e la disciplina."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "決意と意志の力による勝利。あなたはコントロールし、自信を持って前進しています。集中した意図と規律によって障害を乗り越えてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seier gjennom besluttsomhet og viljestyrke. Du har kontroll og beveger deg fremover med selvtillit. Overvinn hindringer gjennom fokusert intensjon og disiplin."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zwycięstwo poprzez determinację i siłę woli. Masz kontrolę i poruszasz się do przodu z pewnością siebie. Pokonuj przeszkody poprzez skupioną intencję i dyscyplinę."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vitória através da determinação e força de vontade. Você está no controle e avançando com confiança. Supere obstáculos através da intenção focada e disciplina."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seger genom beslutsamhet och viljestyrka. Du har kontroll och går framåt med självförtroende. Övervinna hinder genom fokuserad avsikt och disciplin."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Перемога через рішучість і силу волі. Ви контролюєте ситуацію та впевнено рухаєтеся вперед. Подолайте перешкоди за допомогою цілеспрямованого наміру та дисципліни."
          }
        }
      }
    },
    "interpretation.the_chariot_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Es fällt dir schwer, gesunde Gewohnheiten beizubehalten, oder du fühlst dich in entgegengesetzte Richtungen gezogen. Mangel an Disziplin oder Kontrolle. Konzentriere deine gesundheitlichen Absichten neu."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Struggling to maintain healthy habits or feeling pulled in opposite directions. Lack of discipline or control. Refocus your health intentions."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Luchando por mantener hábitos saludables o sintiéndote atraído en direcciones opuestas. Falta de disciplina o control. Vuelve a enfocar tus intenciones de salud."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous avez du mal à maintenir des habitudes saines ou vous vous sentez tiré dans des directions opposées. Manque de discipline ou de contrôle. Recentrez vos intentions en matière de santé."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Difficoltà a mantenere abitudini sane o sentirsi tirati in direzioni opposte. Mancanza di disciplina o controllo. Riconcentra le tue intenzioni per la salute."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "健康的な習慣を維持するのに苦労しているか、反対方向に引っ張られていると感じています。規律やコントロールの欠如。健康に関する意図を再び集中させてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sliter med å opprettholde sunne vaner eller føler deg trukket i motsatte retninger. Mangel på disiplin eller kontroll. Fokuser helseintensjonene dine på nytt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Masz problemy z utrzymaniem zdrowych nawyków lub czujesz się ciągnięty w przeciwnych kierunkach. Brak dyscypliny lub kontroli. Skoncentruj ponownie swoje intencje zdrowotne."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lutando para manter hábitos saudáveis ou se sentindo puxado em direções opostas. Falta de disciplina ou controle. Refoque suas intenções de saúde."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kämpar för att upprätthålla hälsosamma vanor eller känner dig dragen i motsatta riktningar. Brist på disciplin eller kontroll. Fokusera om dina hälsoavsikter."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Важко підтримувати здорові звички або ви відчуваєте, що вас тягнуть у протилежних напрямках. Відсутність дисципліни або контролю. Перефокусуйте свої оздоровчі наміри."
          }
        }
      }
    },
    "interpretation.the_chariot_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Entschlossenheit treibt Gesundheitssiege an. Deine Willenskraft ist stark – nutze sie, um gesundheitliche Herausforderungen zu überwinden. Geist über Materie bringt jetzt echte Ergebnisse."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Determination drives health victories. Your willpower is strong—use it to overcome health challenges. Mind over matter brings real results now."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La determinación impulsa las victorias en la salud. Tu fuerza de voluntad es fuerte: úsala para superar los desafíos de salud. La mente sobre la materia trae resultados reales ahora."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La détermination mène à la victoire en matière de santé. Votre volonté est forte – utilisez-la pour surmonter les problèmes de santé. L'esprit sur la matière donne des résultats concrets maintenant."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La determinazione guida le vittorie sulla salute. La tua forza di volontà è forte – usala per superare le sfide della salute. La mente sulla materia porta risultati reali ora."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "決意が健康上の勝利を促進します。あなたの意志の力は強いです。それを使って健康上の課題を克服してください。精神が物質に勝ることで、今、実際の結果がもたらされます。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Besluttsomhet driver helseseire. Viljestyrken din er sterk – bruk den til å overvinne helseutfordringer. Sinn over materie gir reelle resultater nå."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Determinacja napędza zwycięstwa w zdrowiu. Twoja siła woli jest silna – użyj jej, aby pokonać wyzwania zdrowotne. Umysł nad materią przynosi teraz realne rezultaty."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Determinação impulsiona vitórias na saúde. Sua força de vontade é forte – use-a para superar desafios de saúde. Mente sobre matéria traz resultados reais agora."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beslutsamhet driver hälsosegrar. Din viljestyrka är stark – använd den för att övervinna hälsoutmaningar. Sinn över materia ger verkliga resultat nu."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Рішучість веде до перемог у здоров'ї. Ваша сила волі сильна – використовуйте її, щоб подолати проблеми зі здоров'ям. Розум над матерією приносить реальні результати зараз."
          }
        }
      }
    },
    "interpretation.the_chariot_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mangel an Richtung oder gegensätzliche Kräfte in Beziehungen. Kontrollkämpfe oder verlorener Schwung in der Liebe. Richte deine Absichten neu aus und finde eine klare Richtung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lack of direction or opposing forces in relationships. Control struggles or losing momentum in love. Realign your intentions and find clear direction."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Falta de dirección o fuerzas opuestas en las relaciones. Luchas de control o pérdida de impulso en el amor. Realinea tus intenciones y encuentra una dirección clara."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manque de direction ou forces opposées dans les relations. Luttes de contrôle ou perte d'élan en amour. Réalignez vos intentions et trouvez une direction claire."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mancanza di direzione o forze opposte nelle relazioni. Lotte di controllo o perdita di slancio nell'amore. Riallinea le tue intenzioni e trova una direzione chiara."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "人間関係における方向性の欠如または相反する力。支配権争いや恋愛の勢いの喪失。意図を再調整し、明確な方向性を見つけてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mangel på retning eller motstridende krefter i relasjoner. Kontrollkamper eller tap av fart i kjærlighet. Juster intensjonene dine på nytt og finn en klar retning."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Brak kierunku lub przeciwstawne siły w związkach. Walki o kontrolę lub utrata impetu w miłości. Dostosuj ponownie swoje intencje i znajdź wyraźny kierunek."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Falta de direção ou forças opostas nos relacionamentos. Lutas de controle ou perda de impulso no amor. Realinhe suas intenções e encontre uma direção clara."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Brist på riktning eller motsatta krafter i relationer. Kontrollstrider eller förlust av fart i kärlek. Justera dina avsikter och hitta en tydlig riktning."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Відсутність напрямку або протилежні сили у стосунках. Боротьба за контроль або втрата імпульсу в коханні. Переорієнтуйте свої наміри та знайдіть чіткий напрямок."
          }
        }
      }
    },
    "interpretation.the_chariot_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Entschlossenheit und Willenskraft bewegen dein Liebesleben voran. Du weißt, was du willst, und gehst es an. Sieg in Herzensangelegenheiten durch fokussiertes Handeln."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Determination and willpower move your love life forward. You know what you want and you're going after it. Victory in matters of the heart through focused action."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La determinación y la fuerza de voluntad mueven tu vida amorosa hacia adelante. Sabes lo que quieres y vas por ello. Victoria en asuntos del corazón a través de la acción enfocada."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La détermination et la volonté font avancer votre vie amoureuse. Vous savez ce que vous voulez et vous allez le chercher. Victoire dans les affaires de cœur grâce à une action ciblée."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Determinazione e forza di volontà fanno avanzare la tua vita amorosa. Sai cosa vuoi e lo cerchi. Vittoria nelle questioni di cuore attraverso un'azione focalizzata."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "決意と意志の力があなたの恋愛を前進させます。あなたは自分の欲しいものを知っており、それを追い求めています。集中した行動による心の問題での勝利。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Besluttsomhet og viljestyrke beveger kjærlighetslivet ditt fremover. Du vet hva du vil, og du går etter det. Seier i hjertesaker gjennom fokusert handling."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Determinacja i siła woli przesuwają twoje życie miłosne do przodu. Wiesz, czego chcesz i dążysz do tego. Zwycięstwo w sprawach serca poprzez skoncentrowane działanie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Determinação e força de vontade movem sua vida amorosa para frente. Você sabe o que quer e vai atrás. Vitória em assuntos do coração através de ação focada."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beslutsamhet och viljestyrka förflyttar ditt kärleksliv framåt. Du vet vad du vill och du går efter det. Seger i hjärtefrågor genom fokuserad handling."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Рішучість і сила волі просувають ваше любовне життя вперед. Ви знаєте, чого хочете, і прагнете цього. Перемога в сердечних справах завдяки цілеспрямованим діям."
          }
        }
      }
    },
    "interpretation.the_devil_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sich von der beruflichen Knechtschaft befreien. Loslassen der Bindung an toxische Arbeitssituationen. Sinn über Geld wählen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Breaking free from career bondage. Releasing attachment to toxic work situations. Choosing meaning over money."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Liberarse de la esclavitud profesional. Soltar el apego a situaciones laborales tóxicas. Elegir el significado sobre el dinero."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se libérer de l'esclavage professionnel. Lâcher l'attachement aux situations de travail toxiques. Choisir le sens plutôt que l'argent."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Liberarsi dalla schiavitù professionale. Lasciare andare l'attaccamento a situazioni lavorative tossiche. Scegliere il significato rispetto al denaro."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャリアの束縛からの解放。有害な仕事状況への執着を手放す。お金よりも意味を選ぶ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Å bryte fri fra karrierebinding. Slippe tilknytning til giftige arbeidssituasjoner. Velge mening fremfor penger."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uwalnianie się z zawodowej niewoli. Porzucanie przywiązania do toksycznych sytuacji w pracy. Wybieranie sensu nad pieniądze."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Libertando-se da escravidão da carreira. Liberando o apego a situações de trabalho tóxicas. Escolhendo o significado em vez do dinheiro."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Att bryta sig loss från karriärträldom. Släppa taget om anknytning till giftiga arbetssituationer. Välja mening framför pengar."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Звільнення від кар'єрного рабства. Відпускання прив'язаності до токсичних робочих ситуацій. Вибір сенсу над грошима."
          }
        }
      }
    },
    "interpretation.the_devil_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gefangen in unerfüllter Arbeit oder ungesunden beruflichen Mustern. Materialismus über Sinn. Erkenne, was dich festhält – nur du kannst dich befreien."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trapped in unfulfilling work or unhealthy professional patterns. Materialism over meaning. Recognize what holds you—only you can free yourself."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atrapado en un trabajo insatisfactorio o patrones profesionales poco saludables. El materialismo sobre el significado. Reconoce lo que te retiene, solo tú puedes liberarte."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Prisonnier d'un travail insatisfaisant ou de schémas professionnels malsains. Le matérialisme plutôt que le sens. Reconnaissez ce qui vous retient – vous seul pouvez vous libérer."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Imprigionato in un lavoro insoddisfacente o schemi professionali malsani. Materialismo sopra il significato. Riconosci cosa ti trattiene – solo tu puoi liberarti."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "やりがいのない仕事や不健康な職業的パターンに閉じ込められている。意味よりも物質主義。何があなたを縛っているかを認識してください – あなただけが自分を解放できます。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fanget i uoppfyllende arbeid eller usunne profesjonelle mønstre. Materialisme over mening. Gjenkjenn hva som holder deg – bare du kan frigjøre deg selv."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uwięziony w niespełniającej pracy lub niezdrowych wzorcach zawodowych. Materializm ponad sens. Rozpoznaj, co cię trzyma – tylko ty możesz się uwolnić."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Preso em trabalho insatisfatório ou padrões profissionais prejudiciais. Materialismo sobre significado. Reconheça o que o prende – só você pode se libertar."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fångad i otillfredsställande arbete eller ohälsosamma yrkesmönster. Materialism över mening. Känn igen vad som håller dig – bara du kan befria dig själv."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "У пастці невтішної роботи або нездорових професійних моделей. Матеріалізм над змістом. Визнайте, що вас тримає – тільки ви можете звільнити себе."
          }
        }
      }
    },
    "interpretation.the_devil_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sich von finanzieller Knechtschaft befreien. Ungesunde Geldmuster loslassen. Loslösung vom Materialismus bringt Freiheit."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Breaking free from financial bondage. Releasing unhealthy money patterns. Detachment from materialism brings freedom."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Liberarse de la esclavitud financiera. Soltar patrones monetarios poco saludables. El desapego del materialismo trae libertad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se libérer de l'esclavage financier. Lâcher les schémas monétaires malsains. Le détachement du matérialisme apporte la liberté."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Liberarsi dalla schiavitù finanziaria. Lasciare andare schemi monetari malsani. Il distacco dal materialismo porta libertà."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的な束縛からの解放。不健康なお金のパターンを手放す。物質主義からの解放が自由をもたらします。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Å bryte fri fra økonomisk slaveri. Slippe usunne pengemønstre. Løsrivelse fra materialisme gir frihet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uwalnianie się z finansowej niewoli. Porzucanie niezdrowych wzorców pieniężnych. Odłączenie od materializmu przynosi wolność."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Libertando-se da escravidão financeira. Liberando padrões monetários prejudiciais. O desapego do materialismo traz liberdade."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Att bryta sig loss från ekonomiskt slaveri. Släppa ohälsosamma pengamönster. Frigörelse från materialism ger frihet."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Звільнення від фінансового рабства. Відпускання нездорових грошових моделей. Відчуження від матеріалізму приносить свободу."
          }
        }
      }
    },
    "interpretation.the_devil_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Materialismus, Gier oder ungesunde finanzielle Bindungen. Versklavung durch Schulden oder süchtiges Ausgeben. Du hast mehr Macht, als du denkst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Materialism, greed, or unhealthy financial attachments. Bondage to debt or addictive spending. You have more power than you think."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Materialismo, avaricia o apegos financieros poco saludables. Esclavitud a las deudas o gastos adictivos. Tienes más poder del que crees."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Matérialisme, cupidité ou attachements financiers malsains. Asservissement à la dette ou aux dépenses addictives. Vous avez plus de pouvoir que vous ne le pensez."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Materialismo, avidità o attaccamenti finanziari malsani. Schiavitù del debito o spesa compulsiva. Hai più potere di quanto pensi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "物質主義、貪欲、または不健康な経済的執着。借金や中毒的な支出への束縛。あなたは思っているよりも多くの力を持っています。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Materialisme, grådighet eller usunne økonomiske tilknytninger. Slaveri til gjeld eller avhengighetsskapende utgifter. Du har mer makt enn du tror."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Materializm, chciwość lub niezdrowe przywiązania finansowe. Zniewolenie przez dług lub uzależniające wydatki. Masz więcej władzy, niż myślisz."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Materialismo, ganância ou apegos financeiros prejudiciais. Escravidão a dívidas ou gastos viciantes. Você tem mais poder do que pensa."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Materialism, girighet eller ohälsosamma finansiella anknytningar. Förslavning av skulder eller beroendeframkallande utgifter. Du har mer makt än du tror."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Матеріалізм, жадібність або нездорові фінансові прив'язаності. Поневолення боргами або залежними витратами. У вас більше сили, ніж ви думаєте."
          }
        }
      }
    },
    "interpretation.the_devil_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sich befreien, Bindungen lösen und Freiheit wählen. Du erkennst deine Macht, toxische Situationen zu verlassen. Die Befreiung steht bevor."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Breaking free, releasing attachments, and choosing freedom. You're recognizing your power to leave toxic situations. Liberation is coming."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Liberarse, soltar apegos y elegir la libertad. Estás reconociendo tu poder para salir de situaciones tóxicas. La liberación está llegando."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se libérer, lâcher les attachements et choisir la liberté. Vous reconnaissez votre pouvoir de quitter les situations toxiques. La libération arrive."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Liberarsi, lasciare andare gli attaccamenti e scegliere la libertà. Stai riconoscendo il tuo potere di lasciare situazioni tossiche. La liberazione sta arrivando."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "解放、執着を手放し、自由を選ぶ。あなたは有害な状況から離れる力を認識しています。解放がやって来ます。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Å frigjøre seg, slippe tilknytninger og velge frihet. Du anerkjenner din makt til å forlate giftige situasjoner. Frigjøring kommer."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uwalnianie się, porzucanie przywiązań i wybieranie wolności. Rozpoznajesz swoją moc, by opuścić toksyczne sytuacje. Wyzwolenie nadchodzi."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Libertar-se, soltar apegos e escolher a liberdade. Você está reconhecendo seu poder de sair de situações tóxicas. A libertação está chegando."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Att befria sig, släppa taget och välja frihet. Du erkänner din makt att lämna giftiga situationer. Befrielse kommer."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Звільнення, відпускання прив'язаностей і вибір свободи. Ви визнаєте свою силу залишати токсичні ситуації. Звільнення настає."
          }
        }
      }
    },
    "interpretation.the_devil_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Knechtschaft, Sucht und ungesunde Bindungen. Du bist mehr durch Überzeugungen gefangen als durch die Realität. Die Ketten sind nicht verschlossen – du kannst dich jederzeit befreien."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bondage, addiction, and unhealthy attachments. You're more trapped by beliefs than reality. The chains aren't locked—you can free yourself anytime."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esclavitud, adicción y apegos poco saludables. Estás más atrapado por las creencias que por la realidad. Las cadenas no están cerradas, puedes liberarte en cualquier momento."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Asservissement, addiction et attachements malsains. Vous êtes plus piégé par les croyances que par la réalité. Les chaînes ne sont pas verrouillées – vous pouvez vous libérer à tout moment."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schiavitù, dipendenza e attaccamenti malsani. Sei più intrappolato dalle credenze che dalla realtà. Le catene non sono chiuse a chiave – puoi liberarti in qualsiasi momento."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "束縛、依存、不健康な執着。あなたは現実よりも信念によって閉じ込められています。鎖はロックされていません – いつでも自分を解放できます。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Slaveri, avhengighet og usunne tilknytninger. Du er mer fanget av tro enn virkelighet. Kjedene er ikke låst – du kan frigjøre deg selv når som helst."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niewola, uzależnienie i niezdrowe przywiązania. Jesteś bardziej uwięziony przez przekonania niż przez rzeczywistość. Łańcuchy nie są zamknięte – możesz się uwolnić w każdej chwili."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Escravidão, vício e apegos prejudiciais. Você está mais preso por crenças do que pela realidade. As correntes não estão trancadas – você pode se libertar a qualquer momento."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Slaveri, beroende och ohälsosamma anknytningar. Du är mer fångad av föreställningar än av verklighet. Kedjorna är inte låsta – du kan befria dig själv när som helst."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Рабство, залежність і нездорові прив'язаності. Ви більше потрапили в пастку переконань, ніж реальності. Кайдани не замкнені – ви можете звільнити себе в будь-який час."
          }
        }
      }
    },
    "interpretation.the_devil_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sich von ungesunden Gewohnheiten befreien. Suchtmuster loslassen. Wähle die Freiheit über die vertraute Knechtschaft."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Breaking free from unhealthy habits. Releasing addictive patterns. Choosing freedom over familiar bondage."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Liberarse de hábitos poco saludables. Soltar patrones adictivos. Elegir la libertad sobre la esclavitud familiar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se libérer des habitudes malsaines. Lâcher les schémas addictifs. Choisir la liberté plutôt que l'esclavage familier."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Liberarsi da abitudini malsane. Lasciare andare schemi di dipendenza. Scegliere la libertà rispetto alla schiavitù familiare."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "不健康な習慣からの解放。依存症のパターンを手放す。慣れ親しんだ束縛よりも自由を選ぶ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Å bryte fri fra usunne vaner. Slippe avhengighetsmønstre. Velge frihet fremfor kjent slaveri."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uwalnianie się od niezdrowych nawyków. Porzucanie wzorców uzależnień. Wybieranie wolności nad znaną niewolę."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Libertando-se de hábitos prejudiciais. Liberando padrões viciantes. Escolhendo a liberdade em vez da escravidão familiar."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Att bryta sig loss från ohälsosamma vanor. Släppa beroendemönster. Välja frihet framför bekant slaveri."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Звільнення від шкідливих звичок. Відпускання моделей залежності. Вибір свободи, а не звичного рабства."
          }
        }
      }
    },
    "interpretation.the_devil_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Süchtiges Verhalten oder ungesunde Bindungen beeinträchtigen das Wohlbefinden. Versklavung durch schädliche Gewohnheiten. Die Ketten sind selbst auferlegt – brich sie auf."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Addictive behaviors or unhealthy attachments affect wellbeing. Bondage to harmful habits. The chains are self-imposed—break free."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Comportamientos adictivos o apegos poco saludables afectan el bienestar. Esclavitud a hábitos dañinos. Las cadenas son autoimpuestas, rómpelas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les comportements addictifs ou les attachements malsains affectent le bien-être. Asservissement à des habitudes néfastes. Les chaînes sont auto-imposées – brisez-les."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Comportamenti di dipendenza o attaccamenti malsani influenzano il benessere. Schiavitù di abitudini dannose. Le catene sono autoimposte – rompile."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "依存行動や不健康な執着が健康に影響を与えます。有害な習慣への束縛。鎖は自己課せられたものです – それらを断ち切ってください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avhengighetsatferd eller usunne tilknytninger påvirker velvære. Slaveri til skadelige vaner. Kjedene er selvpålagt – bryt dem."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zachowania uzależniające lub niezdrowe przywiązania wpływają na samopoczucie. Zniewolenie przez szkodliwe nawyki. Łańcuchy są samonarzucane – zerwij je."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Comportamentos viciantes ou apegos prejudiciais afetam o bem-estar. Escravidão a hábitos prejudiciais. As correntes são autoimpostas – quebre-as."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beroendebeteenden eller ohälsosamma anknytningar påverkar välbefinnandet. Förslavning av skadliga vanor. Kedjorna är självpåtagna – bryt dem."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Залежна поведінка або нездорові прив'язаності впливають на благополуччя. Поневолення шкідливими звичками. Кайдани самонав'язані – розірвіть їх."
          }
        }
      }
    },
    "interpretation.the_devil_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sich von toxischen Beziehungsmustern befreien. Ungesunde Bindungen lösen. Du erkennst deine Macht zu gehen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Breaking free from toxic relationship patterns. Releasing unhealthy attachments. You're recognizing your power to leave."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Liberarse de patrones de relación tóxicos. Soltar apegos poco saludables. Estás reconociendo tu poder para irte."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se libérer des schémas relationnels toxiques. Lâcher les attachements malsains. Vous reconnaissez votre pouvoir de partir."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Liberarsi da schemi relazionali tossici. Lasciare andare attaccamenti malsani. Stai riconoscendo il tuo potere di andartene."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "有害な関係パターンからの解放。不健康な執着を手放す。あなたは去る力を認識しています。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Å bryte fri fra giftige forholdsmønstre. Slippe usunne tilknytninger. Du anerkjenner din makt til å forlate."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uwalnianie się od toksycznych wzorców w związkach. Porzucanie niezdrowych przywiązań. Rozpoznajesz swoją siłę, by odejść."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Libertando-se de padrões de relacionamento tóxicos. Liberando apegos prejudiciais. Você está reconhecendo seu poder de sair."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Att bryta sig loss från giftiga relationsmönster. Släppa ohälsosamma anknytningar. Du erkänner din makt att lämna."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Звільнення від токсичних моделей стосунків. Відпускання нездорових прив'язаностей. Ви визнаєте свою силу піти."
          }
        }
      }
    },
    "interpretation.the_devil_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ungesunde Bindungen oder suchtartige Muster in Beziehungen. Versklavung durch Materialismus oder Toxizität. Erkenne die Ketten – sie sind nicht verschlossen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unhealthy attachments or addictive patterns in relationships. Bondage to materialism or toxicity. Recognize the chains—they're not locked."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apegos poco saludables o patrones adictivos en las relaciones. Esclavitud al materialismo o la toxicidad. Reconoce las cadenas: no están cerradas con llave."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Attachements malsains ou schémas addictifs dans les relations. Asservissement au matérialisme ou à la toxicité. Reconnaissez les chaînes – elles ne sont pas verrouillées."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Attaccamenti malsani o schemi di dipendenza nelle relazioni. Schiavitù al materialismo o alla tossicità. Riconosci le catene – non sono chiuse a chiave."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "人間関係における不健康な執着や依存症のパターン。物質主義や有害性への束縛。鎖を認識してください – それらはロックされていません。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Usunne tilknytninger eller avhengighetsmønstre i relasjoner. Slaveri til materialisme eller toksisitet. Gjenkjenn kjedene – de er ikke låst."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niezdrowe przywiązania lub wzorce uzależnień w związkach. Zniewolenie przez materializm lub toksyczność. Rozpoznaj łańcuchy – nie są zamknięte."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apegos prejudiciais ou padrões viciantes nos relacionamentos. Escravidão ao materialismo ou toxicidade. Reconheça as correntes – elas não estão trancadas."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ohälsosamma anknytningar eller beroendemönster i relationer. Förslavning av materialism eller toxicitet. Känn igen kedjorna – de är inte låsta."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Небезпечні прив'язаності або моделі залежності у стосунках. Поневолення матеріалізмом або токсичністю. Визнайте кайдани – вони не замкнені."
          }
        }
      }
    },
    "interpretation.the_emperor_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tyrannische Führung oder übermäßige Starrheit bei der Arbeit. Du könntest zu kontrollierend sein oder einem unflexiblen Chef gegenüberstehen. Finde ein Gleichgewicht zwischen Struktur und Anpassungsfähigkeit."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tyrannical leadership or excessive rigidity at work. You might be too controlling or facing an inflexible boss. Find balance between structure and adaptability."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Liderazgo tiránico o rigidez excesiva en el trabajo. Puede que seas demasiado controlador o te enfrentes a un jefe inflexible. Encuentra el equilibrio entre estructura y adaptabilidad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Leadership tyrannique ou rigidité excessive au travail. Vous pourriez être trop contrôlant ou faire face à un patron inflexible. Trouvez l'équilibre entre structure et adaptabilité."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Leadership tirannico o rigidità eccessiva al lavoro. Potresti essere troppo controllante o affrontare un capo inflessibile. Trova l'equilibrio tra struttura e adattabilità."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "専制的なリーダーシップや職場での過度の硬直性。あなたは支配的すぎるか、柔軟性のない上司に直面しているかもしれません。構造と適応性のバランスを見つけてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tyrannisk lederskap eller overdreven rigiditet på jobb. Du kan være for kontrollerende eller stå overfor en lite fleksibel sjef. Finn balanse mellom struktur og tilpasningsevne."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tyrańskie przywództwo lub nadmierna sztywność w pracy. Możesz być zbyt kontrolujący lub mieć do czynienia z nieelastycznym szefem. Znajdź równowagę między strukturą a elastycznością."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Liderança tirânica ou rigidez excessiva no trabalho. Você pode ser controlador demais ou enfrentar um chefe inflexível. Encontre o equilíbrio entre estrutura e adaptabilidade."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tyrannisk ledarskap eller överdriven rigiditet på jobbet. Du kanske är för kontrollerande eller står inför en oflexibel chef. Hitta balans mellan struktur och anpassningsförmåga."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Тиранічне лідерство або надмірна жорсткість на роботі. Ви можете бути надто контролюючим або стикатися з негнучким начальником. Знайдіть баланс між структурою та адаптивністю."
          }
        }
      }
    },
    "interpretation.the_emperor_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Führungsmöglichkeiten ergeben sich. Deine Fähigkeit, Strukturen zu schaffen und Verantwortung zu übernehmen, dient dir gut. Dies ist deine Zeit, um etwas Dauerhaftes aufzubauen und Autorität zu übernehmen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Leadership opportunities arise. Your ability to create structure and take charge serves you well. This is your time to build something enduring and take authority."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Surgen oportunidades de liderazgo. Tu habilidad para crear estructura y tomar el mando te sirve bien. Este es tu momento para construir algo duradero y asumir la autoridad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Des opportunités de leadership se présentent. Votre capacité à créer une structure et à prendre les choses en main vous sert bien. C'est le moment de construire quelque chose de durable et de prendre l'autorité."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sorgono opportunità di leadership. La tua capacità di creare struttura e prendere il comando ti è utile. Questo è il tuo momento per costruire qualcosa di duraturo e assumere l'autorità."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "リーダーシップの機会が生まれます。構造を作り、指揮を執るあなたの能力は役立ちます。これは、永続的なものを構築し、権威を引き継ぐあなたの時間です。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lederskapsmuligheter oppstår. Din evne til å skape struktur og ta ansvar tjener deg godt. Dette er din tid til å bygge noe varig og ta autoritet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pojawiają się możliwości przywódcze. Twoja zdolność do tworzenia struktury i kierowania zespołem służy ci dobrze. To twój czas, aby zbudować coś trwałego i przejąć władzę."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oportunidades de liderança surgem. Sua capacidade de criar estrutura e assumir o comando serve bem a você. Este é o seu momento de construir algo duradouro e assumir a autoridade."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ledarskapsmöjligheter uppstår. Din förmåga att skapa struktur och ta ledning tjänar dig väl. Detta är din tid att bygga något varaktigt och ta auktoritet."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Виникають можливості для лідерства. Ваша здатність створювати структуру та брати на себе відповідальність служить вам добре. Це ваш час, щоб побудувати щось тривале та взяти на себе відповідальність."
          }
        }
      }
    },
    "interpretation.the_emperor_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Kontrollprobleme oder starres Denken schränken das Wachstum ein. Übermäßige Kontrolle oder mangelnde Flexibilität im Umgang mit Geld. Lockere deinen Griff, während du die Struktur beibehältst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial control issues or rigid thinking limit growth. Excessive control or lack of flexibility with money. Loosen your grip while maintaining structure."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Problemas de control financiero o pensamiento rígido limitan el crecimiento. Control excesivo o falta de flexibilidad con el dinero. Afloja tu agarre mientras mantienes la estructura."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les problèmes de contrôle financier ou la pensée rigide limitent la croissance. Un contrôle excessif ou un manque de flexibilité avec l'argent. Relâchez votre emprise tout en maintenant la structure."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Problemi di controllo finanziario o pensiero rigido limitano la crescita. Controllo eccessivo o mancanza di flessibilità con il denaro. Allenta la presa mantenendo la struttura."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "財務上のコントロールの問題や硬直した思考が成長を制限します。過度のコントロールやお金に対する柔軟性の欠如。構造を維持しながら、あなたの支配を緩めてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomiske kontrollproblemer eller rigid tenkning begrenser vekst. Overdreven kontroll eller mangel på fleksibilitet med penger. Løsne grepet mens du opprettholder strukturen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Problemy z kontrolą finansową lub sztywne myślenie ograniczają rozwój. Nadmierna kontrola lub brak elastyczności w kwestiach pieniężnych. Rozluźnij uścisk, utrzymując strukturę."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Problemas de controle financeiro ou pensamento rígido limitam o crescimento. Controle excessivo ou falta de flexibilidade com o dinheiro. Afrouxe o controle enquanto mantém a estrutura."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomiska kontrollproblem eller stelt tänkande begränsar tillväxten. Överdriven kontroll eller brist på flexibilitet med pengar. Lossna ditt grepp samtidigt som du bibehåller strukturen."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Проблеми фінансового контролю або жорстке мислення обмежують зростання. Надмірний контроль або відсутність гнучкості з грошима. Послабте хватку, зберігаючи структуру."
          }
        }
      }
    },
    "interpretation.the_emperor_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine starke finanzielle Struktur und Disziplin schaffen Sicherheit. Strategische Planung und Führung bei der Ressourcenverwaltung bringen Erfolg. Baue dein Imperium weise auf."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Strong financial structure and discipline create security. Strategic planning and leadership in managing resources bring success. Build your empire wisely."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una fuerte estructura financiera y disciplina crean seguridad. La planificación estratégica y el liderazgo en la gestión de recursos traen éxito. Construye tu imperio sabiamente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une structure financière solide et une discipline créent la sécurité. La planification stratégique et le leadership dans la gestion des ressources apportent le succès. Construisez votre empire judicieusement."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una forte struttura finanziaria e disciplina creano sicurezza. La pianificazione strategica e la leadership nella gestione delle risorse portano al successo. Costruisci il tuo impero saggiamente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "強固な財務構造と規律が安心感を生み出します。戦略的計画とリソース管理におけるリーダーシップが成功をもたらします。あなたの帝国を賢明に築き上げてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sterk økonomisk struktur og disiplin skaper trygghet. Strategisk planlegging og ledelse i ressursforvaltning gir suksess. Bygg ditt imperium klokt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Silna struktura finansowa i dyscyplina tworzą bezpieczeństwo. Planowanie strategiczne i przywództwo w zarządzaniu zasobami przynoszą sukces. Buduj swoje imperium mądrze."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Forte estrutura financeira e disciplina criam segurança. Planejamento estratégico e liderança na gestão de recursos trazem sucesso. Construa seu império com sabedoria."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stark ekonomisk struktur och disciplin skapar trygghet. Strategisk planering och ledarskap i resurshantering ger framgång. Bygg ditt imperium klokt."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сильна фінансова структура та дисципліна створюють безпеку. Стратегічне планування та лідерство в управлінні ресурсами приносять успіх. Будуйте свою імперію мудро."
          }
        }
      }
    },
    "interpretation.the_emperor_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kontrollprobleme, Tyrannei oder übermäßige Starrheit blockieren den Fortschritt. Bist du zu dominant oder hast es mit jemandem zu tun, der es ist? Werde weicher, während du Stärke bewahrst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Control issues, tyranny, or excessive rigidity block progress. Are you being too domineering or facing someone who is? Soften while maintaining strength."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los problemas de control, la tiranía o la rigidez excesiva bloquean el progreso. ¿Eres demasiado dominante o te enfrentas a alguien que lo es? Suaviza mientras mantienes la fuerza."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les problèmes de contrôle, la tyrannie ou une rigidité excessive bloquent le progrès. Êtes-vous trop dominateur ou faites-vous face à quelqu'un qui l'est ? Adoucissez-vous tout en restant fort."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Problemi di controllo, tirannia o rigidità eccessiva bloccano il progresso. Sei troppo dominante o hai a che fare con qualcuno che lo è? Addolcisciti mantenendo la forza."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "コントロールの問題、専制、過度の硬直性が進歩を妨げます。あなたは支配的すぎるのか、それとも支配的な誰かと向き合っているのか？強さを保ちながら和らげてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kontrollproblemer, tyranni eller overdreven rigiditet blokkerer fremgang. Er du for dominerende eller står du overfor noen som er det? Mykne mens du opprettholder styrke."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Problemy z kontrolą, tyrania lub nadmierna sztywność blokują postęp. Czy jesteś zbyt dominujący, czy masz do czynienia z kimś, kto taki jest? Złagodź, zachowując siłę."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Problemas de controle, tirania ou rigidez excessiva bloqueiam o progresso. Você é dominador demais ou está lidando com alguém que é? Suavize enquanto mantém a força."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kontrollproblem, tyranni eller överdriven rigiditet blockerar framsteg. Är du för dominerande eller står inför någon som är det? Mjukna samtidigt som du bibehåller styrka."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Проблеми контролю, тиранія або надмірна жорсткість блокують прогрес. Ви занадто домінуєте чи маєте справу з тим, хто такий? Пом'якшіть, зберігаючи силу."
          }
        }
      }
    },
    "interpretation.the_emperor_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Struktur, Autorität und Führung definieren diesen Moment. Übernimm selbstbewusst die Kontrolle über dein Leben. Baue solide Grundlagen. Setze klare Grenzen und respektiere sie."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Structure, authority, and leadership define this moment. Take charge of your life with confidence. Build solid foundations. Set clear boundaries and honor them."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La estructura, la autoridad y el liderazgo definen este momento. Toma el control de tu vida con confianza. Construye cimientos sólidos. Establece límites claros y respétalos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La structure, l'autorité et le leadership définissent ce moment. Prenez le contrôle de votre vie avec confiance. Construisez des bases solides. Fixez des limites claires et respectez-les."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Struttura, autorità e leadership definiscono questo momento. Prendi il controllo della tua vita con fiducia. Costruisci solide fondamenta. Stabilisci confini chiari e rispettali."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "構造、権威、リーダーシップがこの瞬間を定義します。自信を持って自分の人生を掌握してください。強固な基盤を築いてください。明確な境界を設定し、それらを尊重してください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Struktur, autoritet og lederskap definerer dette øyeblikket. Ta kontroll over livet ditt med selvtillit. Bygg solide fundamenter. Sett klare grenser og ær dem."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Struktura, autorytet i przywództwo definiują tę chwilę. Przejmij kontrolę nad swoim życiem z pewnością siebie. Buduj solidne fundamenty. Wyznacz jasne granice i szanuj je."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estrutura, autoridade e liderança definem este momento. Assuma o controle da sua vida com confiança. Construa bases sólidas. Estabeleça limites claros e honre-os."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Struktur, auktoritet och ledarskap definierar detta ögonblick. Ta kontroll över ditt liv med självförtroende. Bygg solida grunder. Sätt tydliga gränser och hedra dem."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Структура, авторитет і лідерство визначають цей момент. Візьміть під контроль своє життя з впевненістю. Будуйте міцні основи. Встановіть чіткі межі та поважайте їх."
          }
        }
      }
    },
    "interpretation.the_emperor_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Übermäßig starre Gesundheitsansätze oder das Ignorieren der Bedürfnisse deines Körpers. Kontrollprobleme in Bezug auf Ernährung oder Bewegung. Finde ein Gleichgewicht zwischen Disziplin und Selbstmitgefühl."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Overly rigid health approaches or ignoring your body's needs. Control issues around diet or exercise. Find balance between discipline and self-compassion."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enfoques de salud demasiado rígidos o ignorar las necesidades de tu cuerpo. Problemas de control con la dieta o el ejercicio. Encuentra el equilibrio entre disciplina y autocompasión."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Des approches de santé trop rigides ou l'ignorance des besoins de votre corps. Problèmes de contrôle concernant l'alimentation ou l'exercice. Trouvez l'équilibre entre discipline et auto-compassion."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Approcci sanitari eccessivamente rigidi o ignorare i bisogni del tuo corpo. Problemi di controllo su dieta o esercizio. Trova un equilibrio tra disciplina e autocompassione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "過度に硬直した健康法や体のニーズを無視すること。食事や運動に関するコントロールの問題。規律と自己同情のバランスを見つけてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Overdrevne rigide helsetilnærminger eller å ignorere kroppens behov. Kontrollproblemer rundt diett eller trening. Finn balanse mellom disiplin og selvmedfølelse."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zbyt sztywne podejście do zdrowia lub ignorowanie potrzeb ciała. Problemy z kontrolą diety lub ćwiczeń. Znajdź równowagę między dyscypliną a współczuciem dla siebie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abordagens de saúde excessivamente rígidas ou ignorar as necessidades do seu corpo. Problemas de controle com dieta ou exercício. Encontre o equilíbrio entre disciplina e autocompaixão."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alltför rigida hälsotillvägagångssätt eller att ignorera din kropps behov. Kontrollproblem kring kost eller motion. Hitta balans mellan disciplin och självmedkänsla."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Надзвичайно жорсткі підходи до здоров'я або ігнорування потреб вашого тіла. Проблеми контролю за дієтою чи фізичними вправами. Знайдіть баланс між дисципліною та співчуттям до себе."
          }
        }
      }
    },
    "interpretation.the_emperor_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Disziplinierte Gesundheitsroutinen bringen Ergebnisse. Struktur und Beständigkeit bei Wellness-Praktiken dienen dir gut. Übernimm die Verantwortung für deine Gesundheit mit Autorität."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Disciplined health routines bring results. Structure and consistency in wellness practices serve you well. Take charge of your health with authority."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las rutinas de salud disciplinadas traen resultados. La estructura y la consistencia en las prácticas de bienestar te sirven bien. Toma el control de tu salud con autoridad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Des routines de santé disciplinées apportent des résultats. La structure et la constance dans les pratiques de bien-être vous servent bien. Prenez en charge votre santé avec autorité."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Routine di salute disciplinate portano risultati. Struttura e costanza nelle pratiche di benessere ti sono utili. Prendi in carico la tua salute con autorità."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "規律ある健康ルーチンが結果をもたらします。ウェルネス実践における構造と一貫性はあなたに役立ちます。権威を持って自分の健康を管理してください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Disiplinerte helserutiner gir resultater. Struktur og konsistens i velværepraksis tjener deg godt. Ta ansvar for helsen din med autoritet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zdyscyplinowane rutyny zdrowotne przynoszą rezultaty. Struktura i konsekwencja w praktykach wellness służą ci dobrze. Przejmij kontrolę nad swoim zdrowiem z autorytetem."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rotinas de saúde disciplinadas trazem resultados. Estrutura e consistência nas práticas de bem-estar servem bem a você. Assuma o controle da sua saúde com autoridade."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Disciplinerade hälsorutiner ger resultat. Struktur och konsekvens i välmåendepraktiker tjänar dig väl. Ta ansvar för din hälsa med auktoritet."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Дисципліновані оздоровчі процедури приносять результати. Структура та послідовність в оздоровчих практиках служать вам добре. Візьміть на себе відповідальність за своє здоров'я з авторитетом."
          }
        }
      }
    },
    "interpretation.the_emperor_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kontrollprobleme oder Starrheit belasten Beziehungen. Jemand ist zu dominant oder unflexibel. Mildere deinen Ansatz und erlaube mehr Flexibilität."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Control issues or rigidity strain relationships. Someone's being too domineering or inflexible. Soften your approach and allow more flexibility."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los problemas de control o la rigidez tensan las relaciones. Alguien es demasiado dominante o inflexible. Suaviza tu enfoque y permite más flexibilidad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les problèmes de contrôle ou la rigidité pèsent sur les relations. Quelqu'un est trop dominateur ou inflexible. Adoucissez votre approche et laissez plus de flexibilité."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Problemi di controllo o rigidità mettono a dura prova le relazioni. Qualcuno è troppo dominante o inflessibile. Addolcisci il tuo approccio e concedi più flessibilità."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "コントロールの問題や硬直性が人間関係に負担をかけています。誰かが支配的すぎたり、融通が利かなすぎたりします。あなたのアプローチを和らげ、より柔軟に対応しましょう。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kontrollproblemer eller rigiditet belaster relasjoner. Noen er for dominerende eller lite fleksibel. Mykne tilnærmingen din og tillat mer fleksibilitet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Problemy z kontrolą lub sztywność obciążają relacje. Ktoś jest zbyt dominujący lub nieelastyczny. Złagodź swoje podejście i pozwól na większą elastyczność."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Problemas de controle ou rigidez prejudicam os relacionamentos. Alguém é dominador demais ou inflexível. Suavize sua abordagem e permita mais flexibilidade."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kontrollproblem eller rigiditet belastar relationer. Någon är för dominerande eller oflexibel. Mjuka upp ditt förhållningssätt och tillåt mer flexibilitet."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Проблеми контролю або жорсткість обтяжують стосунки. Хтось занадто домінує або негнучкий. Пом'якшіть свій підхід і дозвольте більше гнучкості."
          }
        }
      }
    },
    "interpretation.the_emperor_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Struktur und Engagement stärken Beziehungen. Klare Grenzen und Führung schaffen Sicherheit. Es geht darum, in der Liebe etwas Stabiles und Dauerhaftes aufzubauen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Structure and commitment strengthen relationships. Clear boundaries and leadership create security. This is about building something stable and lasting in love."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La estructura y el compromiso fortalecen las relaciones. Los límites claros y el liderazgo crean seguridad. Se trata de construir algo estable y duradero en el amor."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La structure et l'engagement renforcent les relations. Des limites claires et un leadership créent la sécurité. Il s'agit de construire quelque chose de stable et de durable en amour."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Struttura e impegno rafforzano le relazioni. Confini chiari e leadership creano sicurezza. Si tratta di costruire qualcosa di stabile e duraturo nell'amore."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "構造とコミットメントが人間関係を強化します。明確な境界とリーダーシップが安心感を生み出します。愛において安定した永続的なものを築くことです。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Struktur og forpliktelse styrker relasjoner. Klare grenser og lederskap skaper trygghet. Dette handler om å bygge noe stabilt og varig i kjærlighet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Struktura i zaangażowanie wzmacniają relacje. Jasne granice i przywództwo tworzą bezpieczeństwo. Chodzi o budowanie czegoś stabilnego i trwałego w miłości."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estrutura e compromisso fortalecem os relacionamentos. Limites claros e liderança criam segurança. Trata-se de construir algo estável e duradouro no amor."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Struktur och engagemang stärker relationer. Tydliga gränser och ledarskap skapar trygghet. Det handlar om att bygga något stabilt och varaktigt i kärlek."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Структура та відданість зміцнюють стосунки. Чіткі межі та лідерство створюють безпеку. Йдеться про побудову чогось стабільного та тривалого в коханні."
          }
        }
      }
    },
    "interpretation.the_empress_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kreative Blockaden oder mangelndes Wachstum in deiner Karriere. Du vernachlässigst vielleicht deine Projekte oder fühlst dich eingeengt. Verbinde dich wieder mit dem, was deine Arbeit erfüllend macht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Creative blocks or lack of growth in your career. You might be neglecting your projects or feeling stifled. Reconnect with what makes your work fulfilling."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bloqueos creativos o falta de crecimiento en tu carrera. Puede que estés descuidando tus proyectos o sintiéndote sofocado. Reconecta con lo que hace que tu trabajo sea satisfactorio."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Blocages créatifs ou manque de croissance dans votre carrière. Vous négligez peut-être vos projets ou vous vous sentez étouffé. Renouez avec ce qui rend votre travail épanouissant."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Blocchi creativi o mancanza di crescita nella tua carriera. Potresti trascurare i tuoi progetti o sentirti soffocato. Riconnettiti con ciò che rende il tuo lavoro appagante."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "創造的なブロックやキャリアの成長不足。あなたは自分のプロジェクトを無視しているか、抑圧されていると感じているかもしれません。あなたの仕事をやりがいのあるものにしているものと再びつながってください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kreative blokkeringer eller mangel på vekst i karrieren din. Du kan neglisjere prosjektene dine eller føle deg kvalt. Gjenopprett kontakten med det som gjør arbeidet ditt tilfredsstillende."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Blokady twórcze lub brak rozwoju w twojej karierze. Być może zaniedbujesz swoje projekty lub czujesz się stłamszony. Połącz się ponownie z tym, co sprawia, że twoja praca jest satysfakcjonująca."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bloqueios criativos ou falta de crescimento na sua carreira. Você pode estar negligenciando seus projetos ou se sentindo sufocado. Reconecte-se com o que torna seu trabalho gratificante."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kreativa blockeringar eller brist på tillväxt i din karriär. Du kan försumma dina projekt eller känna dig kvävd. Återknyt kontakten med det som gör ditt arbete tillfredsställande."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Творчі блоки або відсутність зростання у вашій кар'єрі. Можливо, ви нехтуєте своїми проектами або почуваєтеся пригніченими. Возз'єднайтеся з тим, що робить вашу роботу повноцінною."
          }
        }
      }
    },
    "interpretation.the_empress_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kreative Projekte gedeihen jetzt. Dein fürsorglicher Führungsstil schafft Fülle. Dies ist eine ausgezeichnete Zeit für Wachstum, Zusammenarbeit und die Verwirklichung von Ideen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Creative projects flourish now. Your nurturing leadership style creates abundance. This is an excellent time for growth, collaboration, and bringing ideas to fruition."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los proyectos creativos florecen ahora. Tu estilo de liderazgo nutritivo crea abundancia. Este es un excelente momento para el crecimiento, la colaboración y la realización de ideas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les projets créatifs prospèrent maintenant. Votre style de leadership nourricier crée l'abondance. C'est le moment idéal pour la croissance, la collaboration et la concrétisation des idées."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I progetti creativi fioriscono ora. Il tuo stile di leadership nutriente crea abbondanza. Questo è un ottimo momento per la crescita, la collaborazione e la realizzazione delle idee."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "創造的なプロジェクトが今、開花します。あなたの育成するリーダーシップスタイルが豊かさを生み出します。これは、成長、コラボレーション、アイデアの実現に最適な時期です。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kreative prosjekter blomstrer nå. Din nærende lederstil skaper overflod. Dette er en utmerket tid for vekst, samarbeid og å realisere ideer."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kreatywne projekty rozkwitają teraz. Twój opiekuńczy styl przywództwa tworzy obfitość. To doskonały czas na rozwój, współpracę i urzeczywistnianie pomysłów."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Projetos criativos florescem agora. Seu estilo de liderança nutritivo cria abundância. Este é um excelente momento para crescimento, colaboração e realização de ideias."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kreativa projekt blomstrar nu. Din närande ledarstil skapar överflöd. Detta är en utmärkt tid för tillväxt, samarbete och att förverkliga idéer."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Творчі проекти зараз процвітають. Ваш турботливий стиль лідерства створює достаток. Це чудовий час для зростання, співпраці та втілення ідей у життя."
          }
        }
      }
    },
    "interpretation.the_empress_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Vernachlässigung oder zu hohe Ausgaben für Komfortartikel. Ressourcen sind möglicherweise blockiert. Überprüfe deine Beziehung zu materiellem Überfluss und Selbstwert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial neglect or overspending on comfort items. Resources may be blocked. Review your relationship with material abundance and self-worth."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Negligencia financiera o gasto excesivo en artículos de confort. Los recursos pueden estar bloqueados. Revisa tu relación con la abundancia material y la autoestima."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Négligence financière ou dépenses excessives en articles de confort. Les ressources peuvent être bloquées. Examinez votre relation avec l'abondance matérielle et l'estime de soi."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trascurare finanziario o spese eccessive per articoli di conforto. Le risorse potrebbero essere bloccate. Rivedi la tua relazione con l'abbondanza materiale e l'autostima."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的な怠慢または快適さのための支出過多。リソースがブロックされている可能性があります。物質的な豊かさと自己価値との関係を見直してください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk forsømmelse eller overforbruk på komfortvarer. Ressurser kan være blokkert. Gjennomgå forholdet ditt til materiell overflod og egenverdi."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zaniedbanie finansowe lub nadmierne wydatki na przedmioty zapewniające komfort. Zasoby mogą być zablokowane. Przejrzyj swoją relację z materialną obfitością i poczuciem własnej wartości."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Negligência financeira ou gastos excessivos em itens de conforto. Os recursos podem estar bloqueados. Revise seu relacionamento com a abundância material e a autoestima."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomisk försummelse eller överutgifter på komfortartiklar. Resurser kan vara blockerade. Granska din relation till materiellt överflöd och självvärde."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансова недбалість або надмірні витрати на предмети комфорту. Ресурси можуть бути заблоковані. Перегляньте свої стосунки з матеріальним достатком і самооцінкою."
          }
        }
      }
    },
    "interpretation.the_empress_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzieller Überfluss und Wachstum sind verfügbar. Deine Investitionen und Bemühungen tragen Früchte. Dies ist eine fruchtbare Zeit, um durch kreative oder fürsorgliche Bemühungen Wohlstand zu schaffen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial abundance and growth are available. Your investments and efforts bear fruit. This is a fertile time for creating wealth through creative or nurturing endeavors."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La abundancia financiera y el crecimiento están disponibles. Tus inversiones y esfuerzos dan frutos. Este es un momento fértil para crear riqueza a través de esfuerzos creativos o nutritivos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'abondance financière et la croissance sont disponibles. Vos investissements et vos efforts portent leurs fruits. C'est le moment idéal pour créer de la richesse grâce à des efforts créatifs ou nourriciers."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'abbondanza finanziaria e la crescita sono disponibili. I tuoi investimenti e i tuoi sforzi danno frutti. Questo è un periodo fertile per creare ricchezza attraverso sforzi creativi o nutrienti."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的な豊かさと成長が利用可能です。あなたの投資と努力は実を結びます。創造的または育成的な努力を通じて富を生み出す実り多い時期です。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk overflod og vekst er tilgjengelig. Investeringene og innsatsen din bærer frukter. Dette er en fruktbar tid for å skape rikdom gjennom kreativ eller nærende innsats."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dostępna jest obfitość finansowa i wzrost. Twoje inwestycje i wysiłki przynoszą owoce. To płodny czas na tworzenie bogactwa poprzez kreatywne lub opiekuńcze wysiłki."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abundância financeira e crescimento estão disponíveis. Seus investimentos e esforços dão frutos. Este é um momento fértil para criar riqueza por meio de esforços criativos ou nutritivos."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomiskt överflöd och tillväxt är tillgängligt. Dina investeringar och ansträngningar bär frukt. Detta är en fruktbar tid för att skapa rikedom genom kreativa eller närande ansträngningar."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансове достаток і зростання доступні. Ваші інвестиції та зусилля приносять плоди. Це плідний час для створення багатства за допомогою творчих або турботливих зусиль."
          }
        }
      }
    },
    "interpretation.the_empress_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kreative Blockaden, Vernachlässigung oder Abhängigkeitsprobleme treten auf. Du erstickst vielleicht oder wirst erstickt. Erhebe deine kreative Kraft und lerne gesunde Fürsorge."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Creative blocks, neglect, or dependency issues arise. You may be smothering or being smothered. Reclaim your creative power and learn healthy nurturing."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Surgen bloqueos creativos, negligencia o problemas de dependencia. Puede que estés asfixiando o siendo asfixiado. Recupera tu poder creativo y aprende a cuidar de manera saludable."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Des blocages créatifs, des négligences ou des problèmes de dépendance surviennent. Vous étouffez peut-être ou êtes étouffé. Retrouvez votre pouvoir créatif et apprenez à nourrir sainement."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Blocchi creativi, negligenza o problemi di dipendenza sorgono. Potresti soffocare o essere soffocato. Riconquista il tuo potere creativo e impara una sana nutrizione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "創造的なブロック、怠慢、または依存の問題が発生します。あなたは誰かを抑圧しているか、抑圧されているかもしれません。あなたの創造力を取り戻し、健全な養育を学びましょう。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kreative blokkeringer, forsømmelse eller avhengighetsproblemer oppstår. Du kan kvele eller bli kvalt. Gjenvinn din kreative kraft og lær sunn omsorg."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pojawiają się blokady twórcze, zaniedbania lub problemy zależnościowe. Możesz dusić lub być duszonym. Odzyskaj swoją twórczą moc i naucz się zdrowego pielęgnowania."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bloqueios criativos, negligência ou problemas de dependência surgem. Você pode estar sufocando ou sendo sufocado. Recupere seu poder criativo e aprenda a nutrir de forma saudável."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kreativa blockeringar, försummelse eller beroendeproblem uppstår. Du kanske kväver eller blir kvävd. Återfå din kreativa kraft och lär dig sund omvårdnad."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Виникають творчі блоки, нехтування або проблеми залежності. Ви можете душити або вас душать. Поверніть свою творчу силу та навчіться здорової турботи."
          }
        }
      }
    },
    "interpretation.the_empress_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fülle, Kreativität und nährende Energie umgeben dich. Dies ist eine Zeit des Wachstums und der Manifestation. Verbinde dich mit der Natur und deinem sinnlichen Selbst. Schönheit und Fruchtbarkeit in allen Formen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abundance, creativity, and nurturing energy surround you. This is a time of growth and manifestation. Connect with nature and your sensual self. Beauty and fertility in all forms."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La abundancia, la creatividad y la energía nutritiva te rodean. Este es un momento de crecimiento y manifestación. Conéctate con la naturaleza y tu yo sensual. Belleza y fertilidad en todas sus formas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'abondance, la créativité et l'énergie nourricière vous entourent. C'est un moment de croissance et de manifestation. Connectez-vous à la nature et à votre moi sensuel. La beauté et la fertilité sous toutes leurs formes."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'abbondanza, la creatività e l'energia nutriente ti circondano. Questo è un momento di crescita e manifestazione. Connettiti con la natura e il tuo io sensuale. Bellezza e fertilità in tutte le forme."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "豊かさ、創造性、育むエネルギーがあなたを包みます。これは成長と顕現の時期です。自然とあなたの官能的な自分とつながりましょう。あらゆる形の美しさと豊かさ。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Overflod, kreativitet og nærende energi omgir deg. Dette er en tid for vekst og manifestasjon. Koble deg til naturen og ditt sanselige jeg. Skjønnhet og fruktbarhet i alle former."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Obfitość, kreatywność i odżywcza energia cię otaczają. To czas wzrostu i manifestacji. Połącz się z naturą i swoją zmysłową stroną. Piękno i płodność we wszystkich formach."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abundância, criatividade e energia nutritiva o cercam. Este é um momento de crescimento e manifestação. Conecte-se com a natureza e seu eu sensual. Beleza e fertilidade em todas as formas."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Överflöd, kreativitet och närande energi omger dig. Detta är en tid för tillväxt och manifestation. Anslut till naturen och ditt sinnliga jag. Skönhet och fertilitet i alla former."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Достаток, творчість і живильна енергія оточують вас. Це час зростання та прояву. З'єднайтеся з природою та своїм чуттєвим \"я\". Краса і родючість у всіх формах."
          }
        }
      }
    },
    "interpretation.the_empress_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vernachlässigung der Selbstfürsorge oder übermäßiger Genuss. Dein Körper braucht mehr Aufmerksamkeit und Fürsorge. Ignoriere nicht die körperlichen oder emotionalen Bedürfnisse."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Neglecting self-care or overindulging. Your body needs more attention and nurturing. Don't ignore physical or emotional needs."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Descuidar el autocuidado o darse excesos. Tu cuerpo necesita más atención y cuidado. No ignores las necesidades físicas o emocionales."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Négliger les soins personnels ou les excès. Votre corps a besoin de plus d'attention et de soins. N'ignorez pas les besoins physiques ou émotionnels."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trascurare la cura di sé o eccessi. Il tuo corpo ha bisogno di più attenzione e cura. Non ignorare i bisogni fisici o emotivi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "セルフケアの怠りや過剰摂取。あなたの体はより多くの注意と養育を必要としています。身体的または感情的なニーズを無視しないでください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Forsømmelse av egenomsorg eller overgjødsel. Kroppen din trenger mer oppmerksomhet og omsorg. Ikke ignorer fysiske eller følelsesmessige behov."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zaniedbywanie samoopieki lub nadmierne pobłażanie. Twoje ciało potrzebuje więcej uwagi i troski. Nie ignoruj potrzeb fizycznych ani emocjonalnych."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Negligenciar o autocuidado ou excessos. Seu corpo precisa de mais atenção e cuidado. Não ignore as necessidades físicas ou emocionais."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Försumma egenvård eller överdrivet njutande. Din kropp behöver mer uppmärksamhet och omsorg. Ignorera inte fysiska eller känslomässiga behov."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Нехтування самообслуговуванням або надмірне потурання. Ваше тіло потребує більше уваги та турботи. Не ігноруйте фізичні чи емоційні потреби."
          }
        }
      }
    },
    "interpretation.the_empress_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dein Körper befindet sich in einer fruchtbaren, kreativen Phase. Ausgezeichnete Zeit für gesundheitsfördernde Praktiken, sanfte Bewegung und die Verbindung mit der Natur. Höre auf die Weisheit deines Körpers."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your body is in a fertile, creative phase. Excellent time for nurturing health practices, gentle movement, and connecting with nature. Listen to your body's wisdom."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu cuerpo está en una fase fértil y creativa. Excelente momento para prácticas de salud nutritivas, movimiento suave y conexión con la naturaleza. Escucha la sabiduría de tu cuerpo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre corps est dans une phase fertile et créative. C'est le moment idéal pour des pratiques de santé nourrissantes, des mouvements doux et une connexion avec la nature. Écoutez la sagesse de votre corps."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il tuo corpo è in una fase fertile e creativa. Ottimo momento per pratiche di salute nutrienti, movimento delicato e connessione con la natura. Ascolta la saggezza del tuo corpo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたの体は実り多く創造的な段階にあります。健康を育む実践、優しい運動、自然とのつながりに最適な時期です。体の知恵に耳を傾けてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kroppen din er i en fruktbar, kreativ fase. Utmerket tid for nærende helsepraksis, skånsom bevegelse og å koble seg til naturen. Lytt til kroppens visdom."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Twoje ciało jest w płodnej, kreatywnej fazie. Doskonały czas na pielęgnujące praktyki zdrowotne, delikatny ruch i kontakt z naturą. Słuchaj mądrości swojego ciała."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seu corpo está em uma fase fértil e criativa. Excelente momento para práticas de saúde nutritivas, movimento suave e conexão com a natureza. Ouça a sabedoria do seu corpo."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Din kropp är i en fertil, kreativ fas. Utmärkt tid för närande hälsoövningar, skonsam rörelse och att ansluta till naturen. Lyssna på din kropps visdom."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ваше тіло перебуває у родючій, творчій фазі. Чудовий час для оздоровчих практик, ніжних рухів і зв'язку з природою. Слухайте мудрість свого тіла."
          }
        }
      }
    },
    "interpretation.the_empress_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du vernachlässigst dich selbst oder andere in Beziehungen. Die kreative oder sexuelle Energie ist blockiert. Erstrickst du oder wirst du erstickt? Finde ein Gleichgewicht zwischen Geben und Nehmen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You're neglecting yourself or others in relationships. Creative or sexual energy feels blocked. Are you smothering or being smothered? Find balance in giving and receiving."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Te estás descuidando a ti mismo o a los demás en las relaciones. La energía creativa o sexual se siente bloqueada. ¿Estás asfixiando o siendo asfixiado? Encuentra el equilibrio entre dar y recibir."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous vous négligez ou négligez les autres dans vos relations. L'énergie créative ou sexuelle est bloquée. Étouffez-vous ou êtes-vous étouffé ? Trouvez l'équilibre entre donner et recevoir."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stai trascurando te stesso o gli altri nelle relazioni. L'energia creativa o sessuale si sente bloccata. Stai soffocando o vieni soffocato? Trova l'equilibrio tra dare e ricevere."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "人間関係において、自分自身や他人をないがしろにしています。創造的または性的なエネルギーが遮断されていると感じます。あなたは誰かを抑圧しているのか、それとも抑圧されているのか？与えることと受け取ることのバランスを見つけてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du forsømmer deg selv eller andre i relasjoner. Kreativ eller seksuell energi føles blokkert. Kveler du eller blir du kvalt? Finn balanse i å gi og ta."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zaniedbujesz siebie lub innych w związkach. Kreatywna lub seksualna energia jest zablokowana. Czy dusisz, czy jesteś duszony? Znajdź równowagę między dawaniem a otrzymywaniem."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você está negligenciando a si mesmo ou aos outros nos relacionamentos. A energia criativa ou sexual parece bloqueada. Você está sufocando ou sendo sufocado? Encontre equilíbrio entre dar e receber."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du försummar dig själv eller andra i relationer. Kreativ eller sexuell energi känns blockerad. Kväver du eller blir du kvävd? Hitta balans mellan att ge och ta."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ви нехтуєте собою чи іншими у стосунках. Творча чи сексуальна енергія заблокована. Ви душите чи вас душать? Знайдіть баланс між даванням і отриманням."
          }
        }
      }
    },
    "interpretation.the_empress_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reichlich Liebe und nährende Energie fließen durch deine Beziehungen. Dies ist eine fruchtbare Zeit für die Romantik – entweder für neue Liebe oder für die Vertiefung bestehender Bindungen. Umarme deine sinnliche, kreative Seite."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abundant love and nurturing energy flow through your relationships. This is a fertile time for romance—either new love or deepening existing bonds. Embrace your sensual, creative side."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El amor abundante y la energía nutritiva fluyen a través de tus relaciones. Este es un momento fértil para el romance, ya sea para un nuevo amor o para profundizar los lazos existentes. Abraza tu lado sensual y creativo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un amour abondant et une énergie nourricière traversent vos relations. C'est une période fertile pour la romance – que ce soit un nouvel amour ou l'approfondissement des liens existants. Embrassez votre côté sensuel et créatif."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Amore abbondante ed energia nutriente fluiscono attraverso le tue relazioni. Questo è un periodo fertile per il romanticismo – sia per un nuovo amore che per approfondire i legami esistenti. Abbraccia il tuo lato sensuale e creativo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "豊かな愛と育むエネルギーがあなたの人間関係を通して流れています。これはロマンスにとって実り多い時期です。新しい恋であれ、既存の絆を深めるのであれ。あなたの官能的で創造的な側面を受け入れてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rikelig kjærlighet og nærende energi flyter gjennom relasjonene dine. Dette er en fruktbar tid for romantikk – enten ny kjærlighet eller å utdype eksisterende bånd. Omfavn din sensuelle, kreative side."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Obfita miłość i odżywcza energia przepływają przez twoje relacje. To płodny czas na romans – czy to nową miłość, czy pogłębienie istniejących więzi. Przyjmij swoją zmysłową, kreatywną stronę."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Amor abundante e energia nutritiva fluem através de seus relacionamentos. Este é um momento fértil para o romance – seja novo amor ou aprofundamento de laços existentes. Abrace seu lado sensual e criativo."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Riklig kärlek och näringsrik energi flödar genom dina relationer. Detta är en fruktbar tid för romantik – antingen ny kärlek eller fördjupning av befintliga band. Omfamna din sensuella, kreativa sida."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Рясна любов і живильна енергія течуть через ваші стосунки. Це плідний час для романтики – або нового кохання, або поглиблення існуючих зв'язків. Прийміть свою чуттєву, творчу сторону."
          }
        }
      }
    },
    "interpretation.the_fool_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du zögerst, wenn du vorankommen solltest, oder bist vielleicht rücksichtslos ohne Plan. Finde die Balance zwischen Mut und Vorbereitung. Lass dich nicht von Angst zurückhalten, aber springe auch nicht ohne hinzusehen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You're hesitating when you should be moving forward, or perhaps you're being reckless without a plan. Find the balance between courage and preparation. Don't let fear hold you back, but don't jump without looking either."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estás dudando cuando deberías avanzar, o quizás estás siendo imprudente sin un plan. Encuentra el equilibrio entre el coraje y la preparación. No dejes que el miedo te detenga, pero tampoco saltes sin mirar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous hésitez alors que vous devriez avancer, ou peut-être êtes-vous imprudent sans plan. Trouvez l'équilibre entre le courage et la préparation. Ne laissez pas la peur vous retenir, mais ne sautez pas sans regarder non plus."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esiti quando dovresti andare avanti, o forse sei spericolato senza un piano. Trova l'equilibrio tra coraggio e preparazione. Non lasciare che la paura ti trattenga, ma non saltare senza guardare neanche."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "前に進むべき時にためらっているか、計画なしに無謀になっています。勇気と準備のバランスを見つけてください。恐怖に足を止められないようにしつつ、見ずに飛び込まないでください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du nøler når du burde gå fremover, eller kanskje du er hensynsløs uten en plan. Finn balansen mellom mot og forberedelse. Ikke la frykt holde deg tilbake, men ikke hopp uten å se heller."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wahasz się, gdy powinieneś iść naprzód, lub być może jesteś lekkomyślny bez planu. Znajdź równowagę między odwagą a przygotowaniem. Nie pozwól, aby strach cię powstrzymywał, ale też nie skacz bez patrzenia."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você está hesitando quando deveria estar avançando, ou talvez esteja sendo imprudente sem um plano. Encontre o equilíbrio entre coragem e preparação. Não deixe o medo te segurar, mas também não pule sem olhar."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du tvekar när du borde gå framåt, eller så är du kanske hänsynslös utan en plan. Hitta balansen mellan mod och förberedelse. Låt inte rädsla hålla dig tillbaka, men hoppa inte heller utan att titta."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ви вагаєтеся, коли слід рухатися вперед, або, можливо, ви безрозсудні без плану. Знайдіть баланс між сміливістю та підготовкою. Не дозволяйте страху стримувати вас, але також не стрибайте, не подивившись."
          }
        }
      }
    },
    "interpretation.the_fool_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ein Neuanfang kommt auf dich zu – vielleicht ein neuer Job, ein Projekt oder ein unternehmerisches Vorhaben. Diese Karte sagt dir, deiner Vision zu vertrauen und das Risiko einzugehen, das du in Betracht gezogen hast. Das Universum unterstützt mutige Schritte. Bleib neugierig und offen für Neues."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A fresh start is coming your way—perhaps a new job, project, or entrepreneurial venture. This card tells you to trust your vision and take that risk you've been considering. The universe supports bold moves right now. Stay curious and open to learning."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un nuevo comienzo se acerca—quizás un nuevo trabajo, proyecto o emprendimiento. Esta carta te dice que confíes en tu visión y tomes ese riesgo que has estado considerando. El universo apoya los movimientos audaces ahora. Mantén la curiosidad y la apertura para aprender."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un nouveau départ arrive — peut-être un nouvel emploi, projet ou entreprise. Cette carte vous dit de faire confiance à votre vision et de prendre ce risque que vous avez envisagé. L'univers soutient les actions audacieuses en ce moment. Restez curieux et ouvert à l'apprentissage."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un nuovo inizio sta arrivando — forse un nuovo lavoro, progetto o impresa imprenditoriale. Questa carta ti dice di fidarti della tua visione e di correre quel rischio che hai considerato. L'universo supporta le mosse audaci in questo momento. Sii curioso e aperto all'apprendimento."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "新たな始まりが訪れています—おそらく新しい仕事、プロジェクト、または起業です。このカードはあなたのビジョンを信じ、考えているリスクを取るように伝えています。今、宇宙は大胆な行動をサポートしています。好奇心を持ち、学ぶことにオープンでいてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En ny start kommer din vei — kanskje en ny jobb, et prosjekt eller en gründersatsing. Dette kortet forteller deg å stole på visjonen din og ta den risikoen du har vurdert. Universet støtter dristige trekk akkurat nå. Vær nysgjerrig og åpen for å lære."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nowy początek nadchodzi — być może nowa praca, projekt lub przedsięwzięcie biznesowe. Ta karta mówi ci, abyś zaufał swojej wizji i podjął to ryzyko, które rozważałeś. Wszechświat wspiera odważne ruchy w tej chwili. Bądź ciekawy i otwarty na naukę."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um novo começo está a caminho — talvez um novo emprego, projeto ou empreendimento. Esta carta diz para você confiar na sua visão e correr o risco que tem considerado. O universo apoia movimentos ousados agora. Mantenha-se curioso e aberto ao aprendizado."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En ny början är på väg — kanske ett nytt jobb, projekt eller entreprenörssatsning. Det här kortet säger att du ska lita på din vision och ta den risk du har övervägt. Universum stöder djärva drag just nu. Var nyfiken och öppen för att lära."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Новий початок на вашому шляху — можливо, нова робота, проєкт або підприємницька справа. Ця карта каже вам довіряти своєму баченню і ризикнути, як ви обмірковували. Всесвіт підтримує сміливі кроки зараз. Будьте цікавими та відкритими до навчання."
          }
        }
      }
    },
    "interpretation.the_fool_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sorgloser Umgang mit Geld oder schlechte Finanzplanung könnten dir jetzt zum Verhängnis werden. Tätige keine impulsiven Käufe oder Investitionen. Du brauchst einen soliden Plan, bevor du springst. Hol dir Rat von jemandem mit mehr Erfahrung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Careless spending or poor financial planning could be your downfall right now. Don't make impulsive purchases or investments. You need a solid plan before you leap. Seek advice from someone more experienced."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los gastos descuidados o la mala planificación financiera podrían ser tu perdición ahora. No hagas compras o inversiones impulsivas. Necesitas un plan sólido antes de saltar. Busca consejo de alguien con más experiencia."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Des dépenses imprudentes ou une mauvaise planification financière pourraient être votre perte en ce moment. Ne faites pas d'achats ou d'investissements impulsifs. Vous avez besoin d'un plan solide avant de sauter. Demandez conseil à quelqu'un de plus expérimenté."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spese imprudenti o una cattiva pianificazione finanziaria potrebbero essere la tua rovina in questo momento. Non fare acquisti o investimenti impulsivi. Hai bisogno di un piano solido prima di saltare. Cerca consiglio da qualcuno con più esperienza."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "無謀な支出や悪い財務計画が今、あなたの失敗の原因になるかもしれません。衝動的な購入や投資をしないでください。飛び込む前にしっかりとした計画が必要です。より経験のある人にアドバイスを求めてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uforsiktige utgifter eller dårlig økonomisk planlegging kan være din undergang akkurat nå. Ikke gjør impulsive kjøp eller investeringer. Du trenger en solid plan før du hopper. Søk råd fra noen med mer erfaring."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niedbałe wydatki lub złe planowanie finansowe mogą być teraz twoim upadkiem. Nie dokonuj impulsywnych zakupów ani inwestycji. Potrzebujesz solidnego planu, zanim skoczysz. Zasięgnij porady od kogoś z większym doświadczeniem."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gastos descuidados ou planejamento financeiro ruim podem ser sua ruína agora. Não faça compras ou investimentos impulsivos. Você precisa de um plano sólido antes de pular. Busque conselho de alguém com mais experiência."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Slarviga utgifter eller dålig ekonomisk planering kan bli din undergång just nu. Gör inte impulsiva köp eller investeringar. Du behöver en solid plan innan du hoppar. Sök råd från någon med mer erfarenhet."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Необережні витрати або погане фінансове планування можуть стати вашою загибеллю зараз. Не робіть імпульсивних покупок чи інвестицій. Вам потрібен надійний план перед стрибком. Зверніться за порадою до когось із більшим досвідом."
          }
        }
      }
    },
    "interpretation.the_fool_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Neue finanzielle Möglichkeiten entstehen. Das könnte eine Investition, ein Nebenjob oder eine völlig neue Einnahmequelle sein. Vertraue deinen Instinkten, aber mach deine Hausaufgaben. Das Glück ist mit den Mutigen, aber die vorbereiteten Mutigen machen es noch besser."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "New financial opportunities are emerging. This could be an investment, a side hustle, or a completely new income stream. Trust your instincts, but do your homework. Fortune favors the brave, but the prepared brave do even better."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nuevas oportunidades financieras están surgiendo. Podría ser una inversión, un trabajo secundario o una fuente de ingresos completamente nueva. Confía en tus instintos, pero haz tu tarea. La fortuna favorece a los valientes, pero los valientes preparados lo hacen aún mejor."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De nouvelles opportunités financières émergent. Cela pourrait être un investissement, un travail secondaire ou une toute nouvelle source de revenus. Faites confiance à vos instincts, mais faites vos devoirs. La fortune sourit aux audacieux, mais les audacieux préparés font encore mieux."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nuove opportunità finanziarie stanno emergendo. Potrebbe essere un investimento, un'attività secondaria o una fonte di reddito completamente nuova. Fidati dei tuoi istinti, ma fai i compiti a casa. La fortuna favorisce i coraggiosi, ma i coraggiosi preparati fanno ancora meglio."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "新しい経済的機会が現れています。それは投資、副業、またはまったく新しい収入源かもしれません。直感を信じてくださいが、調査も忘れずに。運は勇敢な者を味方しますが、準備された勇敢な者はさらにうまくいきます。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nye økonomiske muligheter dukker opp. Dette kan være en investering, en sidejobb eller en helt ny inntektskilde. Stol på instinktene dine, men gjør leksene dine. Fluen favoriserer de modige, men de forberedte modige gjør det enda bedre."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pojawiają się nowe możliwości finansowe. Może to być inwestycja, dodatkowa praca lub całkowicie nowe źródło dochodu. Zaufaj swoim instynktom, ale odrób pracę domową. Fortuna sprzyja odważnym, ale przygotowani odważni radzą sobie jeszcze lepiej."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Novas oportunidades financeiras estão surgindo. Pode ser um investimento, um trabalho extra ou uma fonte de renda completamente nova. Confie nos seus instintos, mas faça sua lição de casa. A fortuna favorece os corajosos, mas os corajosos preparados se saem ainda melhor."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nya ekonomiska möjligheter dyker upp. Detta kan vara en investering, en sidoverksamhet eller en helt ny inkomstkälla. Lita på dina instinkter, men gör dina läxor. Turen gynnar de modiga, men de förberedda modiga gör det ännu bättre."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "З'являються нові фінансові можливості. Це може бути інвестиція, підробіток або зовсім нове джерело доходу. Довіряйте своїм інстинктам, але виконайте домашнє завдання. Фортуна сприяє сміливим, але підготовлені сміливі роблять ще краще."
          }
        }
      }
    },
    "interpretation.the_fool_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Angst oder Torheit halten dich zurück. Entweder hast du zu viel Angst, um voranzukommen, oder du bist rücksichtslos, ohne die Dinge zu durchdenken. Finde deine Mitte. Wie sieht weiser Mut in dieser Situation aus?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fear or foolishness is holding you back. Either you're too scared to move forward, or you're being reckless without thinking things through. Find your center. What does wise courage look like in this situation?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El miedo o la necedad te están deteniendo. O tienes demasiado miedo para avanzar, o eres imprudente sin pensar las cosas. Encuentra tu centro. ¿Cómo se ve el valor sabio en esta situación?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La peur ou la folie vous retient. Soit vous avez trop peur pour avancer, soit vous êtes imprudent sans réfléchir. Trouvez votre centre. À quoi ressemble un courage sage dans cette situation ?"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La paura o la stoltezza ti stanno trattenendo. O hai troppa paura per andare avanti, o sei spericolato senza pensare alle cose. Trova il tuo centro. Che aspetto ha il coraggio saggio in questa situazione?"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "恐怖か愚かさがあなたを妨げています。前に進むのが怖すぎるか、考えずに無謀になっています。自分の中心を見つけてください。この状況で賢明な勇気とはどのようなものでしょうか？"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Frykt eller dårskap holder deg tilbake. Enten er du for redd til å gå fremover, eller så er du hensynsløs uten å tenke gjennom tingene. Finn ditt sentrum. Hvordan ser visdom mot ut i denne situasjonen?"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Strach lub głupota cię powstrzymują. Albo boisz się iść naprzód, albo jesteś lekkomyślny bez przemyślenia spraw. Znajdź swój środek. Jak wygląda mądra odwaga w tej sytuacji?"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O medo ou a tolice estão te segurando. Ou você está com muito medo de seguir em frente, ou está sendo imprudente sem pensar nas coisas. Encontre seu centro. Como é a coragem sábia nesta situação?"
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rädsla eller dårskap håller dig tillbaka. Antingen är du för rädd för att gå framåt, eller så är du hänsynslös utan att tänka igenom saker. Hitta ditt centrum. Hur ser klokt mod ut i den här situationen?"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Страх або дурість стримують вас. Або ви надто боїтеся рухатися вперед, або ви безрозсудні, не обдумуючи речі. Знайдіть свій центр. Як виглядає мудра сміливість у цій ситуації?"
          }
        }
      }
    },
    "interpretation.the_fool_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du stehst am Rande von etwas Neuem und Wunderbarem. Diese Karte lädt dich ein, einen Vertrauenssprung zu wagen, der bevorstehenden Reise zu vertrauen, auch wenn du den ganzen Weg nicht sehen kannst. Umarme die Ungewissheit mit offenem Herzen. Das Universum hält dir den Rücken frei."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You're standing at the edge of something new and wonderful. This card invites you to take a leap of faith, to trust in the journey ahead even if you can't see the whole path. Embrace uncertainty with an open heart. The universe has your back."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estás al borde de algo nuevo y maravilloso. Esta carta te invita a dar un salto de fe, a confiar en el viaje que tienes por delante incluso si no puedes ver todo el camino. Abraza la incertidumbre con el corazón abierto. El universo te respalda."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous êtes au bord de quelque chose de nouveau et de merveilleux. Cette carte vous invite à faire un acte de foi, à faire confiance au voyage à venir même si vous ne pouvez pas voir tout le chemin. Embrassez l'incertitude avec un cœur ouvert. L'univers vous soutient."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sei sull'orlo di qualcosa di nuovo e meraviglioso. Questa carta ti invita a fare un atto di fede, a fidarti del viaggio che ti aspetta anche se non puoi vedere l'intero percorso. Abbraccia l'incertezza con cuore aperto. L'universo è dalla tua parte."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたは新しい素晴らしい何かの瀬戸際に立っています。このカードは、道全体が見えなくても、これからの旅を信じて、信念を持って飛躍するようあなたを誘います。不確実性をオープンな心で受け入れてください。宇宙はあなたの味方です。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du står på kanten av noe nytt og fantastisk. Dette kortet inviterer deg til å ta et trossprang, til å stole på reisen fremover selv om du ikke kan se hele veien. Omfavn usikkerheten med et åpent hjerte. Universet har din rygg."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stoisz na krawędzi czegoś nowego i wspaniałego. Ta karta zaprasza cię do wykonania skoku wiary, zaufania w podróż przed sobą, nawet jeśli nie widzisz całej ścieżki. Przyjmij niepewność z otwartym sercem. Wszechświat cię wspiera."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você está à beira de algo novo e maravilhoso. Esta carta convida você a dar um salto de fé, a confiar na jornada adiante, mesmo que não possa ver todo o caminho. Abrace a incerteza com o coração aberto. O universo está ao seu lado."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du står vid kanten av något nytt och underbart. Det här kortet inbjuder dig att ta ett språng av tro, att lita på resan framåt även om du inte kan se hela vägen. Omfamna osäkerheten med ett öppet hjärta. Universum har din rygg."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ви стоїте на краю чогось нового та чудового. Ця карта запрошує вас зробити стрибок віри, довіритися подорожі попереду, навіть якщо ви не бачите всього шляху. Прийміть невизначеність з відкритим серцем. Всесвіт підтримує вас."
          }
        }
      }
    },
    "interpretation.the_fool_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du ignorierst vielleicht Warnsignale oder gehst unnötige Risiken mit deiner Gesundheit ein. Verlangsame und höre auf das, was dein Körper dir sagt. Rücksichtslosigkeit könnte später zu Problemen führen. Such bei Bedarf professionelle Beratung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You might be ignoring warning signs or taking unnecessary risks with your health. Slow down and listen to what your body is telling you. Recklessness now could lead to problems later. Seek professional guidance if needed."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Puede que estés ignorando señales de advertencia o tomando riesgos innecesarios con tu salud. Reduce la velocidad y escucha lo que tu cuerpo te dice. La imprudencia ahora podría traer problemas después. Busca orientación profesional si es necesario."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous ignorez peut-être les signes d'avertissement ou prenez des risques inutiles avec votre santé. Ralentissez et écoutez ce que votre corps vous dit. L'imprudence maintenant pourrait causer des problèmes plus tard. Demandez des conseils professionnels si nécessaire."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Potresti ignorare segnali di avvertimento o prendere rischi inutili con la tua salute. Rallenta e ascolta cosa ti dice il tuo corpo. L'imprudenza ora potrebbe portare a problemi in seguito. Cerca una guida professionale se necessario."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "警告サインを無視したり、健康に不要なリスクを取っている可能性があります。速度を落とし、体が伝えていることを聞いてください。今の無謀さは後で問題を引き起こす可能性があります。必要に応じて専門家の指導を求めてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du kan ignorere advarselsskilt eller ta unødvendige risikoer med helsen din. Senk farten og lytt til hva kroppen din forteller deg. Uforsiktighet nå kan føre til problemer senere. Søk profesjonell veiledning om nødvendig."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Możesz ignorować znaki ostrzegawcze lub podejmować niepotrzebne ryzyko ze swoim zdrowiem. Zwolnij i posłuchaj, co mówi ci twoje ciało. Lekkomyślność teraz może prowadzić do problemów później. W razie potrzeby poszukaj profesjonalnej porady."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você pode estar ignorando sinais de alerta ou assumindo riscos desnecessários com sua saúde. Diminua a velocidade e ouça o que seu corpo está dizendo. Imprudência agora pode levar a problemas depois. Busque orientação profissional se necessário."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du kanske ignorerar varningssignaler eller tar onödiga risker med din hälsa. Sakta ner och lyssna på vad din kropp säger dig. Hänsynslöshet nu kan leda till problem senare. Sök professionell vägledning om det behövs."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ви можете ігнорувати попереджувальні знаки або ризикувати своїм здоров'ям без потреби. Уповільніть і прислухайтеся до того, що говорить ваше тіло. Безрозсудність зараз може призвести до проблем пізніше. Зверніться за професійною допомогою, якщо потрібно."
          }
        }
      }
    },
    "interpretation.the_fool_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dies ist der perfekte Zeitpunkt, um eine neue Gesundheitsreise zu beginnen. Ob Fitnessroutine, Ernährungsumstellung oder Wellnesspraxis – die Energie unterstützt Neuanfänge. Geh mit Begeisterung und Offenheit daran. Dein Körper ist bereit für positive Veränderungen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This is the perfect time to start a new health journey. Whether it's a fitness routine, dietary change, or wellness practice, the energy supports new beginnings. Approach it with enthusiasm and an open mind. Your body is ready for positive change."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este es el momento perfecto para comenzar un nuevo viaje de salud. Ya sea una rutina de ejercicios, un cambio dietético o una práctica de bienestar, la energía apoya los nuevos comienzos. Abórdalo con entusiasmo y mente abierta. Tu cuerpo está listo para un cambio positivo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "C'est le moment parfait pour commencer un nouveau parcours de santé. Que ce soit une routine de fitness, un changement alimentaire ou une pratique de bien-être, l'énergie soutient les nouveaux départs. Abordez-le avec enthousiasme et ouverture d'esprit. Votre corps est prêt pour un changement positif."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questo è il momento perfetto per iniziare un nuovo percorso di salute. Che si tratti di una routine di fitness, un cambiamento alimentare o una pratica di benessere, l'energia supporta i nuovi inizi. Affrontalo con entusiasmo e mente aperta. Il tuo corpo è pronto per un cambiamento positivo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "新しい健康の旅を始めるのに完璧な時期です。フィットネスルーティン、食事の変更、ウェルネスプラクティスなど、エネルギーは新たな始まりをサポートします。熱意とオープンマインドで取り組んでください。あなたの体はポジティブな変化の準備ができています。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dette er den perfekte tiden til å starte en ny helsereise. Enten det er en treningsrutine, kostholdsendring eller velværepraksis, støtter energien nye begynnelser. Nærme deg det med entusiasme og et åpent sinn. Kroppen din er klar for positiv endring."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "To idealny czas, aby rozpocząć nową podróż zdrowotną. Niezależnie od tego, czy jest to rutyna fitness, zmiana diety, czy praktyka wellness, energia wspiera nowe początki. Podejdź do tego z entuzjazmem i otwartym umysłem. Twoje ciało jest gotowe na pozytywne zmiany."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este é o momento perfeito para começar uma nova jornada de saúde. Seja uma rotina de exercícios, mudança na dieta ou prática de bem-estar, a energia apoia novos começos. Aborde com entusiasmo e mente aberta. Seu corpo está pronto para mudanças positivas."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Det här är den perfekta tiden att påbörja en ny hälsoresa. Oavsett om det är en träningsrutin, kostförändring eller friskvårdspraktik, stödjer energin nya början. Närma dig det med entusiasm och öppet sinne. Din kropp är redo för positiv förändring."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Це ідеальний час, щоб розпочати нову подорож до здоров'я. Незалежно від того, чи це фітнес-рутина, зміна дієти чи оздоровча практика, енергія підтримує нові починання. Підходьте до цього з ентузіазмом і відкритим розумом. Ваше тіло готове до позитивних змін."
          }
        }
      }
    },
    "interpretation.the_fool_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du stürzt dich vielleicht unüberlegt in etwas. Hier ist eine Naivität, die zu Kummer führen könnte. Tritt einen Schritt zurück und frage dich, ob du in Bezug auf diese Verbindung realistisch bist. Ignoriere keine Warnsignale zugunsten der Aufregung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You may be rushing into something without thinking it through. There's a naivety here that could lead to heartache. Take a step back and ask yourself if you're being realistic about this connection. Don't ignore red flags in favor of excitement."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Puede que te estés apresurando en algo sin pensarlo bien. Hay una ingenuidad aquí que podría llevar a la angustia. Da un paso atrás y pregúntate si estás siendo realista sobre esta conexión. No ignores las banderas rojas en favor de la emoción."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous vous précipitez peut-être dans quelque chose sans réfléchir. Il y a une naïveté ici qui pourrait mener à des chagrins. Reculez d'un pas et demandez-vous si vous êtes réaliste à propos de cette connexion. N'ignorez pas les signaux d'alarme en faveur de l'excitation."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Potresti precipitarti in qualcosa senza pensarci bene. C'è un'ingenuità qui che potrebbe portare a sofferenza. Fai un passo indietro e chiediti se stai essendo realistico riguardo a questa connessione. Non ignorare le bandiere rosse a favore dell'eccitazione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたは考えずに何かに急いでいるかもしれません。ここには苦痛につながる可能性がある無邪気さがあります。一歩下がって、この関係について現実的かどうか自問してください。興奮のために危険信号を無視しないでください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du kan haste inn i noe uten å tenke deg om. Det er en naivitet her som kan føre til hjertesorg. Ta et skritt tilbake og spør deg selv om du er realistisk om denne forbindelsen. Ikke ignorer røde flagg til fordel for spenning."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Możesz pędzić w coś bez zastanowienia. Jest tu naiwność, która może prowadzić do bólu serca. Zrób krok w tył i zapytaj siebie, czy jesteś realistą w kwestii tego połączenia. Nie ignoruj czerwonych flag na rzecz ekscytacji."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você pode estar se apressando em algo sem pensar direito. Há uma ingenuidade aqui que pode levar à mágoa. Dê um passo para trás e pergunte-se se você está sendo realista sobre essa conexão. Não ignore os sinais de alerta em favor da empolgação."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du kanske rusar in i något utan att tänka efter. Det finns en naivitet här som kan leda till hjärtesorg. Ta ett steg tillbaka och fråga dig själv om du är realistisk om denna koppling. Ignorera inte varningssignaler till förmån för spänning."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ви можете поспішати в щось, не обдумавши. Тут є наївність, яка може призвести до серцевого болю. Зробіть крок назад і запитайте себе, чи ви реалістично ставитесь до цього зв'язку. Не ігноруйте червоні прапорці заради хвилювання."
          }
        }
      }
    },
    "interpretation.the_fool_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine neue Romanze am Horizont, voller Aufregung und Spontaneität. Du bist aufgerufen, einen Vertrauenssprung in Herzensangelegenheiten zu wagen. Denk nicht zu viel nach – folge deinen Instinkten und umarme das Abenteuer, das auf dich wartet. Dies ist eine Zeit, offen, authentisch und furchtlos in der Liebe zu sein."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A new romance is on the horizon, filled with excitement and spontaneity. You're being called to take a leap of faith in matters of the heart. Don't overthink it—follow your instincts and embrace the adventure that awaits. This is a time to be open, authentic, and fearless in love."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un nuevo romance está en el horizonte, lleno de emoción y espontaneidad. Estás llamado a dar un salto de fe en asuntos del corazón. No lo pienses demasiado: sigue tus instintos y abraza la aventura que te espera. Este es un momento para ser abierto, auténtico y sin miedo en el amor."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une nouvelle romance se profile à l'horizon, pleine d'excitation et de spontanéité. Vous êtes appelé à faire un acte de foi en matière de cœur. Ne réfléchissez pas trop — suivez vos instincts et embrassez l'aventure qui vous attend. C'est le moment d'être ouvert, authentique et sans peur en amour."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una nuova storia d'amore è all'orizzonte, piena di eccitazione e spontaneità. Sei chiamato a fare un atto di fede nelle questioni del cuore. Non pensarci troppo — segui i tuoi istinti e abbraccia l'avventura che ti aspetta. Questo è un momento per essere aperto, autentico e senza paura nell'amore."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "新しい恋愛が地平線に現れ、興奮と自発性に満ちています。あなたは恋愛において信念を持って飛躍するよう呼ばれています。考えすぎないで—直感に従い、待っている冒険を受け入れてください。これは愛においてオープンで、真実で、恐れを知らない時です。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En ny romanse er i horisonten, fylt med spenning og spontanitet. Du blir kalt til å ta et trossprang i hjertesaker. Ikke overtenk det — følg instinktene dine og omfavn eventyret som venter. Dette er en tid for å være åpen, autentisk og fryktløs i kjærlighet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nowy romans jest na horyzoncie, pełen ekscytacji i spontaniczności. Zostajesz wezwany do wykonania skoku wiary w sprawach sercowych. Nie myśl za dużo — podążaj za swoimi instynktami i przyjmij przygodę, która czeka. To czas, aby być otwartym, autentycznym i nieustraszonym w miłości."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um novo romance está no horizonte, cheio de empolgação e espontaneidade. Você está sendo chamado a dar um salto de fé nas questões do coração. Não pense demais — siga seus instintos e abrace a aventura que o espera. Este é um momento para ser aberto, autêntico e destemido no amor."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En ny romans är i horisonten, fylld av spänning och spontanitet. Du kallas att ta ett språng av tro i hjärtfrågor. Övertänk inte — följ dina instinkter och omfamna äventyret som väntar. Det här är en tid att vara öppen, autentisk och orädd i kärlek."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Новий роман на горизонті, сповнений хвилювання та спонтанності. Вас закликають зробити стрибок віри у сердечних справах. Не переосмислюйте — слідуйте своїм інстинктам і прийміть пригоду, яка чекає. Це час бути відкритим, автентичним і безстрашним у коханні."
          }
        }
      }
    },
    "interpretation.the_hanged_man_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Widerstand gegen notwendige Karrierepausen oder Verzögerungen. Unentschlossenheit und Stillstand verschwenden Zeit. Akzeptiere die Unterbrechung oder triff eine Entscheidung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resisting necessary career pauses or delays. Indecision and stalling waste time. Embrace the suspension or make a decision."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resistencia a las pausas o retrasos necesarios en la carrera. La indecisión y el estancamiento pierden el tiempo. Acepta la suspensión o toma una decisión."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Résistance aux pauses ou retards nécessaires dans la carrière. L'indécision et le blocage font perdre du temps. Acceptez la suspension ou prenez une décision."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resistenza alle pause o ritardi necessari nella carriera. Indecisione e stallo fanno perdere tempo. Accetta la sospensione o prendi una decisione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "必要なキャリアの休止や遅延に対する抵抗。優柔不断と停滞が時間を浪費します。停止を受け入れるか、決断を下してください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Motstand mot nødvendige karrierepauser eller forsinkelser. Ubesluttsomhet og stagnasjon kaster bort tid. Omfavn suspensjonen eller ta en avgjørelse."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opór wobec koniecznych przerw w karierze lub opóźnień. Niezdecydowanie i stagnacja marnują czas. Zaakceptuj zawieszenie lub podejmij decyzję."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resistência a pausas ou atrasos necessários na carreira. Indecisão e estagnação perdem tempo. Aceite a suspensão ou tome uma decisão."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Motstånd mot nödvändiga karriärpauser eller förseningar. Obeslutsamhet och stagnation slösar tid. Acceptera avstängningen eller fatta ett beslut."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Опір необхідним кар'єрним паузам або затримкам. Нерішучість і стагнація витрачають час. Прийміть паузу або прийміть рішення."
          }
        }
      }
    },
    "interpretation.the_hanged_man_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine berufliche Pause bringt neue Perspektiven. Gib alte Ansätze auf und sieh deinen Weg anders. Manchmal ist es der richtige Schritt, nicht voranzukommen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Career pause brings new perspective. Surrender old approaches and see your path differently. Sometimes not moving forward is the right move."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una pausa profesional trae una nueva perspectiva. Abandona los viejos enfoques y mira tu camino de manera diferente. A veces no avanzar es el movimiento correcto."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une pause professionnelle apporte une nouvelle perspective. Abandonnez les anciennes approches et voyez votre chemin différemment. Parfois, ne pas avancer est la bonne décision."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una pausa professionale porta una nuova prospettiva. Abbandona i vecchi approcci e guarda il tuo percorso diversamente. A volte non andare avanti è la mossa giusta."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャリアの一時停止が新しい視点をもたらします。古いアプローチを捨て、自分の道を別の見方で見てください。時には前に進まないことが正しい行動です。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En karrierepause gir nytt perspektiv. Gi slipp på gamle tilnærminger og se veien din annerledes. Noen ganger er det riktig å ikke gå fremover."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pauza w karierze przynosi nową perspektywę. Porzuć stare podejścia i zobacz swoją ścieżkę inaczej. Czasami nie pójście do przodu jest właściwym posunięciem."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uma pausa na carreira traz nova perspectiva. Abandone abordagens antigas e veja seu caminho de forma diferente. Às vezes, não avançar é o movimento certo."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En karriärpaus ger nytt perspektiv. Ge upp gamla tillvägagångssätt och se din väg annorlunda. Ibland är det rätt att inte gå framåt."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Пауза в кар'єрі дає новий погляд. Відмовтеся від старих підходів і подивіться на свій шлях інакше. Іноді не рухатися вперед – це правильний крок."
          }
        }
      }
    },
    "interpretation.the_hanged_man_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Widerstand gegen notwendige finanzielle Anpassungen oder das Feststecken in einer finanziellen Schwebe. Hör auf zu zögern und nimm die Veränderung vor."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resisting necessary financial adjustments or stuck in financial limbo. Stop stalling and make the change."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resistencia a los ajustes financieros necesarios o estancamiento financiero. Deja de procrastinar y haz el cambio."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Résistance aux ajustements financiers nécessaires ou stagnation financière. Cessez de tergiverser et faites le changement."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resistenza ai necessari aggiustamenti finanziari o rimanere bloccati in un limbo finanziario. Smetti di temporeggiare e apporta il cambiamento."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "必要な財務調整への抵抗または経済的な中途半端な状態での停滞。ぐずぐずするのをやめて、変更を行ってください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Motstand mot nødvendige økonomiske justeringer eller å sitte fast i økonomisk limbo. Slutt å nøle og gjør endringen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opór wobec koniecznych korekt finansowych lub utknięcie w finansowym zawieszeniu. Przestań zwlekać i dokonaj zmiany."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resistência a ajustes financeiros necessários ou ficar preso no limbo financeiro. Pare de procrastinar e faça a mudança."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Motstånd mot nödvändiga finansiella justeringar eller att sitta fast i ekonomiskt ingenmansland. Sluta förhala och gör förändringen."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Опір необхідним фінансовим коригуванням або застрягання у фінансовому лімбі. Перестаньте зволікати і внесіть зміни."
          }
        }
      }
    },
    "interpretation.the_hanged_man_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielles Opfer oder eine Pause führen zu langfristigem Gewinn. Betrachte deine Ressourcen aus einem neuen Blickwinkel. Löse dich von alten finanziellen Bindungen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial sacrifice or pause leads to long-term gain. See your resources from a new angle. Let go of old financial attachments."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El sacrificio financiero o la pausa conducen a ganancias a largo plazo. Mira tus recursos desde un nuevo ángulo. Suelta los viejos apegos financieros."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un sacrifice financier ou une pause mène à un gain à long terme. Voyez vos ressources sous un nouvel angle. Lâchez prise sur les anciens attachements financiers."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il sacrificio finanziario o la pausa portano a guadagni a lungo termine. Guarda le tue risorse da una nuova angolazione. Lascia andare i vecchi attaccamenti finanziari."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的な犠牲や一時停止が長期的な利益につながります。新しい角度から自分のリソースを見てください。古い経済的な執着を手放してください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk offer eller pause fører til langsiktig gevinst. Se ressursene dine fra en ny vinkel. Gi slipp på gamle økonomiske tilknytninger."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ofiara finansowa lub pauza prowadzą do długoterminowego zysku. Spójrz na swoje zasoby z nowej perspektywy. Porzuć stare przywiązania finansowe."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sacrifício financeiro ou pausa leva a ganho de longo prazo. Veja seus recursos de um novo ângulo. Liberte-se de velhos apegos financeiros."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomiskt offer eller paus leder till långsiktig vinst. Se dina resurser från en ny vinkel. Släpp gamla finansiella anknytningar."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансова жертва або пауза призводять до довгострокової вигоди. Подивіться на свої ресурси під новим кутом. Відпустіть старі фінансові прив'язаності."
          }
        }
      }
    },
    "interpretation.the_hanged_man_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Widerstand, Stillstand und Weigerung loszulassen. Unentschlossenheit hält dich in der Schwebe. Akzeptiere die Pause oder mach weiter."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resistance, stalling, and refusing to let go. Indecision keeps you suspended in limbo. Embrace the pause or move on."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resistencia, estancamiento y negativa a dejar ir. La indecisión te mantiene en el limbo. Acepta la pausa o sigue adelante."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Résistance, blocage et refus de lâcher prise. L'indécision vous maintient dans les limbes. Acceptez la pause ou passez à autre chose."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resistenza, stallo e rifiuto di lasciare andare. L'indecisione ti tiene in sospeso. Accetta la pausa o vai avanti."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "抵抗、停滞、手放すことの拒否。優柔不断があなたを宙ぶらりんにさせます。休止を受け入れるか、先に進んでください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Motstand, stagnasjon og nektet å gi slipp. Ubesluttsomhet holder deg i limbo. Omfavn pausen eller gå videre."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opór, stagnacja i odmowa puszczenia. Niezdecydowanie trzyma cię w zawieszeniu. Zaakceptuj pauzę lub idź dalej."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resistência, estagnação e recusa em deixar ir. A indecisão mantém você no limbo. Aceite a pausa ou siga em frente."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Motstånd, stagnation och vägran att släppa taget. Obeslutsamhet håller dig i limbo. Acceptera pausen eller gå vidare."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Опір, стагнація та відмова відпустити. Нерішучість тримає вас у підвішеному стані. Прийміть паузу або рухайтеся далі."
          }
        }
      }
    },
    "interpretation.the_hanged_man_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hingabe, neue Perspektive und notwendige Pause. Gib die Kontrolle auf und sieh die Dinge auf den Kopf gestellt. Opfer führen zur Erleuchtung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Surrender, new perspective, and necessary pause. Let go of control and see things upside down. Sacrifice leads to enlightenment."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rendición, nueva perspectiva y pausa necesaria. Pierde el control y ve las cosas al revés. El sacrificio lleva a la iluminación."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abandon, nouvelle perspective et pause nécessaire. Lâchez prise et voyez les choses à l'envers. Le sacrifice mène à l'illumination."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abbandono, nuova prospettiva e pausa necessaria. Lascia andare il controllo e vedi le cose sottosopra. Il sacrificio porta all'illuminazione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "放棄、新しい視点、必要な休止。コントロールを手放し、物事を逆さまに見てください。犠牲は悟りにつながります。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Overgivelse, nytt perspektiv og nødvendig pause. Gi slipp på kontrollen og se ting opp ned. Offer fører til opplysning."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Poddanie się, nowa perspektywa i konieczna pauza. Puść kontrolę i zobacz rzeczy do góry nogami. Poświęcenie prowadzi do oświecenia."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rendição, nova perspectiva e pausa necessária. Abra mão do controle e veja as coisas de cabeça para baixo. O sacrifício leva à iluminação."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Överlämnande, nytt perspektiv och nödvändig paus. Släpp kontrollen och se saker upp och ner. Offer leder till upplysning."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Підкорення, новий погляд і необхідна пауза. Відпустіть контроль і подивіться на речі догори дном. Жертва веде до просвітлення."
          }
        }
      }
    },
    "interpretation.the_hanged_man_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Widerstand gegen notwendige Ruhe oder das Feststecken in ungesunden Mustern. Hör auf zu kämpfen und gib dich dem hin, was dein Körper braucht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resisting necessary rest or stuck in unhealthy patterns. Stop fighting and surrender to what your body needs."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resistencia al descanso necesario o estancamiento en patrones poco saludables. Deja de luchar y entrégate a lo que tu cuerpo necesita."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Résistance au repos nécessaire ou stagnation dans des schémas malsains. Cessez de lutter et abandonnez-vous à ce dont votre corps a besoin."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resistenza al riposo necessario o rimanere bloccati in schemi malsani. Smetti di lottare e abbandonati a ciò di cui il tuo corpo ha bisogno."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "必要な休息への抵抗または不健康なパターンでの停滞。戦うのをやめ、自分の体が必要としているものに身を委ねてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Motstand mot nødvendig hvile eller å sitte fast i usunne mønstre. Slutt å kjempe og overgi deg til det kroppen din trenger."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opór wobec koniecznego odpoczynku lub utknięcie w niezdrowych wzorcach. Przestań walczyć i poddaj się temu, czego potrzebuje twoje ciało."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resistência ao descanso necessário ou ficar preso em padrões prejudiciais. Pare de lutar e se renda ao que seu corpo precisa."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Motstånd mot nödvändig vila eller att sitta fast i ohälsosamma mönster. Sluta kämpa och överlämna dig till vad din kropp behöver."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Опір необхідному відпочинку або застрягання в нездорових моделях. Перестаньте боротися і підкоріться тому, що потребує ваше тіло."
          }
        }
      }
    },
    "interpretation.the_hanged_man_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ruhe und Hingabe unterstützen die Heilung. Sieh deine Gesundheit aus einer neuen Perspektive. Manchmal ist Nichtstun auch etwas tun."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rest and surrender support healing. See your health from a new perspective. Sometimes doing nothing is doing something."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El descanso y la entrega apoyan la curación. Mira tu salud desde una nueva perspectiva. A veces no hacer nada es hacer algo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le repos et l'abandon favorisent la guérison. Voyez votre santé sous un nouvel angle. Parfois, ne rien faire, c'est faire quelque chose."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il riposo e l'abbandono supportano la guarigione. Guarda la tua salute da una nuova prospettiva. A volte non fare nulla è fare qualcosa."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "休息と放棄が癒しをサポートします。新しい視点から自分の健康を見てください。時には何もしないことが何かをするということです。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hvile og overgivelse støtter helbredelse. Se helsen din fra et nytt perspektiv. Noen ganger er å gjøre ingenting å gjøre noe."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odpoczynek i poddanie się wspomagają leczenie. Spójrz na swoje zdrowie z nowej perspektywy. Czasami nicnierobienie jest robieniem czegoś."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Descanso e rendição apoiam a cura. Veja sua saúde de uma nova perspectiva. Às vezes, não fazer nada é fazer algo."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vila och överlämnande stödjer läkning. Se din hälsa från ett nytt perspektiv. Ibland är att göra ingenting att göra något."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Відпочинок і підпорядкування підтримують зцілення. Подивіться на своє здоров'я з нової перспективи. Іноді нічого не робити – це щось робити."
          }
        }
      }
    },
    "interpretation.the_hanged_man_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stillstand oder Widerstand gegen notwendige Beziehungsveränderungen. Unentschlossenheit hält dich fest. Hör auf, die unvermeidliche Pause zu vermeiden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stalling or resisting necessary relationship changes. Indecision keeps you stuck. Stop avoiding the inevitable pause."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estancamiento o resistencia a los cambios necesarios en la relación. La indecisión te mantiene atrapado. Deja de evitar la pausa inevitable."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stagnation ou résistance aux changements relationnels nécessaires. L'indécision vous maintient bloqué. Cessez d'éviter la pause inévitable."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stallo o resistenza ai necessari cambiamenti relazionali. L'indecisione ti tiene bloccato. Smetti di evitare la pausa inevitabile."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "必要な人間関係の変化に対する停滞や抵抗。優柔不断があなたを閉じ込めています。避けられない休止を避けるのをやめてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stagnasjon eller motstand mot nødvendige forandringer i forholdet. Ubesluttsomhet holder deg fast. Slutt å unngå den uunngåelige pausen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zastój lub opór wobec koniecznych zmian w związku. Niezdecydowanie trzyma cię w miejscu. Przestań unikać nieuniknionej pauzy."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estagnação ou resistência a mudanças necessárias no relacionamento. Indecisão mantém você preso. Pare de evitar a pausa inevitável."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stagnation eller motstånd mot nödvändiga relationsförändringar. Obeslutsamhet håller dig fast. Sluta undvika den oundvikliga pausen."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Стагнація або опір необхідним змінам у стосунках. Нерішучість тримає вас у пастці. Перестаньте уникати неминучої паузи."
          }
        }
      }
    },
    "interpretation.the_hanged_man_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gib die Kontrolle in der Liebe auf. Eine neue Perspektive auf Beziehungen entsteht durch Loslassen. Halte inne und sieh die Dinge anders."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Surrender control in love. A new perspective on relationships emerges through letting go. Pause and see things differently."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ríndete al control en el amor. Una nueva perspectiva sobre las relaciones emerge a través del dejar ir. Haz una pausa y mira las cosas de manera diferente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abandonnez le contrôle en amour. Une nouvelle perspective sur les relations émerge en lâchant prise. Faites une pause et voyez les choses différemment."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lascia andare il controllo in amore. Una nuova prospettiva sulle relazioni emerge attraverso il lasciar andare. Fai una pausa e vedi le cose diversamente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "愛においてコントロールを手放しましょう。手放すことで人間関係に対する新しい視点が生まれます。立ち止まり、物事を別の見方で見てください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gi slipp kontrollen i kjærlighet. Et nytt perspektiv på relasjoner dukker opp gjennom å gi slipp. Pause og se ting annerledes."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zrezygnuj z kontroli w miłości. Nowa perspektywa na związki pojawia się poprzez puszczenie. Zatrzymaj się i zobacz rzeczy inaczej."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abra mão do controle no amor. Uma nova perspectiva sobre os relacionamentos surge através do deixar ir. Pause e veja as coisas de forma diferente."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Släpp kontrollen i kärlek. Ett nytt perspektiv på relationer uppstår genom att släppa taget. Pausa och se saker annorlunda."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Відпустіть контроль у коханні. Новий погляд на стосунки з'являється через відпускання. Зробіть паузу та подивіться на речі інакше."
          }
        }
      }
    },
    "interpretation.the_hermit_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Berufliche Isolation oder Ablehnung von Anleitung. Du bist vielleicht zu zurückgezogen oder paranoid gegenüber Kollegen. Nimm das Gespräch wieder auf."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professional isolation or refusing guidance. You might be too withdrawn or paranoid about colleagues. Rejoin the conversation."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aislamiento profesional o rechazo de la orientación. Puede que estés demasiado retraído o paranoico con los colegas. Vuelve a unirte a la conversación."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isolement professionnel ou refus des conseils. Vous êtes peut-être trop renfermé ou paranoïaque envers vos collègues. Rejoignez à nouveau la conversation."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isolamento professionale o rifiuto della guida. Potresti essere troppo ritirato o paranoico nei confronti dei colleghi. Rientra nella conversazione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "職業上の孤立または指導の拒否。あなたは引きこもりすぎているか、同僚に対して偏執的かもしれません。会話に戻ってください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profesjonell isolasjon eller å nekte veiledning. Du kan være for tilbaketrukket eller paranoid overfor kolleger. Bli med i samtalen igjen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Izolacja zawodowa lub odmowa wskazówek. Możesz być zbyt wycofany lub paranoiczny w stosunku do współpracowników. Dołącz do rozmowy."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isolamento profissional ou recusa de orientação. Você pode ser retraído demais ou paranóico com colegas. Retome a conversa."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professionell isolering eller vägran att ta emot vägledning. Du kan vara för tillbakadragen eller paranoid inför kollegor. Delta i samtalet igen."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Професійна ізоляція або відмова від керівництва. Ви можете бути занадто замкнутим або параноїком щодо колег. Приєднуйтесь до розмови знову."
          }
        }
      }
    },
    "interpretation.the_hermit_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Suche nach dem eigenen Ich in Bezug auf deinen Karriereweg bringt Weisheit. Tritt einen Schritt zurück vom Lärm und höre auf deine innere Führung. Mentoring oder tiefgehende Fachkenntnisse entwickeln sich."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Soul-searching about your career path brings wisdom. Step back from the noise and listen to your inner guidance. Mentorship or deep expertise develops."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La introspección sobre tu trayectoria profesional trae sabiduría. Retrocede del ruido y escucha tu guía interior. Se desarrolla la tutoría o la experiencia profunda."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'introspection sur votre cheminement de carrière apporte la sagesse. Reculez-vous du bruit et écoutez votre guidance intérieure. Le mentorat ou l'expertise approfondie se développent."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'introspezione sul tuo percorso di carriera porta saggezza. Fai un passo indietro dal rumore e ascolta la tua guida interiore. Il mentoring o l'esperienza profonda si sviluppano."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたのキャリアパスについての内省が知恵をもたらします。騒音から一歩下がり、あなたの内なる導きに耳を傾けてください。メンターシップや深い専門知識が発展します。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Søken etter sjel om karriereveien din bringer visdom. Ta et skritt tilbake fra støyen og lytt til din indre veiledning. Mentorskap eller dyp ekspertise utvikles."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Poszukiwanie własnej duszy w kwestii ścieżki kariery przynosi mądrość. Odsuń się od hałasu i posłuchaj swojego wewnętrznego przewodnictwa. Rozwija się mentoring lub głęboka wiedza specjalistyczna."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A busca interior sobre seu caminho de carreira traz sabedoria. Afaste-se do barulho e ouça sua orientação interior. Mentoria ou conhecimento profundo se desenvolvem."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Självrannsakan om din karriärväg ger visdom. Ta ett steg tillbaka från bruset och lyssna på din inre vägledning. Mentorskap eller djup expertis utvecklas."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Самопізнання щодо вашого кар'єрного шляху приносить мудрість. Відійдіть від шуму та прислухайтеся до свого внутрішнього керівництва. Розвивається наставництво або глибока експертиза."
          }
        }
      }
    },
    "interpretation.the_hermit_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Isolation oder die Ablehnung von Hilfe, wenn du sie brauchst. Paranoia über Geld oder völliger Rückzug von der Finanzplanung. Suche eine ausgewogene Perspektive."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial isolation or refusing help when you need it. Paranoia about money or complete withdrawal from financial planning. Seek balanced perspective."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aislamiento financiero o rechazo de ayuda cuando la necesitas. Paranoia sobre el dinero o retiro completo de la planificación financiera. Busca una perspectiva equilibrada."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isolement financier ou refus d'aide quand vous en avez besoin. Paranoïa concernant l'argent ou retrait complet de la planification financière. Recherchez une perspective équilibrée."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isolamento finanziario o rifiuto di aiuto quando ne hai bisogno. Paranoia sul denaro o completo ritiro dalla pianificazione finanziaria. Cerca una prospettiva equilibrata."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的な孤立、または必要な時に助けを拒否すること。お金に対する偏執症または財務計画からの完全な撤退。バランスの取れた視点を求めてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk isolasjon eller å nekte hjelp når du trenger det. Paranoia om penger eller full tilbaketrekning fra økonomisk planlegging. Søk et balansert perspektiv."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Izolacja finansowa lub odmowa pomocy, gdy jej potrzebujesz. Paranoja na temat pieniędzy lub całkowite wycofanie się z planowania finansowego. Poszukaj zrównoważonej perspektywy."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isolamento financeiro ou recusa de ajuda quando você precisa. Paranoia sobre dinheiro ou retirada completa do planejamento financeiro. Busque uma perspectiva equilibrada."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomisk isolering eller vägran att ta emot hjälp när du behöver den. Paranoia om pengar eller fullständigt tillbakadragande från ekonomisk planering. Sök ett balanserat perspektiv."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансова ізоляція або відмова від допомоги, коли вона вам потрібна. Параноя щодо грошей або повне відсторонення від фінансового планування. Шукайте збалансовану перспективу."
          }
        }
      }
    },
    "interpretation.the_hermit_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sorgfältige finanzielle Reflexion und konservative Ansätze sind jetzt gut für dich. Suche Weisheit, bevor du Entscheidungen triffst. Innere Führung vor äußerem Lärm."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Careful financial reflection and conservative approaches serve you well. Seek wisdom before making decisions. Inner guidance over external noise."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La reflexión financiera cuidadosa y los enfoques conservadores te sirven bien. Busca sabiduría antes de tomar decisiones. La guía interior sobre el ruido externo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une réflexion financière minutieuse et des approches conservatrices vous servent bien. Cherchez la sagesse avant de prendre des décisions. L'orientation intérieure plutôt que le bruit extérieur."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un'attenta riflessione finanziaria e approcci conservativi ti sono utili. Cerca la saggezza prima di prendere decisioni. Guida interiore sul rumore esterno."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "慎重な財務反省と保守的なアプローチはあなたに役立ちます。決定を下す前に知恵を求めてください。外部の騒音よりも内なる導き。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nøye finansiell refleksjon og konservative tilnærminger tjener deg godt. Søk visdom før du tar avgjørelser. Indre veiledning fremfor ekstern støy."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dokładna refleksja finansowa i konserwatywne podejścia służą ci dobrze. Szukaj mądrości przed podjęciem decyzji. Wewnętrzne prowadzenie nad zewnętrznym hałasem."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reflexão financeira cuidadosa e abordagens conservadoras servem bem a você. Busque sabedoria antes de tomar decisões. Orientação interior sobre o barulho externo."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Noggrann finansiell reflektion och konservativa tillvägagångssätt tjänar dig väl. Sök visdom innan du fattar beslut. Inre vägledning framför externt brus."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ретельне фінансове обмірковування та консервативні підходи служать вам добре. Шукайте мудрості, перш ніж приймати рішення. Внутрішнє керівництво, а не зовнішній шум."
          }
        }
      }
    },
    "interpretation.the_hermit_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isolation, Einsamkeit oder paranoider Rückzug vom Leben. Du bist entweder zu isoliert oder weigerst dich, die notwendige innere Arbeit zu tun. Finde die Balance."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isolation, loneliness, or paranoid withdrawal from life. You're either too isolated or refusing to do necessary inner work. Find balance."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aislamiento, soledad o retiro paranoico de la vida. Estás demasiado aislado o te niegas a hacer el trabajo interior necesario. Encuentra el equilibrio."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isolement, solitude ou retrait paranoïaque de la vie. Vous êtes soit trop isolé, soit vous refusez de faire le travail intérieur nécessaire. Trouvez l'équilibre."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isolamento, solitudine o ritiro paranoico dalla vita. O sei troppo isolato o ti rifiuti di fare il necessario lavoro interiore. Trova l'equilibrio."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "孤立、孤独、または人生からの妄想的な撤退。あなたは孤立しすぎているか、必要な内面の仕事をすることを拒否しています。バランスを見つけてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isolasjon, ensomhet eller paranoid tilbaketrekning fra livet. Du er enten for isolert eller nekter å gjøre nødvendig indre arbeid. Finn balansen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Izolacja, samotność lub paranoiczne wycofanie z życia. Jesteś albo zbyt odizolowany, albo odmawiasz wykonania niezbędnej wewnętrznej pracy. Znajdź równowagę."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isolamento, solidão ou retirada paranoica da vida. Você está isolado demais ou se recusa a fazer o trabalho interior necessário. Encontre o equilíbrio."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isolering, ensamhet eller paranoid tillbakadragande från livet. Du är antingen för isolerad eller vägrar att göra nödvändigt inre arbete. Hitta balansen."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ізоляція, самотність або параноїдальне відсторонення від життя. Ви або занадто ізольовані, або відмовляєтеся виконувати необхідну внутрішню роботу. Знайдіть баланс."
          }
        }
      }
    },
    "interpretation.the_hermit_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zeit für Selbstbeobachtung, Sinnsuche und innere Führung. Tritt einen Schritt zurück vom Lärm und finde dein eigenes Licht. Weisheit kommt von innen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Time for introspection, soul-searching, and inner guidance. Step away from the noise and find your own light. Wisdom comes from within."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tiempo para la introspección, la búsqueda interior y la guía interna. Aléjate del ruido y encuentra tu propia luz. La sabiduría viene de dentro."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Temps d'introspection, de recherche intérieure et de guidance intérieure. Éloignez-vous du bruit et trouvez votre propre lumière. La sagesse vient de l'intérieur."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tempo per l'introspezione, la ricerca interiore e la guida interna. Fatti da parte dal rumore e trova la tua luce. La saggezza viene da dentro."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "内省、魂の探求、内なる導きの時間。騒音から一歩下がり、自分自身の光を見つけてください。知恵は内側から来ます。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tid for introspeksjon, sjelegransking og indre veiledning. Ta et skritt tilbake fra støyen og finn ditt eget lys. Visdom kommer fra innsiden."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Czas na introspekcję, poszukiwanie własnej duszy i wewnętrzne przewodnictwo. Odsuń się od hałasu i znajdź swoje własne światło. Mądrość pochodzi z wnętrza."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tempo para introspecção, busca interior e orientação interna. Afaste-se do barulho e encontre sua própria luz. A sabedoria vem de dentro."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tid för introspektion, själsrannsakan och inre vägledning. Ta ett steg tillbaka från bruset och hitta ditt eget ljus. Visdom kommer inifrån."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Час для самоаналізу, самопізнання та внутрішнього керівництва. Відійдіть від шуму і знайдіть своє власне світло. Мудрість приходить зсередини."
          }
        }
      }
    },
    "interpretation.the_hermit_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ungesunde Isolation oder das Ignorieren von Gesundheitsbedürfnissen. Rückzug von gesunden Aktivitäten oder Verweigerung von Unterstützung. Finde ein Gleichgewicht zwischen Einsamkeit und Verbindung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unhealthy isolation or ignoring health needs. Withdrawal from healthy activities or refusing support. Find balance between solitude and connection."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aislamiento poco saludable o ignorar las necesidades de salud. Retiro de actividades saludables o rechazo de apoyo. Encuentra el equilibrio entre soledad y conexión."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isolement malsain ou ignorance des besoins de santé. Retrait des activités saines ou refus de soutien. Trouvez l'équilibre entre solitude et connexion."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isolamento malsano o ignorare i bisogni di salute. Ritiro da attività salutari o rifiuto di supporto. Trova l'equilibrio tra solitudine e connessione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "不健康な孤立や健康上のニーズを無視すること。健康な活動からの撤退やサポートの拒否。孤独とつながりのバランスを見つけてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Usunn isolasjon eller å ignorere helsebehov. Tilbaketrekning fra sunne aktiviteter eller nekte støtte. Finn balanse mellom ensomhet og tilknytning."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niezdrowa izolacja lub ignorowanie potrzeb zdrowotnych. Wycofanie się z zdrowych aktywności lub odmowa wsparcia. Znajdź równowagę między samotnością a więzią."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isolamento prejudicial ou ignorar as necessidades de saúde. Retirada de atividades saudáveis ou recusa de apoio. Encontre o equilíbrio entre solidão e conexão."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ohälsosam isolering eller att ignorera hälsa. Tillbakadragande från hälsosamma aktiviteter eller vägran att få stöd. Hitta balans mellan ensamhet och anslutning."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Нездорова ізоляція або ігнорування потреб здоров'я. Відхід від здорових видів діяльності або відмова від підтримки. Знайдіть баланс між самотністю та зв'язком."
          }
        }
      }
    },
    "interpretation.the_hermit_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Einsamkeit und Selbstbeobachtung unterstützen die Heilung. Dein Körper braucht ruhige Zeit, um sich zu erholen. Höre tief auf deine innere Weisheit, was du brauchst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Solitude and introspection support healing. Your body needs quiet time to recover. Listen deeply to your inner wisdom about what you need."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La soledad y la introspección apoyan la curación. Tu cuerpo necesita tiempo tranquilo para recuperarse. Escucha profundamente tu sabiduría interior sobre lo que necesitas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La solitude et l'introspection favorisent la guérison. Votre corps a besoin de temps calme pour récupérer. Écoutez profondément votre sagesse intérieure sur ce dont vous avez besoin."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La solitudine e l'introspezione supportano la guarigione. Il tuo corpo ha bisogno di tempo tranquillo per riprendersi. Ascolta profondamente la tua saggezza interiore su ciò di cui hai bisogno."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "孤独と内省が癒しをサポートします。あなたの体は回復するための静かな時間を必要としています。必要なことについて、あなたの内なる知恵に深く耳を傾けてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ensomhet og introspeksjon støtter helbredelse. Kroppen din trenger rolig tid til å komme seg. Lytt dypt til din indre visdom om hva du trenger."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Samotność i introspekcja wspomagają leczenie. Twoje ciało potrzebuje spokojnego czasu, aby wyzdrowieć. Słuchaj głęboko swojej wewnętrznej mądrości na temat tego, czego potrzebujesz."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Solidão e introspecção apoiam a cura. Seu corpo precisa de tempo tranquilo para se recuperar. Ouça profundamente sua sabedoria interior sobre o que você precisa."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enslighet och introspektion stödjer läkning. Din kropp behöver lugn tid för att återhämta sig. Lyssna djupt på din inre visdom om vad du behöver."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Самотність і самоаналіз підтримують зцілення. Ваше тіло потребує спокійного часу для відновлення. Глибоко прислухайтеся до своєї внутрішньої мудрості про те, що вам потрібно."
          }
        }
      }
    },
    "interpretation.the_hermit_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isolation wird in der Liebe zu Einsamkeit. Du ziehst dich vielleicht zu sehr zurück oder vermeidest Verbindungen. Balanciere Einsamkeit mit gesunden Beziehungen aus."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isolation becomes loneliness in love. You might be withdrawing too much or avoiding connection. Balance solitude with healthy relationship."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El aislamiento se convierte en soledad en el amor. Puede que te estés retirando demasiado o evitando la conexión. Equilibra la soledad con relaciones saludables."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'isolement devient solitude en amour. Vous vous retirez peut-être trop ou évitez la connexion. Équilibrez la solitude avec des relations saines."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'isolamento diventa solitudine in amore. Potresti ritirarti troppo o evitare la connessione. Bilancia la solitudine con relazioni sane."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "孤独は恋愛において孤独感になります。あなたは引きこもりすぎているか、つながりを避けているかもしれません。孤独と健全な人間関係のバランスをとってください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isolasjon blir ensomhet i kjærlighet. Du trekker deg kanskje for mye tilbake eller unngår tilknytning. Balanser ensomhet med sunne relasjoner."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Izolacja staje się samotnością w miłości. Być może wycofujesz się zbyt mocno lub unikasz więzi. Zrównoważ samotność ze zdrowymi relacjami."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O isolamento se torna solidão no amor. Você pode estar se retirando demais ou evitando conexão. Equilibre a solidão com relacionamentos saudáveis."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isolering blir ensamhet i kärlek. Du kanske drar dig tillbaka för mycket eller undviker kontakt. Balansera ensamhet med hälsosamma relationer."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ізоляція стає самотністю в коханні. Ви, можливо, занадто відсторонюєтеся або уникаєте зв'язку. Збалансуйте самотність зі здоровими стосунками."
          }
        }
      }
    },
    "interpretation.the_hermit_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Einsamkeit und Selbstreflexion sind in deinem Liebesleben jetzt notwendig. Tritt einen Schritt zurück, um Klarheit zu gewinnen. Die Antworten, die du suchst, kommen von innen, nicht von anderen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Solitude and self-reflection are necessary in your love life now. Step back to gain clarity. The answers you seek come from within, not from others."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La soledad y la autorreflexión son necesarias en tu vida amorosa ahora. Retrocede para ganar claridad. Las respuestas que buscas vienen de dentro, no de los demás."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La solitude et l'introspection sont nécessaires dans votre vie amoureuse maintenant. Prenez du recul pour gagner en clarté. Les réponses que vous cherchez viennent de l'intérieur, pas des autres."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La solitudine e l'autoriflessione sono necessarie nella tua vita amorosa ora. Fai un passo indietro per acquisire chiarezza. Le risposte che cerchi vengono da dentro, non dagli altri."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "今、あなたの恋愛生活には孤独と内省が必要です。明確さを得るために一歩下がってください。あなたが探している答えは、他人からではなく、内側から来ます。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ensomhet og selvrefleksjon er nødvendig i kjærlighetslivet ditt nå. Ta et skritt tilbake for å få klarhet. Svarene du søker kommer fra innsiden, ikke fra andre."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Samotność i autorefleksja są teraz konieczne w twoim życiu miłosnym. Zrób krok w tył, aby zyskać jasność. Odpowiedzi, których szukasz, pochodzą z wewnątrz, a nie od innych."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Solidão e autorreflexão são necessárias em sua vida amorosa agora. Dê um passo atrás para ganhar clareza. As respostas que você busca vêm de dentro, não dos outros."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enslighet och självreflektion är nödvändiga i ditt kärleksliv nu. Ta ett steg tillbaka för att få klarhet. Svaren du söker kommer inifrån, inte från andra."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Самотність і саморефлексія зараз необхідні у вашому любовному житті. Зробіть крок назад, щоб отримати ясність. Відповіді, які ви шукаєте, приходять зсередини, а не від інших."
          }
        }
      }
    },
    "interpretation.the_hierophant_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rebellion gegen traditionelle Karriereerwartungen oder institutionelle Strukturen. Du musst vielleicht deinen eigenen unkonventionellen Weg finden. Hinterfrage Autoritäten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rebelling against traditional career expectations or institutional structures. You may need to find your own unconventional path. Question authority."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rebelarse contra las expectativas profesionales tradicionales o las estructuras institucionales. Es posible que necesites encontrar tu propio camino poco convencional. Cuestiona la autoridad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se rebeller contre les attentes professionnelles traditionnelles ou les structures institutionnelles. Vous devrez peut-être trouver votre propre voie non conventionnelle. Questionnez l'autorité."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ribellarsi contro le aspettative di carriera tradizionali o le strutture istituzionali. Potresti dover trovare la tua strada non convenzionale. Metti in discussione l'autorità."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "伝統的なキャリアの期待や組織構造に反抗すること。あなたは自分自身の非伝統的な道を見つける必要があるかもしれません。権威に疑問を呈してください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gjør opprør mot tradisjonelle karriereforventninger eller institusjonelle strukturer. Du må kanskje finne din egen utradisjonelle vei. Still spørsmål ved autoritet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bunt przeciwko tradycyjnym oczekiwaniom zawodowym lub strukturom instytucjonalnym. Możesz potrzebować znaleźć własną niekonwencjonalną ścieżkę. Kwestionuj autorytet."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rebelar-se contra as expectativas de carreira tradicionais ou estruturas institucionais. Você pode precisar encontrar seu próprio caminho não convencional. Questione a autoridade."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Göra uppror mot traditionella karriärförväntningar eller institutionella strukturer. Du kanske måste hitta din egen okonventionella väg. Ifrågasätt auktoritet."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Повстання проти традиційних кар'єрних очікувань або інституційних структур. Можливо, вам потрібно знайти власний нетрадиційний шлях. Ставте під сумнів авторитет."
          }
        }
      }
    },
    "interpretation.the_hierophant_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Traditionelle Karrierewege, Ausbildung oder etablierte Institutionen unterstützen dein Wachstum. Mentoring und formelles Lernen bringen Fortschritt. Ehre bewährte Methoden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Traditional career paths, education, or established institutions support your growth. Mentorship and formal learning bring advancement. Honor proven methods."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las trayectorias profesionales tradicionales, la educación o las instituciones establecidas apoyan tu crecimiento. La tutoría y el aprendizaje formal traen progreso. Honra los métodos probados."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les parcours professionnels traditionnels, l'éducation ou les institutions établies soutiennent votre croissance. Le mentorat et l'apprentissage formel apportent des progrès. Honorez les méthodes éprouvées."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Percorsi di carriera tradizionali, istruzione o istituzioni consolidate supportano la tua crescita. Il mentoring e l'apprendimento formale portano progresso. Onora i metodi collaudati."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "伝統的なキャリアパス、教育、または確立された機関があなたの成長をサポートします。メンターシップと正式な学習が進歩をもたらします。実績のある方法を尊重してください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tradisjonelle karriereveier, utdanning eller etablerte institusjoner støtter veksten din. Mentorskap og formell læring gir fremgang. Ær velprøvde metoder."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tradycyjne ścieżki kariery, edukacja lub uznane instytucje wspierają twój rozwój. Mentoring i formalna nauka przynoszą postęp. Szanuj sprawdzone metody."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Caminhos de carreira tradicionais, educação ou instituições estabelecidas apoiam seu crescimento. Mentoria e aprendizado formal trazem progresso. Honre métodos comprovados."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Traditionella karriärvägar, utbildning eller etablerade institutioner stödjer din tillväxt. Mentorskap och formellt lärande ger framsteg. Hedra beprövade metoder."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Традиційні кар'єрні шляхи, освіта або усталені установи підтримують ваш розвиток. Наставництво та формальне навчання приносять прогрес. Шануйте перевірені методи."
          }
        }
      }
    },
    "interpretation.the_hierophant_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hinterfrage traditionelle Finanzratschläge oder fühle dich durch konventionelle Ansätze eingeschränkt. Du brauchst vielleicht alternative Finanzstrategien, die zu deinen Werten passen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questioning traditional financial advice or feeling restricted by conventional approaches. You might need alternative financial strategies that match your values."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuestionar el asesoramiento financiero tradicional o sentirse limitado por los enfoques convencionales. Es posible que necesites estrategias financieras alternativas que se ajusten a tus valores."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Remettre en question les conseils financiers traditionnels ou se sentir limité par les approches conventionnelles. Vous aurez peut-être besoin de stratégies financières alternatives qui correspondent à vos valeurs."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mettere in discussione i consigli finanziari tradizionali o sentirsi limitati dagli approcci convenzionali. Potresti aver bisogno di strategie finanziarie alternative che corrispondano ai tuoi valori."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "従来の財務アドバイスに疑問を呈したり、従来のアプローチに制約を感じたりすること。あなたの価値観に合った代替財務戦略が必要かもしれません。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stille spørsmål ved tradisjonelle finansielle råd eller føle seg begrenset av konvensjonelle tilnærminger. Du kan trenge alternative økonomiske strategier som samsvarer med verdiene dine."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kwestionowanie tradycyjnych porad finansowych lub odczuwanie ograniczeń przez konwencjonalne podejścia. Możesz potrzebować alternatywnych strategii finansowych, które pasują do twoich wartości."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questionar o aconselhamento financeiro tradicional ou sentir-se limitado por abordagens convencionais. Você pode precisar de estratégias financeiras alternativas que correspondam aos seus valores."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ifrågasätta traditionella finansiella råd eller känna sig begränsad av konventionella tillvägagångssätt. Du kan behöva alternativa finansiella strategier som matchar dina värderingar."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Поставити під сумнів традиційні фінансові поради або відчувати себе обмеженим загальноприйнятими підходами. Можливо, вам знадобляться альтернативні фінансові стратегії, які відповідають вашим цінностям."
          }
        }
      }
    },
    "interpretation.the_hierophant_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Traditionelle Finanzinstitute, Berater oder konventionelle Weisheit leiten deinen Wohlstand. Befolge etablierte Finanzprinzipien und suche fachkundigen Rat."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Traditional financial institutions, advisors, or conventional wisdom guide your prosperity. Follow established financial principles and seek expert counsel."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las instituciones financieras tradicionales, los asesores o la sabiduría convencional guían tu prosperidad. Sigue los principios financieros establecidos y busca el consejo de expertos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les institutions financières traditionnelles, les conseillers ou la sagesse conventionnelle guident votre prospérité. Suivez les principes financiers établis et demandez l'avis d'experts."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Istituzioni finanziarie tradizionali, consulenti o saggezza convenzionale guidano la tua prosperità. Segui i principi finanziari consolidati e cerca il consiglio di esperti."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "伝統的な金融機関、アドバイザー、または従来の知恵があなたの繁栄を導きます。確立された財務原則に従い、専門家の助言を求めてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tradisjonelle finansinstitusjoner, rådgivere eller konvensjonell visdom veileder din velstand. Følg etablerte finansielle prinsipper og søk ekspertråd."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tradycyjne instytucje finansowe, doradcy lub konwencjonalna mądrość kierują twoim dobrobytem. Przestrzegaj ustalonych zasad finansowych i szukaj porady ekspertów."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Instituições financeiras tradicionais, consultores ou sabedoria convencional guiam sua prosperidade. Siga princípios financeiros estabelecidos e busque aconselhamento especializado."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Traditionella finansinstitutioner, rådgivare eller konventionell visdom vägleder din välstånd. Följ etablerade finansiella principer och sök expertråd."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Традиційні фінансові установи, радники або загальноприйнята мудрість спрямовують ваш добробут. Дотримуйтесь встановлених фінансових принципів і звертайтеся за консультацією до експертів."
          }
        }
      }
    },
    "interpretation.the_hierophant_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rebellion gegen Konventionen und traditionelle Strukturen. Du wirst aufgerufen, deinen eigenen Weg zu finden und Autoritäten in Frage zu stellen. Persönliche Überzeugungen über Dogmen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rebellion against convention and traditional structures. You're being called to find your own path and question authority. Personal beliefs over dogma."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rebelión contra las convenciones y las estructuras tradicionales. Se te llama a encontrar tu propio camino y cuestionar la autoridad. Creencias personales sobre el dogma."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rébellion contre les conventions et les structures traditionnelles. Vous êtes appelé à trouver votre propre voie et à remettre en question l'autorité. Croyances personnelles plutôt que dogme."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ribellione contro le convenzioni e le strutture tradizionali. Sei chiamato a trovare la tua strada e a mettere in discussione l'autorità. Credenze personali sul dogma."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "慣習や伝統的な構造に対する反抗。あなたは自分自身の道を見つけ、権威に疑問を呈するよう呼ばれています。教義よりも個人的な信念。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opprør mot konvensjoner og tradisjonelle strukturer. Du blir kalt til å finne din egen vei og stille spørsmål ved autoritet. Personlige overbevisninger fremfor dogme."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bunt przeciwko konwencjom i tradycyjnym strukturom. Zostajesz wezwany do znalezienia własnej ścieżki i kwestionowania autorytetu. Osobiste przekonania ponad dogmat."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rebelião contra convenções e estruturas tradicionais. Você é chamado a encontrar seu próprio caminho e questionar a autoridade. Crenças pessoais sobre o dogma."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uppror mot konventioner och traditionella strukturer. Du kallas att hitta din egen väg och ifrågasätta auktoritet. Personliga övertygelser framför dogm."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Повстання проти умовностей і традиційних структур. Вас закликають знайти власний шлях і ставити під сумнів авторитет. Особисті переконання, а не догма."
          }
        }
      }
    },
    "interpretation.the_hierophant_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tradition, Bildung und etablierte Institutionen weisen dir den Weg. Suche Mentoring und ehre bewährte Weisheit. Konformität dient jetzt einem Zweck."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tradition, education, and established institutions guide your path. Seek mentorship and honor proven wisdom. Conformity serves a purpose now."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La tradición, la educación y las instituciones establecidas guían tu camino. Busca mentoría y honra la sabiduría probada. La conformidad tiene un propósito ahora."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La tradition, l'éducation et les institutions établies guident votre chemin. Recherchez le mentorat et honorez la sagesse éprouvée. La conformité a un but maintenant."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tradizione, istruzione e istituzioni consolidate guidano il tuo cammino. Cerca un mentore e onora la saggezza comprovata. La conformità serve a uno scopo ora."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "伝統、教育、確立された機関があなたの道を導きます。メンターシップを求め、実績のある知恵を尊重してください。今は同調が役立ちます。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tradisjon, utdanning og etablerte institusjoner veileder veien din. Søk mentorskap og ær velprøvd visdom. Konformitet tjener et formål nå."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tradycja, edukacja i uznane instytucje kierują twoją ścieżką. Szukaj mentoringu i szanuj sprawdzoną mądrość. Konformizm służy teraz celowi."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tradição, educação e instituições estabelecidas guiam seu caminho. Busque orientação e honre a sabedoria comprovada. A conformidade serve a um propósito agora."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tradition, utbildning och etablerade institutioner vägleder din väg. Sök mentorskap och hedra beprövad visdom. Konformitet tjänar ett syfte nu."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Традиція, освіта та усталені установи спрямовують ваш шлях. Шукайте наставництва та шануйте перевірену мудрість. Конформізм зараз служить певній меті."
          }
        }
      }
    },
    "interpretation.the_hierophant_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Traditionelle Gesundheitsansätze sprechen dich vielleicht nicht an. Erkunde alternative Heilmethoden. Vertraue mehr auf dein inneres Wissen als auf externe Autoritäten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Traditional health approaches may not resonate. Explore alternative healing modalities. Trust your inner knowing over external authority."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los enfoques de salud tradicionales pueden no resonar contigo. Explora modalidades de curación alternativas. Confía en tu conocimiento interno sobre la autoridad externa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les approches de santé traditionnelles peuvent ne pas vous convenir. Explorez des modalités de guérison alternatives. Faites confiance à votre savoir intérieur plutôt qu'à l'autorité extérieure."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gli approcci sanitari tradizionali potrebbero non risuonare con te. Esplora modalità di guarigione alternative. Fidati della tua conoscenza interiore rispetto all'autorità esterna."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "伝統的な健康法はあなたに響かないかもしれません。代替療法を探求してください。外部の権威よりも自分の内なる知識を信頼してください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tradisjonelle helsetilnærminger kan ikke resonere med deg. Utforsk alternative helbredelsesmodaliteter. Stol på din indre kunnskap fremfor ekstern autoritet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tradycyjne podejścia do zdrowia mogą do ciebie nie przemawiać. Poznaj alternatywne metody leczenia. Ufaj swojej wewnętrznej wiedzy, a nie zewnętrznym autorytetom."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abordagens de saúde tradicionais podem não ressoar com você. Explore modalidades alternativas de cura. Confie no seu conhecimento interno em vez da autoridade externa."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Traditionella hälsotillvägagångssätt kanske inte resonera med dig. Utforska alternativa läkningsmetoder. Lita på din inre kunskap framför extern auktoritet."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Традиційні підходи до здоров'я можуть не резонувати з вами. Досліджуйте альтернативні методи зцілення. Довіряйте своєму внутрішньому знанню, а не зовнішньому авторитету."
          }
        }
      }
    },
    "interpretation.the_hierophant_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Traditionelle Medizin, etablierte Gesundheitspraktiken oder die Suche nach fachkundigem medizinischem Rat sind jetzt gut für dich. Vertraue auf bewährte Methoden und professionelle Anleitung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Traditional medicine, established health practices, or seeking expert medical advice serves you well. Trust proven methods and professional guidance."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La medicina tradicional, las prácticas de salud establecidas o la búsqueda de consejo médico experto te sirven bien. Confía en métodos probados y orientación profesional."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La médecine traditionnelle, les pratiques de santé établies ou la recherche de conseils médicaux experts vous sont bénéfiques. Faites confiance aux méthodes éprouvées et aux conseils professionnels."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La medicina tradizionale, le pratiche sanitarie consolidate o la ricerca di un consiglio medico esperto ti sono utili. Fidati dei metodi collaudati e della guida professionale."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "伝統医学、確立された健康法、または専門家の医学的アドバイスを求めることは、あなたに役立ちます。実績のある方法と専門家の指導を信頼してください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tradisjonell medisin, etablerte helsepraksiser eller å søke ekspert medisinsk råd tjener deg godt. Stol på velprøvde metoder og profesjonell veiledning."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tradycyjna medycyna, uznane praktyki zdrowotne lub poszukiwanie fachowej porady medycznej służą ci dobrze. Ufaj sprawdzonym metodom i profesjonalnemu doradztwu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Medicina tradicional, práticas de saúde estabelecidas ou buscar conselho médico especializado serve bem a você. Confie em métodos comprovados e orientação profissional."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Traditionell medicin, etablerade hälsopraktiker eller att söka expertråd tjänar dig väl. Lita på beprövade metoder och professionell vägledning."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Традиційна медицина, усталені оздоровчі практики або звернення за експертною медичною консультацією служать вам добре. Довіряйте перевіреним методам і професійному керівництву."
          }
        }
      }
    },
    "interpretation.the_hierophant_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Traditionen in Frage stellen oder sich durch Beziehungserwartungen eingeengt fühlen. Du musst vielleicht deinen eigenen Weg gehen, anstatt der konventionellen Weisheit zu folgen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Challenging traditions or feeling confined by relationship expectations. You might need to forge your own path rather than follow conventional wisdom."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desafiar las tradiciones o sentirse limitado por las expectativas de la relación. Es posible que necesites forjar tu propio camino en lugar de seguir la sabiduría convencional."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Remettre en question les traditions ou se sentir limité par les attentes relationnelles. Vous devrez peut-être tracer votre propre voie plutôt que de suivre la sagesse conventionnelle."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sfidare le tradizioni o sentirsi limitati dalle aspettative relazionali. Potresti dover forgiare la tua strada piuttosto che seguire la saggezza convenzionale."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "伝統に挑戦したり、関係の期待に制約を感じたりすること。従来の知恵に従うのではなく、自分自身の道を切り開く必要があるかもしれません。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utfordre tradisjoner eller føle seg begrenset av forventninger til forhold. Du må kanskje skape din egen vei i stedet for å følge konvensjonell visdom."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kwestionowanie tradycji lub odczuwanie ograniczeń przez oczekiwania wobec związku. Możesz potrzebować wytyczyć własną ścieżkę, zamiast podążać za konwencjonalną mądrością."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desafiar tradições ou se sentir confinado pelas expectativas do relacionamento. Você pode precisar forjar seu próprio caminho, em vez de seguir a sabedoria convencional."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utmana traditioner eller känna sig begränsad av relationsförväntningar. Du kanske måste skapa din egen väg snarare än att följa konventionell visdom."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Кидати виклик традиціям або відчувати себе обмеженим очікуваннями стосунків. Можливо, вам потрібно прокласти власний шлях, а не слідувати загальноприйнятій мудрості."
          }
        }
      }
    },
    "interpretation.the_hierophant_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Traditionelle Beziehungswerte und Verpflichtungen könnten jetzt wichtig sein. Die Ehe, Partnerschaften, die von der Gemeinschaft gesegnet sind, oder gemeinsame spirituelle Werte stärken die Bindungen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Traditional relationship values and commitments may be important now. Marriage, partnerships blessed by community, or shared spiritual values strengthen bonds."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los valores tradicionales de las relaciones y los compromisos pueden ser importantes ahora. El matrimonio, las asociaciones bendecidas por la comunidad o los valores espirituales compartidos fortalecen los lazos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les valeurs relationnelles traditionnelles et les engagements peuvent être importants maintenant. Le mariage, les partenariats bénis par la communauté ou les valeurs spirituelles partagées renforcent les liens."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I valori relazionali tradizionali e gli impegni potrebbero essere importanti ora. Il matrimonio, le partnership benedette dalla comunità o i valori spirituali condivisi rafforzano i legami."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "伝統的な関係の価値観やコミットメントが今は重要かもしれません。結婚、コミュニティに祝福されたパートナーシップ、または共有された精神的価値観が絆を強めます。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tradisjonelle forholdsverdier og forpliktelser kan være viktige nå. Ekteskap, partnerskap velsignet av samfunnet, eller delte åndelige verdier styrker bånd."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tradycyjne wartości relacyjne i zobowiązania mogą być teraz ważne. Małżeństwo, partnerstwa błogosławione przez społeczność lub wspólne wartości duchowe wzmacniają więzi."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Valores de relacionamento tradicionais e compromissos podem ser importantes agora. Casamento, parcerias abençoadas pela comunidade ou valores espirituais compartilhados fortalecem os laços."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Traditionella relationsvärden och åtaganden kan vara viktiga nu. Äktenskap, partnerskap välsignade av samhället eller delade andliga värderingar stärker banden."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Традиційні цінності стосунків та зобов'язання можуть бути важливими зараз. Шлюб, партнерства, благословенні громадою, або спільні духовні цінності зміцнюють зв'язки."
          }
        }
      }
    },
    "interpretation.the_high_priestess_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du bist von deinem inneren Wissen abgeschnitten, oder Arbeitsplatzgeheimnisse beeinträchtigen dich. Vertrauen wurde gebrochen, oder Informationen werden zurückgehalten. Verbinde dich wieder mit deiner Intuition, um diese Situation zu meistern."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You're disconnected from your inner knowing, or there's workplace secrecy affecting you. Trust has been broken, or information is being withheld. Reconnect with your intuition to navigate this situation."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estás desconectado de tu conocimiento interior, o el secreto en el lugar de trabajo te afecta. Se ha roto la confianza o se retiene información. Reconéctate con tu intuición para navegar esta situación."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous êtes déconnecté de votre connaissance intérieure, ou le secret sur le lieu de travail vous affecte. La confiance a été brisée ou des informations sont retenues. Reconnectez-vous à votre intuition pour gérer cette situation."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sei disconnesso dalla tua conoscenza interiore, o la segretezza sul posto di lavoro ti sta influenzando. La fiducia è stata tradita o le informazioni vengono trattenute. Riconnettiti con la tua intuizione per navigare questa situazione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたは内なる知識から切り離されているか、職場の秘密があなたに影響を与えています。信頼が壊れているか、情報が差し控えられています。この状況を乗り切るために直感と再接続してください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du er frakoblet din indre viten, eller hemmelighold på arbeidsplassen påvirker deg. Tillit er brutt, eller informasjon blir tilbakeholdt. Koble deg på nytt til intuisjonen din for å navigere denne situasjonen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jesteś odłączony od swojej wewnętrznej wiedzy lub tajemnica w miejscu pracy cię dotyka. Zaufanie zostało złamane lub informacje są wstrzymywane. Połącz się ponownie ze swoją intuicją, aby poradzić sobie w tej sytuacji."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você está desconectado do seu conhecimento interior, ou o sigilo no local de trabalho está afetando você. A confiança foi quebrada ou informações estão sendo retidas. Reconecte-se com sua intuição para navegar nesta situação."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du är frånkopplad från din inre kunskap, eller hemligheter på arbetsplatsen påverkar dig. Förtroende har brutits eller information hålls inne. Återanslut till din intuition för att navigera denna situation."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ви від'єднані від свого внутрішнього знання, або таємниця на робочому місці впливає на вас. Довіру порушено, або інформацію приховують. Повторно підключіться до своєї інтуїції, щоб орієнтуватися в цій ситуації."
          }
        }
      }
    },
    "interpretation.the_high_priestess_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Höre auf dein Bauchgefühl bezüglich deines Karrierewegs. Die Antwort, die du suchst, wird nicht von externen Ratschlägen kommen – sie ist bereits in dir. Dies ist auch eine Zeit der stillen Beobachtung. Achte auf das, was hinter den Kulissen passiert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Listen to your gut instincts about your career path. The answer you seek won't come from external advice—it's already within you. This is also a time for quiet observation. Pay attention to what's happening behind the scenes."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Escucha tus instintos sobre tu camino profesional. La respuesta que buscas no vendrá de consejos externos—ya está dentro de ti. Este es también un momento para la observación silenciosa. Presta atención a lo que sucede detrás de escena."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Écoutez votre instinct concernant votre cheminement de carrière. La réponse que vous cherchez ne viendra pas de conseils extérieurs — elle est déjà en vous. C'est aussi un moment d'observation silencieuse. Faites attention à ce qui se passe dans les coulisses."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ascolta il tuo istinto riguardo al tuo percorso di carriera. La risposta che cerchi non verrà da consigli esterni — è già dentro di te. Questo è anche un momento di osservazione silenziosa. Presta attenzione a ciò che accade dietro le quinte."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャリアパスについての直感的な感覚を聞いてください。あなたが求めている答えは外部のアドバイスから来るものではありません—それはすでにあなたの中にあります。これは静かな観察の時でもあります。舞台裏で何が起こっているかに注意を払ってください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lytt til magefølelsen din om karriereveien din. Svaret du søker vil ikke komme fra eksterne råd — det er allerede i deg. Dette er også en tid for stille observasjon. Vær oppmerksom på hva som skjer bak kulissene."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Słuchaj swojego instynktu dotyczącego twojej ścieżki kariery. Odpowiedź, której szukasz, nie przyjdzie z zewnętrznych porad — jest już w tobie. To także czas cichej obserwacji. Zwróć uwagę na to, co dzieje się za kulisami."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ouça seus instintos sobre seu caminho de carreira. A resposta que você busca não virá de conselhos externos—já está dentro de você. Este também é um momento de observação silenciosa. Preste atenção ao que está acontecendo nos bastidores."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lyssna på din magkänsla om din karriärväg. Svaret du söker kommer inte från externa råd — det finns redan inom dig. Det här är också en tid för tyst observation. Var uppmärksam på vad som händer bakom kulisserna."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Слухайте свої інстинкти щодо вашого кар'єрного шляху. Відповідь, яку ви шукаєте, не прийде від зовнішніх порад — вона вже всередині вас. Це також час тихого спостереження. Зверніть увагу на те, що відбувається за лаштунками."
          }
        }
      }
    },
    "interpretation.the_high_priestess_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Geheimnisse oder ignorierte Intuition könnten zu Problemen führen. Verbirgst du Ausgaben vor dir selbst oder anderen? Ignorierst du Warnsignale? Bringe die Dinge ans Licht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial secrets or intuition being ignored could lead to problems. Are you hiding spending from yourself or others? Are you ignoring warning signs? Bring things into the light."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los secretos financieros o la intuición ignorada podrían generar problemas. ¿Estás ocultando gastos de ti mismo o de los demás? ¿Estás ignorando las señales de advertencia? Saca las cosas a la luz."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les secrets financiers ou l'intuition ignorée pourraient entraîner des problèmes. Cachez-vous des dépenses à vous-même ou aux autres ? Ignorez-vous les signes d'avertissement ? Mettez les choses au grand jour."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Segreti finanziari o intuizione ignorata potrebbero portare a problemi. Stai nascondendo spese a te stesso o agli altri? Stai ignorando i segnali di avvertimento? Porta le cose alla luce."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的な秘密や無視された直感が問題を引き起こす可能性があります。自分自身や他人から支出を隠していますか？警告サインを無視していますか？物事を明るみに出してください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomiske hemmeligheter eller ignorert intuisjon kan føre til problemer. Skjuler du utgifter for deg selv eller andre? Ignorerer du advarselsskilt? Bring tingene frem i lyset."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tajemnice finansowe lub ignorowana intuicja mogą prowadzić do problemów. Czy ukrywasz wydatki przed sobą lub innymi? Czy ignorujesz znaki ostrzegawcze? Wyprowadź sprawy na światło dzienne."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Segredos financeiros ou intuição ignorada podem levar a problemas. Você está escondendo gastos de si mesmo ou de outros? Está ignorando sinais de alerta? Traga as coisas à luz."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomiska hemligheter eller ignorerad intuition kan leda till problem. Döljer du utgifter för dig själv eller andra? Ignorerar du varningssignaler? Bring saker i ljuset."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансові таємниці або ігнорована інтуїція можуть призвести до проблем. Ви приховуєте витрати від себе чи інших? Ви ігноруєте попереджувальні знаки? Виведіть речі на світло."
          }
        }
      }
    },
    "interpretation.the_high_priestess_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Versteckte finanzielle Möglichkeiten oder Informationen könnten ans Licht kommen. Vertraue deinen Instinkten bei Investitionen und finanziellen Entscheidungen. Recherchiere, aber achte auch auf dein Bauchgefühl. Weisheit kommt von innen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hidden financial opportunities or information may come to light. Trust your instincts about investments and financial decisions. Do your research, but also honor that gut feeling. Wisdom comes from within."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pueden salir a la luz oportunidades o información financiera oculta. Confía en tus instintos sobre inversiones y decisiones financieras. Haz tu investigación, pero también honra ese presentimiento. La sabiduría viene de dentro."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Des opportunités ou informations financières cachées pourraient être révélées. Faites confiance à votre instinct concernant les investissements et les décisions financières. Faites vos recherches, mais honorez également ce sentiment viscéral. La sagesse vient de l'intérieur."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opportunità o informazioni finanziarie nascoste potrebbero venire alla luce. Fidati dei tuoi istinti riguardo a investimenti e decisioni finanziarie. Fai le tue ricerche, ma onora anche quella sensazione istintiva. La saggezza viene da dentro."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "隠された経済的機会や情報が明らかになるかもしれません。投資や財務上の決定について直感を信頼してください。調査をしつつ、その直感も尊重してください。知恵は内側から来ます。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Skjulte økonomiske muligheter eller informasjon kan komme for dagen. Stol på instinktene dine om investeringer og økonomiske beslutninger. Gjør research, men hedre også den magefølelsen. Visdom kommer fra innsiden."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ukryte możliwości finansowe lub informacje mogą wyjść na jaw. Zaufaj swoim instynktom w kwestii inwestycji i decyzji finansowych. Zrób swoje badania, ale także uszanuj to przeczucie. Mądrość pochodzi z wnętrza."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oportunidades ou informações financeiras ocultas podem vir à tona. Confie em seus instintos sobre investimentos e decisões financeiras. Faça sua pesquisa, mas também honre esse pressentimento. A sabedoria vem de dentro."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dolda ekonomiska möjligheter eller information kan komma i dagen. Lita på dina instinkter om investeringar och ekonomiska beslut. Gör din research, men hedra också den magkänslan. Visdom kommer inifrån."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Приховані фінансові можливості або інформація можуть вийти на світло. Довіряйте своїм інстинктам щодо інвестицій та фінансових рішень. Проведіть дослідження, але також поважайте це внутрішнє чуття. Мудрість приходить зсередини."
          }
        }
      }
    },
    "interpretation.the_high_priestess_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du bist von deiner inneren Weisheit abgeschnitten, oder Geheimnisse fügen Schaden zu. Verbinde dich wieder mit deiner Intuition. Vor welcher Wahrheit hast du Angst gehabt? Es ist Zeit, dich ihr zu stellen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You're cut off from your inner wisdom, or secrets are causing harm. Reconnect with your intuitive self. What truth have you been afraid to acknowledge? It's time to face it."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estás desconectado de tu sabiduría interior, o los secretos están causando daño. Reconecta con tu ser intuitivo. ¿Qué verdad has temido reconocer? Es hora de enfrentarla."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous êtes coupé de votre sagesse intérieure, ou des secrets vous nuisent. Renouez avec votre moi intuitif. Quelle vérité avez-vous eu peur de reconnaître ? Il est temps d'y faire face."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sei tagliato dalla tua saggezza interiore, o i segreti causano danni. Riconnettiti con la tua intuizione. Quale verità hai avuto paura di riconoscere? È tempo di affrontarla."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたは内なる知恵から切り離されているか、秘密が害を及ぼしています。直感的な自分と再びつながりましょう。認めるのが怖かった真実は何ですか？今こそ向き合う時です。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du er avskåret fra din indre visdom, eller hemmeligheter skader deg. Gjenopprett kontakten med ditt intuitive jeg. Hvilken sannhet har du vært redd for å erkjenne? Det er på tide å møte den."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jesteś odcięty od swojej wewnętrznej mądrości, a tajemnice wyrządzają krzywdę. Połącz się ponownie ze swoją intuicją. Jakiej prawdy bałeś się uznać? Czas się z nią zmierzyć."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você está desconectado da sua sabedoria interior, ou segredos estão causando danos. Reconecte-se com seu eu intuitivo. Que verdade você teve medo de reconhecer? É hora de enfrentá-la."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du är avskuren från din inre visdom, eller hemligheter orsakar skada. Återanslut till ditt intuitiva jag. Vilken sanning har du varit rädd för att erkänna? Det är dags att möta den."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ви відрізані від своєї внутрішньої мудрості, або таємниці завдають шкоди. Возз'єднайтеся зі своєю інтуїцією. Якої правди ви боялися визнати? Час подивитися їй в обличчя."
          }
        }
      }
    },
    "interpretation.the_high_priestess_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Antworten, die du suchst, liegen in dir. Dies ist eine Zeit der Stille, Meditation und des tiefen inneren Zuhörens. Vertraue deiner Intuition, auch wenn die Logik sie nicht erklären kann. Die Geheimnisse werden sich offenbaren, wenn die Zeit reif ist."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The answers you seek lie within. This is a time for stillness, meditation, and deep inner listening. Trust your intuition even when logic can't explain it. The mysteries will reveal themselves when the time is right."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las respuestas que buscas están dentro de ti. Este es un momento de quietud, meditación y escucha interna profunda. Confía en tu intuición incluso cuando la lógica no pueda explicarla. Los misterios se revelarán cuando sea el momento adecuado."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les réponses que vous cherchez sont à l'intérieur. C'est un moment de calme, de méditation et d'écoute intérieure profonde. Faites confiance à votre intuition même lorsque la logique ne peut l'expliquer. Les mystères se révéleront au moment opportun."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le risposte che cerchi sono dentro di te. Questo è un momento di quiete, meditazione e profondo ascolto interiore. Fidati della tua intuizione anche quando la logica non può spiegarla. I misteri si riveleranno quando sarà il momento giusto."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたが求めている答えは内側にあります。これは静けさ、瞑想、そして深い内なる傾聴の時です。論理が説明できなくても直感を信頼してください。神秘は適切な時に明らかになります。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Svarene du søker ligger inni deg. Dette er en tid for stillhet, meditasjon og dyp indre lytting. Stol på intuisjonen din selv når logikken ikke kan forklare den. Mysteriene vil åpenbare seg når tiden er inne."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odpowiedzi, których szukasz, leżą w tobie. To czas ciszy, medytacji i głębokiego wewnętrznego słuchania. Zaufaj swojej intuicji, nawet gdy logika nie może jej wyjaśnić. Tajemnice ujawnią się, gdy nadejdzie odpowiedni czas."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As respostas que você procura estão dentro de você. Este é um momento de quietude, meditação e escuta interna profunda. Confie na sua intuição, mesmo quando a lógica não puder explicá-la. Os mistérios se revelarão quando for a hora certa."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Svaren du söker finns inom dig. Det här är en tid för stillhet, meditation och djup inre lyssnande. Lita på din intuition även när logiken inte kan förklara den. Mysterierna kommer att avslöjas när tiden är inne."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Відповіді, які ви шукаєте, лежать всередині. Це час тиші, медитації та глибокого внутрішнього слухання. Довіряйте своїй інтуїції, навіть коли логіка не може її пояснити. Таємниці розкриються, коли прийде час."
          }
        }
      }
    },
    "interpretation.the_high_priestess_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du ignorierst Symptome oder bist von den Botschaften deines Körpers abgeschnitten. Unterdrückte Emotionen könnten sich körperlich manifestieren. Es ist Zeit, dich einzustimmen und das anzusprechen, was du vermeidest."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You're ignoring symptoms or disconnected from your body's messages. Repressed emotions may be manifesting physically. It's time to tune in and address what you've been avoiding."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estás ignorando los síntomas o desconectado de los mensajes de tu cuerpo. Las emociones reprimidas pueden estar manifestándose físicamente. Es hora de sintonizar y abordar lo que has estado evitando."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous ignorez les symptômes ou vous êtes déconnecté des messages de votre corps. Les émotions refoulées peuvent se manifester physiquement. Il est temps de vous connecter et de vous attaquer à ce que vous avez évité."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stai ignorando i sintomi o sei disconnesso dai messaggi del tuo corpo. Le emozioni represse potrebbero manifestarsi fisicamente. È tempo di sintonizzarti e affrontare ciò che stai evitando."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたは症状を無視しているか、体のメッセージから切り離されています。抑圧された感情が身体的に現れている可能性があります。自分を調整し、避けてきたことに取り組む時です。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du ignorerer symptomer eller er frakoblet fra kroppens meldinger. Undertrykte følelser kan manifestere seg fysisk. Det er på tide å stille inn og adressere det du har unngått."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ignorujesz objawy lub jesteś odłączony od wiadomości swojego ciała. Stłumione emocje mogą manifestować się fizycznie. Czas się dostroić i zająć się tym, czego unikałeś."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você está ignorando sintomas ou desconectado das mensagens do seu corpo. Emoções reprimidas podem estar se manifestando fisicamente. É hora de sintonizar e abordar o que você tem evitado."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du ignorerar symtom eller är frånkopplad från din kropps meddelanden. Undertryckta känslor kan manifestera sig fysiskt. Det är dags att stämma in och ta itu med det du har undvikit."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ви ігноруєте симптоми або від'єднані від повідомлень свого тіла. Пригнічені емоції можуть проявлятися фізично. Настав час налаштуватися і вирішити те, чого ви уникали."
          }
        }
      }
    },
    "interpretation.the_high_priestess_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dein Körper versucht dir etwas zu sagen. Höre auf subtile Signale und achte auf dein Bedürfnis nach Ruhe und Selbstreflexion. Ganzheitliche oder intuitive Heilmethoden könnten jetzt besonders vorteilhaft sein. Vertraue der Weisheit deines Körpers."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your body is trying to tell you something. Listen to subtle signals and honor your need for rest and introspection. Holistic or intuitive healing modalities may be particularly beneficial now. Trust your body's wisdom."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu cuerpo está tratando de decirte algo. Escucha las señales sutiles y honra tu necesidad de descanso e introspección. Las modalidades de curación holísticas o intuitivas pueden ser particularmente beneficiosas ahora. Confía en la sabiduría de tu cuerpo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre corps essaie de vous dire quelque chose. Écoutez les signaux subtils et honorez votre besoin de repos et d'introspection. Les modalités de guérison holistiques ou intuitives peuvent être particulièrement bénéfiques en ce moment. Faites confiance à la sagesse de votre corps."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il tuo corpo sta cercando di dirti qualcosa. Ascolta i segnali sottili e onora il tuo bisogno di riposo e introspezione. Le modalità di guarigione olistiche o intuitive possono essere particolarmente benefiche ora. Fidati della saggezza del tuo corpo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたの体は何かを伝えようとしています。微妙なサインを聞き、休息と内省の必要性を尊重してください。ホリスティックまたは直感的なヒーリング法が特に有益かもしれません。あなたの体の知恵を信頼してください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kroppen din prøver å fortelle deg noe. Lytt til subtile signaler og hedre ditt behov for hvile og introspeksjon. Helhetlige eller intuitive helbredelsesmetoder kan være spesielt fordelaktige nå. Stol på kroppens visdom."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Twoje ciało próbuje ci coś powiedzieć. Słuchaj subtelnych sygnałów i szanuj swoją potrzebę odpoczynku i introspekcji. Holistyczne lub intuicyjne metody leczenia mogą być teraz szczególnie korzystne. Zaufaj mądrości swojego ciała."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seu corpo está tentando lhe dizer algo. Ouça sinais sutis e honre sua necessidade de descanso e introspecção. Modalidades de cura holísticas ou intuitivas podem ser particularmente benéficas agora. Confie na sabedoria do seu corpo."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Din kropp försöker säga dig något. Lyssna på subtila signaler och hedra ditt behov av vila och introspektion. Holistiska eller intuitiva läkningsmetoder kan vara särskilt fördelaktiga nu. Lita på din kropps visdom."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ваше тіло намагається щось вам сказати. Слухайте тонкі сигнали та поважайте свою потребу у відпочинку та самоаналізі. Цілісні або інтуїтивні методи зцілення можуть бути особливо корисними зараз. Довіряйте мудрості свого тіла."
          }
        }
      }
    },
    "interpretation.the_high_priestess_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du ignorierst deine Intuition, oder Geheimnisse schaffen Distanz in einer Beziehung. Was willst du nicht sehen? Was wird verborgen? Es ist Zeit, tiefer zu schauen und dem zu vertrauen, was du fühlst, auch wenn du es nicht beweisen kannst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You're ignoring your intuition, or secrets are creating distance in a relationship. What are you not willing to see? What's being hidden? It's time to look deeper and trust what you feel, even if you can't prove it."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estás ignorando tu intuición, o los secretos están creando distancia en una relación. ¿Qué no estás dispuesto a ver? ¿Qué se está ocultando? Es hora de mirar más profundamente y confiar en lo que sientes, incluso si no puedes probarlo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous ignorez votre intuition, ou des secrets créent une distance dans une relation. Qu'est-ce que vous ne voulez pas voir ? Qu'est-ce qui est caché ? Il est temps de regarder plus profondément et de faire confiance à ce que vous ressentez, même si vous ne pouvez pas le prouver."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stai ignorando la tua intuizione, o i segreti stanno creando distanza in una relazione. Cosa non vuoi vedere? Cosa viene nascosto? È tempo di guardare più a fondo e fidarti di ciò che senti, anche se non puoi provarlo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたは直感を無視しているか、秘密が関係に距離を作っています。あなたは何を見たくないのですか？何が隠されていますか？証明できなくても、もっと深く見て、自分の感情を信じる時です。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du ignorerer intuisjonen din, eller hemmeligheter skaper avstand i et forhold. Hva er du ikke villig til å se? Hva blir skjult? Det er på tide å se dypere og stole på det du føler, selv om du ikke kan bevise det."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ignorujesz swoją intuicję lub tajemnice tworzą dystans w związku. Czego nie chcesz widzieć? Co jest ukrywane? Czas spojrzeć głębiej i zaufać temu, co czujesz, nawet jeśli nie możesz tego udowodnić."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você está ignorando sua intuição, ou segredos estão criando distância em um relacionamento. O que você não quer ver? O que está sendo escondido? É hora de olhar mais fundo e confiar no que você sente, mesmo que não possa provar."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du ignorerar din intuition, eller hemligheter skapar avstånd i en relation. Vad vill du inte se? Vad döljs? Det är dags att titta djupare och lita på vad du känner, även om du inte kan bevisa det."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ви ігноруєте свою інтуїцію, або таємниці створюють відстань у стосунках. Що ви не хочете бачити? Що приховується? Настав час подивитися глибше і довіритися тому, що ви відчуваєте, навіть якщо не можете це довести."
          }
        }
      }
    },
    "interpretation.the_high_priestess_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vertraue jetzt in Liebesangelegenheiten auf deine Intuition. Was sagt dir deine innere Stimme? Es könnte Geheimnisse oder unausgesprochene Gefühle unter der Oberfläche geben. Achte auf das, was nicht gesagt wird. Deine psychischen Sinne sind geschärft."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trust your intuition in matters of love right now. What is your inner voice telling you? There may be secrets or unspoken feelings beneath the surface. Pay attention to what's not being said. Your psychic senses are heightened."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confía en tu intuición en asuntos del amor ahora mismo. ¿Qué te dice tu voz interior? Puede haber secretos o sentimientos no expresados debajo de la superficie. Presta atención a lo que no se dice. Tus sentidos psíquicos están agudizados."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Faites confiance à votre intuition en matière d'amour en ce moment. Que vous dit votre voix intérieure ? Il peut y avoir des secrets ou des sentiments non-dits sous la surface. Faites attention à ce qui n'est pas dit. Vos sens psychiques sont accrus."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fidati della tua intuizione nelle questioni d'amore in questo momento. Cosa ti sta dicendo la tua voce interiore? Potrebbero esserci segreti o sentimenti inespressi sotto la superficie. Presta attenzione a ciò che non viene detto. I tuoi sensi psichici sono acuiti."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "今、恋愛において直感を信頼してください。あなたの内なる声は何と言っていますか？表面の下には秘密や言葉にされていない感情があるかもしれません。言われていないことに注意を払ってください。あなたの精神的な感覚が高まっています。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stol på intuisjonen din i kjærlighetssaker akkurat nå. Hva forteller din indre stemme deg? Det kan være hemmeligheter eller uuttalte følelser under overflaten. Vær oppmerksom på det som ikke blir sagt. Dine psykiske sanser er skjerpet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zaufaj swojej intuicji w sprawach miłosnych w tej chwili. Co mówi ci twój wewnętrzny głos? Pod powierzchnią mogą być sekrety lub niewypowiedziane uczucia. Zwróć uwagę na to, co nie jest powiedziane. Twoje zmysły psychiczne są wyostrzone."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confie na sua intuição em questões de amor agora. O que sua voz interior está lhe dizendo? Pode haver segredos ou sentimentos não ditos abaixo da superfície. Preste atenção ao que não está sendo dito. Seus sentidos psíquicos estão aguçados."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lita på din intuition i kärleksfrågor just nu. Vad säger din inre röst dig? Det kan finnas hemligheter eller outtalade känslor under ytan. Var uppmärksam på det som inte sägs. Dina psykiska sinnen är skärpta."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Довіряйте своїй інтуїції в любовних справах зараз. Що говорить вам ваш внутрішній голос? Під поверхнею можуть бути таємниці або невисловлені почуття. Зверніть увагу на те, що не сказано. Ваші психічні почуття загострені."
          }
        }
      }
    },
    "interpretation.the_lovers_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Berufliche Entscheidungen fühlen sich nicht mit deinen Werten vereinbar an. Du gibst dich vielleicht zufrieden oder gehst zu viele Kompromisse ein. Überlege, ob deine Arbeit widerspiegelt, wer du wirklich bist."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Career decisions feel misaligned with your values. You might be settling or compromising too much. Examine if your work reflects who you truly are."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las decisiones profesionales se sienten desalineadas con tus valores. Puede que te estés conformando o comprometiendo demasiado. Examina si tu trabajo refleja quién eres realmente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les décisions de carrière semblent en décalage avec vos valeurs. Vous vous contentez peut-être de moins ou faites trop de compromis. Examinez si votre travail reflète qui vous êtes vraiment."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le decisioni professionali sembrano in disallineamento con i tuoi valori. Potresti accontentarti o scendere a troppi compromessi. Esamina se il tuo lavoro riflette chi sei veramente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャリアの決断が自分の価値観と合っていないと感じられます。あなたは甘んじているか、妥協しすぎているかもしれません。自分の仕事が本当の自分を反映しているかどうかを考えてみてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karrierevalg føles feiljustert med verdiene dine. Du nøyer deg kanskje eller kompromisser for mye. Undersøk om arbeidet ditt reflekterer hvem du virkelig er."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Decyzje zawodowe wydają się niezgodne z twoimi wartościami. Być może zadowalasz się mniej lub zbyt wiele kompromisów. Sprawdź, czy twoja praca odzwierciedla to, kim naprawdę jesteś."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Decisões de carreira parecem desalinhadas com seus valores. Você pode estar se contentando ou comprometendo demais. Examine se seu trabalho reflete quem você realmente é."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriärbeslut känns felaktiga i förhållande till dina värderingar. Du kanske nöjer dig eller kompromissar för mycket. Undersök om ditt arbete speglar vem du verkligen är."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Кар'єрні рішення здаються неузгодженими з вашими цінностями. Можливо, ви задовольняєтеся меншим або йдете на занадто великі компроміси. Перевірте, чи ваша робота відображає те, ким ви є насправді."
          }
        }
      }
    },
    "interpretation.the_lovers_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine wichtige berufliche Entscheidung steht vor dir. Diese Entscheidung sollte mit deinen Kernwerten und deiner langfristigen Vision übereinstimmen. Wähle nicht nur aufgrund des Geldes – wähle, was sich in deiner Seele richtig anfühlt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "An important professional choice is before you. This decision should align with your core values and long-term vision. Don't choose based on money alone—choose what feels right in your soul."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una decisión profesional importante está ante ti. Esta decisión debe alinearse con tus valores fundamentales y tu visión a largo plazo. No elijas solo por el dinero: elige lo que se sienta bien en tu alma."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un choix professionnel important se présente à vous. Cette décision doit être alignée sur vos valeurs fondamentales et votre vision à long terme. Ne choisissez pas seulement pour l'argent – choisissez ce qui vous semble juste dans l'âme."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una scelta professionale importante è davanti a te. Questa decisione dovrebbe allinearsi con i tuoi valori fondamentali e la tua visione a lungo termine. Non scegliere solo in base al denaro – scegli ciò che ti sembra giusto nell'anima."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "重要な仕事上の選択が目前に迫っています。この決断は、あなたの中核となる価値観と長期的なビジョンに沿ったものでなければなりません。お金だけで選ばないでください。魂が正しいと感じるものを選んでください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Et viktig karrierevalg står foran deg. Denne avgjørelsen bør være i samsvar med kjerneverdiene dine og langsiktig visjon. Ikke velg basert på penger alene – velg det som føles riktig i sjelen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przed tobą ważny wybór zawodowy. Ta decyzja powinna być zgodna z twoimi podstawowymi wartościami i długoterminową wizją. Nie wybieraj tylko na podstawie pieniędzy – wybierz to, co czujesz w duszy."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uma escolha profissional importante está diante de você. Essa decisão deve estar alinhada com seus valores fundamentais e visão de longo prazo. Não escolha apenas com base no dinheiro – escolha o que parece certo na sua alma."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ett viktigt karriärval står framför dig. Detta beslut bör vara i linje med dina kärnvärden och långsiktiga vision. Välj inte enbart baserat på pengar – välj det som känns rätt i själen."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Перед вами важливий професійний вибір. Це рішення має відповідати вашим основним цінностям і довгостроковому баченню. Не обирайте лише на основі грошей – обирайте те, що відчувається правильним у душі."
          }
        }
      }
    },
    "interpretation.the_lovers_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Werte stehen im Konflikt oder Partnerschaften sind unausgewogen. Die Prioritäten einer Person stimmen nicht mit deinen überein. Überdenke gemeinsame Ressourcen und Vereinbarungen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial values conflict or partnerships are unbalanced. Someone's priorities don't match yours. Reassess shared resources and agreements."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los valores financieros entran en conflicto o las asociaciones están desequilibradas. Las prioridades de alguien no coinciden con las tuyas. Reevalúa los recursos compartidos y los acuerdos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les valeurs financières sont en conflit ou les partenariats sont déséquilibrés. Les priorités de quelqu'un ne correspondent pas aux vôtres. Réévaluez les ressources partagées et les accords."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I valori finanziari sono in conflitto o le partnership sono sbilanciate. Le priorità di qualcuno non corrispondono alle tue. Rivaluta le risorse condivise e gli accordi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "財務上の価値観が衝突しているか、パートナーシップが不均衡です。誰かの優先事項があなたのものと一致していません。共有リソースと合意を再評価してください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomiske verdier kolliderer eller partnerskap er ubalanserte. Noens prioriteringer samsvarer ikke med dine. Revurder delte ressurser og avtaler."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wartości finansowe są sprzeczne lub partnerstwa są niezrównoważone. Czyjeś priorytety nie pasują do twoich. Oceń ponownie wspólne zasoby i umowy."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Valores financeiros entram em conflito ou parcerias estão desequilibradas. As prioridades de alguém não correspondem às suas. Reavalie recursos compartilhados e acordos."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomiska värderingar kolliderar eller partnerskap är obalanserade. Någons prioriteringar matchar inte dina. Omvärdera delade resurser och avtal."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансові цінності конфліктують, або партнерства незбалансовані. Чиїсь пріоритети не збігаються з вашими. Переоцініть спільні ресурси та угоди."
          }
        }
      }
    },
    "interpretation.the_lovers_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Entscheidungen erfordern eine Werteausrichtung. Triff Entscheidungen, die sowohl deinen praktischen Bedürfnissen als auch deinen ethischen Standards entsprechen. Partnerschaftsmöglichkeiten könnten günstig sein."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial decisions require value alignment. Make choices that honor both your practical needs and your ethical standards. Partnership opportunities may be favorable."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las decisiones financieras requieren alineación de valores. Elige opciones que honren tanto tus necesidades prácticas como tus estándares éticos. Las oportunidades de asociación pueden ser favorables."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les décisions financières nécessitent un alignement des valeurs. Faites des choix qui honorent à la fois vos besoins pratiques et vos normes éthiques. Les opportunités de partenariat peuvent être favorables."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le decisioni finanziarie richiedono l'allineamento dei valori. Fai scelte che onorano sia le tue esigenze pratiche che i tuoi standard etici. Le opportunità di partnership potrebbero essere favorevoli."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "財務上の決定には価値観の一致が必要です。実用的なニーズと倫理的な基準の両方を尊重する選択をしてください。パートナーシップの機会は有利かもしれません。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomiske beslutninger krever verdijustering. Gjør valg som ærer både dine praktiske behov og dine etiske standarder. Partnerskapsmuligheter kan være gunstige."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Decyzje finansowe wymagają zgodności wartości. Dokonuj wyborów, które szanują zarówno twoje praktyczne potrzeby, jak i standardy etyczne. Możliwości partnerstwa mogą być korzystne."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Decisões financeiras exigem alinhamento de valores. Faça escolhas que honrem tanto suas necessidades práticas quanto seus padrões éticos. Oportunidades de parceria podem ser favoráveis."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomiska beslut kräver värdejustering. Gör val som hedrar både dina praktiska behov och dina etiska standarder. Partnerskapsmöjligheter kan vara gynnsamma."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансові рішення вимагають узгодження цінностей. Робіть вибір, який поважає як ваші практичні потреби, так і ваші етичні стандарти. Партнерські можливості можуть бути сприятливими."
          }
        }
      }
    },
    "interpretation.the_lovers_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Innerer Konflikt oder schlechte Entscheidungen erzeugen Disharmonie. Du bist vielleicht mit dir selbst im Widerstreit oder triffst Entscheidungen, die nicht deine wahren Werte widerspiegeln. Richte dich neu auf das aus, was dir am wichtigsten ist."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inner conflict or poor choices are creating disharmony. You may be at odds with yourself or making decisions that don't reflect your true values. Realign with what matters most to you."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El conflicto interno o las malas decisiones están creando desarmonía. Puede que estés en desacuerdo contigo mismo o tomando decisiones que no reflejan tus verdaderos valores. Realíneate con lo que más te importa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un conflit intérieur ou de mauvais choix créent de la disharmonie. Vous êtes peut-être en désaccord avec vous-même ou prenez des décisions qui ne reflètent pas vos véritables valeurs. Recentrez-vous sur ce qui compte le plus pour vous."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conflitto interiore o cattive scelte stanno creando disarmonia. Potresti essere in disaccordo con te stesso o prendere decisioni che non riflettono i tuoi veri valori. Riallineati con ciò che è più importante per te."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "内なる葛藤や誤った選択が不調和を生み出しています。あなたは自分自身と対立しているか、自分の真の価値観を反映しない決断をしているかもしれません。自分にとって最も重要なことに再び調和させてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Indre konflikt eller dårlige valg skaper disharmoni. Du kan være i strid med deg selv eller ta avgjørelser som ikke gjenspeiler dine sanne verdier. Juster deg på nytt med det som betyr mest for deg."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Konflikt wewnętrzny lub złe wybory tworzą dysharmonię. Możesz być w niezgodzie ze sobą lub podejmować decyzje, które nie odzwierciedlają twoich prawdziwych wartości. Dostrój się ponownie do tego, co jest dla ciebie najważniejsze."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conflito interno ou más escolhas estão criando desarmonia. Você pode estar em desacordo consigo mesmo ou tomando decisões que não refletem seus verdadeiros valores. Realinhe-se com o que mais importa para você."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inre konflikt eller dåliga val skapar disharmoni. Du kan vara i strid med dig själv eller fatta beslut som inte speglar dina sanna värderingar. Justera dig igen med det som betyder mest för dig."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Внутрішній конфлікт або неправильний вибір створюють дисгармонію. Ви можете бути в розладі з собою або приймати рішення, які не відображають ваші справжні цінності. Переорієнтуйтеся на те, що для вас найважливіше."
          }
        }
      }
    },
    "interpretation.the_lovers_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine bedeutende Wahl steht vor dir. Wähle aus deinem Herzen und deinen Werten, nicht aus Angst oder Verpflichtung. Diese Entscheidung wird deinen Weg nach vorne prägen. Wie fühlt sich Ausrichtung in deinem Körper an?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A significant choice stands before you. Choose from your heart and your values, not from fear or obligation. This decision will shape your path forward. What does alignment feel like in your body?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una elección significativa se presenta ante ti. Elige desde tu corazón y tus valores, no desde el miedo o la obligación. Esta decisión dará forma a tu camino a seguir. ¿Cómo se siente la alineación en tu cuerpo?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un choix important se présente à vous. Choisissez avec votre cœur et vos valeurs, non par peur ou obligation. Cette décision façonnera votre chemin à venir. À quoi ressemble l'alignement dans votre corps ?"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una scelta significativa è di fronte a te. Scegli dal tuo cuore e dai tuoi valori, non dalla paura o dall'obbligo. Questa decisione plasmerà il tuo percorso futuro. Come ti senti l'allineamento nel tuo corpo?"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "重要な選択があなたの前にあります。恐怖や義務ではなく、心と価値観から選んでください。この決断はあなたの将来の道を形作ります。調和はあなたの体の中でどのように感じられますか？"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Et betydningsfullt valg står foran deg. Velg fra hjertet og verdiene dine, ikke fra frykt eller plikt. Denne avgjørelsen vil forme veien din videre. Hvordan føles justering i kroppen din?"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przed tobą znaczący wybór. Wybierz z serca i swoich wartości, a nie ze strachu lub obowiązku. Ta decyzja ukształtuje twoją dalszą ścieżkę. Jak odczuwasz dostrojenie w swoim ciele?"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uma escolha significativa está diante de você. Escolha a partir do seu coração e dos seus valores, não do medo ou da obrigação. Esta decisão moldará seu caminho adiante. Como o alinhamento se sente em seu corpo?"
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ett betydelsefullt val står framför dig. Välj från ditt hjärta och dina värderingar, inte från rädsla eller skyldighet. Detta beslut kommer att forma din väg framåt. Hur känns justering i din kropp?"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Значний вибір стоїть перед вами. Обирайте серцем і своїми цінностями, а не страхом чи обов'язком. Це рішення сформує ваш подальший шлях. Як відчувається узгодженість у вашому тілі?"
          }
        }
      }
    },
    "interpretation.the_lovers_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Innerer Konflikt beeinträchtigt deine Gesundheit. Deine Entscheidungen entsprechen möglicherweise nicht den Bedürfnissen deines Körpers. Höre tiefer auf das, was dich wirklich nährt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Internal conflict affects your health. Your choices may not align with your body's needs. Listen more deeply to what truly nourishes you."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El conflicto interno afecta tu salud. Tus elecciones pueden no alinearse con las necesidades de tu cuerpo. Escucha más profundamente lo que realmente te nutre."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un conflit interne affecte votre santé. Vos choix peuvent ne pas être alignés sur les besoins de votre corps. Écoutez plus profondément ce qui vous nourrit vraiment."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il conflitto interno influisce sulla tua salute. Le tue scelte potrebbero non essere allineate con le esigenze del tuo corpo. Ascolta più profondamente ciò che ti nutre veramente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "内なる葛藤があなたの健康に影響を与えています。あなたの選択は、体のニーズと一致していない可能性があります。本当に自分を養うものにもっと深く耳を傾けてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Indre konflikt påvirker helsen din. Valgene dine samsvarer kanskje ikke med kroppens behov. Lytt dypere til hva som virkelig nærer deg."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Konflikt wewnętrzny wpływa na twoje zdrowie. Twoje wybory mogą nie być zgodne z potrzebami twojego ciała. Słuchaj głębiej tego, co naprawdę cię odżywia."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O conflito interno afeta sua saúde. Suas escolhas podem não estar alinhadas com as necessidades do seu corpo. Ouça mais profundamente o que realmente te nutre."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inre konflikt påverkar din hälsa. Dina val kanske inte är i linje med din kropps behov. Lyssna djupare på vad som verkligen näring du."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Внутрішній конфлікт впливає на ваше здоров'я. Ваші вибори можуть не відповідати потребам вашого тіла. Слухайте глибше те, що справді живить вас."
          }
        }
      }
    },
    "interpretation.the_lovers_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Ausrichtung von Geist, Körper und Seele ist der Schlüssel zu deinem Wohlbefinden. Wähle Gesundheitspraktiken, die mit deinem gesamten Selbst in Einklang stehen. Eine Partnerschaft auf deinem Gesundheitsweg könnte vorteilhaft sein."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mind-body-spirit alignment is key to your wellbeing now. Choose health practices that resonate with your whole self. Partnership in your health journey may be beneficial."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La alineación mente-cuerpo-espíritu es clave para tu bienestar ahora. Elige prácticas de salud que resuenen con todo tu ser. Una asociación en tu viaje de salud puede ser beneficiosa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'alignement corps-esprit est essentiel à votre bien-être actuel. Choisissez des pratiques de santé qui résonnent avec votre être tout entier. Un partenariat dans votre parcours de santé peut être bénéfique."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'allineamento mente-corpo-spirito è la chiave per il tuo benessere ora. Scegli pratiche di salute che risuonano con tutto te stesso. Una partnership nel tuo percorso di salute potrebbe essere benefica."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "心身と精神の調和が、今のあなたの健康の鍵です。自分全体に響く健康習慣を選びましょう。健康の旅におけるパートナーシップは有益かもしれません。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sinn-kropp-ånd-justering er nøkkelen til ditt velvære nå. Velg helsepraksiser som resonnerer med hele deg selv. Partnerskap på helsereisen din kan være gunstig."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dostrojenie umysłu, ciała i ducha jest kluczem do twojego dobrego samopoczucia. Wybieraj praktyki zdrowotne, które rezonują z całym tobą. Partnerstwo w twojej podróży zdrowotnej może być korzystne."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O alinhamento mente-corpo-espírito é a chave para o seu bem-estar agora. Escolha práticas de saúde que ressoem com todo o seu ser. Uma parceria em sua jornada de saúde pode ser benéfica."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sinn-kropp-ande-justering är nyckeln till ditt välbefinnande nu. Välj hälsoövningar som resonerar med hela ditt jag. Partnerskap i din hälsa kan vara fördelaktigt."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Узгодження розуму, тіла та духу є ключем до вашого благополуччя зараз. Обирайте практики здоров'я, які резонують з усім вашим єством. Партнерство у вашій оздоровчій подорожі може бути корисним."
          }
        }
      }
    },
    "interpretation.the_lovers_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Missverhältnis, Disharmonie oder schwierige Entscheidungen plagen dein Liebesleben. Werte könnten kollidieren, oder du gibst dich mit weniger zufrieden, als du verdienst. Ignoriere diese Unvereinbarkeiten nicht – sie sind wichtiger, als du denkst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Misalignment, disharmony, or difficult choices plague your love life. Values may clash, or you're settling for less than you deserve. Don't ignore these incompatibilities—they matter more than you think."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El desalineamiento, la desarmonía o las decisiones difíciles afectan tu vida amorosa. Los valores pueden chocar, o te estás conformando con menos de lo que mereces. No ignores estas incompatibilidades: son más importantes de lo que crees."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le désalignement, la disharmonie ou des choix difficiles perturbent votre vie amoureuse. Les valeurs peuvent s'affronter, ou vous vous contentez de moins que ce que vous méritez. N'ignorez pas ces incompatibilités – elles sont plus importantes que vous ne le pensez."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Disallineamento, disarmonia o scelte difficili affliggono la tua vita amorosa. I valori possono scontrarsi, o ti accontenti di meno di quanto meriti. Non ignorare queste incompatibilità – sono più importanti di quanto pensi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "不一致、不調和、または困難な選択があなたの恋愛を悩ませています。価値観が衝突しているか、自分が値するもの以下のものに甘んじているかもしれません。これらの不一致を無視しないでください。それらはあなたが思っている以上に重要です。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Feiljustering, disharmoni eller vanskelige valg plager kjærlighetslivet ditt. Verdier kan kollidere, eller du nøyer deg med mindre enn du fortjener. Ikke ignorer disse inkompatibilitetene – de er viktigere enn du tror."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Brak harmonii, dysharmonia lub trudne wybory nękają twoje życie miłosne. Wartości mogą być sprzeczne lub zadowalasz się mniej, niż zasługujesz. Nie ignoruj tych niezgodności – są ważniejsze, niż myślisz."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desalinhamento, desarmonia ou escolhas difíceis assolam sua vida amorosa. Os valores podem entrar em conflito, ou você está se contentando com menos do que merece. Não ignore essas incompatibilidades – elas são mais importantes do que você pensa."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Feljustering, disharmoni eller svåra val plågar ditt kärleksliv. Värderingar kan kollidera, eller så nöjer du dig med mindre än du förtjänar. Ignorera inte dessa inkompatibiliteter – de är viktigare än du tror."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Неузгодженість, дисгармонія або важкі вибори переслідують ваше любовне життя. Цінності можуть конфліктувати, або ви задовольняєтеся меншим, ніж заслуговуєте. Не ігноруйте цю несумісність – вона важливіша, ніж ви думаєте."
          }
        }
      }
    },
    "interpretation.the_lovers_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das ist die Karte der tiefen, authentischen Verbindung. Du bist aufgerufen, eine wichtige Wahl in der Liebe zu treffen, die im Einklang mit deinen Werten steht. Echte Partnerschaft erfordert Verletzlichkeit und Ehrlichkeit. Bist du bereit, dich voll und ganz zu zeigen?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This is the card of deep, authentic connection. You're being called to make an important choice in love from a place of alignment with your values. True partnership requires vulnerability and honesty. Are you ready to show up fully?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esta es la carta de la conexión profunda y auténtica. Estás llamado a tomar una decisión importante en el amor desde la alineación con tus valores. La verdadera pareja requiere vulnerabilidad y honestidad. ¿Estás listo para mostrarte por completo?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "C'est la carte de la connexion profonde et authentique. Vous êtes appelé à faire un choix important en amour en accord avec vos valeurs. Une véritable relation de couple exige vulnérabilité et honnêteté. Êtes-vous prêt à vous montrer pleinement ?"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questa è la carta della connessione profonda e autentica. Sei chiamato a fare una scelta importante in amore in allineamento con i tuoi valori. La vera partnership richiede vulnerabilità e onestà. Sei pronto a mostrarti completamente?"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "これは深く本物のつながりのカードです。あなたは自分の価値観に沿った愛における重要な選択をするよう呼ばれています。真のパートナーシップには、弱さと誠実さが必要です。完全に自分を見せる準備はできていますか？"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dette er kortet for dyp, autentisk forbindelse. Du blir kalt til å ta et viktig valg i kjærlighet fra et sted i samsvar med dine verdier. Ekte partnerskap krever sårbarhet og ærlighet. Er du klar til å vise deg fullt ut?"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "To jest karta głębokiego, autentycznego połączenia. Zostajesz wezwany do dokonania ważnego wyboru w miłości w zgodzie ze swoimi wartościami. Prawdziwe partnerstwo wymaga wrażliwości i szczerości. Czy jesteś gotów pokazać się w pełni?"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esta é a carta da conexão profunda e autêntica. Você é chamado a fazer uma escolha importante no amor a partir do alinhamento com seus valores. A verdadeira parceria requer vulnerabilidade e honestidade. Você está pronto para se mostrar completamente?"
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Detta är kortet för djup, autentisk kontakt. Du kallas att göra ett viktigt val i kärlek utifrån dina värderingar. Sann partnerskap kräver sårbarhet och ärlighet. Är du redo att visa dig fullt ut?"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Це карта глибокого, автентичного зв'язку. Вас закликають зробити важливий вибір у коханні, узгоджуючись зі своїми цінностями. Справжнє партнерство вимагає вразливості та чесності. Чи готові ви показати себе повністю?"
          }
        }
      }
    },
    "interpretation.the_magician_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du nutzt dein volles Potenzial nicht aus, oder du bist manipulativ, um voranzukommen. Unterschätzt du dich selbst? Oder versuchst du, andere zu täuschen? Keiner dieser Wege führt zu dauerhaftem Erfolg. Sei authentisch und ergreife deine Macht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You're not using your full potential, or you're being manipulative to get ahead. Are you underestimating yourself? Or are you trying to trick others? Neither path leads to lasting success. Be authentic and own your power."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No estás usando todo tu potencial, o estás siendo manipulador para avanzar. ¿Te estás subestimando? ¿O estás tratando de engañar a los demás? Ningún camino lleva al éxito duradero. Sé auténtico y asume tu poder."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous n'utilisez pas tout votre potentiel, ou vous êtes manipulateur pour avancer. Vous sous-estimez-vous ? Ou essayez-vous de tromper les autres ? Aucun de ces chemins ne mène à un succès durable. Soyez authentique et assumez votre pouvoir."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Non stai usando il tuo pieno potenziale, o sei manipolativo per andare avanti. Ti stai sottovalutando? O stai cercando di ingannare gli altri? Nessuna di queste strade porta al successo duraturo. Sii autentico e prendi il tuo potere."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたは自分の可能性を最大限に活用していないか、出世のために操作的に振る舞っています。自分を過小評価していますか？それとも他人を騙そうとしていますか？どちらの道も長続きする成功にはつながりません。本物であり、自分の力を所有してください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du bruker ikke ditt fulle potensial, eller du er manipulerende for å komme videre. Undervurderer du deg selv? Eller prøver du å lure andre? Ingen av veiene fører til varig suksess. Vær autentisk og eie din makt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nie wykorzystujesz swojego pełnego potencjału lub jesteś manipulacyjny, aby iść do przodu. Czy nie doceniasz siebie? Czy próbujesz oszukać innych? Żadna z tych ścieżek nie prowadzi do trwałego sukcesu. Bądź autentyczny i przejmij swoją moc."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você não está usando todo o seu potencial, ou está sendo manipulador para avançar. Você está se subestimando? Ou está tentando enganar os outros? Nenhum dos caminhos leva ao sucesso duradouro. Seja autêntico e assuma o seu poder."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du använder inte din fulla potential, eller så är du manipulativ för att komma framåt. Underskattar du dig själv? Eller försöker du lura andra? Ingen av vägarna leder till varaktig framgång. Var autentisk och äg din kraft."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ви не використовуєте свій повний потенціал або маніпулюєте, щоб просунутися. Ви недооцінюєте себе? Чи намагаєтеся обдурити інших? Жоден із цих шляхів не веде до тривалого успіху. Будьте автентичними та візьміть свою силу."
          }
        }
      }
    },
    "interpretation.the_magician_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du bist in einer starken Position, um deine Karriereziele zu verwirklichen. Du hast die Fähigkeiten, Ressourcen und Möglichkeiten direkt vor dir. Dies ist dein Moment, um selbstbewusst zu handeln. Kommuniziere deine Vision klar und sieh zu, wie sie zum Leben erwacht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You're in a powerful position to manifest your career goals. You have the skills, resources, and opportunities right in front of you. This is your moment to take action with confidence. Communicate your vision clearly and watch it come to life."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estás en una posición poderosa para manifestar tus metas profesionales. Tienes las habilidades, recursos y oportunidades justo frente a ti. Este es tu momento para actuar con confianza. Comunica tu visión claramente y mírala hacerse realidad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous êtes dans une position puissante pour manifester vos objectifs de carrière. Vous avez les compétences, les ressources et les opportunités juste devant vous. C'est votre moment pour agir avec confiance. Communiquez clairement votre vision et regardez-la prendre vie."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sei in una posizione potente per manifestare i tuoi obiettivi di carriera. Hai le competenze, le risorse e le opportunità proprio di fronte a te. Questo è il tuo momento per agire con fiducia. Comunica la tua visione chiaramente e guardala prendere vita."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたはキャリア目標を実現する強力な立場にいます。スキル、リソース、機会が目の前にあります。自信を持って行動する時です。自分のビジョンを明確に伝え、それが現実になるのを見届けてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du er i en kraftig posisjon til å manifestere karrieremålene dine. Du har ferdighetene, ressursene og mulighetene rett foran deg. Dette er ditt øyeblikk for å handle med selvtillit. Kommuniser visjonen din tydelig og se den bli levende."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jesteś w silnej pozycji, aby zamanifestować swoje cele zawodowe. Masz umiejętności, zasoby i możliwości tuż przed sobą. To twój moment, aby działać z pewnością siebie. Komunikuj swoją wizję jasno i obserwuj, jak ożywa."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você está em uma posição poderosa para manifestar seus objetivos de carreira. Você tem as habilidades, recursos e oportunidades bem à sua frente. Este é o seu momento de agir com confiança. Comunique sua visão claramente e veja ela ganhar vida."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du är i en kraftfull position för att manifestera dina karriärmål. Du har färdigheterna, resurserna och möjligheterna precis framför dig. Det här är ditt ögonblick att agera med självförtroende. Kommunicera din vision tydligt och se den bli verklighet."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ви в потужній позиції для втілення своїх кар'єрних цілей. У вас є навички, ресурси та можливості прямо перед вами. Це ваш момент діяти впевнено. Чітко повідомте своє бачення і спостерігайте, як воно оживає."
          }
        }
      }
    },
    "interpretation.the_magician_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Täuschung oder schlechte Planung könnten deine finanziellen Ziele untergraben. Mach keine Kompromisse bei der Qualität oder versuche nicht, das System zu manipulieren. Achte auch auf Betrug oder Angebote, die zu gut sind, um wahr zu sein. Bleib auf dem Boden der Realität."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trickery or poor planning could undermine your financial goals. Don't cut corners or try to manipulate the system. Also watch for scams or too-good-to-be-true offers. Stay grounded in reality."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El engaño o la mala planificación podrían socavar tus metas financieras. No tomes atajos ni intentes manipular el sistema. También ten cuidado con estafas u ofertas demasiado buenas para ser verdad. Mantente con los pies en la realidad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La tromperie ou une mauvaise planification pourraient compromettre vos objectifs financiers. Ne prenez pas de raccourcis et n'essayez pas de manipuler le système. Méfiez-vous également des arnaques ou des offres trop belles pour être vraies. Restez ancré dans la réalité."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'inganno o una cattiva pianificazione potrebbero minare i tuoi obiettivi finanziari. Non tagliare gli angoli o cercare di manipolare il sistema. Fai anche attenzione a truffe o offerte troppo belle per essere vere. Resta con i piedi per terra."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "策略や計画不足があなたの経済的目標を損なう可能性があります。手を抜いたり、システムを操作しようとしないでください。また、詐欺や話が良すぎるオファーにも注意してください。現実に根ざしていてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lureri eller dårlig planlegging kan undergrave dine økonomiske mål. Ikke ta snarveier eller prøv å manipulere systemet. Se også opp for svindel eller tilbud som er for gode til å være sanne. Hold deg forankret i virkeligheten."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oszustwo lub złe planowanie mogą podważyć twoje cele finansowe. Nie idź na skróty ani nie próbuj manipulować systemem. Uważaj również na oszustwa lub oferty, które są zbyt piękne, aby były prawdziwe. Pozostań zakorzeniony w rzeczywistości."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trapaças ou planejamento ruim podem minar seus objetivos financeiros. Não corte atalhos ou tente manipular o sistema. Também fique atento a golpes ou ofertas boas demais para ser verdade. Mantenha-se com os pés na realidade."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bedrägeri eller dålig planering kan undergräva dina ekonomiska mål. Ta inte genvägar eller försök manipulera systemet. Se också upp för bedrägerier eller erbjudanden som är för bra för att vara sanna. Förbli förankrad i verkligheten."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Хитрість або погане планування можуть підірвати ваші фінансові цілі. Не зрізайте кути і не намагайтеся маніпулювати системою. Також остерігайтеся шахрайства або пропозицій, які є надто хорошими, щоб бути правдою. Залишайтеся в реальності."
          }
        }
      }
    },
    "interpretation.the_magician_finance_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Manifestation ist in deiner Reichweite. Du hast die Ressourcen und das Wissen, um Wohlstand zu schaffen – jetzt geht es darum, strategisch zu handeln. Dies ist eine ausgezeichnete Zeit für Verhandlungen, Investitionen oder die Gründung finanzieller Unternehmungen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial manifestation is within your reach. You have the resources and knowledge to create wealth—now it's about taking strategic action. This is an excellent time for negotiations, investments, or launching financial ventures."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La manifestación financiera está a tu alcance. Tienes los recursos y el conocimiento para crear riqueza—ahora se trata de tomar medidas estratégicas. Este es un excelente momento para negociaciones, inversiones o lanzar emprendimientos financieros."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La manifestation financière est à votre portée. Vous avez les ressources et les connaissances pour créer de la richesse — il s'agit maintenant de prendre des mesures stratégiques. C'est un excellent moment pour les négociations, les investissements ou le lancement d'entreprises financières."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La manifestazione finanziaria è alla tua portata. Hai le risorse e le conoscenze per creare ricchezza — ora si tratta di agire strategicamente. Questo è un ottimo momento per negoziazioni, investimenti o avvio di imprese finanziarie."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的な実現はあなたの手の届くところにあります。富を創造するためのリソースと知識を持っています—今は戦略的に行動することです。交渉、投資、または金融ベンチャーの立ち上げに最適な時期です。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk manifestasjon er innen rekkevidde. Du har ressursene og kunnskapen til å skape rikdom — nå handler det om å ta strategiske handlinger. Dette er en utmerket tid for forhandlinger, investeringer eller å starte økonomiske satsinger."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finansowa manifestacja jest w twoim zasięgu. Masz zasoby i wiedzę, aby tworzyć bogactwo — teraz chodzi o podjęcie strategicznych działań. To doskonały czas na negocjacje, inwestycje lub rozpoczynanie przedsięwzięć finansowych."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A manifestação financeira está ao seu alcance. Você tem os recursos e o conhecimento para criar riqueza—agora é sobre agir estrategicamente. Este é um excelente momento para negociações, investimentos ou lançamento de empreendimentos financeiros."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekonomisk manifestation är inom räckhåll. Du har resurserna och kunskapen för att skapa rikedom — nu handlar det om att ta strategiska åtgärder. Det här är en utmärkt tid för förhandlingar, investeringar eller att starta finansiella satsningar."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Фінансова реалізація в межах вашої досяжності. У вас є ресурси та знання для створення багатства — тепер справа в стратегічних діях. Це чудовий час для переговорів, інвестицій або запуску фінансових підприємств."
          }
        }
      }
    },
    "interpretation.the_magician_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ungenutztes Potenzial oder Manipulation ist das Thema. Entweder du nutzt deine Gaben nicht, oder du nutzt sie auf eine Weise, die nicht deinem höchsten Wohl dient. Leite deine Energie neu in Richtung authentischer Schöpfung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Untapped potential or manipulation is the theme. Either you're not using your gifts, or you're using them in ways that don't serve your highest good. Redirect your energy toward authentic creation."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El tema es el potencial sin explotar o la manipulación. O no estás usando tus dones, o los estás usando de maneras que no sirven a tu mayor bien. Redirige tu energía hacia la creación auténtica."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le thème est le potentiel inexploité ou la manipulation. Soit vous n'utilisez pas vos dons, soit vous les utilisez d'une manière qui ne sert pas votre plus grand bien. Redirigez votre énergie vers la création authentique."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il tema è il potenziale inespresso o la manipolazione. O non stai usando i tuoi doni, o li stai usando in modi che non servono il tuo bene più alto. Reindirizza la tua energia verso la creazione autentica."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "未開拓の可能性または操作がテーマです。あなたは自分の才能を使っていないか、それらを自分の最高の利益にならない方法で使っています。エネルギーを本物の創造に向け直してください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uoppdaget potensial eller manipulasjon er temaet. Enten bruker du ikke gavene dine, eller så bruker du dem på måter som ikke tjener ditt høyeste gode. Omdiriger energien din mot autentisk skapelse."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niewykorzystany potencjał lub manipulacja to temat. Albo nie używasz swoich darów, albo używasz ich w sposób, który nie służy twojemu najwyższemu dobru. Przekieruj swoją energię na autentyczne tworzenie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Potencial inexplorado ou manipulação é o tema. Ou você não está usando seus dons, ou os está usando de maneiras que não servem ao seu bem maior. Redirecione sua energia para a criação autêntica."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oanvänd potential eller manipulation är temat. Antingen använder du inte dina gåvor, eller så använder du dem på sätt som inte tjänar ditt högsta bästa. Omdirigera din energi mot autentisk skapelse."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Невикористаний потенціал або маніпуляція є темою. Або ви не використовуєте свої дари, або використовуєте їх у спосіб, який не служить вашому найвищому благу. Перенаправте свою енергію на автентичне творення."
          }
        }
      }
    },
    "interpretation.the_magician_general_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dies ist deine Zeit zu glänzen. Du hast alles, was du brauchst, um deine Wünsche zu verwirklichen – das Einzige, was fehlt, ist Handeln. Lenke deinen Willen mit Klarheit und Zielstrebigkeit. Wie oben, so unten. Was du fokussierst, erschaffst du."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This is your time to shine. You have everything you need to manifest your desires—the only thing missing is action. Channel your will with clarity and purpose. As above, so below. What you focus on, you create."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este es tu momento para brillar. Tienes todo lo que necesitas para manifestar tus deseos—lo único que falta es la acción. Canaliza tu voluntad con claridad y propósito. Como es arriba, es abajo. En lo que te enfocas, lo creas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "C'est votre moment de briller. Vous avez tout ce dont vous avez besoin pour manifester vos désirs — la seule chose qui manque, c'est l'action. Canalisez votre volonté avec clarté et détermination. Comme en haut, ainsi en bas. Ce sur quoi vous vous concentrez, vous le créez."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questo è il tuo momento di brillare. Hai tutto ciò che ti serve per manifestare i tuoi desideri — l'unica cosa che manca è l'azione. Canalizza la tua volontà con chiarezza e scopo. Come in alto, così in basso. Ciò su cui ti concentri, lo crei."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "これはあなたが輝く時です。欲望を実現するために必要なものはすべて揃っています—欠けているのは行動だけです。明確さと目的をもってあなたの意志を導いてください。上と同じように下も同じ。あなたが集中することが、あなたが創造するものです。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dette er din tid til å skinne. Du har alt du trenger for å manifestere dine ønsker — det eneste som mangler er handling. Kanaliser viljen din med klarhet og formål. Som over, så under. Det du fokuserer på, skaper du."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "To twój czas, aby zabłysnąć. Masz wszystko, czego potrzebujesz, aby zamanifestować swoje pragnienia — jedyne, czego brakuje, to działanie. Skieruj swoją wolę z jasnością i celem. Jak na górze, tak na dole. To, na czym się skupiasz, tworzysz."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este é o seu momento de brilhar. Você tem tudo o que precisa para manifestar seus desejos—a única coisa que falta é a ação. Canalize sua vontade com clareza e propósito. Como acima, assim abaixo. No que você foca, você cria."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Det här är din tid att lysa. Du har allt du behöver för att manifestera dina önskningar — det enda som saknas är handling. Kanalisera din vilja med klarhet och syfte. Som ovan, så nedan. Det du fokuserar på skapar du."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Це ваш час сяяти. У вас є все необхідне для втілення ваших бажань — єдине, чого бракує, це дії. Спрямовуйте свою волю з ясністю та метою. Як нагорі, так і внизу. Те, на чому ви зосереджуєтесь, ви створюєте."
          }
        }
      }
    },
    "interpretation.the_magician_health_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du könntest dich über deine Gesundheit täuschen oder schnelle Lösungen anstelle von echten Lösungen versuchen. Stelle dich der Wahrheit deiner Situation. Echte Heilung erfordert Ehrlichkeit und anhaltende Anstrengung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You might be deceiving yourself about your health or trying quick fixes instead of real solutions. Face the truth of your situation. Real healing requires honesty and sustained effort."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Puede que te estés engañando sobre tu salud o probando soluciones rápidas en lugar de soluciones reales. Enfrenta la verdad de tu situación. La verdadera curación requiere honestidad y esfuerzo sostenido."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous vous trompez peut-être sur votre santé ou vous essayez des solutions rapides plutôt que de véritables solutions. Affrontez la vérité de votre situation. Une véritable guérison nécessite de l'honnêteté et un effort soutenu."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Potresti ingannare te stesso sulla tua salute o provare soluzioni rapide invece di soluzioni reali. Affronta la verità della tua situazione. La vera guarigione richiede onestà e sforzo sostenuto."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "自分の健康について自己欺瞞をしていたり、本当の解決策ではなく簡単な対処法を試しているかもしれません。状況の真実に直面してください。本当の癒しには正直さと持続的な努力が必要です。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du kan lure deg selv om helsen din eller prøve raske løsninger i stedet for ekte løsninger. Møt sannheten i situasjonen din. Ekte helbredelse krever ærlighet og vedvarende innsats."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Możesz oszukiwać siebie w kwestii swojego zdrowia lub próbować szybkich rozwiązań zamiast prawdziwych. Zmierz się z prawdą o swojej sytuacji. Prawdziwe uzdrowienie wymaga uczciwości i ciągłego wysiłku."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você pode estar se enganando sobre sua saúde ou tentando soluções rápidas em vez de soluções reais. Enfrente a verdade da sua situação. A verdadeira cura exige honestidade e esforço sustentado."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du kanske lurar dig själv om din hälsa eller provar snabba lösningar istället för riktiga lösningar. Möt sanningen i din situation. Verklig läkning kräver ärlighet och ihållande ansträngning."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ви можете обманювати себе щодо свого здоров'я або пробувати швидкі виправлення замість справжніх рішень. Зіткніться з правдою своєї ситуації. Справжнє зцілення вимагає чесності та постійних зусиль."
          }
        }
      }
    },
    "interpretation.the_magician_health_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du hast die Kraft, deine Gesundheit zu verändern. Geist über Materie ist jetzt besonders stark. Ob durch Visualisierung, Absichtsbekundung oder diszipliniertes Handeln – du kannst echte Verbesserungen deines Wohlbefindens erreichen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You have the power to transform your health. Mind over matter is especially strong now. Whether through visualization, intention-setting, or disciplined action, you can manifest real improvements in your wellbeing."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tienes el poder de transformar tu salud. La mente sobre la materia es especialmente fuerte ahora. Ya sea a través de la visualización, el establecimiento de intenciones o la acción disciplinada, puedes manifestar mejoras reales en tu bienestar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous avez le pouvoir de transformer votre santé. L'esprit sur la matière est particulièrement fort en ce moment. Que ce soit par la visualisation, la définition d'intentions ou une action disciplinée, vous pouvez manifester de réelles améliorations de votre bien-être."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hai il potere di trasformare la tua salute. La mente sulla materia è particolarmente forte ora. Sia attraverso la visualizzazione, l'impostazione di intenzioni o l'azione disciplinata, puoi manifestare reali miglioramenti nel tuo benessere."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたには健康を変える力があります。今は特に精神が物質に勝ります。視覚化、意図の設定、または規律ある行動を通じて、あなたのウェルビーイングの本当の改善を実現できます。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du har makten til å transformere helsen din. Sinn over materie er spesielt sterkt nå. Enten gjennom visualisering, intensjonssetting eller disiplinert handling, kan du manifestere reelle forbedringer i ditt velvære."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Masz moc, aby przekształcić swoje zdrowie. Umysł nad materią jest teraz szczególnie silny. Czy to poprzez wizualizację, ustalanie intencji czy zdyscyplinowane działanie, możesz zamanifestować realne poprawy w swoim samopoczuciu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você tem o poder de transformar sua saúde. A mente sobre a matéria é especialmente forte agora. Seja através da visualização, definição de intenções ou ação disciplinada, você pode manifestar melhorias reais no seu bem-estar."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du har kraften att förvandla din hälsa. Sinnet över materien är särskilt starkt nu. Oavsett om det är genom visualisering, avsiktsinställning eller disciplinerad handling, kan du manifestera verkliga förbättringar i ditt välbefinnande."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "У вас є сила трансформувати своє здоров'я. Розум над матерією зараз особливо сильний. Через візуалізацію, встановлення намірів або дисципліновану дію ви можете втілити реальні покращення свого самопочуття."
          }
        }
      }
    },
    "interpretation.the_magician_love_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manipulation oder Täuschung könnte im Spiel sein, entweder von dir oder deinem Partner. Bist du ehrlich darüber, was du willst? Nutzt jemand Charme, um dich in die Irre zu führen? Vertraue deinem Bauchgefühl, wenn sich etwas falsch anfühlt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manipulation or deception may be at play, either from you or your partner. Are you being honest about what you want? Is someone using charm to mislead you? Trust your gut if something feels off."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Puede haber manipulación o engaño, ya sea por tu parte o por la de tu pareja. ¿Eres honesto sobre lo que quieres? ¿Alguien está usando el encanto para engañarte? Confía en tu instinto si algo no se siente bien."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La manipulation ou la tromperie peut être en jeu, que ce soit de votre part ou de celle de votre partenaire. Êtes-vous honnête sur ce que vous voulez ? Quelqu'un utilise-t-il le charme pour vous induire en erreur ? Faites confiance à votre instinct si quelque chose ne va pas."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manipolazione o inganno potrebbero essere in gioco, da parte tua o del tuo partner. Sei onesto su ciò che vuoi? Qualcuno sta usando il fascino per ingannarti? Fidati del tuo istinto se qualcosa non sembra giusto."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "操作や欺瞞が働いている可能性があります。あなたかあなたのパートナーのどちらかです。自分が望むことについて正直ですか？誰かが魅力を使ってあなたを誤解させていますか？何かがおかしいと感じたら、直感を信じてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manipulasjon eller bedrag kan være i spill, enten fra deg eller partneren din. Er du ærlig om hva du vil? Bruker noen sjarm for å villede deg? Stol på magefølelsen din hvis noe føles feil."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manipulacja lub oszustwo mogą być w grze, zarówno z twojej strony, jak i twojego partnera. Czy jesteś szczery co do tego, czego chcesz? Czy ktoś używa uroku, aby cię wprowadzić w błąd? Zaufaj swojemu instynktowi, jeśli coś jest nie tak."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manipulação ou engano podem estar em jogo, seja de você ou do seu parceiro. Você está sendo honesto sobre o que quer? Alguém está usando charme para enganá-lo? Confie no seu instinto se algo parecer errado."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manipulation eller bedrägeri kan vara i spel, antingen från dig eller din partner. Är du ärlig om vad du vill? Använder någon charm för att vilseleda dig? Lita på din magkänsla om något känns fel."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Маніпуляція або обман можуть мати місце, з вашого боку чи вашого партнера. Чи чесні ви щодо того, чого хочете? Чи використовує хтось шарм, щоб ввести вас в оману? Довіряйте своєму чуттю, якщо щось здається не так."
          }
        }
      }
    },
    "interpretation.the_magician_love_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du hast alle Werkzeuge, die du brauchst, um die Liebe zu manifestieren, die du dir wünschst. Wenn du Single bist, ist deine magnetische Energie stark – zeig dich. Wenn du in einer Beziehung bist, ist dies eine Zeit, aktiv die Beziehung zu schaffen, die du willst, durch klare Kommunikation und Absicht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You have all the tools you need to manifest the love you desire. If you're single, your magnetic energy is strong—put yourself out there. If you're partnered, this is a time to actively create the relationship you want through clear communication and intention."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tienes todas las herramientas que necesitas para manifestar el amor que deseas. Si estás soltero, tu energía magnética es fuerte—muéstrate. Si estás en pareja, este es un momento para crear activamente la relación que deseas a través de una comunicación clara y la intención."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous avez tous les outils dont vous avez besoin pour manifester l'amour que vous désirez. Si vous êtes célibataire, votre énergie magnétique est forte — montrez-vous. Si vous êtes en couple, c'est le moment de créer activement la relation que vous voulez grâce à une communication claire et à l'intention."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hai tutti gli strumenti di cui hai bisogno per manifestare l'amore che desideri. Se sei single, la tua energia magnetica è forte — mettiti in gioco. Se sei in coppia, questo è un momento per creare attivamente la relazione che vuoi attraverso una comunicazione chiara e l'intenzione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたには望む愛を実現するために必要なすべてのツールがあります。独身なら、あなたの磁気エネルギーは強い—自分を外に出してください。パートナーがいるなら、明確なコミュニケーションと意図を通じて、望む関係を積極的に創造する時です。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du har alle verktøyene du trenger for å manifestere kjærligheten du ønsker. Hvis du er singel, er din magnetiske energi sterk — vis deg frem. Hvis du er i et forhold, er dette en tid for å aktivt skape forholdet du vil ha gjennom klar kommunikasjon og intensjon."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Masz wszystkie narzędzia, których potrzebujesz, aby zamanifestować miłość, której pragniesz. Jeśli jesteś singlem, twoja magnetyczna energia jest silna — pokaż się. Jeśli jesteś w związku, to czas, aby aktywnie tworzyć relację, której chcesz, poprzez jasną komunikację i intencję."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você tem todas as ferramentas necessárias para manifestar o amor que deseja. Se você é solteiro, sua energia magnética é forte — mostre-se. Se você tem um parceiro, este é um momento para criar ativamente o relacionamento que você deseja através de comunicação clara e intenção."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du har alla verktyg du behöver för att manifestera den kärlek du önskar. Om du är singel är din magnetiska energi stark — visa dig själv. Om du är i ett förhållande är det här en tid att aktivt skapa det förhållande du vill ha genom tydlig kommunikation och avsikt."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "У вас є всі інструменти, необхідні для втілення кохання, яке ви бажаєте. Якщо ви самотні, ваша магнетична енергія сильна — покажіть себе. Якщо ви в парі, це час активно створювати стосунки, які ви хочете, через чітке спілкування та намір."
          }
        }
      }
    },
    "interpretation.the_moon_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klarheit im Beruf entsteht aus Verwirrung. Geheimnisse am Arbeitsplatz werden gelüftet. Die berufliche Angst lässt nach, als die Wahrheit ans Licht kommt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Career clarity emerges from confusion. Workplace secrets revealed. Professional anxiety subsides as truth comes to light."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La claridad profesional emerge de la confusión. Los secretos del lugar de trabajo se revelan. La ansiedad profesional disminuye a medida que sale la verdad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La clarté professionnelle émerge de la confusion. Les secrets du lieu de travail sont révélés. L'anxiété professionnelle diminue à mesure que la vérité éclate."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La chiarezza professionale emerge dalla confusione. I segreti del posto di lavoro vengono rivelati. L'ansia professionale diminuisce man mano che la verità viene alla luce."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "混乱から職業上の明確さが現れます。職場の秘密が明らかになります。真実が明らかになるにつれて、キャリア不安は和らぎます。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profesjonell klarhet dukker opp fra forvirring. Arbeidsplasshemmeligheter avsløres. Karriereangst avtar når sannheten kommer fram."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jasność zawodowa wyłania się z zamieszania. Tajemnice w miejscu pracy zostają ujawnione. Niepokój o karierę ustępuje, gdy prawda wychodzi na jaw."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A clareza profissional emerge da confusão. Segredos do local de trabalho são revelados. A ansiedade na carreira diminui à medida que a verdade vem à tona."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professionell klarhet uppstår ur förvirring. Arbetsplatshemligheter avslöjas. Karriärångest minskar när sanningen kommer fram."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Професійна ясність виникає з плутанини. Таємниці робочого місця розкриваються. Кар'єрна тривога зменшується, коли правда виходить на світ."
          }
        }
      }
    },
    "interpretation.the_moon_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Berufliche Unsicherheit, Arbeitsplatzgeheimnisse oder Karriereangst. Vertraue deiner Intuition – die Dinge sind nicht so, wie sie scheinen. Navigiere durch inneres Wissen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professional uncertainty, workplace secrets, or career anxiety. Trust your intuition—things aren't what they seem. Navigate by inner knowing."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Incertidumbre profesional, secretos en el lugar de trabajo o ansiedad profesional. Confía en tu intuición, las cosas no son lo que parecen. Navega por el conocimiento interno."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Incertitude professionnelle, secrets sur le lieu de travail ou anxiété professionnelle. Faites confiance à votre intuition – les choses ne sont pas ce qu'elles semblent. Naviguez par la connaissance intérieure."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Incertezza professionale, segreti sul lavoro o ansia di carriera. Fidati del tuo intuito – le cose non sono come sembrano. Naviga attraverso la conoscenza interiore."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "職業上の不確実性、職場の秘密、またはキャリア不安。自分の直感を信頼してください – 物事は見た目通りではありません。内なる知識でナビゲートしてください。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profesjonell usikkerhet, hemmeligheter på arbeidsplassen eller karriereangst. Stol på intuisjonen din – ting er ikke som de ser ut. Naviger med indre kunnskap."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niepewność zawodowa, tajemnice w miejscu pracy lub niepokój o karierę. Zaufaj swojej intuicji – sprawy nie są takie, jak się wydają. Nawiguj za pomocą wewnętrznej wiedzy."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Incerteza profissional, segredos no local de trabalho ou ansiedade na carreira. Confie na sua intuição – as coisas não são o que parecem. Navegue pelo conhecimento interno."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professionell osäkerhet, arbetsplatshemligheter eller karriärångest. Lita på din intuition – saker är inte vad de verkar. Navigera med inre kunskap."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Професійна невизначеність, таємниці на роботі або кар'єрна тривога. Довіряйте своїй інтуїції – речі не такі, якими здаються. Орієнтуйтеся за допомогою внутрішнього знання."
          }
        }
      }
    },
    "interpretation.the_moon_finance_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finanzielle Klarheit stellt sich ein. Geldgeheimnisse werden gelüftet. Die Angst vor Ressourcen lässt nach, wenn du die Wahrheit siehst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Financial clarity emerges. Money secrets revealed. Anxiety about resources subsides as you see the truth."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La claridad financiera emerge. Los secretos del dinero se revelan. La ansiedad por los recursos disminuye a medida que ves la verdad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La clarté financière émerge. Les secrets de l'argent sont révélés. L'anxiété liée aux ressources diminue à mesure que vous voyez la vérité."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La chiarezza finanziaria emerge. I segreti del denaro vengono rivelati. L'ansia per le risorse diminuisce man mano che vedi la verità."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "経済的な明確さが現れます。お金の秘密が明らかになります。真実を見るにつれて、リソースに対する不安は和らぎます。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Økonomisk klarhet dukker opp. Pengehemmeligheter avsløres. Angst for ressurser avtar når du ser sannheten."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pojawia się jasność finansowa. Tajemnice pieniężne zostają ujawnione. Lęk o zasoby maleje, gdy widzisz prawdę."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A clareza financeira emerge. Segredos de dinheiro são revelados. A ansiedade sobre os recursos diminui à medida que você vê a verdade."
          }
        },
