        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Speranza e ispirazione professionale dopo le difficoltà. I tuoi sogni professionali sono validi – mantieni la fede. La guida divina illumina il tuo cammino futuro."
          }
        },
        "ja" : {
          "stringUnit" : {
