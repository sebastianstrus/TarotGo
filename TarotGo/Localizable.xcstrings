        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zrównoważony styl życia przynosi uzdrowienie. Umiar we wszystkim wspiera dobre samopoczucie. Cierpliwość wobec naturalnych rytmów twojego ciała."
          }
