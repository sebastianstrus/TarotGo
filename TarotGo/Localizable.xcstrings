    "interpretation.nine_of_wands_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriereerschöpfung oder berufliche Paranoia. Bei der Arbeit ohne Unterstützung kämpfen. Hilfe am Arbeitsplatz verweigern. Kaum durchhalten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Career exhaustion or professional paranoia. Struggling on at work without support. Refusing job help. Barely holding on."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Agotamiento profesional o paranoia laboral. Luchando en el trabajo sin apoyo. Negando ayuda en el trabajo. Apenas aguantando."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Épuisement de carrière ou paranoïa professionnelle. Lutter au travail sans soutien. Refuser l'aide au travail. Tenant à peine le coup."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esaurimento della carriera o paranoia professionale. Lottare sul lavoro senza supporto. Rifiutare l'aiuto sul lavoro. A malapena resistere."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャリアの疲労や職業上のパラノイア。サポートなしで仕事に苦闘する。仕事の助けを拒否する。かろうじて持ちこたえている。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriereutmattelse eller profesjonell paranoia. Slite på jobb uten støtte. Nekte jobbhjelp. Så vidt holde ut."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wyczerpanie w karierze lub zawodowa paranoja. Walczenie w pracy bez wsparcia. Odmawianie pomocy w pracy. Ledwo się trzymając."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Exaustão na carreira ou paranoia profissional. Lutando no trabalho sem apoio. Recusando ajuda no trabalho. Mal se segurando."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karriärutmattning eller professionell paranoia. Kämpa på jobbet utan stöd. Vägra jobbhjälp. Hålla knappt ut."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Виснаження в кар'єрі або професійна параноя. Боротьба на роботі без підтримки. Відмова від допомоги на роботі. Ледве тримаючись."
          }
        }
      }
    },
