        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Legado de salud y base de bienestar duradera. La fuerza física es familiar. Sabiduría sanitaria generacional. Construyendo una salud que perdura."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Héritage de santé et fondation de bien-être durable. La force physique est héréditaire. Sagesse en matière de santé générationnelle. Construire une santé qui dure."
