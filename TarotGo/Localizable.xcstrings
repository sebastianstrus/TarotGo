    "interpretation.two_of_wands_general_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Angst vor dem Unbekannten, mangelnde Planung, auf Nummer sicher gehen und schlechte Planung. Du steckst am Scheideweg fest. Triff eine Entscheidung und gehe vorwärts."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fear of unknown, lack of planning, playing it safe, and bad planning. You're stuck at the crossroads. Make a decision and move forward."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Miedo a lo desconocido, falta de planificación, jugar sobre seguro y mala planificación. Estás atascado en la encrucijada. Toma una decisión y sigue adelante."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Peur de l'inconnu, manque de planification, jouer la sécurité et mauvaise planification. Vous êtes bloqué à la croisée des chemins. Prenez une décision et avancez."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Paura dell'ignoto, mancanza di pianificazione, giocare sul sicuro e cattiva pianificazione. Sei bloccato al bivio. Prendi una decisione e vai avanti."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "未知への恐れ、計画の欠如、安全策、そして悪い計画。あなたは岐路で立ち往生している。決断を下し、前進しなさい。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Frykt for det ukjente, mangel på planlegging, spille det trygt og dårlig planlegging. Du sitter fast ved veiskillet. Ta en beslutning og gå videre."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Strach przed nieznanym, brak planowania, gra na bezpieczeństwo i złe planowanie. Utknąłeś na rozdrożu. Podejmij decyzję i idź naprzód."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Medo do desconhecido, falta de planejamento, jogar pelo seguro e mau planejamento. Você está preso na encruzilhada. Tome uma decisão e siga em frente."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rädsla för det okända, brist på planering, spela säkert och dålig planering. Du är fast vid vägskälet. Fatta ett beslut och gå framåt."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Страх перед невідомим, відсутність планування, гра на безпеці та погане планування. Ви застрягли на роздоріжжі. Прийміть рішення та рухайтеся вперед."
          }
        }
      }
    },
