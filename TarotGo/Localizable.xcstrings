        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abordagem de relacionamento nutritiva e prática. Amor pé no chão e provedor para o parceiro. Cuidado fundamentado cria segurança. Lar e coração se alinham lindamente."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Omhändertagande, praktisk relationsstrategi. Jordnär kärlek och att försörja partnern. Jordnär omsorg skapar trygghet. Hem och hjärna passar vackert ihop."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Піклувальний, практичний підхід до стосунків. Приземлена любов та забезпечення партнера. Приземлена турбота створює безпеку. Дім і серце прекрасно поєднуються."
          }
        }
      }
    },
    "interpretation.queen_of_swords_career_reversed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Berufliche Kälte oder Grausamkeit am Arbeitsplatz. Karriere-Bitterkeit. Durch Abwehrhaltung isoliert. Harte Kommunikation schadet den Arbeitsbeziehungen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professional coldness or workplace cruelty. Career bitterness. Isolated through defensiveness. Harsh communication damages work relationships."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Frialdad profesional o crueldad en el lugar de trabajo. Amargura profesional. Aislado por la actitud defensiva. La comunicación dura daña las relaciones laborales."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Froideur professionnelle ou cruauté sur le lieu de travail. Amertume professionnelle. Isolé par la défensive. Une communication dure nuit aux relations de travail."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Freddezza professionale o crudeltà sul posto di lavoro. Amarezza professionale. Isolato dalla difensiva. La comunicazione dura danneggia le relazioni lavorative."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "仕事上の冷たさや職場での残酷さ。キャリアへの bitterness。防御的な態度による孤立。厳しいコミュニケーションが仕事関係を損なう。"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profesjonell kulde eller grusomhet på arbeidsplassen. Karrierebitterhet. Isolert gjennom defensivitet. Hard kommunikasjon skader arbeidsforhold."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zawodowy chłód lub okrucieństwo w miejscu pracy. Gorycz kariery. Odizolowany przez defensywność. Surowe komunikowanie szkodzi relacjom w pracy."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Frieza profissional ou crueldade no local de trabalho. Amargura na carreira. Isolado pela defensividade. Comunicação dura prejudica as relações de trabalho."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Professionell kyla eller grymhet på arbetsplatsen. Karriärbitterhet. Isolerad genom defensivitet. Hård kommunikation skadar arbetsrelationer."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Професійна холодність або жорстокість на робочому місці. Кар'єрна гіркота. Ізоляція через захисну реакцію. Суворе спілкування шкодить робочим стосункам."
          }
        }
      }
    },
    "interpretation.queen_of_swords_career_upright" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unabhängiger, klardenkender professioneller Ansatz. Ehrlich und direkt bei der Arbeit. Intellektuelle Führung. Wahrheit und Grenzen dienen der Karriere."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Independent, clear-thinking professional approach. Honest and direct at work. Intellectual leadership. Truth and boundaries serve career."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enfoque profesional independiente y de pensamiento claro. Honesto y directo en el trabajo. Liderazgo intelectual. La verdad y los límites sirven a la carrera."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Approche professionnelle indépendante et claire. Honnête et direct au travail. Leadership intellectuel. La vérité et les limites servent la carrière."
